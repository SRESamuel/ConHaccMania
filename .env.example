# NewGenLearning — environment template
# Copy this file to .env and fill in real values.
# .env is gitignored; .env.example is committed.

# === Shared: Neon PostgreSQL ===
# Used by all three services (quiz-api, submission-api, analysis-service).
DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require

# === Quiz API only: Gemini ===
# Get a key at https://aistudio.google.com/app/apikey (free tier).
GEMINI_API_KEY=

# === Service ports (defaults from SPEC.md) ===
QUIZ_API_PORT=8001
SUBMISSION_API_PORT=8002
ANALYSIS_SERVICE_PORT=8003
