}


function processInstructorImages() {
    var thisinstructor = alldata.InstructorImages.shift();
    
    var tstamp = new Date().getTime();
    $('.canvaszone').append('<div><img id="cropcanvas-'+thisinstructor.Identifier+'" src="/d2l/common/viewprofileimage.d2l?oi=6606&ui='+thisinstructor.Identifier+'&s=700&t='+tstamp+'"></div>');
    var image = document.getElementById('cropcanvas-'+thisinstructor.Identifier);
    //console.log(image);
    var cropper = new Cropper(image, {
        aspectRatio: 1,
        viewMode: 1,
        data: thisinstructor.ProfileImageCrop,
        ready: function() {
            // Crop
            var croppedCanvas = cropper.getCroppedCanvas();

            // Round
            var roundedCanvas = getRoundedCanvas(croppedCanvas);

            // Show
            var roundedImage = document.createElement('img');
            roundedImage.src = roundedCanvas.toDataURL();
            //console.log(roundedImage);

            $('.echsprofileimg-'+thisinstructor.Identifier).attr('src',roundedImage.src);
            
            if(alldata.InstructorImages.length > 0) {
                processInstructorImages();
            }            
        },
    }); 
}

function buildInstructorDisplay() {
    alldata.InstructorDisplay = {
        Objects: []
    }
    
    $('.canvaszone').html('');
    
    var settingscheck = false;
    if(alldata.CustomSettings !== null) {
        if(alldata.CustomSettings.Instructor !== undefined) {
            settingscheck = true;
            for(var i=0; i<alldata.Instructors.Objects.length; i++) {
                //console.log(alldata.Instructors.Objects[i]);
                var settingfound = false;
                for(var csi=0; csi<alldata.CustomSettings.Instructor.length; csi++) {
                    //console.log(alldata.CustomSettings.Instructor[csi]);
                    if(parseInt(alldata.Instructors.Objects[i].Identifier) === alldata.CustomSettings.Instructor[csi].Identifier) {
                        settingfound = true;
                        //console.log(alldata.CustomSettings.Instructor[csi].Visibility.Visible);
                        if(alldata.CustomSettings.Instructor[csi].Visibility.Visible) {
                            if(alldata.CustomSettings.Instructor[csi].Visibility.Primary) {
                                alldata.Instructors.Objects[i].Primary = true;
                                alldata.InstructorDisplay.Objects.unshift(alldata.Instructors.Objects[i]);
                            }
                            else {
                                alldata.Instructors.Objects[i].Primary = false;
                                alldata.InstructorDisplay.Objects.push(alldata.Instructors.Objects[i]);
                            }
                        }
                        if(alldata.CustomSettings.Instructor[csi].Visibility.Profile !== undefined) {
                            if(alldata.CustomSettings.Instructor[csi].Visibility.Profile) {
                                alldata.Instructors.Objects[i].Profile = alldata.CustomSettings.Instructor[csi].Visibility.Profile;
                            }
                            else {
                                alldata.Instructors.Objects[i].Profile = false;
                            }
                        }
                        else {
                            alldata.Instructors.Objects[i].Profile = false;
                        }
                        alldata.Instructors.Objects[i].Availability = alldata.CustomSettings.Instructor[csi].Availability;
                    }
                }
                //console.log(settingfound);
                if(!settingfound) {
                    alldata.Instructors.Objects[i].Availability = '';
                    alldata.Instructors.Objects[i].Profile = false;
                    alldata.Instructors.Objects[i].Primary = false;
                    alldata.InstructorDisplay.Objects.push(alldata.Instructors.Objects[i]);
                }
            }
        }
    }
    if(!settingscheck) {
        alldata.InstructorDisplay = alldata.Instructors;
    }
    
    //console.log(alldata.InstructorDisplay);
    if(alldata.InstructorDisplay.Objects.length > 0) {
        var instructorstring = '';
        var thisinstructor = alldata.InstructorDisplay.Objects[0];
        instructorstring += '<div class="row">';
        instructorstring += '<div class="col-12 textfix">';
        
        if(thisinstructor.Profile) {
            instructorstring += '<div class="instructor-block-primary instructor-block-hasimage">';
            var tstamp = new Date().getTime();
            instructorstring += '<div class="instructor-block-profile-image">';
            instructorstring += '<img class="echsprofileimg echsprofileimg-'+thisinstructor.Identifier+'" src="/d2l/common/viewprofileimage.d2l?oi=6606&ui='+thisinstructor.Identifier+'&s=100&t='+tstamp+'" alt="Profile Image for '+thisinstructor.FirstName+' '+thisinstructor.LastName+'">';
            instructorstring += '</div>';                
        }
        else {
            instructorstring += '<div class="instructor-block-primary">';
        }
        
        instructorstring += '<div class="instructor-block-contact">';
        instructorstring += '<table class="table">';
        instructorstring += '<tbody>';
        instructorstring += '<tr><th>Instructor</th><td>'+thisinstructor.FirstName+' '+thisinstructor.LastName+'</td></tr>';

        //instructorstring += '<strong>'+thisinstructor.FirstName+' '+thisinstructor.LastName+'</strong><br>';
        if(thisinstructor.Email !== null) {
            instructorstring += '<tr><th>Email</th><td><a href="mailto:'+thisinstructor.Email+'" title="Send Email" target="_blank">'+thisinstructor.Email+'</a></td></tr>';
            //instructorstring += '<a href="/shared/CustomWidgets/Compose-New-Message/index.html?e='+condorid+'" title="Send Email" target="_blank"><i class="fa fa-envelope" aria-hidden="true"></i></a> ';
        }
        
        var hasavail = false;
        if(thisinstructor.Availability !== undefined) {
            if(thisinstructor.Availability !== '') {
                instructorstring += '<tr><th>Availability</th><td>'+thisinstructor.Availability+'</a></td></tr>';
                //instructorstring += '<tr><th>Availability</th><td><a href="javascript:openInstructorAvailability(0)" title="View Availability"><i class="fas fa-calendar-check"></i></a></td></tr>';
                //instructorstring += '<a href="javascript:openInstructorAvailability(0)" title="View Availability"><i class="fas fa-calendar-check"></i></a> ';
            }
        }        
        
        /*
        if(thisinstructor.Email !== null) {
            instructorstring += '<p><a href="'+thisinstructor.Contact+'" target="_blank">'+thisinstructor.Email+'</a></p>';     
        }
        */
        /*
        instructorstring += '</div>';
        var hasavail = false;
        if(thisinstructor.Availability !== undefined) {
            if(thisinstructor.Availability !== '') {
                hasavail = true;
                //instructorstring += '<h3 class="sec-title">Availability</h3>';

                var availhtml = thisinstructor.Availability;
                var availclean = cleanTextInput(availhtml);

                //console.log(availclean);

                instructorstring += '<p>' + availclean + '</p>';    
            }
        }
        */
        
        instructorstring += '</tbody>';
        instructorstring += '</table>';        
        
        instructorstring += '</div>';
        instructorstring += '</div>';     
        
        
        if(alldata.InstructorDisplay.Objects.length > 1) {
            instructorstring += '<div class="instructormore">';
            instructorstring += '<h3>Additional Instructors: '+(alldata.InstructorDisplay.Objects.length - 1)+'</h3>';
            instructorstring += '<a class="instructorexpand" data-toggle="collapse" href="#collapseInstructors" aria-expanded="false" aria-controls="collapseInstructors" title="View Additional Instructors"><i class="far fa-plus-circle"></i></a>';
            instructorstring += '</div>';
            instructorstring += '<div class="collapse" id="collapseInstructors">';
            instructorstring += '<div class="card card-body">';
            instructorstring += '<div class="row">';
            for(var id=1; id<alldata.InstructorDisplay.Objects.length; id++) {
                var thisinstructor = alldata.InstructorDisplay.Objects[id];
                
                if(alldata.InstructorDisplay.Objects.length === 2) {
                    instructorstring += '<div class="col-12 textfix mb-4">';
                }
                else {
                    instructorstring += '<div class="col-12 col-sm-6 textfix mb-4">';
                }
                
                instructorstring += '<strong>'+thisinstructor.FirstName+' '+thisinstructor.LastName+'</strong><br>';
                if(thisinstructor.Email !== null) {
                    instructorstring += '<a href="'+thisinstructor.Contact+'" target="_blank"><i class="fa fa-envelope" aria-hidden="true"></i></a> ';
                }
                var hasavail = false;
                if(thisinstructor.Availability !== undefined) {
                    if(thisinstructor.Availability !== '') {
                        hasavail = true;

                        var availhtml = thisinstructor.Availability;
                        var availclean = cleanTextInput(availhtml);
                        
                        instructorstring += '<a href="javascript:openInstructorAvailability('+id+')" title="View Availability"><i class="fas fa-calendar-check"></i></a> ';                        

                        //console.log(availclean);

                        instructorstring += '';    
                    }
                }
                instructorstring += '</div>';
                
            }            
            instructorstring += '</div>';
            instructorstring += '</div>';
            instructorstring += '</div>';

        }
        
        instructorstring += '</div>';     
        
        $('.instructor-block').html(instructorstring);
        
        alldata.InstructorImages = [];
        for(var i=0; i<alldata.Instructors.Objects.length; i++) {
            var thisinstructor = alldata.Instructors.Objects[i];
            if(thisinstructor.ProfileImageCrop !== undefined) {
                alldata.InstructorImages.push(thisinstructor);
            }
        }
        if(alldata.InstructorImages.length > 0) {
            processInstructorImages();
        }        
        
        $('.instructor-block .collapse').on('hidden.bs.collapse', function () {
            clearInterval(frameloop);
            frameloop = false;
            //frameHeight();
            $('.instructorexpand i').removeClass("fa-minus-circle");
            $('.instructorexpand i').addClass("fa-plus-circle");
            $('.instructorexpand').attr("title","View Additional Instructors");
            
        });
        $('.instructor-block .collapse').on('shown.bs.collapse', function () {
            clearInterval(frameloop);
            frameloop = false;
            //frameHeight();
            $('.instructorexpand i').removeClass("fa-plus-circle");
            $('.instructorexpand i').addClass("fa-minus-circle");
            $('.instructorexpand').attr("title","Hide Additional Instructors");
        });    
        $('.instructor-block .collapse').on('show.bs.collapse', function () {
            frameloop = setInterval(function(){
                //frameHeight();
            },1);
        });        
        
    }
    else {
        //$('.instructor-block').html('<p>There were no Instructors found in the classlist.</p>');
    }
}

