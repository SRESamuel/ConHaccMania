function initializeLinkListCustom() {
    
    $('#cc-home .links-container .scrollable-wrapper .link-custom').remove();
    $('#cc-home-student .links-container .scrollable-wrapper .link-custom').remove();
    $('.instructor-content .links-container-edit .scrollable-wrapper .link-custom').remove();
    
    var linklist = [];
    if(alldata.CustomSettings !== null) {
        if(alldata.CustomSettings.LinkList !== undefined) {
            //console.log(alldata.CustomSettings.LinkList);
            linklist = alldata.CustomSettings.LinkList.Items;
            for(var ll=0; ll<alldata.CustomSettings.LinkList.Items.length; ll++) {
                var thislink = alldata.CustomSettings.LinkList.Items[ll];
                var newlinkstring = buildNewLinkString(thislink.URL, thislink.Label, thislink.Icon, ll);
                $('#cc-home .links-container .scrollable-wrapper').append(newlinkstring);
                var safeforstu = true;
                if(thislink.URL.indexOf("/admin/") > -1) { 
                    safeforstu = false;
                }
                if(thislink.URL.indexOf("userprogress") > -1) { 
                    safeforstu = false;
                }
                if(safeforstu) {
                    $('#cc-home-student .links-container .scrollable-wrapper').append(newlinkstring);
                }                
            }
        }
    }
    
    if((alldata.CourseType !== "Standard") && (alldata.CourseType !== "High Capacity")) {
        if(linklist.length === 0) {
            var placeholderlink = buildNewLinkString("javascript:shortcutAddNewLink()", "Add New Link", "question", -1);
            
            var csplaceholderhtml = '';
            csplaceholderhtml += '<div class="links-container-message d-flex">';
            csplaceholderhtml += '<div class="links-container-placeholder">' + placeholderlink + '</div>';
            csplaceholderhtml += '<div class="links-container-highcapinfo d-flex"><div class="cc-icon dark-bg warning-light align-self-center m-3"></div><div class="align-self-center">You can add custom links for your students here, which will appear like the placeholder item on the left. Note that if you have not added any links, this section will not appear for your students. You can confirm this by reviewing the \"Student View\" tab.</div></div>';
            csplaceholderhtml += '</div>';
            
            $('.instructor-content .links-container.links-container-display').append(csplaceholderhtml);     
            $('.instructor-content .links-container.links-container-display').addClass('links-container-highcap-preview');
            
            $('.student-content .links-container').addClass('d-none');
            
        }
        else {
            $('.instructor-content .links-container.links-container-display .scrollable-wrapper [data-llindex="-1"]').remove();
            $('.instructor-content .links-container.links-container-display .links-container-message').remove();
            $('.instructor-content .links-container.links-container-display').removeClass('links-container-highcap-preview');
            $('.student-content .links-container').removeClass('d-none');
        }
    }
    
    refreshLinkList();
    
}

