function daysBetween(date1, date2) {
    // The number of ms in one day
    const ONE_DAY = 1000 * 60 * 60 * 24;
    // Calculate the difference in ms
    const differenceMs = Math.abs(date1 - date2);
    // Convert back to days and return
    return Math.round(differenceMs / ONE_DAY);
}


function getEnrollmentChanges() {
    
    var tdate = new Date();
    var datedata;
    var pastcourse = false;
    
    if(alldata.CourseOffering.EndDate !== null) {
        var edate = new Date(alldata.CourseOffering.EndDate);
        if(edate < tdate) {
            pastcourse = true;
        }
    }
    
    if(!pastcourse) {
        if(alldata.CourseOffering.StartDate !== null) {
            datedata = {
                StartDate: alldata.CourseOffering.StartDate
            }

            var sdate = new Date(alldata.CourseOffering.StartDate);
            datedata.StartDate = tdate.subDays(14);
            datedata.StartDate.setHours(0, 0, 0, 0);
            datedata.StartDate = datedata.StartDate.toJSON();        
            alldata.Enrollment = {
                Window: datedata
            }
            getWithdrawals(datedata);
            getAdditions(datedata);
        }
        else {

            datedata = {
                StartDate: new Date()
            }
            datedata.StartDate = tdate.subDays(14);
            datedata.StartDate.setHours(0, 0, 0, 0);
            datedata.StartDate = datedata.StartDate.toJSON(); 

            alldata.Enrollment = {
                Window: datedata
            }

            getWithdrawals(datedata);
            getAdditions(datedata);    
        }  

        $('#enrollchangewindow').text("Since " + new Date(alldata.Enrollment.Window.StartDate).toLocaleDateString('en-us', { weekday:"long", year:"numeric", month:"long", day:"numeric"}));
    }
    else {
        alldata.Enrollment = {
            Additions: [],
            Withdrawals: []
        }
        //console.log("ced1");
        checkEnrollmentDone();
    }

}


function getWithdrawals(datedata) {
    var opts = { apiVersion: '1.4' };
    if(datedata !== undefined) {
        if(datedata.StartDate !== undefined) {
            opts.startDate = datedata.StartDate;
        }
        if(datedata.EndDate !== undefined) {
            opts.endDate = datedata.EndDate;
        }
    }

    ecplusClient.econestoga.getWithdrawals(orgUnitId, opts).then(function (resp) {
        if (resp.isSuccess) {
            var data = resp.Result;
            var datastudentonly = [];
            for(var wd=0; wd<data.length; wd++) {
                if(data[wd].RoleId === 103) {
                    datastudentonly.push(data[wd]);
                }
            }
            //console.log(data);
            alldata.Enrollment.Withdrawals = datastudentonly.reverse();
        }
        else {
            alldata.Enrollment.Withdrawals = [];
        }
        //console.log("ced2");
        checkEnrollmentDone();
    });
}

function getAdditions(datedata) {
    var opts = { apiVersion: '1.4' };
    if(datedata !== undefined) {
        if(datedata.StartDate !== undefined) {
            opts.startDate = datedata.StartDate;
        }
        if(datedata.EndDate !== undefined) {
            opts.endDate = datedata.EndDate;
        }
    }

    ecplusClient.econestoga.getEnrollments(orgUnitId, opts).then(function (resp) {
        if (resp.isSuccess) {
            var data = resp.Result;
            //console.log(data);
            alldata.Enrollment.Additions = data.reverse();
        }
        else {
            alldata.Enrollment.Additions = [];
        }
        //console.log("ced3");
        checkEnrollmentDone();
    });
}

function getStudentEnroll(userid, bookmark) {
    var enrolldataurl = "/d2l/api/lp/unstable/enrollments/users/" + userid + "/orgUnits/";
    enrolldataurl = enrolldataurl + "?roleId=103";
	if (bookmark !== undefined) {
		enrolldataurl = enrolldataurl + "&bookmark=" + bookmark;
	}
    $.ajax({
        method: "GET",
        url: enrolldataurl,
        dataType: 'json',
        success: function (enrolldata_tmp) {
            
            var itemindex = -1;
            for(var i=0; i<enrolldata_tmp.Items.length; i++) {
                if(enrolldata_tmp.Items[i].OrgUnit.Id === parseInt(orgUnitId)) {
                    itemindex = i;
                    break;
                }
            }
            
            var foundnew = false;
            var foundmore = true;
            if(itemindex > -1) {
                for(var n=0; n<alldata.Enrollment.Additions.length; n++) {
                    if(alldata.Enrollment.Additions[n].UserId === userid) {
                        alldata.Enrollment.Additions[n].Data = enrolldata_tmp.Items[itemindex];
                        foundnew = true;
                    }
                }
            }
            else {
                if(enrolldata_tmp.PagingInfo !== undefined) {
                    if(enrolldata_tmp.PagingInfo.HasMoreItems) {
                        getStudentEnroll(userid, enrolldata_tmp.PagingInfo.Bookmark);
                        
                    }
                    else {
                        foundmore = false;
                    }
                }
            }
            
            if(foundnew) {
                alldata.Enrollment.Done++;
            }
            else {
                if(!foundmore) {
                    alldata.Enrollment.Done++;
                }
            }
        
            if(alldata.Enrollment.Done === alldata.Enrollment.Additions.length) {
                //console.log("ced4");
                checkEnrollmentDone();
            }             
            
        }, //end success
        error: function (xhr, ajaxOptions, thrownError) {
            console.log(xhr);
        }
    }) //end ajax
}

function checkEnrollmentDone() {
    
    //console.log("check enrollment done");
    //console.log(JSON.parse(JSON.stringify(alldata.Enrollment)));
    
    var withdrawaldone = false;
    var additionsdone = false;
    
    if(alldata.Enrollment.Additions !== undefined) {
        if(alldata.Enrollment.Additions.length > 0) {
            //if(alldata.Enrollment.Done === alldata.Enrollment.Additions.length) {
                additionsdone = true;
            //}            
        }
        else {
            additionsdone = true;
        }
    }
    
    if(alldata.Enrollment.Withdrawals !== undefined) {
        if(alldata.Enrollment.Withdrawals.length > 0) {
            //console.log(alldata.Enrollment.FrameCheck);
            //if(alldata.Enrollment.FrameCheck) {
                withdrawaldone = true;
            //}
        }
        else {
            withdrawaldone = true;
        }
    }
    
    
    if(withdrawaldone && additionsdone) {

        alldone.Enrollment = true;
        //console.log("ad12");
        checkAllDone();
        
    }
}

