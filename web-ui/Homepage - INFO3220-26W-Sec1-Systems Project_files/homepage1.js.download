                        if(displaythis) {

                            var announcestring = buildAnnounceString(thisannounce, true, true);
                            releasedhtml += announcestring;
                            //$('.announcement-wrapper').append(announcestring);

                            announcedisplayed++;
                            studenthtml += announcestring;

                        }
                        else {
                            
                            var announcestring = buildAnnounceString(thisannounce, true, false);
                            if(!thisannounce.IsHidden) {
                                //console.log(thisannounce);
                                var sdate = new Date(thisannounce.StartDate);                                
                                if(sdate > tdate) {
                                    upcominghtml += announcestring;
                                }
                                else {
                                    var isexpired = false;
                                    if(thisannounce.EndDate !== null) {
                                        var edate = new Date(thisannounce.EndDate);
                                        if(edate <= tdate) {
                                            isexpired = true;
                                        }
                                    }
                                    if(isexpired) {
                                        expiredhtml += announcestring;
                                    }
                                    else {
                                        drafthtml += announcestring;
                                    }
                                }
                            }
                        }
                        
                        break;
                    }
                }
            }
        }
    }
    */
    
    
    for(var a=0; a<alldata.Announcements.length; a++) {
        var thisannounce = alldata.Announcements[a];
        if(thisannounce.IsPinned) {
            pinnedlist.push(thisannounce);
        }
    }
    pinnedlist.sort((a, b) => (a.PinnedDate < b.PinnedDate) ? 1 : -1);
    
    for(var a=0; a<pinnedlist.length; a++) {
        var thisannounce = pinnedlist[a];
        var displaythis = checkAnnounceVisibility(thisannounce);;
        if(displaythis) {
            var announcestring = buildAnnounceString(thisannounce, true, true);
            releasedhtml += announcestring;
            //$('.announcement-wrapper').append(announcestring);

            announcedisplayed++;
            studenthtml += announcestring;
        }
        else {
            var announcestring = buildAnnounceString(thisannounce, true, false);
            if(!thisannounce.IsHidden) {
                //console.log(thisannounce);
                var sdate = new Date(thisannounce.StartDate);                                
                if(sdate > tdate) {
                    upcominghtml += announcestring;
                }
                else {
                    var isexpired = false;
                    if(thisannounce.EndDate !== null) {
                        var edate = new Date(thisannounce.EndDate);
                        if(edate <= tdate) {
                            isexpired = true;
                        }
                    }
                    if(isexpired) {
                        expiredhtml += announcestring;
                    }
                    else {
                        drafthtml += announcestring;
                    }
                }
            }
        }
    }    
    
    for(var a=0; a<alldata.Announcements.length; a++) {
        var thisannounce = alldata.Announcements[a];
        
        if(thisannounce.IsPinned) {
            //do nothing, already displayed;
        }
        else {
            var displaythis = checkAnnounceVisibility(thisannounce);;
            if(displaythis) {
                var announcestring = buildAnnounceString(thisannounce, false, true);
                
                //$('.announcement-wrapper').append(announcestring);

                announcedisplayed++;
                if(announcedisplayed <= announcemax) {
                    releasedhtml += announcestring;
                    studenthtml += announcestring;
                }
                else {
                    var astring = $(announcestring);
                    $(astring).removeClass('announce-visible');
                    $(astring).addClass('announce-extra');
                    //console.log(astring);
                    
                    releasedhtml += astring[0].outerHTML;                  
