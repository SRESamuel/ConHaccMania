function getAnnouncementData() {
    var announceurl = "/d2l/api/le/" + alldata.APIVersions.LE.LatestVersion + "/" + orgUnitId + "/news/";
    
    if((alldata.CourseType !== "Standard") && (alldata.CourseType !== "High Capacity")) {
        var today_EST = getServerTime().toLocaleString("en-US", {
            timeZone: "America/New_York"
        });
        var tdate = new Date(today_EST);
        var sdate = new Date(tdate.subDays(150)).toISOString();   
        
        announceurl += '?since='+sdate;
        //console.log(announceurl);
    }
    
    $.ajax({
        method: "GET",
        url: announceurl,
        dataType: 'json',
        success: function (announce_tmp) {
            
            alldata.Announcements = announce_tmp;
            
            alldone.Announcements = true;
            //console.log("ad36");
            checkAllDone();
            
        }, //end success
        error: function (announce_tmp) {
            //assuming the Announcements Tool is turned off
            var studentdisplay = $('#student-announcements');
            $(studentdisplay).addClass('d-none');
            var instructortab = $('.nav-link[data-target="#cc-announcements"]').parent('.nav-item');
            $(instructortab).addClass('d-none');
            
            alldata.Announcements = [];
            alldone.Announcements = true;
            //console.log("ad37");
            checkAllDone();
        }
    }) //end ajax
}

function putAnnouncementData(announceid, announceobj) {
    var token;
    $.ajax({
        method: "GET",
        url: "/d2l/lp/auth/xsrf-tokens",
        success: function(ltoken) {
            token = ltoken;
            //console.log(token);
            
            var announceurl = "/d2l/api/le/" + alldata.APIVersions.LE.LatestVersion + "/" + orgUnitId + "/news/" + announceid;
            var announceput = JSON.stringify(announceobj);

            //console.log(announceurl);
            //console.log(announceput);
            
            $.ajax({
                beforeSend: function(request) {
                    request.setRequestHeader("X-Csrf-Token", token.referrerToken);
                },
                method: 'PUT',
                url: announceurl,
                dataType: 'json',
                data: announceput,
                complete: function (putnews_tmp) {
                    //console.log(putnews_tmp);
                    if(putnews_tmp.status === 200) {
                        //console.log("announce pin update success");
                        
                        for(var a=0; a<alldata.Announcements.length; a++) {
                            var thisannounce = alldata.Announcements[a];
                            //console.log(announceid);
                            //console.log(thisannounce.Id);
                            if(announceid === thisannounce.Id) {      
                                alldata.Announcements[a] = announceobj;
                                break;
                            }
                        }
                        
                        initializeAnnouncements();
                        
                        $('#announcePinModal').modal('hide');
                        $('#announceUnPinModal').modal('hide');
                    }
                } //end success
            });                  
        }
    });   
}


function deleteAnnouncementItem(announceid) {
    var token;
    $.ajax({
        method: "GET",
        url: "/d2l/lp/auth/xsrf-tokens",
        success: function(ltoken) {
            token = ltoken;
            
            var deletenewsurl = "/d2l/api/le/" + alldata.APIVersions.LE.LatestVersion + "/" + orgUnitId + "/news/"+announceid;
            $.ajax({
                beforeSend: function(request) {
                    request.setRequestHeader("X-Csrf-Token", token.referrerToken);
                },        
                method: "DELETE",
                url: deletenewsurl,
                dataType: 'json',
                complete: function (deletenews_tmp) {
                    if(deletenews_tmp.status === 200) {
                        for(var a=0; a<alldata.Announcements.length; a++) {
                            var thisannounce = alldata.Announcements[a];
                            if(thisannounce.Id === announceid) {
                                alldata.Announcements.splice(a,1);
                                break; 
                            }                                               
                        }
                        initializeAnnouncements();
                    }
                } //end success
            }) //end ajax    
        }
            
    });
}

var RecurrenceDays = [
	"Sunday",
	"Monday",
	"Tuesday",
	"Wednesday",
	"Thursday",
	"Friday",
	"Saturday"
]

var MonthAbbreviations = [
	"JAN",
	"FEB",
	"MAR",
	"APR",
	"MAY",
	"JUN",
	"JUL",
	"AUG",
	"SEP",
	"OCT",
	"NOV",
	"DEC"
]

function getServerTime() {
	var req = new XMLHttpRequest();
	req.open('GET', document.location, false);
	req.send(null);
	var stime = new Date(req.getResponseHeader("Date"));
	if (stime.getFullYear() < 2020) {
		stime = new Date();
	}
	return stime;
}

Date.prototype.addDays = function (days) {
	let date = new Date(this.valueOf());
	date.setDate(date.getDate() + days);
	return date;
};

Date.prototype.subDays = function (days) {
  let date = new Date(this.valueOf());
  date.setDate(date.getDate() - days);
  return date;
}

function dateSort(a, b) {
	return new Date(a.StartDateTime) - new Date(b.StartDateTime);
}

function getDSTStart(year) {
	var date = new Date(year, 2, 7, 2);
	date.setDate(7 + (7 - date.getDay()));
	return date;
}

function getDSTEnd(year) {
	var date = new Date(year, 10, 7, 2);
	date.setDate(0 + (7 - date.getDay()));
	return date
}

function userClockRespectsDST(d) {
    var respectsDST = false;
	var jan = new Date(d.getFullYear(), 0, 1).getTimezoneOffset();
    //console.log(jan);
	var jul = new Date(d.getFullYear(), 6, 1).getTimezoneOffset();
    //console.log(jul);
    if(jan !== jul) {
        respectsDST = true;
    }
	return respectsDST;
}

function zoomDateInfo(event) {
    var s_EST = new Date(event.StartDateTime).toLocaleString("en-US", {
        timeZone: "America/New_York"
    });
    var s = new Date(s_EST);
    //console.log(s);

    var e_EST = new Date(event.EndDateTime).toLocaleString("en-US", {
        timeZone: "America/New_York"
    });
    var e = new Date(e_EST);
    //console.log(e);

    var ms = Math.abs(s - e);
    var days = Math.floor(ms / (24 * 60 * 60 * 1000));
    var daysms = ms % (24 * 60 * 60 * 1000);
    var hours = Math.floor((daysms) / (60 * 60 * 1000));
    var hoursms = ms % (60 * 60 * 1000);
    var minutes = Math.floor((hoursms) / (60 * 1000));
    var minutesms = ms % (60 * 1000);
    var sec = Math.floor((minutesms) / (1000));
    var d = "";

    if (days > 0) {
        d += days;
        if (days === 1) {
            d += " day";
        } else {
            d += " days";
        }
    }
    if (hours > 0) {
        if (days > 0) {
            d += " ";
        }
        d += hours;
        if (hours === 1) {
            d += " hour";
        } else {
            d += " hours";
        }
    }
    if (minutes > 0) {
        if (minutes > 0) {
            d += " ";
        }
        d += " " + minutes;
        if (minutes === 1) {
            d += " minute";
        } else {
            d += " minutes";
        }
    }
    //console.log(d);

    var dstring;
    var sstring = s.toLocaleDateString('en-us', { weekday:"long", year:"numeric", month:"long", day:"numeric"});
    var estring = e.toLocaleDateString('en-us', { weekday:"long", year:"numeric", month:"long", day:"numeric"});
    if (sstring === estring) {
        dstring = s.toLocaleDateString('en-us', { weekday:"long", year:"numeric", month:"long", day:"numeric"});
    }
    else {
        dstring = s.toLocaleDateString('en-us', { weekday:"long", year:"numeric", month:"long", day:"numeric"});
    }

    var trange;
    var stime = formatAMPM(s);
    var etime = formatAMPM(e);

    var trange;
    if (days > 0) {
        trange = stime;
    } else {
        trange = stime + " – " + etime;
    }

    var dateobj = {
        "DateString": dstring,
        "Duration": d,
        "MonthAbbr": MonthAbbreviations[s.getMonth()],
        "NumDate": s.getDate(),
        "TimeRange": trange
    }

    //console.log(dateobj);
    return dateobj;
}

function formatAMPM(date) {
    var hours = date.getHours();
    var minutes = date.getMinutes();
    var ampm = hours >= 12 ? 'PM' : 'AM';
    hours = hours % 12;
    hours = hours ? hours : 12; // the hour '0' should be '12'
    minutes = minutes < 10 ? '0' + minutes : minutes;
    var strTime = hours + ':' + minutes + ' ' + ampm;
    return strTime;
}

function getCalendarData() {
    var today_EST = getServerTime().toLocaleString("en-US", {
        timeZone: "America/New_York"
    });    
    
    var tdate = new Date(today_EST);
    var year = tdate.getFullYear();
    var month = tdate.getMonth();
    var day = tdate.getDate();
    var sdatestring;
    var edatestring;
    
    if((alldata.CourseOffering.StartDate !== null) && (alldata.CourseOffering.EndDate !== null)) {
        var sdate = new Date(alldata.CourseOffering.StartDate);
        var syear = sdate.getFullYear();
        var smonth = sdate.getMonth();
        var sday = sdate.getDate();
        sdatestring = new Date(syear, smonth - 1, sday).toISOString();
        
        var edate = new Date(alldata.CourseOffering.EndDate);
        var eyear = edate.getFullYear();
        var emonth = edate.getMonth();
        var eday = edate.getDate();
        edatestring = new Date(eyear, emonth + 1, eday).toISOString();
    }
    else {
        if((alldata.CourseOffering.StartDate === null) && (alldata.CourseOffering.EndDate === null)) {
            sdatestring = new Date(year - 1, month, day).toISOString();
            edatestring = new Date(year + 1, month, day).toISOString();
        }
        else {
            if(alldata.CourseOffering.StartDate !== null) {
                var sdate = new Date(alldata.CourseOffering.StartDate);
                var syear = sdate.getFullYear();
                var smonth = sdate.getMonth();
                var sday = sdate.getDate();
                sdatestring = new Date(sdate).toISOString();
                edatestring = new Date(syear + 1, smonth, sday).toISOString();
            }
            else {
                var edate = new Date(alldata.CourseOffering.EndDate);
                var eyear = edate.getFullYear();
                var emonth = edate.getMonth();
                var eday = edate.getDate();
                sdatestring = new Date(eyear - 1, emonth, eday).toISOString();
                edatestring = new Date(edate).toISOString();
            }            
        }
    }
    
    //console.log(sdatestring);
    //console.log(edatestring);
    getMyCalendar(sdatestring, edatestring);
}

function getMyCalendar(sdate, edate, next) {
    var calendarurl = "/d2l/api/le/" + alldata.APIVersions.LE.LatestVersion + "/" + orgUnitId + "/calendar/events/myEvents/";
	if (next !== undefined) {
		calendarurl = next;
	} else {
		calendarurl += "?startDateTime=" + sdate + "&endDateTime=" + edate;
	}    
    //console.log(calendarurl);
    $.ajax({
        method: "GET",
        url: calendarurl,
        dataType: 'json',
        success: function (mycalendar_tmp) {
            
            //console.log(mycalendar_tmp);
			if (alldata.Calendar === undefined) {
				alldata.Calendar = mycalendar_tmp.Objects;
			} else {
				alldata.Calendar = alldata.Calendar.concat(mycalendar_tmp.Objects);
			}

			if (mycalendar_tmp.Next !== null) {
				getMyCalendar(sdate, edate, mycalendar_tmp.Next);
			} else {
                processCalendarRecurring();
			}
        } //end success
    }) //end ajax
}

function processCalendarRecurring() {
	for (var c = 0; c < alldata.Calendar.length; c++) {
		if (alldata.Calendar[c].StartDateTime === null) {
			if (alldata.Calendar[c].StartDay !== null) {
				alldata.Calendar[c].StartDateTime = alldata.Calendar[c].StartDay;
			}
		}
		if (alldata.Calendar[c].EndDateTime === null) {
			if (alldata.Calendar[c].EndDay !== null) {
				alldata.Calendar[c].EndDateTime = alldata.Calendar[c].EndDay;
			}
		}
	}
    
    alldata.CalendarAll = JSON.parse(JSON.stringify(alldata.Calendar));
    
    alldata.CalendarRecurring = {
        Check:0,
        Done:0,
        ItemList: []
    }
    
	for (var c = 0; c < alldata.Calendar.length; c++) {
		
        //console.log(alldata.CalendarRecurring.ItemList);
        //console.log(alldata.Calendar[c].CalendarEventId);
        //console.log(alldata.CalendarRecurring.ItemList.indexOf(alldata.Calendar[c].CalendarEventId));
        
		if(alldata.CalendarRecurring.ItemList.indexOf(alldata.Calendar[c].CalendarEventId) === -1) {
			alldata.CalendarAll[c].StartDateTime = new Date(alldata.Calendar[c].StartDateTime);
            
            if(alldata.CalendarAll[c].EndDateTime !== null) {
                alldata.CalendarAll[c].EndDateTime = new Date(alldata.Calendar[c].EndDateTime);
            }
            else {
                if(alldata.CalendarAll[c].EndDay !== null) {
                    var alldayend = new Date(alldata.CalendarAll[c].EndDay);
                    //console.log(alldayend);
                    var alldaydisplay = addMinutes(alldayend,-1);
                    //console.log(alldaydisplay);                
                    alldata.CalendarAll[c].EndDateTime = alldaydisplay;
                }
            }            
			

			if (alldata.Calendar[c].RecurrenceInfo !== null) {
				var rsdate = new Date(alldata.Calendar[c].StartDateTime);
				var redate = new Date(alldata.Calendar[c].EndDateTime);
				var rcdate = new Date(alldata.Calendar[c].StartDateTime);
				var rudate = new Date(alldata.Calendar[c].RecurrenceInfo.RepeatUntilDate);

				var s_dst = getDSTStart(new Date(rsdate).getFullYear());
				var e_dst = getDSTEnd(new Date(rsdate).getFullYear());

				var startsinDST = false;
				if((rsdate > s_dst) && (rsdate < e_dst)) {
					startsinDST = true;
				}
                //console.log(startsinDST);

                var someadded = false;
				while (rcdate <= rudate) {

					var addit = false;
					rcdate.setDate(rcdate.getDate() + 1);
					redate.setDate(redate.getDate() + 1);

					if (alldata.Calendar[c].RecurrenceInfo.RepeatType === 2) {
						addit = true;
					} else if (alldata.Calendar[c].RecurrenceInfo.RepeatType === 3) {
						var thisday = rcdate.getDay();

						var RepeatOn = alldata.Calendar[c].RecurrenceInfo.RepeatOnInfo[RecurrenceDays[thisday]];
						if (RepeatOn) {
							addit = true;
						}

					}

					if (addit) {
                        someadded = true;
						var todaystart = new Date(rcdate);
						todaystart.setHours(0, 0, 0, 0);
						todaystart = todaystart.toISOString();
						var todayend = new Date(todaystart);
						todayend.setDate(todayend.getDate() + 1);
						todayend = todayend.toISOString();

						//console.log(todaystart);
						//console.log(todayend);

						var newDateObj = JSON.parse(JSON.stringify(alldata.Calendar[c]));

						newDateObj.StartDateTime = new Date(rcdate);
						newDateObj.EndDateTime = new Date(redate);

						var this_s_dst = getDSTStart(newDateObj.StartDateTime.getFullYear());
						var this_e_dst = getDSTEnd(newDateObj.StartDateTime.getFullYear());				
						var thisinDST = false;
						if((newDateObj.StartDateTime > this_s_dst) && (newDateObj.StartDateTime < this_e_dst)) {
							thisinDST = true;
						}		

                        //console.log(thisinDST);
                        
						if(startsinDST) {
							if (!thisinDST) {
								var tnow = new Date();
								if (!userClockRespectsDST(tnow)) {
									newDateObj.StartDateTime.setHours(newDateObj.StartDateTime.getHours() + 1);
									newDateObj.EndDateTime.setHours(newDateObj.EndDateTime.getHours() + 1);
								}
							}	
						}
                        

						if(!startsinDST) {
							if (thisinDST) {
								var tnow = new Date();
								if (!userClockRespectsDST(tnow)) {
									newDateObj.StartDateTime.setHours(newDateObj.StartDateTime.getHours() - 1);
									newDateObj.EndDateTime.setHours(newDateObj.EndDateTime.getHours() - 1);
								}
							}	
						}		

						alldata.CalendarRecurring.Check++;
						//console.log(todaystart);
						//console.log(todayend);
						//console.log(c);
						//console.log(newDateObj);
						checkCalendarRecur(todaystart, todayend, newDateObj);

						//alldata.CalendarAll.push(newDateObj);
					}
				}
                
                if(someadded) {
                    alldata.CalendarRecurring.ItemList.push(alldata.Calendar[c].CalendarEventId);
                }
			}
		}
	}

	if (alldata.CalendarRecurring.Check === 0) {
		processCalendarAll();
	}    

}

function checkCalendarRecur(sdate, edate, eobj, next) {
    
    var calendarurl = "/d2l/api/le/" + alldata.APIVersions.LE.LatestVersion + "/" + orgUnitId + "/calendar/events/myEvents/";
	if (next !== undefined) {
		calendarurl = next;
	} else {
		calendarurl += "?startDateTime=" + sdate + "&endDateTime=" + edate;
	}    
    $.ajax({
        method: "GET",
        url: calendarurl,
        dataType: 'json',
        success: function (mycalendar_tmp) {
        
			//console.log(mycalendar_tmp);
			var isfound = false;
			for (var e = 0; e < mycalendar_tmp.Objects.length; e++) {
				if (mycalendar_tmp.Objects[e].CalendarEventId === eobj.CalendarEventId) {
					isfound = true;
                    break;
				}
			}

            var donecheck = false;
			if (isfound) {
				//console.log(eobj);
                donecheck = true;
				alldata.CalendarAll.push(eobj);
			}
            else {
                if (mycalendar_tmp.Next !== null) {
                    checkCalendarRecur(sdate, edate, eobj, mycalendar_tmp.Next);
                } else {
                    donecheck = true;
                }
            }

            if(donecheck) {
                alldata.CalendarRecurring.Done++;
                if (alldata.CalendarRecurring.Check === alldata.CalendarRecurring.Done) {
                    processCalendarAll();
                }
            }        

        } //end success
    }) //end ajax       
}

var zoom_firstfound = false;
var zoom_allfound = false;
var zoom_pauseindex = -1;
function processCalendarAll() {
    alldata.CalendarAll.sort(dateSort);
    alldata.CalendarZoom = {
        Done: [],
        Items: []
    }
    
    var today_EST = getServerTime().toLocaleString("en-US", {
        timeZone: "America/New_York"
    });
    var tdate = new Date(today_EST);    
    
	for (var c = 0; c < alldata.CalendarAll.length; c++) {
		
		//if(alldata.CalendarZoom.Done.indexOf(alldata.CalendarAll[c].CalendarEventId) === -1) {
			alldata.CalendarZoom.Done.push(alldata.CalendarAll[c].CalendarEventId);		

			var checkdates = false;
			if (alldata.CalendarAll[c].AssociatedEntity === null) {
				checkdates = true;
			} else {
				if (alldata.CalendarAll[c].AssociatedEntity.AssociatedEntityType === "D2L.LE.Content.ContentObject.TopicCO") {
					checkdates = true;
				}
			}

			if (checkdates) {
				var isfuture = true;
				//console.log(tdate);
				if (alldata.CalendarAll[c].EndDateTime !== null) {
					var end_EST = new Date(alldata.CalendarAll[c].EndDateTime).toLocaleString("en-US", {
						timeZone: "America/New_York"
					});
					var edate = new Date(end_EST);
					//console.log(edate);
					if (edate < tdate) {
						isfuture = false;
					}
				}

				if (isfuture) {
					if (alldata.CalendarAll[c].Description !== "") {
                        
						var thishtml = $.parseHTML(alldata.CalendarAll[c].Description);
						//console.log(thishtml);

						var afound = $(thishtml).find("a");
						//console.log(afound);

						var azoomhref = "";
						for (var a = 0; a < afound.length; a++) {
							if ((afound[a].href.indexOf("conestogac.zoom.us/j/") > -1) || 
                                (afound[a].href.indexOf("conestogac.zoom.us/s/") > -1) || 
								(afound[a].href.indexOf("conestogac.zoom.us%2Fj%2F") > -1) || 
								(afound[a].href.indexOf("conestogac.zoom.us/my/") > -1) || (afound[a].href.indexOf("conestogac.zoom.us/meeting/") > -1) || 
								((afound[a].href.indexOf("teams.microsoft.com") > -1) && (afound[a].href.indexOf("/meet/") > -1)) || 
								((afound[a].href.indexOf("teams.microsoft.com") > -1) && (afound[a].href.indexOf("meetup-join") > -1))
							   ) {
                                if(afound[a].href.indexOf("/ics?") === -1) {
                                    azoomhref = afound[a].href;
                                    break;
                                }
							}
						}

						if (azoomhref !== "") {
							var zoomlink = {
								"href": azoomhref,
								"event": alldata.CalendarAll[c]
							}
							alldata.CalendarZoom.Items.push(zoomlink);
							zoom_firstfound = true;
							zoom_pauseindex = c;
							break;
						}
					}
				}
			}
		//}
	}

	//console.log(alldata.CalendarAll);
	//console.log(alldata.CalendarZoom.Items);

	if (alldata.CalendarZoom.Items.length > 0) {
		// Present Zoom Item
	}    
    
    alldone.Calendar = true;
    //console.log("ad38");
    checkAllDone();
}

