function modelEnrollCopyAccess(accessdata) {
    ecplusClient.courseReadiness.grantCopyAccess(accessdata.OrgID, accessdata.UserID, { deliveryId: accessdata.ToOrgID, roleId: '114' }).then(function (resp) {
        if (resp.isSuccess) {
            for(var m=0; m<alldata.Readiness.Result[0].MatchingModels.length; m++) {
                var thismodel = alldata.Readiness.Result[0].MatchingModels[m];
                if(thismodel.OrgUnitId === accessdata.OrgID) {
                    thismodel.AccessConfirmed = true;
                    thismodel.AccessEnrolled = true;
                    break;
                }
            }
            alldata.Readiness.Result[0].EmptyCheck.Access++;
            processModelMatchesAccess();
        }
        else {
            for(var m=0; m<alldata.Readiness.Result[0].MatchingModels.length; m++) {
                var thismodel = alldata.Readiness.Result[0].MatchingModels[m];
                if(thismodel.OrgUnitId === accessdata.OrgID) {
                    thismodel.AccessConfirmed = false;
                    thismodel.NotFound = true;
                    break;
                }
            }
            alldata.Readiness.Result[0].EmptyCheck.Access++;
            processModelMatchesAccess();
        }
    });
}

