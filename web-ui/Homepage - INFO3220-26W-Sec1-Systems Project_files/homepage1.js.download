function processModelMatchesEmpty() {
    
    //console.log(alldata.Readiness.Result[0].EmptyCheck.Content);
    //console.log(alldata.Readiness.Result[0].EmptyCheck.Grades);
    //console.log(alldata.Readiness.Result[0].EmptyCheck.ReadyDates);
    //console.log(alldata.Readiness.Result[0].MatchingModels.length);
    
    if((alldata.Readiness.Result[0].EmptyCheck.Content === alldata.Readiness.Result[0].MatchingModels.length) 
       && (alldata.Readiness.Result[0].EmptyCheck.Grades === alldata.Readiness.Result[0].MatchingModels.length)
       && (alldata.Readiness.Result[0].EmptyCheck.ReadyDates == alldata.Readiness.Result[0].MatchingModels.length)
      ) {
        
        for(var m=0; m<alldata.Readiness.Result[0].MatchingModels.length; m++) {
            var contentfound = false;
            var gradesfound = false;
            var thismodel = alldata.Readiness.Result[0].MatchingModels[m];
            
            if(thismodel.AccessConfirmed) {
                if(thismodel.Content.Modules.length > 0) {
                    contentfound = true;
                }
                if(thismodel.GradeItems.Objects.length > 0) {
                    gradesfound = true;
                }
                if((contentfound === false) && (gradesfound === false)) {
                    thismodel.IsEmpty = true;   
                }
                else {
                    thismodel.IsEmpty = false;
                }
            }
            else {
                thismodel.Empty = false;
            }
        }
        
        emptycheckdone = true;
        displayModelMatchResults();
        
    }
}

function processModelMatchesAccess() {
    if((alldata.Readiness.Result[0].EmptyCheck.Access === alldata.Readiness.Result[0].MatchingModels.length)) {
        for(var m=0; m<alldata.Readiness.Result[0].MatchingModels.length; m++) {
            var thismodel = alldata.Readiness.Result[0].MatchingModels[m];
            //console.log(thismodel);
            if(thismodel.AccessConfirmed) {
                getCourseContentTOC(thismodel.OrgUnitId);
                getGradeItems(thismodel.OrgUnitId);
                getCustomWidgetData(CustomWidgetUC, false, thismodel.OrgUnitId);
            }
            else {
                alldata.Readiness.Result[0].EmptyCheck.Content++;
                alldata.Readiness.Result[0].EmptyCheck.Grades++;
                alldata.Readiness.Result[0].EmptyCheck.ReadyDates++;
                processModelMatchesEmpty();                
            }
        }
    }
}

var emptycheckdone = false;
function checkModelMatchesEmpty() {
    if(alldata.Readiness !== null) {
        alldata.Readiness.Result[0].EmptyCheck = {
            Access: 0,
            Content: 0,
            Grades: 0,
            ReadyDates: 0
        }
        for(var m=0; m<alldata.Readiness.Result[0].MatchingModels.length; m++) {
            var thismodel = alldata.Readiness.Result[0].MatchingModels[m];
            thismodel.AccessConfirmed = false;

            var queuedata = {
                OrgID: thismodel.OrgUnitId,
                ToOrgID: orgUnitId,
                UserID: alldata.WhoAmI.Identifier
            }
            checkModelUserAccess(queuedata);

            //getCourseContentTOC(thismodel.OrgUnitId);
            //getGradeItems(thismodel.OrgUnitId);

        }
    }
    else {
        displayModelMatchResults();
    }
}


function removeDeletedModels() {
    var deletefound = false;
    if(alldata.Readiness !== undefined) {
        if(alldata.Readiness !== null) {
            var resultmatches = [];
            for(var m=0; m<alldata.Readiness.Result[0].MatchingModels.length; m++) {
                var thismodel = alldata.Readiness.Result[0].MatchingModels[m];
                if(thismodel.NotFound === undefined) {
                    resultmatches.push(thismodel);
                }
                else {
                    deletefound = true;
                }
            }
            alldata.Readiness.Result[0].MatchingModels = resultmatches;
        }
    }
    
    //console.log(deletefound);
    if(deletefound) {
        processModelMatchMulti();
    }
}


function displayModelSelection(modelmatch, ismulti) {
    
    $('#course-copy-end-chair').addClass('d-none');
    $('#course-copy-construction-ready-date').html('');
    $('#course-copy-construction-ready-date').addClass('d-none');    
    
    var modelstring = modelmatch.CopiedFromName;
    var modeltokens = modelstring.split('-');
    var modeltitle = '';
    for(var mt=0; mt<modeltokens.length-1; mt++) {
        modeltitle += modeltokens[mt];
        if(mt < (modeltokens.length-2)) {
            modeltitle += '-';
        }
    }
    
    var chairemail;
    if(alldata.SIS !== null) {
        if(alldata.SIS.Chair !== null) {
            if(alldata.SIS.Chair.SectionDelivery !== null) {
                if(alldata.SIS.Chair.SectionDelivery.Email !== null) {
                    chairemail = alldata.SIS.Chair.SectionDelivery.Email;
                }
            }                                        
        }
    }
    
    $('#course-copy-match-confirm').removeClass('d-none');
        
    if(modelmatch.InDevelopment) {
        $('#course-copy-begin-btn').addClass('d-none');
        $('.course-copy-info-box').addClass('d-none');
        $('#course-copy-begin-info').addClass('d-none');

        $('#course-copy-confirm-header').text('Model Update in Progress');
        
        var notificationfound = false;
        if(alldata.UserNotifications !== null) {
            for(var un=0; un<alldata.UserNotifications.length; un++) {
                var thisnotification = alldata.UserNotifications[un];
                if(parseInt(thisnotification.Trigger) === modelmatch.OrgUnitId) {
                    notificationfound = true;
                }
            }
        }

        if(!notificationfound) {

            /*
            $('#course-copy-begin-btn').attr('disabled','disabled');
            $('#course-copy-begin-info').addClass('d-none');

            $('#course-copy-match-confirm .course-copy-info-box').addClass('under-construction');
            */

            //var confirmtext = 'We found a Model that matches your course but it is currently under construction. ';
            var confirmtext = '';
            if(modelmatch.ReadyDate !== null) {
                var ucdate = new Date(modelmatch.ReadyDate.ReadyDate).toLocaleDateString('en-us', { weekday:"long", year:"numeric", month:"long", day:"numeric"});
                confirmtext += 'Estimated ready date: ' + ucdate;
                $('#course-copy-construction-ready-date').html(confirmtext);
                $('#course-copy-construction-ready-date').removeClass('d-none');                
            }
            
            $('#course-construction-image').removeClass('d-none');

            $('#course-copy-confirm-body').text("A course editor is updating this model ("+modeltitle+") to ensure it is up-to-date. Want an email when it's ready to copy?");

            //$('#subscribeCopyReadyEmail').val(parent.userEmail);

            if(alldata.CourseOffering.StartDate !== null) {
                var today_EST = getServerTime().toLocaleString("en-US", {
                    timeZone: "America/New_York"
                });
                var tdate = new Date(today_EST);
                var csdate = new Date(alldata.CourseOffering.StartDate);
                
                var sstext;
                if(csdate < tdate) {
                    if(chairemail !== undefined) {
                        sstext = '<em class="course-copy-helptext">Since your course has already started, we recommend that you <a style="text-decoration:underline" href="javascript:contactDeliveryChair(\'notready\')">email your chair</a> ('+chairemail+') to discuss next steps.</em>';
                    }
                    else {
                        sstext = '<em class="course-copy-helptext">Since your course has already started, we recommend that you email your chair to discuss next steps.</em>';
                    }
                }
                else {
                    //console.log(daysBetween(tdate,csdate));
                    if(daysBetween(tdate,csdate) < 15) {
                        if(chairemail !== undefined) {
                            sstext = '<em class="course-copy-helptext">Since your course is scheduled to start in less than two weeks, we recommend that you <a style="text-decoration:underline" href="javascript:contactDeliveryChair(\'notready\')">email your chair</a> ('+chairemail+') to discuss next steps.</em>';
                        }
                        else {
                            sstext = '<em class="course-copy-helptext">Since your course is scheduled to start in less than two weeks, we recommend that you email your chair to discuss next steps.</em>';
                        }
                    }
                }

                if(sstext !== undefined) {
                    $('#course-copy-construction-start-soon').html(sstext);
                    $('#course-copy-construction-start-soon').removeClass('d-none');
                }
            }

            $('#course-copy-subscribe').attr('onClick', 'subscribeNotificationConfirm('+modelmatch.OrgUnitId+')');
            $('#course-copy-subscribe').removeClass('d-none');
            //$('#course-copy-subscribe-found').addClass('d-none');       
        }
        else {
            
            var previoustext = 'This model ('+modeltitle+') is currently being updated and is not yet available to copy.';
            if(modelmatch.ReadyDate !== null) {
                var ucdate = new Date(modelmatch.ReadyDate.ReadyDate).toLocaleDateString('en-us', { weekday:"long", year:"numeric", month:"long", day:"numeric"});
                previoustext += ' Estimated ready date: ' + ucdate + '.';           
            }            
            
            $('#course-copy-subscribed-previously').text(previoustext);
            $('#course-copy-subscribed-previously').removeClass('d-none');
            
            $('#course-copy-subscribed-already-email').text(parent.userEmail);  
            
            $('#course-copy-match-confirm').addClass('d-none');
            $('#course-copy-email-confirm').removeClass('d-none');

            //$('#course-copy-subscribe').addClass('d-none');
            //$('#course-copy-subscribe-found').removeClass('d-none');
        }
    }
    else if(modelmatch.IsEmpty) {
        $('#course-copy-begin-btn').addClass('d-none');
        $('.course-copy-info-box').addClass('d-none');
        $('#course-copy-begin-info').addClass('d-none');
        
        $('#course-copy-confirm-header').text('Model is Missing Content');

        /*
        $('#course-copy-begin-btn').attr('disabled','disabled');
        $('#course-copy-begin-info').addClass('d-none');
        
        $('#course-copy-match-confirm .course-copy-info-box').addClass('under-construction');
        */
        
        var emptytext = '';
        if(chairemail !== undefined) {
            emptytext = 'Please contact your Chair to discuss updating the model ('+modeltitle+')  or consider populating your current section from a different source.';
        }
        else {
            emptytext = 'Please contact your chair to discuss updating the model ('+modeltitle+')  or consider populating your current section from a different source.';
        }
        
        $('#course-copy-confirm-body').html(emptytext);  

        $('#course-copy-construction-chair').removeClass('d-none');
        $('#course-copy-end-chair').removeClass('d-none');
    }        
    else {

        $('#course-copy-begin-btn').removeClass('d-none');
        $('.course-copy-info-box').removeClass('d-none');
        $('#course-copy-begin-info').removeClass('d-none');

        $('#course-copy-begin-btn').removeAttr('disabled');
        $('#course-copy-begin-info').removeClass('d-none');

        $('#course-copy-match-confirm .course-copy-info-box').removeClass('under-construction');

        if(ismulti) {
            $('#course-copy-confirm-header').text("Confirm Content");
            $('#course-copy-confirm-body').text("Please confirm that this is the model you wish to copy from:");   
        }
        else {
            $('#course-copy-confirm-header').text("Match found!");
            $('#course-copy-confirm-body').text("We found a Model that matches your course:");    
        }
        
        $('#course-copy-match-confirm #course-copy-info-box-title').text(modelmatch.CopiedFromName);
        var deliverymode = modelmatch.DeliveryModeName;
        /*
        if(deliverymode === "IP") {
            deliverymode = "In Person";
        }
        if(deliverymode === "HY") {
            deliverymode = "Hybrid";
        }
        */

        $('#course-copy-match-confirm #course-copy-info-box-delivery').text(deliverymode);
        $('#course-copy-match-confirm #course-copy-info-box-duration').text(modelmatch.Length + " weeks");

        var indevelopment = "";
        if(modelmatch.InDevelopment) {
            indevelopment = "Model update in progress";
        }
        else {
            if(modelmatch.IsEmpty) {
                indevelopment = "Model missing content";
            }
            else {
                indevelopment = "Ready to copy";
            }

        }
        $('#course-copy-match-confirm .course-copy-info-box-status').text(indevelopment);
        
    }
    
    if(ismulti) {
        $('#course-copy-end-single').addClass('d-none');
        $('.course-copy-end-multi').removeClass('d-none');
    }
    else {
        $('.course-copy-end-multi').addClass('d-none');
        $('#course-copy-end-single').removeClass('d-none');
    }
    
}


function displayModelMatchResults() {
    
    removeDeletedModels();
    
    var ctitle = '';
    if(alldata.Outline.length > 0) {
        ctitle = alldata.Outline[0].Course;
    }
    else {
        if(alldata.Offering !== null) {
            ctitle = alldata.Offering.Title;
        }
        else {
            ctitle = alldata.CourseOffering.Name;
        }
    }                                
    $('.course-copy-header h1').text(ctitle);

    var sectionstring = '';
    if(alldata.Semester !== undefined) {
        if(alldata.Semester.Term === "W") {
            sectionstring += "Winter ";
        }
        if(alldata.Semester.Term === "S") {
            sectionstring += "Spring ";
        }
        if(alldata.Semester.Term === "F") {
            sectionstring += "Fall ";
        }
        sectionstring += 2000 + alldata.Semester.Year;
        sectionstring += " - ";

        if(alldata.Offering.Sec.length > 0) {
            if(alldata.Offering.Sec.length === 1) {
                sectionstring += " Section ";
                sectionstring += alldata.Offering.Sec[0];
            }
            else {
                sectionstring += " Sections ";
                for (var sn=0; sn<alldata.Offering.Sec.length; sn++) {
                    if(sn !== (alldata.Offering.Sec.length-1)) {
                        sectionstring += alldata.Offering.Sec[sn] + ", ";
                    }
                    else {
                        sectionstring += alldata.Offering.Sec[sn];
                    }
                }
            }
        }                                
    }
    $('.course-copy-header h2').text(sectionstring);    
    
    $('#course-copy-construction-chair').addClass('d-none');
    $('#course-copy-match-multi .course-copy-table tbody').html('');
    
    var chairfound = false;
    var chairemail;
    if(alldata.SIS !== null) {
        if(alldata.SIS.Chair !== null) {
            chairfound = true;
            if(alldata.SIS.Chair.SectionDelivery !== null) {
                if(alldata.SIS.Chair.SectionDelivery.Email !== null) {
                    chairemail = alldata.SIS.Chair.SectionDelivery.Email;
                }
            }
            
            /*
            $('.course-copy-chair-name').html(alldata.SIS.Chair.SectionDelivery.Name);
            if(chairemail !== undefined) {
                $('.course-copy-chair-email').html('<a style="text-decoration:underline" href="mailto:'+chairemail+'?Subject=Model for '+alldata.CourseOffering.Name+'">'+chairemail+'</a>');
            }
            else {
                $('.course-copy-chair-email').html('Not available');
            }
            */

        }
    }
    if(!chairfound) {
        $('.course-copy-chair-contact').addClass('d-none');
    }     
    
    if(alldata.Readiness !== undefined) {
        if(alldata.Readiness !== null) {
            if(alldata.Readiness.Result[0].MatchingModels.length > 0) {
                
                var exactfound = false;
                if(alldata.Readiness.Result[0].MatchingModels.length === 1) {
                    if(alldata.Readiness.Matches.Exact.length === 1) {
                        exactfound = true;
                    }   
                }
                
                if(exactfound) {
                    $('.course-copy-gray-bar').removeClass('d-none');
                    //console.log(modeltitle);
                    
                    var modelmatch = alldata.Readiness.Result[0].MatchingModels[0];
                    displayModelSelection(modelmatch);
                    alldata.Readiness.Selected = modelmatch;
                }
                else {
                    
                    var sdatefound = false;
                    var edatefound = false;
                    var sdate;
                    var edate;
                    var sdatetext;
                    var edatetext;
                    var nweeks;
                    
                    if(alldata.CourseOffering.StartDate !== null) {
                        sdatefound = true;
                        sdatetext = new Date(alldata.CourseOffering.StartDate).toLocaleDateString('en-us', { weekday:"long", year:"numeric", month:"long", day:"numeric"});
                        $('#match-multi-start').text(sdatetext);
                    }
                    if(alldata.CourseOffering.EndDate !== null) {
                        edatefound = true;
                        edatetext = new Date(alldata.CourseOffering.EndDate).toLocaleDateString('en-us', { weekday:"long", year:"numeric", month:"long", day:"numeric"});
                        $('#match-multi-end').text(edatetext);
                    }
                    if(sdatefound && edatefound) {
                        sdate = new Date(alldata.CourseOffering.StartDate);
                        edate = new Date(alldata.CourseOffering.EndDate);

                        nweeks = nWeeks(sdate, edate);                        
                        $('#match-multi-duration').text(nweeks + ' weeks');
                    }
                    
                    for(var m=0; m<alldata.Readiness.Result[0].MatchingModels.length; m++) {
                        
                        var thismodel = alldata.Readiness.Result[0].MatchingModels[m];
                        var modelstring = thismodel.CopiedFromName;
                        var modeltokens = modelstring.split('-');
                        var modeltitle = '';
                        for(var mt=0; mt<modeltokens.length-1; mt++) {
                            modeltitle += modeltokens[mt];
                            if(mt < (modeltokens.length-2)) {
                                modeltitle += '-';
                            }
                        }
                        
                        var notificationfound = false;
                        if(alldata.UserNotifications !== null) {
                            for(var un=0; un<alldata.UserNotifications.length; un++) {
                                var thisnotification = alldata.UserNotifications[un];
                                if(parseInt(thisnotification.Trigger) === thismodel.OrgUnitId) {
                                    notificationfound = true;
                                }
                            }
                        }                        
                        
                        if(thismodel.CopiedFromName.toLowerCase().indexOf("-model-") > -1) {

                            var indevelopment = "";
                            if(thismodel.InDevelopment) {
                                indevelopment = "Model update in progress";
                                var matchobj = '';
                                    if(notificationfound) {
                                        matchobj += '<tr class="under-construction-multi">';
                                    }
                                    else {
                                        matchobj += '<tr>';
                                    }
                                    //matchobj += '<tr class="under-construction">';
                                    //matchobj += '<tr>';
                                    matchobj += '<td class="course-copy-table-mobile align-middle">';
                                    matchobj += '<p>'+modeltitle+'</p>';
                                    matchobj += '<p><strong>Duration:</strong> '+thismodel.Length+' weeks</p>';
                                    matchobj += '<div>';
                                    if(notificationfound) {
                                        matchobj += '<a href="javascript:void(0)" class="under-construction-status course-copy-ui-tooltip" data-toggle="tooltip" data-html="true" title="You are registered to receive an email when this model is ready.">';
                                    }
                                    else {
                                        matchobj += '<a href="javascript:void(0)" class="under-construction-status course-copy-ui-tooltip" data-toggle="tooltip" data-html="true" title="A course editor is updating this model. Select it to be emailed when the model is ready.">';
                                    }
                                    matchobj += '<span class="mr-1">'+indevelopment+'</span>';
                                    matchobj += '<sup><img src="assets/icons/info.svg"></sup>';
                                    matchobj += '</a>';
                                    matchobj += '</div>';
                                    matchobj += '</td>';
                                    matchobj += '<td class="course-copy-table-full align-middle">';
                                    matchobj += modeltitle;
                                    matchobj += '</td>';
                                    matchobj += '<td class="course-copy-table-full align-middle">'+thismodel.Length+' weeks</td>';
                                    matchobj += '<td class="course-copy-table-full align-middle">';
                                
                                    if(notificationfound) {
                                        matchobj += '<a href="javascript:void(0)" class="under-construction-status course-copy-ui-tooltip" data-toggle="tooltip" data-html="true" title="You are registered to receive an email when this model is ready.">';
                                    }
                                    else {
                                        matchobj += '<a href="javascript:void(0)" class="under-construction-status course-copy-ui-tooltip" data-toggle="tooltip" data-html="true" title="A course editor is updating this model. Select it to be emailed when the model is ready.">';
                                    }
                                    
                                    matchobj += '<span class="mr-1">'+indevelopment+'</span>';
                                    matchobj += '<sup><img src="assets/icons/info.svg"></sup>';
                                    matchobj += '</a>';
                                    matchobj += '</td>';
                                    matchobj += '<td class="course-copy-table-all course-copy-table-selectbox align-middle">';
                                    matchobj += '<div class="radio-container">';
                                    matchobj += '<input type="radio" id="course-copy-select-'+thismodel.OrgUnitId+'" name="course-copy-select" value="'+thismodel.OrgUnitId+'">';
                                    matchobj += '</div>';
                                    matchobj += '</td>';                                
                                    matchobj += '</tr>';                           
                            }
                            else {
                                if(thismodel.IsEmpty) {
                                    indevelopment = "Model missing content";
                                    var matchobj = '';
                                        //matchobj += '<tr class="under-construction">';
                                        matchobj += '<tr>';
                                        matchobj += '<td class="course-copy-table-mobile align-middle">';
                                        matchobj += '<p>'+modeltitle+'</p>';
                                        matchobj += '<p><strong>Duration:</strong> '+thismodel.Length+' weeks</p>';
                                        //matchobj += '<p>'+indevelopment+'</p>';
                                    
                                        matchobj += '<div>';
                                        matchobj += '<a href="javascript:void(0)" class="empty-model-status course-copy-ui-tooltip" data-toggle="tooltip" data-html="true" title="If this is the best model match, continue to the next screen for the option to contact your Chair.">';
                                        matchobj += '<span class="mr-1">'+indevelopment+'</span>';
                                        matchobj += '<sup><img src="assets/icons/info.svg"></sup>';
                                        matchobj += '</a>';                                    
                                        matchobj += '</div>';
                                    
                                        matchobj += '</td>';
                                        matchobj += '<td class="course-copy-table-full align-middle">';
                                        matchobj += modeltitle;
                                        matchobj += '</td>';
                                        matchobj += '<td class="course-copy-table-full align-middle">'+thismodel.Length+' weeks</td>';
                                        matchobj += '<td class="course-copy-table-full align-middle">';
                                        matchobj += '<a href="javascript:void(0)" class="empty-model-status course-copy-ui-tooltip" data-toggle="tooltip" data-html="true" title="If this is the best model match, continue to the next screen for the option to contact your Chair.">';
                                        matchobj += '<span class="mr-1">'+indevelopment+'</span>';
                                        matchobj += '<sup><img src="assets/icons/info.svg"></sup>';
                                        matchobj += '</a>';    
                                        matchobj += '</td>';
                                        matchobj += '<td class="course-copy-table-all course-copy-table-selectbox align-middle">';
                                        matchobj += '<div class="radio-container">';
                                        matchobj += '<input type="radio" id="course-copy-select-'+thismodel.OrgUnitId+'" name="course-copy-select" value="'+thismodel.OrgUnitId+'">';
                                        matchobj += '</div>';
                                        matchobj += '</td>';                                    
                                        matchobj += '</tr>';  
                                }
                                else {
                                    indevelopment = "Ready to copy";
                                    var matchobj = '';
                                        matchobj += '<tr>';
                                        matchobj += '<td class="course-copy-table-mobile align-middle">';
                                        matchobj += '<p>'+modeltitle+'</p>';
                                        matchobj += '<p><strong>Duration:</strong> '+thismodel.Length+' weeks</p>';
                                        matchobj += '</td>';
                                        matchobj += '<td class="course-copy-table-full align-middle">'+modeltitle+'</td>';
                                        matchobj += '<td class="course-copy-table-full align-middle">'+thismodel.Length+' weeks</td>';  
                                        matchobj += '<td class="course-copy-table-full align-middle"><span class="course-copy-status">'+indevelopment+'</span></td>';
                                        matchobj += '<td class="course-copy-table-all course-copy-table-selectbox align-middle">';
                                        matchobj += '<div class="radio-container">';
                                        matchobj += '<input type="radio" id="course-copy-select-'+thismodel.OrgUnitId+'" name="course-copy-select" value="'+thismodel.OrgUnitId+'" />';
                                        matchobj += '</div>';
                                        matchobj += '</td>';
                                        matchobj += '</tr>';    
                                }
                            }

                            $('#course-copy-match-multi .course-copy-table tbody').append(matchobj);   
                        }
                    }
                    
                    $('#course-copy-match-multi input[name="course-copy-select"]').on('change',function(){
                        var thischecked = $('#course-copy-match-multi input[name="course-copy-select"]:checked');
                        if(thischecked.length > 0) {
                            $('#course-copy-multi-next-btn').removeAttr('disabled');
                        }
                    });
                    
                    var ccmultitext = '';
                    var ccmultitooltip = '';
                    
                    ccmultitooltip += '<strong>Course Code:</strong> '+alldata.Code.String+'<br>';
                    ccmultitooltip += '<strong>Delivery Mode:</strong> '+alldata.SIS.DeliveryMode.Code + ' ('+alldata.SIS.DeliveryMode.Description+')<br>';
                    if(nweeks !== undefined) {
                        ccmultitooltip += '<strong>Duration:</strong> '+nweeks+' weeks<br>';                       if(sdatefound && edatefound) {
                            ccmultitooltip += '<strong>Start Date:</strong> '+sdatetext+'<br>';
                            ccmultitooltip += '<strong>End Date:</strong> '+edatetext;
                        }
                    }
                    
                    ccmultitext += '<p>We found models with different durations than <a href="javascript:void(0)" class="course-copy-match-criteria course-copy-ui-tooltip" data-toggle="tooltip" data-html="true" title="'+ccmultitooltip+'"><span class="mr-1">your course</span><sup><img src="assets/icons/info.svg"></sup></a>. Select the best match or the model identified by your Chair.</p>';
                    
                    if(chairemail !== undefined) {
                        ccmultitext += '<p><em class="course-copy-helptext">If you are unsure which model to use, please <a style="text-decoration:underline" href="javascript:contactDeliveryChair(\'multi\')">email your Chair</a> ('+chairemail+') for confirmation.</em></p>';
                    }
                    else {
                        ccmultitext += '<p><em class="course-copy-helptext">If you are unsure which model to use, please email your Chair for confirmation.</em></p>';
                    }
                    
                    $('#course-copy-multi-body').html(ccmultitext);
                    
                    $('.course-copy-ui-tooltip').tooltip({
                        placement:'auto',
                        boundary:'viewport'
                    });
                    
                    $('.under-construction-status').on('show.bs.tooltip', function () {
                        preventresize = true;
                        $('.under-construction-status').addClass('active');
                    });

                    $('.under-construction-status').on('hidden.bs.tooltip', function () {
                        preventresize = false;
                        $('.under-construction-status').removeClass('active');
                    });
                    
                    $('.empty-model-status').on('show.bs.tooltip', function () {
                        preventresize = true;
                        $('.empty-model-status').addClass('active');
                    });

                    $('.empty-model-status').on('hidden.bs.tooltip', function () {
                        preventresize = false;
                        $('.empty-model-status').removeClass('active');
                    });
                    
                    $('.course-copy-match-criteria').on('show.bs.tooltip', function () {
                        preventresize = true;
                        $('.course-copy-match-criteria').addClass('active');
                    });

                    $('.course-copy-match-criteria').on('hidden.bs.tooltip', function () {
                        preventresize = false;
                        $('.course-copy-match-criteria').removeClass('active');
                    });
                                    

                    $('.course-copy-progress-bar').removeClass('d-none');
                    $('#course-copy-match-multi').removeClass('d-none');
                }                
            }
            else {
                $('.course-copy-gray-bar').removeClass('d-none');
                $('#course-copy-match-missing').removeClass('d-none');
            }
        }
        else {
            $('.course-copy-gray-bar').removeClass('d-none');
            $('#course-copy-match-missing').removeClass('d-none');
        }

        var copysearchdone = new Date().getTime();
        var copytimepassed = copysearchdone - copybuttonclicked;
        var copyminimumdif = 5000 - copytimepassed;
        //console.log(copyminimumdif);
        
        if(copyminimumdif > 0) {
            setTimeout(function(){
                $('.cc-homepage-container').addClass('d-none');
                $('#course-copy-search-load').addClass('d-none');
                $('#course-copy-search-results').removeClass('d-none');     
            }, copyminimumdif)
        }
        else {
            $('.cc-homepage-container').addClass('d-none');
            $('#course-copy-search-load').addClass('d-none');
            $('#course-copy-search-results').removeClass('d-none');            
        }

        
    }
}

function contactDeliveryChair(type) {
    var chairfound = false;
    if(alldata.SIS !== null) {
        if(alldata.SIS.Chair !== null) {
            
            if(alldata.SIS.Chair.SectionDelivery.Email !== null) {
                chairfound = true;
            }
        }
    }
    if(chairfound) {
        var mailtosubject = '';
        var mailtobody = 'Hello ' + alldata.SIS.Chair.SectionDelivery.Name.split(" ")[0]+',';
        var mailtohref = 'mailto:' + alldata.SIS.Chair.SectionDelivery.Email;
        if (type==='missing') {
            mailtosubject += 'Missing Model'; 
            if(alldata.CheckModels !== undefined) {
                if(alldata.CheckModels !== null) {
                    if(alldata.CheckModels.length === 1) {
                        mailtosubject += ': '+alldata.CheckModels[0].CourseCode+'-'+alldata.CheckModels[0].Version+'-Model-'+alldata.CheckModels[0].DeliveryMode+'-'+alldata.CheckModels[0].Length;
                        
                        mailtobody += '%0D%0A%0D%0A';
                        mailtobody += 'I was attempting to use the Guided Copy process to populate my term shell, but there was no model found matching my course section attributes:';
                        
                        mailtobody += '%0D%0A%0D%0A';
                        mailtobody += 'Code: ' + alldata.CheckModels[0].CourseCode;
                        mailtobody += '%0D%0A';
                        mailtobody += 'Version: ' + alldata.CheckModels[0].Version;
                        mailtobody += '%0D%0A';
                        mailtobody += 'Delivery Mode: ' + alldata.CheckModels[0].DeliveryMode;
                        mailtobody += '%0D%0A';
                        mailtobody += 'Duration: ' + alldata.CheckModels[0].Length + ' weeks';
                        mailtobody += '%0D%0A';                        
                    }
                }
            }
        }
        else if(type === 'empty') {
            mailtosubject += 'Model Content'; 
            if(alldata.Readiness !== undefined) {
                if(alldata.Readiness !== null) {
                    if(alldata.Readiness.Selected !== undefined) {
                        if(alldata.Readiness.Selected !== null) {
                            mailtosubject += ': '+alldata.Readiness.Selected.CopiedFromName;
                        
                            mailtobody += '%0D%0A%0D%0A';
                            mailtobody += 'I was attempting to use the Guided Copy process to populate my term shell, but the matching model was found to be missing content:';
                            mailtobody += '%0D%0A%0D%0A';
                            mailtobody += alldata.Readiness.Selected.CopiedFromName;
                            mailtobody += '%0D%0A';
                            mailtobody += 'https://conestoga.desire2learn.com/d2l/home/' + alldata.Readiness.Selected.OrgUnitId
                        }
                    }
                }
            }
        }
        else if(type ==='notready') {
            mailtosubject += 'Model Not Ready';
            if(alldata.Readiness !== undefined) {
                if(alldata.Readiness !== null) {
                    if(alldata.Readiness.Selected !== undefined) {
                        if(alldata.Readiness.Selected !== null) {
                            mailtosubject += ': '+alldata.Readiness.Selected.CopiedFromName;
                            
                            mailtobody += '%0D%0A%0D%0A';
                            mailtobody += 'I was attempting to use the Guided Copy process to populate my term shell, but the model matching my course section is not ready:';                           mailtobody += '%0D%0A%0D%0A';
                            mailtobody += alldata.Readiness.Selected.CopiedFromName;
                            mailtobody += '%0D%0A';
                            mailtobody += 'https://conestoga.desire2learn.com/d2l/home/' + alldata.Readiness.Selected.OrgUnitId                            
                        }
                    }
                }
            }

                                    
        }
        else if(type === 'multi') {
            mailtosubject += 'Multiple Model Matches: ' + alldata.CourseOffering.Name;
            mailtobody += '%0D%0A%0D%0A';
            mailtobody += 'I was attempting to use the Guided Copy process to populate my term shell, but there were multiple models found matching my course section attributes:';
            mailtobody += '%0D%0A%0D%0A';
            for(var mm=0; mm<alldata.Readiness.Matches.Close.length; mm++) {
                mailtobody += alldata.Readiness.Matches.Close[mm].CopiedFromName;
                mailtobody += '%0D%0A';                
                mailtobody += 'https://testconestoga.desire2learn.com/d2l/home/'+alldata.Readiness.Matches.Close[mm].OrgUnitId;
                mailtobody += '%0D%0A%0D%0A';
            }            
        }
        mailtohref += '?subject=' + mailtosubject;
        mailtohref += '&body=' + mailtobody;
        window.location.href = mailtohref;
    }   
}

function deepEqual(obj1, obj2) {
  // Base case: If both objects are identical, return true.
  if (obj1 === obj2) {
    return true;
  }
  // Check if both objects are objects and not null.
  if (typeof obj1 !== 'object' || typeof obj2 !== 'object' || obj1 === null || obj2 === null) {
    return false;
  }
  // Get the keys of both objects.
  const keys1 = Object.keys(obj1);
  const keys2 = Object.keys(obj2);
  // Check if the number of keys is the same.
  if (keys1.length !== keys2.length) {
    return false;
  }
  // Iterate through the keys and compare their values recursively.
  for (const key of keys1) {
    if (!keys2.includes(key) || !deepEqual(obj1[key], obj2[key])) {
      return false;
    }
  }
  // If all checks pass, the objects are deep equal.
  return true;
}

var copybuttonclicked;
function initiateModelMatchSearch() {
    
    copybuttonclicked = new Date().getTime();    
    //$('.course-setup-progress-bar-container').addClass('d-none');
    //$('.course-setup-progress-bar-header').addClass('d-none');
    //$('#course-setup-start').addClass('d-none');
    $('.cc-homepage-container').addClass('d-none');
    $('#course-copy-search-load').removeClass('d-none');
    
    alldata.CheckModels = [];
    emptycheckdone = false;
    
    if(alldata.MergeComponents !== null) {
        if(alldata.MergeComponents.SourceCourses.length > 0) {
            for(var sc=0; sc<alldata.MergeComponents.SourceCourses.length; sc++) {
                var thissource = alldata.MergeComponents.SourceCourses[sc];
                
                var sdate = new Date(thissource.CourseOffering.StartDate);
                var edate = new Date(thissource.CourseOffering.EndDate);

                var nweeks;
                nweeks = nWeeks(sdate, edate);                  
                
                var sourcedelivery = {
                    "Version": parseInt(thissource.Attributes.Ver),
                    "Length": nweeks,
                    "DeliveryMode": thissource.SIS.DeliveryMode.Code,
                    "CourseCode": thissource.Attributes.Code,
                    "SemesterCode": thissource.Attributes.Sem,
                    "OrgUnitId": parseInt(orgUnitId),
                    "UserId": parseInt(userId)
                }
                
                var isunique = true;
                for(var c=0; c<alldata.CheckModels.length; c++) {
                    if(deepEqual(alldata.CheckModels[c],sourcedelivery)) {
                        isunique = false;
                        break;
                    }
                }
                if(isunique) {
                    alldata.CheckModels.push(sourcedelivery);
                }
            }
        }
    }
    else {
        
        var sdate = new Date(alldata.CourseOffering.StartDate);
        var edate = new Date(alldata.CourseOffering.EndDate);

        var nweeks;
        nweeks = nWeeks(sdate, edate);        
        
        var thisdelivery = {
            "Version": parseInt(alldata.Offering.Ver),
            "Length": nweeks,
            "DeliveryMode": alldata.SIS.DeliveryMode.Code,
            "CourseCode": alldata.Offering.Code[0],
            "SemesterCode": alldata.Offering.Sem,
            "OrgUnitId": parseInt(orgUnitId),
            "UserId": parseInt(userId)
        }
        alldata.CheckModels.push(thisdelivery);
    }

    //console.log(alldata.CheckModels);
    alldata.Readiness = {
        Result: [ 
            {
                MatchingModels:[],
                OrgUnitId: parseInt(orgUnitId)
            }
        ],
        Matches: {
            Exact: [],
            Close: []
        },
        SearchStart: alldata.CheckModels.length,
        SearchDone: 0
    }
    for(var cm=0; cm<alldata.CheckModels.length; cm++) {
        checkModelMatch(alldata.CheckModels[cm]);
    }
}


function processUserSubscriptions() {
    if((studentroles.indexOf(alldata.CurrentRole) > -1) || (observeroles.indexOf(alldata.CurrentRole) > -1)) {
        var notificationfound = false;
        if(alldata.UserNotifications.length > 0) {
            for(var un=0; un<alldata.UserNotifications.length; un++) {
                var thisnotification = alldata.UserNotifications[un];
                if(thisnotification.Trigger === alldata.CourseOffering.Identifier) {
                    $('#subscribed-already-text').removeClass('d-none');
                    notificationfound = true;
                    break;
                }
            }
        }
        if(!notificationfound) {
            $('#subscribe-ready-btn').removeClass('d-none');
            $('#subscribe-ready-text').removeClass('d-none');
        }        
    }
}

var futurestart = false;
var courselaunch = false;
var courseempty = false;
var guidedcopy = false;
var copystarted = false;
function processCourseReadiness() {
    
    if(!alldata.NotSection) {
        if(alldata.Offering !== undefined) {
            if(alldata.Offering !== null) {
                if((alldata.CourseType === "Standard") || (alldata.CourseType === "High Capacity")) {

                    //var copylogfound = false;
                    var contentfound = false;
                    var gradesfound = false;

                    if(alldata.CourseOffering !== undefined) {
                        var today_EST = getServerTime().toLocaleString("en-US", {
                            timeZone: "America/New_York"
                        });
                        var tdate = new Date(today_EST);
                        var start_EST = new Date(alldata.CourseOffering.StartDate).toLocaleString("en-US", {
                            timeZone: "America/New_York"
                        });
                        var sdate = new Date(start_EST);
                        var end_EST = new Date(alldata.CourseOffering.EndDate).toLocaleString("en-US", {
                            timeZone: "America/New_York"
                        });
                        var edate = new Date(end_EST);
                        //console.log(edate);
                        //sdate = sdate.addDays(10);
                        //console.log(sdate); 
                        
                        if(sdate > tdate) {
                            futurestart = true;
                        }
                    }

                    //console.log(sdate);
                    //console.log(futurestart);
                    if(futurestart) {
                        courselaunch = true;
                    }
                    
                    if(alldata.Content.Modules.length > 0) {
                        contentfound = true;
                    }
                    if(alldata.GradeItems.Objects.length > 0) {
                        gradesfound = true;
                    }
                    if((contentfound === false) && (gradesfound === false)) {
                        //console.log("Course Empty");

                        courseempty = true;
                        
                        if(edate > tdate) {
                            guidedcopy = true;
                            //initiateModelMatchSearch();
                            checkCommonMerge(alldata.Offering.Code[0]);
                        }

                    }
                    else {
                        alldata.MergeCandidate = null;
                        guidedCopyLoad();
                    }
                }
            }
        }
    }
}

function getQuizzesUser(next) {
    var quizzesuserurl;
    if(next === undefined) {
        quizzesuserurl = "/d2l/api/le/" + alldata.APIVersions.LE.LatestVersion + "/" + orgUnitId + "/quizzes/";
    }
    else {
        quizzesuserurl = next;
    }
    $.ajax({
        method: "GET",
        url: quizzesuserurl,
        dataType: 'json',
        success: function (quizzesuserresponse_tmp) {
            if (alldata.QuizzesUser === undefined) {
                alldata.QuizzesUser = quizzesuserresponse_tmp;
            } else {
                alldata.QuizzesUser.Objects = alldata.QuizzesUser.Objects.concat(quizzesuserresponse_tmp.Objects)
            }

            if (quizzesuserresponse_tmp.Next === null) {
                alldone.QuizzesUser = true;
                checkAllDone();                
            } else {
                getQuizzesUser(quizzesuserresponse_tmp.Next);
            }

        }, //end success
        error: function (xhr, ajaxOptions, thrownError) {
            alldata.QuizzesUser = null;
            alldone.QuizzesUser = true;
            checkAllDone();
        }
    }) //end ajax    
}

function processQuizzesData() {
    
    if(studentroles.indexOf(alldata.CurrentRole) > -1) {
        if(alldata.QuizzesUser !== undefined) {
            if(alldata.QuizzesUser !== null) {
                for(var qu=0; qu<alldata.QuizzesUser.Objects.length; qu++) {
                    var thisqu = alldata.QuizzesUser.Objects[qu];
                    for(var qa=0; qa<alldata.QuizzesAll.Objects.length; qa++) {
                        var thisqa = alldata.QuizzesAll.Objects[qa];
                        if(thisqu.QuizId === thisqa.QuizId) {
                            thisqa.StartDate = thisqu.StartDate;
                            thisqa.EndDate = thisqu.EndDate;
                            thisqa.DueDate = thisqu.DueDate;
                            break;
                        }
                    }
                }
            }
        }
    }
    
    var allquizzesconfirmed = [];
    for(var q=0; q<alldata.QuizzesAll.Objects.length; q++) {
        var thisquiz = alldata.QuizzesAll.Objects[q];
        var includequiz = false;
        //console.log(thisquiz);
        //console.log(thisquiz.AllowOnlyUsersWithSpecialAccess);  
        
        if (studentroles.indexOf(alldata.CurrentRole) > -1) {
            //thisquiz.URL = '/d2l/lms/quizzing/user/quiz_summary.d2l?qi=' + thisquiz.QuizId + '&ou=' + orgUnitId;
            var quizuserfound = false;
            if(alldata.QuizzesUser !== undefined) {
                if(alldata.QuizzesUser !== null) {
                    for(var qu=0; qu<alldata.QuizzesUser.Objects.length; qu++) {
                        var thisqu = alldata.QuizzesUser.Objects[qu];
                        if(thisqu.QuizId === thisquiz.QuizId) {
                            quizuserfound = true;
                            break;
                        }
                    }
                }
            }
            
            if(thisquiz.AllowOnlyUsersWithSpecialAccess) {
                if(quizuserfound) {
                    includequiz = true;
                }
            }
            else {
                includequiz = true;
            }
            
            if(quizuserfound) {
                thisquiz.URL = '/d2l/lms/quizzing/user/quiz_summary.d2l?qi=' + thisquiz.QuizId + '&ou=' + orgUnitId;
            }
            else {
                thisquiz.URL = '';
            }
            
        } 
        else if (observeroles.indexOf(alldata.CurrentRole) > -1) {
            thisquiz.URL = '';
            includequiz = true;
        }
        else {
            thisquiz.URL = '/d2l/lms/quizzing/admin/modify/quiz_newedit_properties.d2l?qi=' + thisquiz.QuizId + '&ou=' + orgUnitId;
            includequiz = true;
        }
        
        if(includequiz) {
            allquizzesconfirmed.push(thisquiz);
        }
    }
        
    //console.log(allquizzesconfirmed);
    alldata.QuizzesAll.Objects = allquizzesconfirmed;
    
}

function getCourseQuizzesAll() {
    ecplusClient.econestoga.getQuizzes(orgUnitId, { apiVersion: '1.4' }).then(function (resp) {
