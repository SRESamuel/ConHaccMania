function openNotes() {
    //console.log(userid);
    
    //Find whether User has specific notes saved in the central Custom Widget Data block.

    $('#notesModal .modal-title span').text(alldata.CourseOffering.Name);
    $('#notesModal .modal-body').html('<div id="wysiwyg-adminnotes"></div>');
    $('#wysiwyg-adminnotes').trumbowyg({
        btns: [
            ['viewHTML'],
            ['undo', 'redo'], // Only supported in Blink browsers
            ['formatting'],
            ['strong', 'em', 'del'],
            ['superscript', 'subscript'],
            ['link'],
            ['insertImage'],
            ['justifyLeft', 'justifyCenter', 'justifyRight', 'justifyFull'],
            ['unorderedList', 'orderedList'],
            ['horizontalRule'],
            ['removeformat']
        ],
        semantic: false,
        tagsToRemove: ['script', 'link', 'style'],
        defaultLinkTarget: '_blank'
    });

    if(alldata.AdminNotes !== null) {
        $('#wysiwyg-adminnotes').trumbowyg('html',alldata.AdminNotes.Notes);
    }

    $('#notesModal .modal-footer .btn-primary').attr('onClick','saveNotes()');       
    //console.log($('#notesModal'));
    $('#notesModal').modal('show'); 
        
}

function initializeHomepageDisplay() {
    
    //console.log(alldata.Offering);
    //console.log(alldata.Outline);
    //console.log(alldata.Classlist);
    //console.log(alldata.MergeRecords);
    
    var isvisible = true;
    var ismergesource = false;
    
    if(alldata.CourseOffering.IsActive) {
        var tdate = new Date();
        if(alldata.CourseOffering.StartDate !== null) {
            var csdate = new Date(alldata.CourseOffering.StartDate);
            if(csdate > tdate) {
                isvisible = false;
            }
        }
        /*
        if(alldata.CourseOffering.EndDate !== null) {
            var cedate = new Date(alldata.CourseOffering.EndDate);
            if(cedate < tdate) {
                isvisible = false;
            }
        }
        */
    }
    else {
        isvisible = false;
        if(alldata.MergeRecords !== null) {
            if(alldata.MergeRecords.length > 0) {
                ismergesource = true;
            }   
        }
    }
    
    if(!ismergesource) {
        if(isvisible) {
            $('.course-visiblity').html('<img src="assets/img/eye-visible.svg" alt="This course is available to your students." title="This course is available to your students.">');
        }
        else {
            $('.course-visiblity').html('<img src="assets/img/eye-hidden.svg" alt="This course is not yet available to your students." title="This course is not yet available to your students.">');
            $('.course-visiblity').addClass('cc-invisible');
        }    

        if(alldata.Outline.length > 0) {
            $('.course-title').text(alldata.Outline[0].Course);
        }
        else {
            if(alldata.Offering !== null) {
                $('.course-title').text(alldata.Offering.Title);
            }
            else {
                $('.course-title').text(alldata.CourseOffering.Name);
            }
        }
        $('#echs-instructorname').text(', ' + alldata.WhoAmI.FirstName + ' ' + alldata.WhoAmI.LastName);

        var crolehtml = '';
        crolehtml += '<p>Your current role in this course is: <strong>' + alldata.CurrentRole + '</strong>';
        if(adminroles.indexOf(alldata.CurrentRole) > -1) {
            if(alldata.AdminNotes !== null) {
                crolehtml += ' <a class="btn btn-success" id="btn-adminnotes" href="javascript:openNotes()"><i class="fas fa-file-edit"></i></a>';
            }
            else {
                crolehtml += ' <a class="btn btn-primary" id="btn-adminnotes" href="javascript:openNotes()"><i class="fas fa-file-edit"></i></a>';
            }
        }        
        crolehtml += '</p>';
        $('#current-role').html(crolehtml);

        if(observeroles.indexOf(alldata.CurrentRole) > -1) {
            var oroledisplay = '';

            if(alldata.CurrentRole === 'AccessibilityService') {
                oroledisplay += '<div class="d-flex align-items-center mb-3"><div class="mr-4">Your current role in this course is: <strong>' + alldata.CurrentRole + '</strong></div>';
                oroledisplay += ' <button type="button" class="cc-button cc-button-user-switch userswitch" title="Switch Role" data-toggle="collapse" data-target="#collapseTempRoleSwitch" aria-expanded="false" aria-controls="collapseTempRoleSwitch">Switch</button>';
                oroledisplay += '</div>';
                oroledisplay += '<div class="row"><div class="col-12">';
                oroledisplay += '<div class="collapse" id="collapseTempRoleSwitch">';
                oroledisplay += '<div class="card card-body">';
                oroledisplay += '<p>Click the button below to change your role to <strong>Student</strong>, which will automatically revert back to <strong>AccessbilityService</strong> in 10 minutes.</p>';
                oroledisplay += '<p><button class="cc-button" onClick="tempSwitchRole()">Temporarily Switch My Role</button>'
                oroledisplay += '<div id="observer-switch-msg"></div>';
                oroledisplay += '</div>';
                oroledisplay += '</div>';
                oroledisplay += '</div>';
                oroledisplay += '</div>';
                oroledisplay += '</div>';
            }        
            else {
                oroledisplay += '<p>Your current role in this course is: <strong>' + alldata.CurrentRole + '</strong></p>';
            }
            $('#observer-role').html(oroledisplay);
            $('#echs-observername').text(', ' + alldata.WhoAmI.FirstName + ' ' + alldata.WhoAmI.LastName);
            $('#observerwelcome').removeClass('d-none');
        }

        var sectionstring = '';

        if(alldata.Code !== undefined) {
            if(alldata.Code.String !== undefined) {
                sectionstring += alldata.Code.String + " - ";
            }
        }

        if(alldata.Semester !== undefined) {
            if(alldata.Semester.Term === "W") {
                sectionstring += "Winter ";
            }
            if(alldata.Semester.Term === "S") {
                sectionstring += "Spring ";
            }
            if(alldata.Semester.Term === "F") {
                sectionstring += "Fall ";
            }
            sectionstring += 2000 + alldata.Semester.Year;
            sectionstring += " - ";

            if(alldata.Offering.Sec.length > 0) {
                if(alldata.Offering.Sec.length === 1) {
                    sectionstring += " Section ";
                    sectionstring += alldata.Offering.Sec[0];
                }
                else {
                    sectionstring += " Sections ";
                    for (var sn=0; sn<alldata.Offering.Sec.length; sn++) {
                        if(sn !== (alldata.Offering.Sec.length-1)) {
                            sectionstring += alldata.Offering.Sec[sn] + ", ";
                        }
                        else {
                            sectionstring += alldata.Offering.Sec[sn];
                        }
                    }
                }
            }

            $('.semester').text(sectionstring);
        }
        else {
            if(alldata.NotSection) {
                if(alldata.CourseOffering.Code.toLowerCase().indexOf("d2lgroup") > -1) {
                    sectionstring += "Community Group";
                }
                else {
                    if(alldata.CourseOffering.Code.toLowerCase().indexOf("model") > -1) {
                        sectionstring += "Model";
                        if(alldata.Ancestors.length > 0) {
                            for(var a=0; a<alldata.Ancestors.length; a++) {
                                if(alldata.Ancestors[a].Name.toLowerCase() === "model shells"){
                                    ecPlusGetModelAttributes();
                                    break;
                                }
                            }
                        }
                    }
                    else {
                        sectionstring += "Permanent Shell";
                    }
                }     
            }
        }

        $('.semester').text(sectionstring);
        fetchOntarioLearnData();
        $('.nav-course-icon img').attr("src","/d2l/api/lp/" + alldata.APIVersions.LP.LatestVersion + "/courses/" + orgUnitId + "/image?t=" + timestarted);

        //console.log(alldata.CourseType);
        if((alldata.CourseType === "Community") || (alldata.CourseType === "D2L Group")) {        
            $('#student-upcoming').addClass('d-none');
            $('#student-upcoming').removeClass('col-md-4');
            $('#student-announcements').removeClass('col-md-8');
        }

        if(alldata.CourseType === "High Capacity") {
            $('#update-stuatrisk').addClass('d-none');
            $('#update-flaggedassess').addClass('d-none');

            $('#cc-dashboard .essential-dash-section').addClass('d-none');
            $('.instructor-dash-summary').addClass('d-none');
            $('.management-container').addClass('d-none');

			/*
            var highcapdash = '';
            highcapdash += '<div class="text-center">';
            highcapdash += '<img class="mt-4 mb-4" src="assets/img/high-capacity-course-load_illustration.svg">';
            highcapdash += '<p>Because this is a High Capacity course (greater than 300 students) the Homepage does not load data for Student At-Risk or Assessment Analysis Reports automatically. You can click the button below to retrieve this information. Please note it may take up to several minutes.</p>';
            highcapdash += '<button id="highcap-dash-load-btn" class="cc-button m-auto" onClick="highCapDashLoad()">Load Dashboard Data</button>';
            highcapdash += '</div>';
            $('#high-cap-message').html(highcapdash);
			*/
			
            $('#high-cap-message').removeClass('d-none');        
        }

        if((alldata.CourseType === "Standard") || (alldata.CourseType === "High Capacity")) {
            buildInstructorDisplay();

            $('.link-whatifcalc button').on('click', function(){
                window.open('/d2l/le/content/6606/fullscreen/8123012/View?oid=' + orgUnitId, "_blank");
            });
            if((studentroles.indexOf(alldata.CurrentRole) === -1) && (observeroles.indexOf(alldata.CurrentRole) === -1)) {
                $('#democheck').on('change',function() {
                    var whatifhref = '/d2l/le/content/6606/fullscreen/8123012/View?oid=' + orgUnitId;
                    if($("#democheck").is(':checked')) {
                        whatifhref += '&demomode=true';
                    }
                    $('#cc-dashboard .link-whatifcalc button').prop("onclick", null).off("click");            
                    $('#cc-dashboard .link-whatifcalc button').on('click', function(){
                        window.open(whatifhref, "_blank");
                    });            
                });         
            }    
            $('.link-whatifcalc button').removeAttr('disabled');
        }
        else {
            buildInstructorDisplay();

            $('a[data-target="#cc-coming-up"] .nav-label').text('Calendar');
            $('a[data-target="#cc-coming-up-student"] .nav-label').text('Calendar');

            $('.essential-elements-block').addClass('d-none');
            $('.course-checklist-callout-container').addClass('d-none');
            $('#cc-dashboard .essential-dash-section').addClass('d-none');

            $('#update-stuatrisk').addClass('d-none');
            $('#update-flaggedassess').addClass('d-none');
            $('.nav-link[data-target="#cc-dashboard"]').parent('.nav-item').addClass('d-none');
            $('.nav-link[data-target="#cc-dashboard-student"]').parent('.nav-item').addClass('d-none');
        }


        if((pagetype === "preview") || (pagetype === "testing")) {
            $('#admin-load').addClass('d-none');
            $('#course-list-area').addClass('d-none');
            //$('.preview-reload-button').removeClass('d-none');
        }

        if(studentroles.indexOf(alldata.CurrentRole) > -1) {
            $('.nav-switch').parent('.nav-item').addClass('d-none');

            $('#student-nav').addClass("active");
            $('.student-content').addClass("active");        
        }
        else if(observeroles.indexOf(alldata.CurrentRole) > -1) {

            $('.nav-switch').parent('.nav-item').addClass('d-none');
            $('.nav-link[data-target="#cc-dashboard-student"]').parent('.nav-item').addClass('d-none');
            $('.nav-link[data-target="#cc-help-student"]').parent('.nav-item').addClass('d-none');

            $('#student-nav').addClass("active");
            $('.student-content').addClass("active");       
        }
        else {
            $('#instructor-nav .nav-course-icon.course-image-edit').attr('href','javascript:browseImages('+orgUnitId+')');
            $('#instructor-nav').addClass("active");
            $('.instructor-content').addClass("active");
        }  
    }
    else {
        $('#course-component-merged-dest').html('');
        for(var mr=0; mr<alldata.MergeRecords.length; mr++) {
            var thismerge = alldata.MergeRecords[mr];
            if(thismerge.Deleted === false) {
                var mergelink = '';
                mergelink += '<p>';
                mergelink += '<a href="/d2l/home/'+thismerge.OrgUnitId+'" target="_blank">'+thismerge.MergedCourseName+'</a>';
                mergelink += ' <i class="fas fa-external-link" aria-hidden="true"></i><span class="sr-only">Opens in a new tab</span>';
                mergelink += '</p>';
                $('#course-component-merged-dest').append(mergelink);
            }
        }
        
        $('#course-component-merged').removeClass('d-none');
    }

    initNav();
    frameHeight();
    
    const resizeObserver = new ResizeObserver(entries => {
        frameHeight();
    });

    // start observing a DOM node
    resizeObserver.observe(document.body)
    
}


function updateMeetingPreview() {

    $('.meeting-preview .meeting-block').removeClass("invisible");
    var meetingval = $('.instructor-content #cc-settings .form-check-meeting .form-check-input:checked').val();
    //console.log(meetingval)
    var meetdef = true;
    var meetdif = false;
    
    var meetingsaved;
    var datafound = false;
    if(alldata.CustomSettings !== null) {
        if(alldata.CustomSettings.Meeting !== undefined) {
            meetingsaved = alldata.CustomSettings.Meeting.Option;
            datafound = true;
        }
    }
    if(!datafound) {
        meetingsaved = 'meet-defaultshow';
    }
    if(meetingsaved !== meetingval) {
        meetdif = true;
    }    
    
    if(alldata.CustomSettings !== null) {
        if(alldata.CustomSettings.Meeting !== undefined) {
            if(meetingval === 'meet-customtag') {
                var valtag = $('#editmeettag').val();
                if(alldata.CustomSettings.Meeting.CalendarTag !== valtag) {                    
                    meetdif = true;
                    $('#editmeettag').addClass('changed');
                }
                else {
                    $('#editmeettag').removeClass('changed');
                }
            }
            if(meetingval === 'meet-manualinfo') {
                if(alldata.CustomSettings.Meeting.Info !== undefined) {  
                    if(alldata.CustomSettings.Meeting.Info.Title !== $('#editmeettitle').val()) {
                        meetdif = true;
                        $('#editmeettitle').addClass('changed');
                    }
                    else {
                        $('#editmeettitle').removeClass('changed');
                    }
                    if(alldata.CustomSettings.Meeting.Info.Body !== $('#editmeetbody').val()) {
                        meetdif = true;
                        $('#editmeetbody').addClass('changed');
                    }
                    else {
                        $('#editmeetbody').removeClass('changed');
                    }
                }
            }
        }
    }
    
    if(meetdif) {
        $('.meeting-preview').addClass('changed');
        $('#editmeetpreviewtext').html('If you <strong>Save</strong> the settings below, your <strong>Next Meeting</strong> section will look like this:');
        updateMeetingDisplay(meetingval);
    }
    else {
        $('.meeting-preview').removeClass('changed');
        $('#editmeetpreviewtext').html('With the current settings, your <strong>Next Meeting</strong> section looks like this:');
        updateMeetingDisplay();
    }

    $('#editmeetform .collapse').removeClass('show');
    $('#editmeetform #collapse-'+meetingval).addClass('show');

    $('.meetingsettings').addClass('d-none');
    if(meetingval === "meet-customtag") {
        validateMeetTag();
        $('#meet-customtag').removeClass('d-none');
    }
    else if (meetingval === "meet-manualinfo") {
        validateMeetInfo();
        $('#meet-manualinfo').removeClass('d-none');
    }
    else {
        $('#editmeetsave').removeAttr('disabled');
    }
}


function updateMeetingDisplay(previewtype) {
    
    var displaytype;
    if(previewtype !== undefined) {
        displaytype = previewtype;
    }
    else {
        var meetingdata = false;
        if(alldata.CustomSettings !== null) {
            if(alldata.CustomSettings.Meeting !== undefined) {
                displaytype = alldata.CustomSettings.Meeting.Option;
                meetingdata = true;
            }
        }
        if(!meetingdata) {
            displaytype === "meet-defaultshow";
        }
    }
    
    var selectmod = '';
    if(previewtype) {
        selectmod = '.meeting-preview ';
    }
    $(selectmod + '.meeting-join').addClass('d-none');
    
    if(displaytype === "meet-displaynone") {
        if(previewtype) {
            
        }
        else {
            $('.sec-next-meeting').addClass('d-none');
            //$('.course-image-overlay').removeClass('displayed');
        }
        $(selectmod + '.meeting-title').addClass('d-none');
        $(selectmod + '.meeting-block').addClass('d-none');
        $('.meeting-preview #meeting-displaynone-previewmsg').removeClass('d-none');
    }
    else if(displaytype === "meet-manualinfo") {
        $(selectmod + '.meeting-block').removeClass("invisible");
        $('.meeting-preview #meeting-displaynone-previewmsg').addClass('d-none');
        
        var valtitle;
        var valbody;
        if(previewtype) {
            valtitle = $('#editmeettitle').val();
            valbody = $('#editmeetbody').val();
        }
        else {
            $('.sec-next-meeting').removeClass('d-none');
            //$('.course-image-overlay').addClass('displayed');
            valtitle = alldata.CustomSettings.Meeting.Info.Title;
            valbody = alldata.CustomSettings.Meeting.Info.Body;
        }        
        
        $(selectmod + '.meeting-title').html(valtitle);
        $(selectmod + '.meeting-block .meeting-custom').html('<p>'+valbody+'</p>');
        $(selectmod + '.meeting-block .meeting-custom').removeClass("d-none");
        $(selectmod + '.meeting-block .cc-icon').addClass("d-none");
        $(selectmod + '.meeting-details').addClass("d-none");
        $(selectmod + '.meeting-controls').addClass("d-none");
        $(selectmod + '.meeting-title').removeClass('d-none');
        $(selectmod + '.meeting-block').removeClass('d-none');
    }
    else if(displaytype === "meet-customtag") {
        $(selectmod + '.meeting-block').removeClass("invisible");
        $('.meeting-preview #meeting-displaynone-previewmsg').addClass('d-none');
        
        if(previewtype) {
            var valtag = $('#editmeettag').val();
            if(valtag.length >= 3) {
                initializeNextTagged($('#editmeettag').val(), true);
            }
            else {
                $(selectmod + '.meeting-title').html('Next Meeting');
                $(selectmod + '.meeting-block .meeting-custom').html("<p>No upcoming meetings to display at this time.</p>");
                $(selectmod + '.meeting-block .cc-icon').addClass("d-none");
                $(selectmod + '.meeting-details').addClass("d-none");
                $(selectmod + '.meeting-controls').addClass("d-none");                
                $(selectmod + '.meeting-title').removeClass('d-none');
                $(selectmod + '.meeting-block .meeting-custom').removeClass("d-none");
                $(selectmod + '.meeting-block').removeClass('d-none');                                
            }            
        }
        else {
            $('.sec-next-meeting').removeClass('d-none');
            //$('.course-image-overlay').addClass('displayed');
            initializeNextTagged(alldata.CustomSettings.Meeting.CalendarTag);
        }
    }
    else {
        $(selectmod + '.meeting-block').removeClass("invisible");
        $('.meeting-preview #meeting-displaynone-previewmsg').addClass('d-none');
        
        if(previewtype) {
            initializeNextOnline(true);
        }
        else {
            $('.sec-next-meeting').removeClass('d-none');
            //$('.course-image-overlay').addClass('displayed');
            initializeNextOnline();
        }        
    }
}


var liveinterval;
function zoomLiveCheck() {
    
    var zoomdisplay = true;
    if(alldata.CustomSettings !== null) {
        if(alldata.CustomSettings.Meeting !== undefined) {
            displaytype = alldata.CustomSettings.Meeting.Option;
            if(displaytype !== "meet-defaultshow") {
                zoomdisplay = false;
            }
        }
    }
    
    var selectmod = '';
    if(!zoomdisplay) {
        selectmod = '.meeting-preview ';
    }
    //console.log("checking");

	if (alldata.CalendarZoom.Items.length > 0) {
		var today_EST = getServerTime().toLocaleString("en-US", {
			timeZone: "America/New_York"
		});
		var tdate = new Date(today_EST);
		var start_EST = new Date(alldata.CalendarZoom.Items[0].event.StartDateTime).toLocaleString("en-US", {
			timeZone: "America/New_York"
		});
		var sdate = new Date(start_EST);
		
        var minbefore = 5;
        if(alldata.CustomSettings !== null) {
            if(alldata.CustomSettings.JoinEarly !== undefined) {
                minbefore = alldata.CustomSettings.JoinEarly;
            }                    
        }
		sdate.setMinutes(sdate.getMinutes() - minbefore);

		var end_EST = new Date(alldata.CalendarZoom.Items[0].event.EndDateTime).toLocaleString("en-US", {
			timeZone: "America/New_York"
		});
		var edate = new Date(end_EST);

		var scheck = false;
		var echeck = false;

		if (alldata.CalendarZoom.Items[0].event.StartDateTime !== null) {
			if (sdate < tdate) {
				scheck = true;
			}
		}

		if (alldata.CalendarZoom.Items[0].event.EndDateTime !== null) {
			if (edate > tdate) {
				echeck = true;
			}
		}

        //console.log(scheck);
        //console.log(echeck);
		if (scheck && echeck) {
			var zoomlivehtml = '';

			var live_EST = new Date(alldata.CalendarZoom.Items[0].event.StartDateTime).toLocaleString("en-US", {
				timeZone: "America/New_York"
			});
			var livetime = new Date(live_EST);
			if (livetime > tdate) {
				zoomlivehtml += '<h3>Online Meeting Starting Soon!</h3>';
			} else {
				zoomlivehtml += '<h3>Meeting is Live!</h3>';
			}

            /*
			zoomlivehtml += '<a class="btn btn-primary btn-lg btn-block" href="' + alldata.CalendarZoom.Items[0].href + '" title="Join Online Meeting" target="_blank">Join Now</a>';
			$('.zoomLiveNow').html(zoomlivehtml);
			$('.calevent:first').addClass('active');
            */
            
            $(selectmod + '.meeting-join').prop("onclick", null).off("click");
            $(selectmod + '.meeting-join').on('click',function(){
                window.open(alldata.CalendarZoom.Items[0].href, '_blank'); 
            });
            $(selectmod + '.meeting-join').removeClass('d-none');
			//frameHeight();
		} else {
			if (edate < tdate) {
				alldata.CalendarZoom.Items.shift();
                $(selectmod + '.meeting-join').prop("onclick", null).off("click");
                $(selectmod + '.meeting-join').addClass('d-none');
                processCalendarNext();
			} else {
                /*
				var minbefore = 5;
                if(alldata.CustomSettings !== null) {
                    if(alldata.CustomSettings.JoinEarly !== undefined) {
                        minbefore = alldata.CustomSettings.JoinEarly;
                    }                    
                }

				$('.zoomLiveNow').html('<p>A link to join will appear here <strong><span class="setJoinEarly">'+minbefore+'</span> minutes</strong> before the scheduled start.</p>');
				$('.calevent:first').removeClass('active');
				//frameHeight();
                */
			}
		}
	} else {
		ZoomDisplay = false;
		clearInterval(liveinterval);
	}
}

var zoomintervalstart = false;

function initializeNextOnline(ispreview) {
    
    var selectmod = '';
    if(ispreview) {
        selectmod = '.meeting-preview ';
    }
    else {
        //$('.course-image-overlay').addClass('displayed');
    }
    
    $(selectmod + '.meeting-title').text("Next Online Meeting");
    $(selectmod + '.meeting-block .meeting-custom').addClass("d-none");
    
    var nextonlinehtml = '';
    if(alldata.CalendarZoom.Items.length > 0) {
        var dateobj = zoomDateInfo(alldata.CalendarZoom.Items[0].event);
        //console.log(dateobj);

        $(selectmod + ".meeting-block .cc-icon").removeClass("calendar");
        $(selectmod + ".meeting-block .cc-icon").addClass("online-class");
        $(selectmod + ".meeting-date").html(dateobj.MonthAbbr+' '+dateobj.NumDate);
        $(selectmod + ".meeting-time").html(dateobj.TimeRange);
        
        $(selectmod + '.meeting-block .cc-icon').removeClass("d-none");
        $(selectmod + '.meeting-details').removeClass("d-none");
        $(selectmod + '.meeting-controls').removeClass("d-none");        
        $(selectmod + '.meeting-title').removeClass("d-none");
        $(selectmod + '.meeting-block').removeClass("d-none");                

        $(selectmod + '.meeting-review').on('click',function() {
            var modalbody = '';
            modalbody += '<p><strong>'+alldata.CalendarZoom.Items[0].event.Title+'</strong></p>';
            modalbody += alldata.CalendarZoom.Items[0].event.Description;
            $('#onlineMeetingModal .modal-body').html(modalbody);
            
            var linkcheck = $('#onlineMeetingModal .modal-body').find("a");
            //console.log(linkcheck);
            $(linkcheck).each(function () {
                if($(this)[0].target !== "_blank") {
                    $(this)[0].target = "_blank";
                }
            });
            //console.log(modalbody);            
            
            $('#onlineMeetingModal').modal('show');
        });

        zoomLiveCheck();
        if(!zoomintervalstart) {
            zoomintervalstart = true;
            liveinterval = setInterval(function () {
                zoomLiveCheck();
            }, 30000);               
        }
    }
    else {
        /*
        $(selectmod + '.meeting-block .meeting-custom').html('<p>No upcoming online meetings to display at this time.</p>');
        $(selectmod + '.meeting-block .meeting-custom').removeClass("d-none");
        $(selectmod + '.meeting-block .cc-icon').addClass("d-none");
        $(selectmod + '.meeting-details').addClass("d-none");
        $(selectmod + '.meeting-controls').addClass("d-none");
        $(selectmod + '.meeting-title').removeClass('d-none');
        $(selectmod + '.meeting-block').removeClass('d-none');        
        if(zoomintervalstart) {
            ZoomDisplay = false;
            clearInterval(liveinterval);
        }
        */
        
        //$('.course-image-overlay').removeClass("displayed");
        $('.sec-next-meeting').addClass("d-none");
        $(selectmod + '.meeting-title').addClass("d-none");
        $(selectmod + '.meeting-block').addClass("d-none");
        $(selectmod + '.meeting-details').addClass("d-none");
        $(selectmod + '.meeting-controls').addClass("d-none");        
        if(zoomintervalstart) {
            ZoomDisplay = false;
            clearInterval(liveinterval);
        }          
        
    }
    $(selectmod + '.meeting-block').removeClass("invisible");

    //frameHeight();
    
}

function initializeNextTagged(tagstring, ispreview) {
    
    //console.log(tagstring);
    //$('.meeting-title').text("Next Online Meeting");
    
    var today_EST = getServerTime().toLocaleString("en-US", {
        timeZone: "America/New_York"
    });
    var tdate = new Date(today_EST);      
    
    alldata.CalendarTagged = [];
    for(var ca=0; ca<alldata.CalendarAll.length; ca++) {
        var thisevent = alldata.CalendarAll[ca];
        if(thisevent.Title.toLowerCase().indexOf(tagstring.toLowerCase()) > -1) {
            
            var isfuture = true;
            //console.log(tdate);
            if (thisevent.EndDateTime !== null) {
                var end_EST = new Date(thisevent.EndDateTime).toLocaleString("en-US", {
                    timeZone: "America/New_York"
                });
                var edate = new Date(end_EST);
                //console.log(edate);
                if (edate < tdate) {
                    isfuture = false;
                }
            }
            if(isfuture) {
                alldata.CalendarTagged.push(thisevent);
            }            
        }
    }
    
    //console.log(alldata.CalendarTagged);
    var nexttaggedhtml = '';
    var selectmod = "";
    if(ispreview) {
        selectmod = ".meeting-preview ";
    }
    else {
        //$('.course-image-overlay').addClass('displayed');
    }
    //console.log(selectmod);
    
    if(alldata.CalendarTagged.length > 0) {
        var dateobj = zoomDateInfo(alldata.CalendarTagged[0]);
        //console.log(dateobj);
        $(selectmod + ".meeting-block .cc-icon").removeClass("online-class");
        $(selectmod + ".meeting-block .cc-icon").addClass("calendar");
        $(selectmod + ".meeting-date").html(dateobj.MonthAbbr+' '+dateobj.NumDate);
        $(selectmod + ".meeting-time").html(dateobj.TimeRange);

        $(selectmod + '.meeting-title').text(alldata.CalendarTagged[0].Title);
        $(selectmod + '.meeting-review').on('click',function(){
            var modalbody = '';
            modalbody += '<p><strong>'+alldata.CalendarTagged[0].Title+'</strong></p>';
            modalbody += alldata.CalendarTagged[0].Description;
            $('#onlineMeetingModal .modal-body').html(modalbody);
            $('#onlineMeetingModal').modal('show');
        });
        
        $(selectmod + '.meeting-block .meeting-custom').addClass("d-none");
        $(selectmod + '.meeting-block .cc-icon').removeClass("d-none");
        $(selectmod + '.meeting-details').removeClass("d-none");
        $(selectmod + '.meeting-controls').removeClass("d-none");
        $(selectmod + '.meeting-title').removeClass("d-none");
        $(selectmod + '.meeting-block').removeClass("d-none");
        $(selectmod + '.meeting-block').removeClass("invisible");
    }
    else {
        $(selectmod + '.meeting-title').html('Next Meeting');
        $(selectmod + '.meeting-block .meeting-custom').html("<p>No upcoming meetings to display at this time.</p>");
        $(selectmod + '.meeting-block .cc-icon').addClass("d-none");
        $(selectmod + '.meeting-details').addClass("d-none");
        $(selectmod + '.meeting-controls').addClass("d-none");                
        $(selectmod + '.meeting-title').removeClass('d-none');
        $(selectmod + '.meeting-block .meeting-custom').removeClass("d-none");
        $(selectmod + '.meeting-block').removeClass('d-none');  
        $(selectmod + '.meeting-block').removeClass("invisible");
    }
}

function openLinkTeams() {
    $('#linkListTeams').modal('show');
}

function openLinkTextbook(type) {
    var texthtml = '';
    if(type === "outline") {
        for(var bl=0; bl<alldata.BookList.length; bl++) {
            texthtml += '<table class="table table-dark">';
            texthtml += '<tbody>';
            
            if(alldata.BookList[bl].SubCategory.Description !== '') {
                texthtml += '<tr><th style="width:200px">Type</th><td>'+alldata.BookList[bl].SubCategory.Description+'</td></tr>';
            }
            
            if(alldata.BookList[bl].Book.Author !== '') {
                texthtml += '<tr><th style="width:200px">Author</th><td>'+alldata.BookList[bl].Book.Author+'</td></tr>';
            }
            
            if(alldata.BookList[bl].Book.Title !== '') {
                texthtml += '<tr><th style="width:200px">Title</th><td>'+alldata.BookList[bl].Book.Title+'</td></tr>';
            }
            
            if(alldata.BookList[bl].Book.Publisher !== '') {
                texthtml += '<tr><th style="width:200px">Publisher</th><td>'+alldata.BookList[bl].Book.Publisher+'</td></tr>';
            }
            
            if(alldata.BookList[bl].Book.ISBN !== null) {
                if(alldata.BookList[bl].Book.ISBN !== '') {
                    texthtml += '<tr><th style="width:200px">ISBN</th><td>'+alldata.BookList[bl].Book.ISBN+'</td></tr>';
                }
            }
            
            texthtml += '</tbody>';
            texthtml += '</table>';
        }        
    }
    else if(type === "custom") {
        texthtml += '<table class="table table-dark">';
        texthtml += '<tbody>';
        texthtml += '<tr><th style="width:200px">Type</th><td>Physical Textbook</td></tr>';
        
        if(alldata.CustomSettings.Textbook.Info.Author !== '') {
            texthtml += '<tr><th style="width:200px">Author</th><td>'+alldata.CustomSettings.Textbook.Info.Author+'</td></tr>';
        }
        
        texthtml += '<tr><th style="width:200px">Title</th><td>'+alldata.CustomSettings.Textbook.Info.Title+'</td></tr>';
        
        if(alldata.CustomSettings.Textbook.Info.Publisher !== '') {
            texthtml += '<tr><th style="width:200px">Publisher</th><td>'+alldata.CustomSettings.Textbook.Info.Publisher+'</td></tr>';
        }
        
        if(alldata.CustomSettings.Textbook.Info.ISBN !== '') {
            texthtml += '<tr><th style="width:200px">ISBN</th><td>'+alldata.CustomSettings.Textbook.Info.ISBN+'</td></tr>';
        }
        
        texthtml += '</tbody>';
        texthtml += '</table>';
    }
    else if(type === "etextmulti") {
        
        texthtml += '<p>This course has several eText resources available to you:</p>';
        texthtml += '<ul>';
        for(var osr=0; osr<alldata.Outline[0].StudentResources.length; osr++) {
            var thisresource = alldata.Outline[0].StudentResources[osr];
            if(thisresource.MainCategory.Description.toLowerCase().indexOf("etext") > -1) {
                texthtml += '<li>'+thisresource.Book.Title+'</li>';
            }
        }
        texthtml += '</ul>';
        
        texthtml += '<p>Use the following links to access these resources:</p>';
        texthtml += '<ul>';
        for(var et=0; et<alldata.EText.length; et++) {
            if(alldata.EText[et].Search.length > 0) {
                for(var ets=0; ets<alldata.EText[et].Search.length; ets++) {
                    var thistop = alldata.EText[et].Search[ets].Topic;
                    if(!thistop.IsHidden) {
                        texthtml += '<li><a target="_blank" href="'+thistop.Url+'">'+alldata.EText[et].Title+'</a></li>';
                        break;
                    }
                }
            }                            
        }
        texthtml += '</ul>';
    }
    
    $('#linkListTextbook .modal-body').html(texthtml);
    $('#linkListTextbook').modal('show');
}


function initializeEnrollmentDisplay() {
    
    var uniqueadditions = [];
    for(var a=0; a<alldata.Enrollment.Additions.length; a++) {
        for(var u=0; u<alldata.Classlist.Objects.length; u++) {
            //console.log(parseInt(alldata.Classlist.Objects[u].Identifier));
            //console.log(alldata.Enrollment.Additions[a].UserId);
            if(parseInt(alldata.Classlist.Objects[u].Identifier) === alldata.Enrollment.Additions[a].UserId) {
                if(uniqueadditions.indexOf(alldata.Enrollment.Additions[a].UserId) === -1) {
                    uniqueadditions.push(alldata.Enrollment.Additions[a].UserId);
                }
                break;
            }
        }        
    }
    //console.log(uniqueadditions);
    
    $('#pills-additions-tab .displaynum').text(uniqueadditions.length);
    $('#pills-withdrawals-tab .displaynum').text(alldata.Enrollment.Withdrawals.length);
    
    var totalchanges = uniqueadditions.length + alldata.Enrollment.Withdrawals.length;
    //if(totalchanges > 0) {
        $('#home-enrollchanges .badge').text(totalchanges);
    //}
    $('#dash-enrollchanges .management-count').text(totalchanges);
    
    if(totalchanges === 0) {
        $('#dash-enrollchanges .management-button').attr('disabled','disabled');
    }
    
    if(totalchanges > 0) {
        $('#dash-enrollchanges .management-button').on('click',function(){
            openReport_EnrollChanges();
        });
    }
    else {
        $('#dash-enrollchanges .management-button').attr('disabled','disabled');
    }    
}


function initializeLinkList() {
    //console.log(alldata);
    
    if((alldata.CourseType === "Standard") || (alldata.CourseType === "High Capacity")) {
        if((alldata.NotSection === false) || (alldata.OfficialModel === true)) {
            if(alldata.Outline.length > 0) {
                var outlineurl = 'https://employeeportal.conestogac.on.ca/CourseOutlineAccessible/CourseOutline/Index/CRSCode^'+alldata.Offering.Code[0]+'~CRSTitle^~ACYId^'+alldata.Outline[0].AcademicYearId+'~CRSVersion^'+alldata.Offering.Ver+'~OutlineID^'+alldata.Outline[0].OutlineId;
                //var outlineurl = 'https://employeeportal.conestogac.on.ca/CollegePortal/Pages/Angel/Outline.aspx?COURSE='+alldata.CourseOffering.Code;

                $('.link-courseoutline a').attr('href',outlineurl);
                $('.link-courseoutline a').removeClass('disabled');
                $('.link-courseoutline .link-ico').removeClass('disabled');
            }
        }
        
        var ipfound = false;
        if(alldata.InstructionalPlan.Topics.Dynamic.length > 0) {
            for(var ipd=0; ipd<alldata.InstructionalPlan.Topics.Dynamic.length; ipd++) {
                var thistop = alldata.InstructionalPlan.Topics.Dynamic[ipd].Topic;
                var thismod = alldata.InstructionalPlan.Topics.Dynamic[ipd].Module;
                if((thistop.IsHidden === false) && (thismod.IsHidden === false)) {
                    ipfound = true;
                    var topid = thistop.TopicId;
                    $('.link-instructionalplan a').attr('href','/d2l/le/content/'+orgUnitId+'/viewContent/'+topid+'/View');
                    $('.link-instructionalplan a').removeClass('disabled');   
                    $('.link-instructionalplan .link-ico').removeClass('disabled');
                    break;
                }                    
            }
        }
        if(!ipfound) {
            if(alldata.InstructionalPlan.Topics.Other.length > 0) {
                for(var ipo=0; ipo<alldata.InstructionalPlan.Topics.Other.length; ipo++) {
                    var thistop = alldata.InstructionalPlan.Topics.Other[ipo].Topic;
                    var thismod = alldata.InstructionalPlan.Topics.Other[ipo].Module;
                    if((thistop.IsHidden === false) && (thismod.IsHidden === false)) {
                        ipfound = true;
                        var topid = thistop.TopicId;
                        $('.link-instructionalplan a').attr('href','/d2l/le/content/'+orgUnitId+'/viewContent/'+topid+'/View');
                        $('.link-instructionalplan a').removeClass('disabled');   
                        $('.link-instructionalplan .link-ico').removeClass('disabled');
                        break;   
                    }
                }
            }
        }

        updateTextbookLink();        
    }
    else {
        $('.link-courseoutline').remove();
        $('.link-instructionalplan').remove();
        $('.link-textbookinfo').remove();  
    }
    
    $('.instructor-content .cc-homepage-panel .links-container .edit-button').attr("onClick","openLinkListSettings()");
    $('.instructor-content .cc-homepage-panel .links-container .edit-button').addClass("active");
    $('.instructor-content .cc-homepage-panel .links-container .close-button').attr("onClick","closeLinkListSettings()");
    $('.instructor-content .cc-homepage-panel .links-container .close-button').addClass("active");
    manageLinkList();
    
}

