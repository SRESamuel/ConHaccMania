            var data = resp.Result;
            //console.log(data);

            alldata.QuizzesAll = {
                Objects: data
            }

        } else {
            alldata.QuizzesAll = {
                Objects: []
            }
            //console.log('error');
        }

        if(alldata.QuizzesAll.Objects.length > 0) {
            if(alldata.CourseType === "Standard") {
                alldata.QuizzesAll.AttemptsDone = 0;
                getQuizAttemptsAll();
            }
            else if(alldata.CourseType === "High Capacity") {
                if(studentroles.indexOf(alldata.CurrentRole) > -1) {
                    alldata.QuizzesAll.AttemptsDone = 0;
                    getQuizAttemptsAll();
                }
                else {
                    alldone.Quizzes = true;
                    //console.log("ad13");
                    checkAllDone();
                }
            }
            else {
                alldone.Quizzes = true;
                //console.log("ad14");
                checkAllDone();
            }
        }
        else {
            alldone.Quizzes = true;
            //console.log("ad15");
            checkAllDone();
        }
    });
}

function getQuizAttemptsAll() {
    if(observeroles.indexOf(alldata.CurrentRole) === -1) {
        for(var q=0; q<alldata.QuizzesAll.Objects.length; q++) {
            var thisquiz = alldata.QuizzesAll.Objects[q];

            if(studentroles.indexOf(alldata.CurrentRole) > -1) {
                getQuizAttempted(thisquiz.QuizId, alldata.WhoAmI.Identifier);
            }

            else {
                getQuizAttempts(thisquiz.QuizId);
            }
        }
    }
    else {
        alldone.Quizzes = true;
        //console.log("ad16");
        checkAllDone();
    }
}

function getQuizAttempts(quizid, bookmark) {
    var quizattempturl = "/d2l/api/le/" + alldata.APIVersions.LE.LatestVersion + "/" + orgUnitId + "/quizzes/" + quizid + "/attempts/";
    if(bookmark !== undefined) {
        quizattempturl = bookmark;
    }
    $.ajax({
        method: "GET",
        url: quizattempturl,
        dataType: 'json',
        success: function (quizattempts_tmp) {
            for(var q=0; q<alldata.QuizzesAll.Objects.length; q++) {
                if(alldata.QuizzesAll.Objects[q].QuizId === quizid) {
                    if(alldata.QuizzesAll.Objects[q].Attempts === undefined) {
                        alldata.QuizzesAll.Objects[q].Attempts = quizattempts_tmp;
                    }
                    else {
                        alldata.QuizzesAll.Objects[q].Attempts.Objects = alldata.QuizzesAll.Objects[q].Attempts.Objects.concat(quizattempts_tmp.Objects);
                    }
                    break;
                }
            }
            
            if(quizattempts_tmp.Next !== null) {
                getQuizAttempts(quizid, quizattempts_tmp.Next);
            }
            else {
                alldata.QuizzesAll.AttemptsDone++;
                if(alldata.QuizzesAll.AttemptsDone === alldata.QuizzesAll.Objects.length) {

                    alldone.Quizzes = true;
                    //console.log("ad17");
                    checkAllDone();
                }                
            }

            
        } //end success
    }) //end ajax
}

