}

function initializeModelOnlyDisplay() {
    if(alldata.OfficialModel === true) {
        $('.course-checklist-callout-content button').attr('title','Not Applicable in Model Shells');
        $('.course-checklist-callout-content button').attr('disabled','disabled');
        $('.course-checklist-callout-content button').removeAttr('onclick');
    }
}

function getAnnounceFile(announceid, announcefileid) {
    var getannouncefileurl = "/d2l/api/le/" + alldata.APIVersions.LE.LatestVersion + "/" + orgUnitId + "/news/" + announceid + "/attachments/" + announcefileid;
    
    // Utility to get file name from Content-Disposition header
    const getFileNameFromContentDisposition = (headerValue) => {
        if (!headerValue) return null;

        const matches = /filename\*?=[^;\n]*utf-8''([^;\n]*)/i.exec(headerValue) || /filename[^;=\n]*=((['"]).*?\2|[^;\n]*)/.exec(headerValue);
        if (matches && matches[1]) {
            return decodeURIComponent(matches[1].replace(/['"]/g, ''));
        }
        return null;
    };

    // Fetch data from API
    fetch(getannouncefileurl, {
        method: 'GET',
        headers: {
            'Accept': 'application/octet-stream',
        },
    })
    .then(response => {
        if (!response.ok) {
            throw new Error('Network response was not ok');
        }
        const contentDisposition = response.headers.get('Content-Disposition');
        const fileName = getFileNameFromContentDisposition(contentDisposition) || 'download';
        return response.blob().then(blob => ({ blob, fileName }));
    })
    .then(({ blob, fileName }) => {
        // Handle the blob data (file stream) here
        const url = window.URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.style.display = 'none';
        a.href = url;
        a.download = fileName;
        document.body.appendChild(a);
        a.click();
        window.URL.revokeObjectURL(url);
    })
    .catch(error => {
        console.error('There was a problem with the fetch operation:', error.message);
    });    
    
}


function openAnnouncement(announceid) {
    var url = '/d2l/le/news/'+orgUnitId+'/'+announceid+'/view?ou='+orgUnitId;
    //console.log(url);
    window.open(url,'_blank');
}


function checkAnnounceImage(obj, announceid) {
    if(obj[0].naturalWidth > 400) {
        var newlinkstring = '<button type="button" class="btn btn-link btn-announce-new-tab" onClick="openAnnouncement(\''+announceid+'\')">Is this image too small to view all details? Open this Announcement in a new tab.</button>';
        $(newlinkstring).insertAfter($(obj));
    }
}


function fixAnnounceHTML(htmlstring, announceid) {
    //console.log(htmlstring);
    var htmlobjects = $('<div>' + htmlstring + '</div>');
    //for(var o=0; o<htmlobjects.length; o++) {
    //}
    
    var iframes = htmlobjects.find('iframe');
    $(iframes).each(function() {
        var ifwidth = $(this).attr('width');
        var ifheight = $(this).attr('height')
        $(this).removeAttr('width');
        $(this).css({
            width: ifwidth + "px",
            maxWidth: "100%"
        });
    });
    
    var images = htmlobjects.find('img');
    $(images).each(function() {
        var imgwidth = $(this).attr('width');
        if(imgwidth !== undefined) {
            var imgheight = $(this).attr('height')
            $(this).removeAttr('width');
            $(this).removeAttr('height');
            $(this).css({
                width: imgwidth + "px",
                height: "auto",
                maxWidth: "100%"
            });
        }
        else {
            $(this).css({
                maxWidth:"100%",
                height: "auto"
            });    
        }
        $(this).attr('data-announceid', announceid);
        $(this).addClass('inline-img');
        
        
        //$(this).on('load',function(){
        //    checkAnnounceImage($(this), announceid);
        //})

    });
    
    var atags = htmlobjects.find('a');
    $(atags).each(function() {
        if($(this).attr('target') !== '_blank') {
            $(this).attr('target','_blank');
        }
    });
    
    var tabletags = htmlobjects.find('table');
    $(tabletags).each(function() {
        $(this).removeAttr('width');
        //$(this).removeAttr('style');
        $(this).css({
            width: "auto",
            height: "auto",
            maxWidth: "100%"
        });          
    });
    
    var trtags = htmlobjects.find('tr');
    $(trtags).each(function() {
        $(this).removeAttr('width');
        //$(this).removeAttr('style');
        $(this).css({
            width: "auto",
            height: "auto",
            maxWidth: "100%"
        }); 
    });
    
    var thtags = htmlobjects.find('th');
    $(thtags).each(function() {
        $(this).removeAttr('width');
        //$(this).removeAttr('style');
        $(this).css({
            width: "auto",
            height: "auto",
            maxWidth: "100%"
        }); 
    });
    
    var tdtags = htmlobjects.find('td');
    $(tdtags).each(function() {
        $(this).removeAttr('width');
        //$(this).removeAttr('style');
        $(this).css({
            width: "auto",
            height: "auto",
            maxWidth: "100%"
        }); 
    });
    
    var divtags = htmlobjects.find('div');
    $(divtags).each(function() {
        var divstyle = $(this).attr('style');
        if(divstyle !== undefined) {
            divstyle = divstyle.toLowerCase();
            divstyle = divstyle.replace("absolute","");
            divstyle = divstyle.replace("background: white","");
            divstyle = divstyle.replace("background-color: rgb(255, 255, 255)","");
            $(this).attr('style',divstyle);
        }
        $(this).removeClass("embed-responsive-16by9");
    });
    
    var spantags = htmlobjects.find('span');
    $(spantags).each(function() {
        var spanstyle = $(this).attr('style');
        if(spanstyle !== undefined) {
            spanstyle = spanstyle.toLowerCase();
            spanstyle = spanstyle.replace("absolute","");
            spanstyle = spanstyle.replace("background: white","");
            spanstyle = spanstyle.replace("background-color: rgb(255, 255, 255)","");
            $(this).attr('style',spanstyle);
        }
    });
    
    var ptags = htmlobjects.find('p');
    $(ptags).each(function() {
        var pstyle = $(this).attr('style');
        if(pstyle !== undefined) {
            pstyle = pstyle.toLowerCase();
            pstyle = pstyle.replace("background: white","");
            pstyle = pstyle.replace("background-color: rgb(255, 255, 255)","");
            $(this).attr('style',pstyle);
        }
    });
    
    var litags = htmlobjects.find('li');
    $(litags).each(function() {
        var listyle = $(this).attr('style');
        if(listyle !== undefined) {
            listyle = listyle.toLowerCase();
            listyle = listyle.replace("background: white","");
            listyle = listyle.replace("background-color: rgb(255, 255, 255)","");
            $(this).attr('style',listyle);
        }
    });
    
    var returnstring = $(htmlobjects)[0].outerHTML;
    //returnstring = cleanTextInput(returnstring);
    //console.log(returnstring);
    
    return returnstring;
    
}


function buildAnnounceString(thisannounce, ispinned, canbepinned) {
    
    var announcestring = '';
    if(ispinned) {
        announcestring += '<div class="announcement-card announce-visible pinned announcement-'+thisannounce.Id+'">';
    }
    else {
        announcestring += '<div class="announcement-card announce-visible announcement-'+thisannounce.Id+'">';
    }
    
    announcestring += '<div class="announcement-icon">';

    var iconstring = '<div class="cc-icon blue-bg megaphone"></div>';
    
    
    if(alldata.CustomSettings !== null) {
        if(alldata.CustomSettings.Announce !== undefined) {
            //console.log(alldata.CustomSettings.Announce);
            if(alldata.CustomSettings.Announce.Icons !== undefined) {
                for(var ai=0; ai<alldata.CustomSettings.Announce.Icons.length; ai++) {
                    var thisicon = alldata.CustomSettings.Announce.Icons[ai];
                    if(thisicon.ID === thisannounce.Id) {
                        iconstring = '<div class="cc-icon '+thisicon.Color+' '+thisicon.Icon+'"></div>';
                    }
                }
            }
        }
    }
    announcestring += iconstring;
    announcestring += '</div>';
    announcestring += '<div class="announcement-body">';
    announcestring += '<div class="announcement-title-block">';
    announcestring += '<div class="announcement-title">';
    announcestring += '<h3>'+thisannounce.Title+'</h3>';
    
    var sdate = new Date(thisannounce.StartDate);
    announcestring += '<p>'+sdate.toLocaleDateString('en-us', { weekday:"long", year:"numeric", month:"long", day:"numeric"})+', ' + formatAMPM(sdate) + '</p>';
    announcestring += '</div>';
    announcestring += '<div class="announcement-controls">';
    if(canbepinned) {
        if(ispinned) {
            announcestring += '<button class="announcement-pin" onClick="announceUnPin('+thisannounce.Id+')" title="Unpin Announcement"></button>';
        }
        else {
            announcestring += '<button class="announcement-pin" onClick="announcePin('+thisannounce.Id+')" title="Pin Announcement"></button>';
        }        
    }
    else {
        //announcestring += '<button class="announcement-pin" disabled="disabled" title="Pinning Disabled on Homepage"></button>';
    }
    
    announcestring += '<button class="announcement-style" onClick="announceStyle('+thisannounce.Id+')" title="Style Announcement"></button>';
    announcestring += '<button class="announcement-edit" onClick="announceEdit('+thisannounce.Id+')" title="Edit Announcement"></button>';  
    announcestring += '<button class="announcement-delete" onClick="announceDelete('+thisannounce.Id+')" title="Delete Announcement"></button>';
    //announcestring += '<button class="announcement-dismiss" onClick="announceDismiss('+thisannounce.Id+')"></button>';
    announcestring += '</div>';
    announcestring += '</div>';
    announcestring += '<div class="announcement-content textfix">';
    announcestring += fixAnnounceHTML(thisannounce.Body.Html, thisannounce.Id);
    
    if(thisannounce.Attachments.length > 0) {
        for(var aa=0; aa<thisannounce.Attachments.length; aa++) {
            announcestring += '<p>';            
            if(
                (thisannounce.Attachments[aa].FileName.toLowerCase().indexOf(".jpg") > -1) || (thisannounce.Attachments[aa].FileName.toLowerCase().indexOf(".jpeg") > -1) || 
                (thisannounce.Attachments[aa].FileName.toLowerCase().indexOf(".gif") > -1) ||
                (thisannounce.Attachments[aa].FileName.toLowerCase().indexOf(".png") > -1) ||
                (thisannounce.Attachments[aa].FileName.toLowerCase().indexOf(".svg") > -1)
              ) 
            {
                announcestring += '<img src="https://s.brightspace.com/lib/bsi/20.23.11-218/images/tier1/file-image.svg" width="1" height="1" alt="" style="width: 16px; height: 16px;">';
            }
            else if(
                (thisannounce.Attachments[aa].FileName.toLowerCase().indexOf(".swf") > -1) ||
                (thisannounce.Attachments[aa].FileName.toLowerCase().indexOf(".mp4") > -1) ||
                (thisannounce.Attachments[aa].FileName.toLowerCase().indexOf(".mov") > -1)
              ) 
            {
                announcestring += '<img src="https://s.brightspace.com/lib/bsi/20.23.11-218/images/tier1/file-video.svg" width="1" height="1" alt="" style="width: 16px; height: 16px;">';
            }
            else if(
                (thisannounce.Attachments[aa].FileName.toLowerCase().indexOf(".mp3") > -1) ||
                (thisannounce.Attachments[aa].FileName.toLowerCase().indexOf(".wav") > -1)
              ) 
            {
                announcestring += '<img src="https://s.brightspace.com/lib/bsi/20.23.11-218/images/tier1/file-audio.svg" width="1" height="1" alt="" style="width: 16px; height: 16px;">';
            }
            else if(
                (thisannounce.Attachments[aa].FileName.toLowerCase().indexOf(".zip") > -1)
              ) 
            {
                announcestring += '<img src="https://s.brightspace.com/lib/bsi/20.23.11-218/images/tier1/file-archive.svg" width="1" height="1" alt="" style="width: 16px; height: 16px;">';
            }
            else {
                announcestring += '<img src="https://s.brightspace.com/lib/bsi/20.23.9-217/images/tier1/file-document.svg" width="1" height="1" alt="" style="width: 16px; height: 16px;">';
            }            
            announcestring += ' <a style="text-decoration:underline" href="javascript:getAnnounceFile('+thisannounce.Id+','+thisannounce.Attachments[aa].FileId+')">'+thisannounce.Attachments[aa].FileName;
            announcestring += '</a>';
            announcestring += '</p>';
        }
    }
    
    /*
    var announcehtml = thisannounce.Body.Text;
    var announceclean = cleanTextInput(announcehtml);

    //console.log(announceclean);
    
    var announcesplit = announceclean.split(" ");
    var previewtext = '';
    var index = 0;
    
    for(var as=0; as<announcesplit.length; as++) {
        if(previewtext.length < 150) {
            if(as > 0) {
                previewtext += " ";
                previewtext += announcesplit[as];
            }
            else {
                previewtext += announcesplit[as];
            }
        }
        else {
            break;
        }
    }

    if(index < (announcesplit.length - 1)) {
        previewtext += " ...";
    }

    if(previewtext === "") {
        //console.log(thisannounce);
        var isvideo = false;
        if(thisannounce.Body.Html.indexOf("youtube.com") > -1) {
            isvideo = true;
        }
        if(thisannounce.Body.Html.indexOf("youtu.be") > -1) {
            isvideo = true;
        }
        if(thisannounce.Body.Html.indexOf("panopto.com") > -1) {
            isvideo = true;
        }
        if(isvideo) {
            previewtext = "A video has been posted. View the full announcement to access this material."
        }
        else {
            previewtext = "The contents of this announcement cannot be displayed here. View the full announcement to access this material."
        }
    }
    announcestring += '<p>'+previewtext+'</p>';
    announcestring += '<p><a class="announce-viewfull" href="/d2l/le/news/'+orgUnitId+'/'+thisannounce.Id+'/view" target="_blank">View Full Announcement <i class="fas fa-external-link" aria-hidden="true"></i><span class="sr-only">Opens in a new tab</span></a></p>';
    */
    
    announcestring += '</div>';
    announcestring += '</div>';
    announcestring += '</div>';
    
    return announcestring;
}


function checkAnnounceVisibility(thisannounce) {
    var displaythis = false;
    if(!thisannounce.IsHidden) {
        if(thisannounce.IsPublished) {
            var tdate = new Date();
            var sdate = new Date(thisannounce.StartDate);
            if(sdate <= tdate) {
                if(thisannounce.EndDate === null) {
                    displaythis = true;
                }
                else {
                    var edate = new Date(thisannounce.EndDate);
                    if(edate > tdate) {
                        displaythis = true;
                    }
                }
            }               
        }         
    }
    
    return displaythis;
}


function processPinnedAnnounce() {
    for(var a=0; a<alldata.Announcements.length; a++) {
        var thisannounce = alldata.Announcements[a];
        if(thisannounce.IsPinned) {
            var pinfound = false;
            if(alldata.CustomSettings !== null) {
                if(alldata.CustomSettings.Announce !== undefined) {
                    if(alldata.CustomSettings.Announce.Pins !== undefined) {
                        for(var ap=0; ap<alldata.CustomSettings.Announce.Pins.length; ap++) {
                            var thispin = alldata.CustomSettings.Announce.Pins[ap];
                            if(thisannounce.Id === thispin.ID) {
                                pinfound = true;
                                break;
                            }
                        }
                    }
                }
            }
            if(!pinfound) {
                //console.log(thisannounce);
                var newpin = {
                    ID: thisannounce.Id,
                    User: null,
                    Time: '1970-01-01T00:00:00.000Z'
                }
                if(alldata.CustomSettings !== null) {
                    if(alldata.CustomSettings.Announce !== undefined) {               
                        alldata.CustomSettings.Announce.Pins.push(newpin);
                    }
                    else {
                        alldata.CustomSettings.Announce = {
                            Pins: [newpin]
                        }
                    }
                }
                else {
                    alldata.CustomSettings = {
                        Announce: {
                            Pins: [newpin]
                        }
                    }
                }
            }
        }
    }
}


