function processCourseType() {
    alldata.CourseType = "Standard";
    if((alldone.Classlist === true) && (alldone.Offering === true)) {
        
        if((studentroles.indexOf(alldata.CurrentRole) > -1) || (observeroles.indexOf(alldata.CurrentRole) > -1)) {
            alldone.Enrollment = true;
            //console.log("ad44");
            checkAllDone();
        }
        else {
            getEnrollmentChanges();
        }          
        
        if(alldata.Classlist.Objects.length > 300) {
            if(alldata.NotSection) {
                alldata.CourseType = "Model";
            }
            else {
                alldata.CourseType = "High Capacity";
            }
        }    
        
        if(alldata.CourseOffering.Code.indexOf("Model-") > -1) {
            if(alldata.Ancestors !== undefined) {
                if(alldata.Ancestors.length > 0) {
                    for(var a=0; a<alldata.Ancestors.length; a++) {
                        if(alldata.Ancestors[a].Name.toLowerCase() === "model shells"){
                            alldata.OfficialModel = true;
                            //alldata.CourseType = "Official Model";
                            break;
                        }
                    }
                }
            }
        }
        
        if(alldata.CourseOffering.CourseTemplate.Code.toLowerCase().indexOf("d2lgroup") > -1) {
            alldata.CourseType = "D2L Group";
        }
        
        if(alldata.CourseOffering.CourseTemplate.Name.toLowerCase().indexOf("community group") > -1) {
            alldata.CourseType = "Community";
        }
        
        if(alldata.OfficialModel === false) {
            alldone.ModelAttributes = true;
        }
        getAllDataCalls();
    }
}

function getAllDataCalls() {
    
    initializeModelOnlyDisplay();
    initializeLinkListTeams();
    initializeLinkListCustom();
    initializeInstructorSettings();
    
    if(alldata.Instructors.Objects.length > 0) {
        getProfileImageCrop(ProfileCropField);
    }
    else {
        alldone.ProfileImageCrop = true;
        //console.log("ad4");
        checkAllDone();
    }
    
    //console.log(alldata.CourseType);
    if(alldata.CourseType === "Standard") {
        getCourseGradesAll();
        getGroupCategories();            
        getContentProgressAll();
        getClasslistGradeValues();
        if(studentroles.indexOf(alldata.CurrentRole) > -1) {
            alldone.CopyLogs = true;
        }
        else {
            alldone.CopyLogs = true;
            //getCourseCopyLogs();
        }
    }
    else if(alldata.CourseType === "High Capacity") {
        getCourseGradesAll();
        if(studentroles.indexOf(alldata.CurrentRole) > -1) {
            getContentProgressAll();
            getClasslistGradeValues();
            getGroupCategories();
            alldone.CopyLogs = true;
        }
        else {
            alldone.Groups = true;
            alldone.Progress = true;
            alldone.Values = true;
            alldone.CopyLogs = true;
            //getCourseCopyLogs();
        }
    }
    else {          
        //console.log(alldata.CourseType);
        initializeLinkList();
        alldone.Grades = true;
        alldone.Groups = true;
        alldone.Progress = true;
        alldone.Values = true;
        alldone.CopyLogs = true;
    }    
    
    if(studentroles.indexOf(alldata.CurrentRole) > -1) {
        getAssignmentsUser();
        getQuizzesUser();
    }
    else {
        alldata.AssignmentsUser = null;
        alldone.AssignmentsUser = true;
        alldata.QuizzesUser = null;
        alldone.QuizzesUser = true;
    }
    
    //ecPlusGetAncestors(orgUnitId, 105);
    getAnnouncementData();
    getCourseAssignmentsAll();
    getChecklistsAll();
    getCourseContentTOC();
    //getCourseContentUnstable();
    getCourseDiscussionsAll();
    getCourseQuizzesAll();
    getCourseUpdatesAll();
    ecPlusGetUserNotifications();

}

function putProfileImageCrop(userID, fieldID, demographdata, canvasdata) {
    
    var token;
    $.ajax({
        method: "GET",
        url: "/d2l/lp/auth/xsrf-tokens",
        success: function(ltoken) {
            token = ltoken;
            //console.log(token);
            
            var putdemographurl = "/d2l/api/lp/" + alldata.APIVersions.LP.LatestVersion + "/demographics/users/" + userID;
            putdemographurl += "?fieldIds="+fieldID;

            //console.log(putdemographurl);
            //console.log(demographdata);

            $.ajax({
                beforeSend: function(request) {
                    request.setRequestHeader("X-Csrf-Token", token.referrerToken);
                },        
                url: putdemographurl,
                type: 'PUT',
                dataType: 'json',
                data: JSON.stringify(demographdata),
                success: function (data, textStatus, xhr) {
                    //console.log(userID);
                    for(var i=0; i<alldata.InstructorDisplay.Objects.length; i++) {
                        //console.log(alldata.InstructorDisplay.Objects[i].Identifier);
                        if(userID === parseInt(alldata.InstructorDisplay.Objects[i].Identifier)) {
                            //console.log(canvasdata);
                            alldata.InstructorDisplay.Objects[i].ProfileImageCrop = canvasdata;
                            //console.log(alldata.InstructorDisplay.Objects[i]);
                            break;
                        }
                    }
                },
                error: function (xhr, textStatus, errorThrown) {
                    console.log(xhr);
                    console.log(textStatus);
                    console.log(errorThrown);
                }
            });       
        }
    });
}

function getProfileImageCrop(fieldID) {
    var getdemographurl = "/d2l/api/lp/" + alldata.APIVersions.LP.LatestVersion + "/demographics/users/";
    getdemographurl += "?fieldIds="+fieldID;
    getdemographurl += "&userIds=";
    for(var i=0; i<alldata.Instructors.Objects.length; i++) {
        getdemographurl += alldata.Instructors.Objects[i].Identifier;
        if(i < (alldata.Instructors.Objects.length - 1)) {
            getdemographurl+=",";
        }
    }
    
    $.ajax({
        method: "GET",
        url: getdemographurl,
        dataType: 'json',
        success: function (demographresponse_tmp) {
            
            //console.log(demographresponse_tmp);
            alldata.ProfileImageCrop = demographresponse_tmp;
            
            for(var pic=0; pic<alldata.ProfileImageCrop.Items.length; pic++) {
                for(var i=0; i<alldata.Instructors.Objects.length; i++) {
                    if(parseInt(alldata.Instructors.Objects[i].Identifier) === alldata.ProfileImageCrop.Items[pic].UserId) {
                        for(var e=0; e<alldata.ProfileImageCrop.Items[pic].EntryValues.length; e++) {
                            var thisval = alldata.ProfileImageCrop.Items[pic].EntryValues[e];
                            if(thisval.FieldId === fieldID) {
                                alldata.Instructors.Objects[i].ProfileImageCrop = JSON.parse(thisval.Values[0]);
                            }                                 
                        }                       
                    }                    
                }
            }

            alldone.ProfileImageCrop = true;
            //console.log("ad5");
            checkAllDone();

        } //end success
    }) //end ajax   
    
}

function getCourseContentUnstable() {
    var getcontenturl = "/d2l/api/le/unstable/" + orgUnitId + "/content/toc";
    $.ajax({
        method: "GET",
        url: getcontenturl,
        dataType: 'json',
        success: function (contentresponse_tmp) {
            
            if(alldata.CurrentRole === "Student") {
                alldata.ContentUnstable = processProgressTOC(contentresponse_tmp);
            }
            else {
                alldata.ContentUnstable = contentresponse_tmp;
            }
            
            checkContentRetrieved();

        } //end success
    }) //end ajax    
}

function getCourseContentTOC(modelmatchouid) {
    var getcontenturl;
    if(modelmatchouid === undefined) {
        getcontenturl = "/d2l/api/le/" + alldata.APIVersions.LE.LatestVersion + "/" + orgUnitId + "/content/toc";
    }
    else {
        getcontenturl = "/d2l/api/le/" + alldata.APIVersions.LE.LatestVersion + "/" + modelmatchouid + "/content/toc";
    }
    getcontenturl += '?ignoreDateRestrictions=true';
    $.ajax({
        method: "GET",
        url: getcontenturl,
        dataType: 'json',
        success: function (contentresponse_tmp) {
            
            if(modelmatchouid === undefined) {
                if(alldata.CurrentRole === "Student") {
                    alldata.Content = processProgressTOC(contentresponse_tmp);
                }
                else {
                    alldata.Content = contentresponse_tmp;
                }

                checkContentRetrieved();                
            }
            else {
                for(var m=0; m<alldata.Readiness.Result[0].MatchingModels.length; m++) {
                    var thismodel = alldata.Readiness.Result[0].MatchingModels[m];
                    if(thismodel.OrgUnitId === modelmatchouid) {
                        thismodel.Content = contentresponse_tmp;
                    }
                }
                alldata.Readiness.Result[0].EmptyCheck.Content++;
                processModelMatchesEmpty();
                
            }
            
        }, //end success
        error: function (xhr, ajaxOptions, thrownError) {
            if(modelmatchouid !== undefined) {
                for(var m=0; m<alldata.Readiness.Result[0].MatchingModels.length; m++) {
                    var thismodel = alldata.Readiness.Result[0].MatchingModels[m];
                    if(thismodel.OrgUnitId === modelmatchouid) {
                        thismodel.Content = null;
                        break;
                    }
                }
                alldata.Readiness.Result[0].EmptyCheck.Content++;
                processModelMatchesEmpty();
            }
        }
    }) //end ajax
}

function getContentProgressAll() {
    
    //console.log(alldata.WhoAmI);
    //console.log(alldata.Classlist);
    //getContentViewsAll();
    if(observeroles.indexOf(alldata.CurrentRole) === -1) {
        if(studentroles.indexOf(alldata.CurrentRole) > -1) {
            //console.log("Student");
            var studentfound = false;
            for(var cl=0; cl<alldata.Classlist.Objects.length; cl++) {
                var thisuser = alldata.Classlist.Objects[cl];
                if(thisuser.Identifier === alldata.WhoAmI.Identifier) {
                    studentfound = true;
                    getContentProgress(thisuser.Identifier);
                }
            }
            if(studentroles.indexOf(alldata.CurrentRole) > -1) {
                if(!studentfound) {
                    alldone.Progress = true;
                    //console.log("ad6");
                    checkAllDone();
                }
            }
        }
        else {
            alldata.Classlist.ProgressDone = 0;
            if(alldata.Classlist.Objects.length > 0) {
                for(var cl=0; cl<alldata.Classlist.Objects.length; cl++) {
                    var thisuser = alldata.Classlist.Objects[cl];
                    getContentProgress(thisuser.Identifier);
                }            
            }
            else {
                alldone.Progress = true;
                //console.log("ad7");
                checkAllDone();
            }
        }
    }
    else {
        alldone.Progress = true;
        //console.log("ad8");
        checkAllDone();
    }        
}

function getContentViewsAll(bookmark) {
    var userviewsurl = "/d2l/api/le/unstable/" + orgUnitId + "/content/userprogress/";
    userviewsurl += '?pageSize=100';
	if (bookmark !== undefined) {
		userviewsurl += '&bookmark=' + bookmark;
	}
    //console.log(userviewsurl);
    $.ajax({
        method: "GET",
        url: userviewsurl,
        dataType: 'json',
        success: function (userviews_tmp) {
            
            if(alldata.ContentViews === undefined) {
                alldata.ContentViews = userviews_tmp;
                alldata.ContentViews.Done = false;
            }
            else {
                alldata.ContentViews.Objects = alldata.ContentViews.Objects.concat(userviews_tmp.Objects);
            }
            
            //console.log(alldata.ContentViews.Objects.length);

            if(userviews_tmp.Next !== null) {
                var nextstring = userviews_tmp.Next;
                var bookmarkstring = nextstring.slice(nextstring.indexOf('bookmark=')+9);
                var splitstring = bookmarkstring.split('&');
                var bookmark = splitstring[0];
                //console.log(bookmark);
                getContentViewsAll(bookmark);
            }
            else {
                alldata.ContentViews.Done = true;
                checkContentProgressDone();
            }
        } //end success
    }) //end ajax    
}

function getContentProgress(userid) {
    var userprogressurl = "/d2l/api/le/" + alldata.APIVersions.LE.LatestVersion + "/" + orgUnitId + "/content/completions/";
    userprogressurl += '?userIdsCSV='+userid;
    $.ajax({
        method: "GET",
        url: userprogressurl,
        dataType: 'json',
        success: function (userprogress_tmp) {
            for(var cl=0; cl<alldata.Classlist.Objects.length; cl++) {
                if(alldata.Classlist.Objects[cl].Identifier === userid) {
                    alldata.Classlist.Objects[cl].Progress = userprogress_tmp[0];
                    break;
                }
            }
            
            if(studentroles.indexOf(alldata.CurrentRole) > -1) {
                alldata.Classlist.ProgressDone = alldata.Classlist.Objects.length;
                checkContentProgressDone();
            }
            else {
                alldata.Classlist.ProgressDone++;
                if(alldata.Classlist.ProgressDone === alldata.Classlist.Objects.length) {
                    checkContentProgressDone();
                }                
            }

            
        } //end success
    }) //end ajax
}

