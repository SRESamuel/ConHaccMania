function cleanTextInput(item) {    
    var div = document.createElement("div");
    div.innerHTML = item;
    var itemtext = div.textContent || div.innerText || "";
    var itemclean = itemtext.replace(/(<([^>]+)>)/gi, "");    
    return itemclean;
}

function highCapDashLoad() {
    $('#highcap-dash-load-btn').addClass('disabled');
    $('#highcap-dash-load-btn').attr('disabled','disabled');
    
    alldata.CourseType = "Standard";
    
    alldone.Quizzes = false;
    alldone.Assignments = false;
    alldone.Grades = false;
    
    alldone.Groups = false;
    alldone.Progress = false;
    alldone.Values = false;
    
    alldata.Displayed.ProgressStudents = false
    alldata.Displayed.ProgressAssess = false;
    alldata.Displayed.Dashboards = false;        

    if(alldata.QuizzesAll.Objects.length > 0) {
        alldata.QuizzesAll.AttemptsDone = 0;
        getQuizAttemptsAll();
    }
    else {
        alldone.Quizzes = true;
        //console.log("ad1");
        checkAllDone();
    }
    if(alldata.AssignmentsAll.Objects.length > 0) {
        alldata.AssignmentsAll.SubmissionsDone = 0;
        getAssignmentSubmissionsAll();          
    }
    else {
        alldone.Assignments = true;
        //console.log("ad2");
        checkAllDone();
    }
        
    if(alldata.GradeItems.Objects.length > 0) {
        alldata.GradeItems.StatsDone = 0;
        alldata.GradeItems.ValuesDone = 0;
        getGradeResults();
    }
    else {
        alldone.Grades = true;
        //console.log("ad3");
        checkAllDone();
    }
    
    getContentProgressAll();
    getClasslistGradeValues();
    getGroupCategories();
    
}

