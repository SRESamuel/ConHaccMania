function processAssignmentData() {
    
    if(studentroles.indexOf(alldata.CurrentRole) > -1) {
        if(alldata.AssignmentsUser !== undefined) {
            if(alldata.AssignmentsUser !== null) {
                for(var au=0; au<alldata.AssignmentsUser.Objects.length; au++) {
                    var thisau = alldata.AssignmentsUser.Objects[au];
                    if(alldata.AssignmentsAll !== null) {
                        for(var aa=0; aa<alldata.AssignmentsAll.Objects.length; aa++) {
                            var thisaa = alldata.AssignmentsAll.Objects[aa];
                            if(thisau.Id === thisaa.Id) {
                                thisaa.Availability = thisau.Availability;
                                thisaa.DueDate = thisau.DueDate;
                                break;
                            }
                        }
                    }
                }
            }
        }
    } 
    
    var allassignconfirmed = [];
    for(var a=0; a<alldata.AssignmentsAll.Objects.length; a++) {
        var thisassign = alldata.AssignmentsAll.Objects[a];
        var includeassign = false;
        
        if (studentroles.indexOf(alldata.CurrentRole) > -1) {
            if(thisassign.GroupTypeId === null) {
                thisassign.URL = '/d2l/lms/dropbox/user/folder_submit_files.d2l?db=' + thisassign.Id + '&ou=' + orgUnitId;
            }
            else {
                var groupid = -1;
                for(var ga=0; ga<alldata.GroupsAll.Objects.length; ga++) {
                    if(alldata.AssignmentsAll.Objects[a].GroupTypeId === alldata.GroupsAll.Objects[ga].GroupCategoryId) {

                        for(var gd=0; gd< alldata.GroupsAll.Objects[ga].Groups.length; gd++) {
                            var thisgd = alldata.GroupsAll.Objects[ga].GroupsData[gd];
                            if(thisgd.Enrollments.indexOf(parseInt(alldata.WhoAmI.Identifier)) > -1) {
                                groupid = thisgd.GroupId;
                                break;
                            }
                        }

                        break;
                    }
                }
                if(groupid > -1) {
                    thisassign.URL = '/d2l/lms/dropbox/user/folder_submit_files.d2l?db=' + thisassign.Id + '&ou=' + orgUnitId + '&grpid=' + groupid;
                }
                else {
                    thisassign.URL = '/d2l/lms/dropbox/user/folders_list.d2l?ou=' + orgUnitId + '&isprv=0';
                }
            }
            
            var assignuserfound = false;
            if(alldata.AssignmentsUser !== undefined) {
                if(alldata.AssignmentsUser !== null) {
                    for(var au=0; au<alldata.AssignmentsUser.Objects.length; au++) {
                        var thisau = alldata.AssignmentsUser.Objects[au];
                        if(thisau.Id === thisassign.Id) {
                            assignuserfound = true;
                            break;
                        }
                    }
                }
            }            
            if(thisassign.AllowOnlyUsersWithSpecialAccess) {
                if(assignuserfound) {
                    includeassign = true;
                }
            }
            else {
                includeassign = true;
            }
            
            if(!assignuserfound) {
                thisassign.URL = '';
            }            
            
        }
        else if (observeroles.indexOf(alldata.CurrentRole) > -1) {
            thisassign.URL = '';
            includeassign = true;
        }
        else {
            
            thisassign.URL = '/d2l/lms/dropbox/admin/mark/folder_submissions_observed.d2l?db=' + thisassign.Id + '&ou=' + orgUnitId;
            //thisassign.URL = '/d2l/lms/dropbox/admin/modify/folder_newedit_properties.d2l?ou=' + orgUnitId + '&db=' +thisassign.Id;
            includeassign = true;
        }
        
        if(includeassign) {
            allassignconfirmed.push(thisassign);
        }
    }
    
    //console.log(allassignconfirmed);
    alldata.AssignmentsAll.Objects = allassignconfirmed;
    
}

function getCourseAssignmentsAll() {
    ecplusClient.econestoga.getAssignments(orgUnitId, { apiVersion: '1.4' }).then(function (resp) {
        if (resp.isSuccess) {
            var data = resp.Result;
            //console.log(data);

            alldata.AssignmentsAll = {
                Objects:data
            }

        } else {
            alldata.AssignmentsAll = {
                Objects:[]
            }
        }

        if(alldata.AssignmentsAll.Objects.length > 0) {
            if(alldata.CourseType === "Standard") {
                alldata.AssignmentsAll.SubmissionsDone = 0;
                getAssignmentSubmissionsAll();
            }
            else if(alldata.CourseType === "High Capacity") {
                if(studentroles.indexOf(alldata.CurrentRole) > -1) {
                    alldata.AssignmentsAll.SubmissionsDone = 0;
                    getAssignmentSubmissionsAll();
                }
                else {
                    alldone.Assignments = true;
                    //console.log("ad20");
                    checkAllDone();
                }
            }
            else {
                alldone.Assignments = true;
                //console.log("ad21");
                checkAllDone();
            }
        }
        else {

            alldone.Assignments = true;
            //console.log("ad22");
            checkAllDone();
        }
    });
}

function getAssignmentSubmissionsAll() {
    if(observeroles.indexOf(alldata.CurrentRole) === -1) {
        for(var asf=0; asf<alldata.AssignmentsAll.Objects.length; asf++) {
            var thisassign = alldata.AssignmentsAll.Objects[asf];
            if((thisassign.TotalUsersWithSubmissions > 0) || (thisassign.TotalUsersWithFeedback > 0)) {
                if(studentroles.indexOf(alldata.CurrentRole) > -1) {
                    getAssignmentSubmitted(thisassign.Id, alldata.WhoAmI.Identifier);
                }
                else {
                    getAssignmentSubmissions(thisassign.Id);
                }            
            }
            else {
                alldata.AssignmentsAll.SubmissionsDone++;
                if(alldata.AssignmentsAll.SubmissionsDone === alldata.AssignmentsAll.Objects.length) {

                    alldone.Assignments = true;
                    //console.log("ad23");
                    checkAllDone();            
                }
            }
        }        
    }
    else {
        alldone.Assignments = true;
        //console.log("ad24");
        checkAllDone();   
    }
}

function getAssignmentSubmissions(assignid) {
    var assignsubmiturl = "/d2l/api/le/" + alldata.APIVersions.LE.LatestVersion + "/" + orgUnitId + "/dropbox/folders/" + assignid + "/submissions/";
    $.ajax({
        method: "GET",
        url: assignsubmiturl,
        dataType: 'json',
        success: function (assignsubmits_tmp) {
            for(var asf=0; asf<alldata.AssignmentsAll.Objects.length; asf++) {
                if(alldata.AssignmentsAll.Objects[asf].Id === assignid) {
                    alldata.AssignmentsAll.Objects[asf].Submissions = assignsubmits_tmp;
                    break;
                }
            }
            
            alldata.AssignmentsAll.SubmissionsDone++;
            if(alldata.AssignmentsAll.SubmissionsDone === alldata.AssignmentsAll.Objects.length) {

                alldone.Assignments = true;
                //console.log("ad25");
                checkAllDone();            
            }
            
        } //end success
    }) //end ajax
}

function getCourseGradesAll() {
    getGradeItems();
    getGradeCategories();
    getGradeSetup();
}

function getGradeItems(modelmatchouid) {
    var gradeitemsurl;
    if(modelmatchouid === undefined) {
        gradeitemsurl = "/d2l/api/le/" + alldata.APIVersions.LE.LatestVersion + "/" + orgUnitId + "/grades/";
    }
    else {
        gradeitemsurl = "/d2l/api/le/" + alldata.APIVersions.LE.LatestVersion + "/" + modelmatchouid + "/grades/";
    }
    $.ajax({
        method: "GET",
        url: gradeitemsurl,
        dataType: 'json',
        success: function (gradeitems_tmp) {
            
            if(modelmatchouid === undefined) {
                alldata.GradeItems = {
                    Objects: gradeitems_tmp
                }
                checkGradesDone();
            }
            else {
                for(var m=0; m<alldata.Readiness.Result[0].MatchingModels.length; m++) {
                    var thismodel = alldata.Readiness.Result[0].MatchingModels[m];
                    if(thismodel.OrgUnitId === modelmatchouid) {
                        thismodel.GradeItems = {
                            Objects: gradeitems_tmp
                        }
                    }
                }
                alldata.Readiness.Result[0].EmptyCheck.Grades++;
                processModelMatchesEmpty();
                
            }
            
        } //end success
    }) //end ajax
}

function getGradeCategories() {
    var gradecatsurl = "/d2l/api/le/" + alldata.APIVersions.LE.LatestVersion + "/" + orgUnitId + "/grades/categories/";
    $.ajax({
        method: "GET",
        url: gradecatsurl,
        dataType: 'json',
        success: function (gradecats_tmp) {
            
            alldata.GradeCategories = gradecats_tmp;
            checkGradesDone();
            
        } //end success
    }) //end ajax
}

function getGradeSetup() {
    var gradesetupurl = "/d2l/api/le/" + alldata.APIVersions.LE.LatestVersion + "/" + orgUnitId + "/grades/setup/";
    $.ajax({
        method: "GET",
        url: gradesetupurl,
        dataType: 'json',
        success: function (gradesetup_tmp) {
            
            alldata.GradeSetup = gradesetup_tmp;
            checkGradesDone();
            
        } //end success
    }) //end ajax
}

function checkGradesDone() {
    //console.log(alldata.GradeItems);
    //console.log(alldata.GradeCategories);
    //console.log(alldata.GradeSetup);
    
    if((alldata.GradeItems !== undefined) && (alldata.GradeCategories !== undefined) && (alldata.GradeSetup !== undefined)) {
        
        if(alldata.GradeItems.Objects.length > 0) {
            if(alldata.CourseType === "Standard") {
                alldata.GradeItems.StatsDone = 0;
                alldata.GradeItems.ValuesDone = 0;
                getGradeResults();
            }
            else if(alldata.CourseType === "High Capacity") {
                if(studentroles.indexOf(alldata.CurrentRole) > -1) {
                    alldata.GradeItems.StatsDone = 0;
                    alldata.GradeItems.ValuesDone = 0;
                    getGradeResults();
                }
                else {
                    alldone.Grades = true;
                    //console.log("ad26");
                    checkAllDone();
                }
            }
        }
        else {
            alldone.Grades = true;
            //console.log("ad27");
            checkAllDone();
        }
    }
}

function getGradeResults() {
    if(observeroles.indexOf(alldata.CurrentRole) === -1) {
        for(var gi=0; gi<alldata.GradeItems.Objects.length; gi++) {
            var thisgrade = alldata.GradeItems.Objects[gi];
            if(studentroles.indexOf(alldata.CurrentRole) > -1) {
                alldata.GradeItems.StatsDone++;     
                if(alldata.GradeItems.StatsDone === alldata.GradeItems.Objects.length) {
                    checkGradeResultsDone();
                }                
            }
            else {
                if((thisgrade.GradeType === "Numeric") || (thisgrade.GradeType === "PassFail") || (thisgrade.GradeType === "SelectBox")) {
                    getGradeStatistics(thisgrade.Id);
                }
                else {
                    thisgrade.Statistics = null;
                    alldata.GradeItems.StatsDone++;
                    if(alldata.GradeItems.StatsDone === alldata.GradeItems.Objects.length) {

                        checkGradeResultsDone();
                    }
                }                
            }
            
            if((thisgrade.GradeType === "Numeric") || (thisgrade.GradeType === "PassFail") || (thisgrade.GradeType === "SelectBox")) {
                getGradeValues(thisgrade.Id);
            }
            else {
                thisgrade.Values = {
                    Objects:[]
                }
                alldata.GradeItems.ValuesDone++;
                if(alldata.GradeItems.ValuesDone === alldata.GradeItems.Objects.length) {
                    
                    checkGradeResultsDone();
                }    
            }
        }        
    }
    else {
        alldone.Grades = true;
        //console.log("ad28");
        checkAllDone();
    }
}

function getGradeStatistics(gradeid) {
    var gradestatsurl = "/d2l/api/le/" + alldata.APIVersions.LE.LatestVersion + "/" + orgUnitId + "/grades/" + gradeid + "/statistics";
    $.ajax({
        method: "GET",
        url: gradestatsurl,
        dataType: 'json',
        success: function (gradestats_tmp) {
            for(var gi=0; gi<alldata.GradeItems.Objects.length; gi++) {
                if(alldata.GradeItems.Objects[gi].Id === gradeid) {
                    alldata.GradeItems.Objects[gi].Statistics = gradestats_tmp;
                    break;
                }
            }
            
            alldata.GradeItems.StatsDone++;
            if(alldata.GradeItems.StatsDone === alldata.GradeItems.Objects.length) {
                
                checkGradeResultsDone();
            }
            
        }, //end success
        error: function (xhr, ajaxOptions, thrownError) {
            //console.log(xhr);   
            for(var gi=0; gi<alldata.GradeItems.Objects.length; gi++) {
                if(alldata.GradeItems.Objects[gi].Id === gradeid) {
                    alldata.GradeItems.Objects[gi].Statistics = null;
                    break;
                }
            }
            alldata.GradeItems.StatsDone++;
            if(alldata.GradeItems.StatsDone === alldata.GradeItems.Objects.length) {
                checkGradeResultsDone();
            }               
        }
    }) //end ajax
}

function getGradeValues(gradeid, bookmark) {
    var gradevaluesurl = "/d2l/api/le/" + alldata.APIVersions.LE.LatestVersion + "/" + orgUnitId + "/grades/" + gradeid + "/values/";
    
    if(studentroles.indexOf(alldata.CurrentRole) > -1) {
        gradevaluesurl += alldata.WhoAmI.Identifier
    }
    else {
        if(bookmark !== undefined) {
            gradevaluesurl = bookmark;
        }        
    }

    $.ajax({
        method: "GET",
        url: gradevaluesurl,
        dataType: 'json',
        success: function (gradevalues_tmp) {
            for(var gi=0; gi<alldata.GradeItems.Objects.length; gi++) {
                if(alldata.GradeItems.Objects[gi].Id === gradeid) {
                    if(alldata.GradeItems.Objects[gi].Values === undefined) {
                        if(studentroles.indexOf(alldata.CurrentRole) > -1) {
                            alldata.GradeItems.Objects[gi].Values = {
                                Objects: [gradevalues_tmp]
                            }
                        }
                        else {
                            alldata.GradeItems.Objects[gi].Values = gradevalues_tmp;
                        }
                        
                    }
                    else {
                        alldata.GradeItems.Objects[gi].Values.Objects = alldata.GradeItems.Objects[gi].Values.Objects.concat(gradevalues_tmp.Objects);
                    }                    
                    break;
                }
            }
            
            if(studentroles.indexOf(alldata.CurrentRole) > -1) {
                alldata.GradeItems.ValuesDone++;
                if(alldata.GradeItems.ValuesDone === alldata.GradeItems.Objects.length) {

                    checkGradeResultsDone();
                }  
            }
            else {
                if(gradevalues_tmp.Next !== null) {
                    getGradeValues(gradeid, gradevalues_tmp.Next);
                }
                else {
                    alldata.GradeItems.ValuesDone++;
                    if(alldata.GradeItems.ValuesDone === alldata.GradeItems.Objects.length) {

                        checkGradeResultsDone();
                    }                
                }
            }

        }, //end success
        error: function (xhr, ajaxOptions, thrownError) {
            //console.log(xhr.status);
            for(var gi=0; gi<alldata.GradeItems.Objects.length; gi++) {
                if(alldata.GradeItems.Objects[gi].Id === gradeid) {
                    alldata.GradeItems.Objects[gi].Values = 
                        {
                            Objects:[]
                        }
                    break;
                }
            }
            alldata.GradeItems.ValuesDone++;
            if(alldata.GradeItems.ValuesDone === alldata.GradeItems.Objects.length) {

                checkGradeResultsDone();
            }                  
        }        
    }) //end ajax
}

function checkGradeResultsDone() {
    if((alldata.GradeItems.ValuesDone === alldata.GradeItems.Objects.length) && (alldata.GradeItems.StatsDone === alldata.GradeItems.Objects.length)) {
        alldone.Grades = true;
        //console.log("ad29");
        checkAllDone();
    }
}

function getClasslistGradeValues() {
    alldata.Classlist.ValuesDone = 0;
    
    if(observeroles.indexOf(alldata.CurrentRole) === -1) {
        if(alldata.Classlist.Objects.length > 0) {
            var studentfound = false;
            for(var cl=0; cl<alldata.Classlist.Objects.length; cl++) {
                var thisuser = alldata.Classlist.Objects[cl];
                if(thisuser.RoleId === 103) {
                    if(studentroles.indexOf(alldata.CurrentRole) > -1) {
                        if(thisuser.Identifier === alldata.WhoAmI.Identifier) {
                            studentfound = true;
                            getUserGradeValues(thisuser.Identifier);
                        }
                    }
                    else {
                        getUserGradeValues(thisuser.Identifier);
                    }
                }
                else {
                    alldata.Classlist.ValuesDone++;
                    if(alldata.Classlist.ValuesDone === alldata.Classlist.Objects.length) {

                        alldone.Values = true;
                        //console.log("ad30");
                        checkAllDone();
                    }
                }
            }     
            if(studentroles.indexOf(alldata.CurrentRole) > -1) {
                if(!studentfound) {
                    alldone.Values = true;
                    //console.log("ad31");
                    checkAllDone();                    
                }   
            }
        }
        else {
            alldone.Values = true;
            //console.log("ad32");
            checkAllDone();
        }        
    }
    else {
        alldone.Values = true;
        //console.log("ad33");
        checkAllDone();
    }

}

function getUserGradeValues(userid) {
    var usergradevalurl = "/d2l/api/le/" + alldata.APIVersions.LE.LatestVersion + "/" + orgUnitId + "/grades/values/" + userid + "/";
    $.ajax({
        method: "GET",
        url: usergradevalurl,
        dataType: 'json',
        success: function (usergradeval_tmp) {
            
            //console.log(usergradeval_tmp);
            
            for(var cl=0; cl<alldata.Classlist.Objects.length; cl++) {
                var thisuser = alldata.Classlist.Objects[cl];
                if(thisuser.Identifier === userid) {
                    thisuser.Values = usergradeval_tmp;
                    break;
                }
            }
            
            if(studentroles.indexOf(alldata.CurrentRole) > -1) {
                
                alldata.Classlist.ValuesDone = alldata.Classlist.Objects.length;
                alldone.Values = true;
                
                //console.log("ad34");
                checkAllDone();
            }
            else {
                alldata.Classlist.ValuesDone++;
                if(alldata.Classlist.ValuesDone === alldata.Classlist.Objects.length) {
                    // Classlist Grades Done;
                    alldone.Values = true;
                    //console.log("ad35");
                    checkAllDone();
                }
            }
            
        } //end success
    }) //end ajax
}

