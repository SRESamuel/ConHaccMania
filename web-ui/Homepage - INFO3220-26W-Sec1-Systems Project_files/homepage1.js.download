    }, 200);
    
}

function saveMeetingSetting(isimport) {
    
    var MeetingSaveObj;
    if(alldata.CustomSettings.Meeting !== undefined) {
        MeetingSaveObj = JSON.parse(JSON.stringify(alldata.CustomSettings.Meeting));
    }
    else {
        MeetingSaveObj = JSON.parse(JSON.stringify(meeting_setting_template));
    }
    
    var meetingval = $('.form-check-meeting .form-check-input:checked').val();
    
    MeetingSaveObj.Option = meetingval;
    //console.log(meetingval);
    
    if(meetingval === "meet-customtag") {
        var validtag = false;

        var tagclean = cleanTextInput($("#editmeettag").val());
        $("#editmeettag").val(tagclean);
        
        if(tagclean.length >= 3) {
            validtag = true;
        }
        
        if(validtag) {
            MeetingSaveObj.CalendarTag = tagclean;
            //console.log("save");
        }
        else {
            //console.log("no save");
        }
    }
    else if (meetingval === "meet-manualinfo") {
        var validtitle = false;

        var titletext;
        var titleclean;

        var bodytext;
        var bodyclean;

        titletext = $("#editmeettitle").val();
        titleclean = cleanTextInput(titletext);
        $("#editmeettitle").val(titleclean);

        bodytext = $("#editmeetbody").val();
        bodyclean = cleanTextInput(bodytext);
        $("#editmeetbody").val(bodyclean);

        //console.log(titleclean);
        if(titleclean.length > 3) {
            validtitle = true;
        }

        if(validtitle) {
            MeetingSaveObj.Info = {
                Title: titleclean,
                Body: bodyclean
            }
            //console.log("save");
        }
        else {
            //console.log("no save");
        }
    }
    else {
        //console.log("save");
    }

    //console.log(MeetingSaveObj);
    if(isimport === undefined) {
        alldata.CustomSettings.Meeting = MeetingSaveObj;
        putCustomWidgetData(CustomWidgetH1,"Meeting"); 

        //updateTextbookLink();
        $('#collapseEditText').collapse('hide');    
    }
}

function saveInstructorInfo(instructorid) {
    
    var availhtml = $('#settings-instructor-'+instructorid+' .wysiwyg-instructor').trumbowyg('html');
    
    //var availclean = cleanTextInput(availhtml);
    //console.log(availclean);
    //$('#settings-instructor-'+instructorid+' .wysiwyg-instructor').trumbowyg('html',availclean);
    
    var instructorobj = {
        Identifier: instructorid,
        Availability: availhtml,
        Visibility: {
            Visible: $('#visible-instructor-'+instructorid).prop('checked'),
            Primary: $('#primary-instructor-'+instructorid).prop('checked'),
            Profile: $('#visible-profilepic-'+instructorid).prop('checked')
        }
    }
    
    if(alldata.CustomSettings !== null) {
        if(alldata.CustomSettings.Instructor !== undefined) {
            var datafound = false;
            var primaryreset = instructorobj.Visibility.Primary;
            
            for(var csi=0; csi<alldata.CustomSettings.Instructor.length; csi++) {
                if(alldata.CustomSettings.Instructor[csi].Identifier === instructorid) {
                    alldata.CustomSettings.Instructor[csi].Availability = instructorobj.Availability;
                    alldata.CustomSettings.Instructor[csi].Visibility = {
                        Visible: instructorobj.Visibility.Visible,
                        Primary: instructorobj.Visibility.Primary,
                        Profile: instructorobj.Visibility.Profile
                    }
                    datafound = true;
                }
                else {
                    if(primaryreset) {
                        alldata.CustomSettings.Instructor[csi].Visibility.Primary = false;
                    }
                }
            }
            if(!datafound) {
                alldata.CustomSettings.Instructor.push(instructorobj);
            }
        }
        else {
            alldata.CustomSettings.Instructor = [instructorobj];
        }
    }
    else {
        alldata.CustomSettings = {
            Instructor: [instructorobj]
        }
    }
    
    //console.log(instructorobj);
    //console.log(alldata.CustomSettings);
    putCustomWidgetData(CustomWidgetH1,"Instructors",instructorid);
        
    buildInstructorDisplay();
}

function getRoundedCanvas(sourceCanvas) {
    var canvas = document.createElement('canvas');
    var context = canvas.getContext('2d');
    var width = sourceCanvas.width;
    var height = sourceCanvas.height;

    canvas.width = width;
    canvas.height = height;
    context.imageSmoothingEnabled = true;
    context.drawImage(sourceCanvas, 0, 0, width, height);
    context.globalCompositeOperation = 'destination-in';
    context.beginPath();
    context.arc(width / 2, height / 2, Math.min(width, height) / 2, 0, 2 * Math.PI, true);
    context.fill();
    return canvas;
}

function profileImageEditConfirm() {
    var croppedCanvas;
    var croppedValues;
    var roundedCanvas;
    var roundedImage;

    if (!croppable) {
        return;
    }

    // Crop
    croppedCanvas = cropper.getCroppedCanvas();
    croppedValues = cropper.getData();
    //console.log(cropper.getData());
    var newEntryVal = JSON.parse(JSON.stringify(EntryVal));	
    newEntryVal.Values.push(JSON.stringify(cropper.getData()));
    //console.log(newEntryVal);
    var dObj = {
        "EntryValues":[newEntryVal]
    };
    
    putProfileImageCrop(parseInt(alldata.WhoAmI.Identifier), ProfileCropField, dObj, croppedValues);

    // Round
    roundedCanvas = getRoundedCanvas(croppedCanvas);

    // Show
    roundedImage = document.createElement('img');
    $('.echsprofileimg-'+alldata.WhoAmI.Identifier).attr('src',roundedCanvas.toDataURL());
    
    $('#profileImageEdit').modal('hide');
    
}

function openProfileEditor() {
    
    if(cropper !== undefined) {
        cropper.destroy();
    }
    
    $('#profileImageEdit .modal-body').html('');
    $('#profileImageEdit').modal('show');
}

function initializeInstructorSettings() {
    
    for(var i=0; i<alldata.Instructors.Objects.length; i++) {
        var thisinstructor = alldata.Instructors.Objects[i];
        
        if(thisinstructor.Email !== null) {
            var instructable = '';
            instructable += '<div class="settings-instructor" id="settings-instructor-'+thisinstructor.Identifier+'">';
            instructable += '<div class="row">';
            instructable += '<div class="col-12 col-sm-8">';
            instructable += '<table class="table table-borderless">';
            instructable += '<tbody>';
            instructable += '<tr>'
            instructable += '<th style="width:130px">Name</th>';
            instructable += '<td>'+thisinstructor.FirstName + ' ' + thisinstructor.LastName+'</td>';
            instructable += '</tr>';
            instructable += '<tr>';
            instructable += '<th>Email</th>';
            instructable += '<td>' + thisinstructor.Email + ' </td>';
            instructable += '</tr>';
            instructable += '<tr>';
            instructable += '<th>Availability</th>';
            instructable += '<td><div class="wysiwyg-instructor"></div></td>';
            instructable += '</tr>';
            instructable += '<tr>';
            instructable += '<th>Visibility</th>';
            instructable += '<td>';
            instructable += '<div class="form-check form-check-inline"><input class="form-check-input visible-instructor" type="checkbox" id="visible-instructor-'+thisinstructor.Identifier+'"><label class="form-check-label" for="visible-instructor-'+thisinstructor.Identifier+'">Visible on Homepage</label></div>';
            instructable += '<div class="form-check form-check-inline"><input class="form-check-input primary-instructor" type="checkbox" id="primary-instructor-'+thisinstructor.Identifier+'"><label class="form-check-label" for="primary-instructor-'+thisinstructor.Identifier+'">Primary on Homepage</label></div></td>';
            instructable += '</tr>';
            instructable += '<tr>';
            instructable += '</tr>';
            instructable += '</tbody>';
            instructable += '</table>';
            instructable += '</div>';
            
            var tstamp = new Date().getTime();
            instructable += '<div class="col-12 col-sm-4 text-center">';
            instructable += '<div class="settings-instructor-image">';
            instructable += '<img class="echsprofileimg echsprofileimg-'+thisinstructor.Identifier+'" src="/d2l/common/viewprofileimage.d2l?oi=6606&ui='+thisinstructor.Identifier+'&s=160&t='+tstamp+'" alt="Profile Image for '+thisinstructor.FirstName+' '+thisinstructor.LastName+'">';
            if(thisinstructor.Identifier === alldata.WhoAmI.Identifier) {
                
                instructable += '<button type="button" class="btn btn-dark profile-image-edit" title="Crop Profile Image" onClick="openProfileEditor()"><i class="fas fa-pencil"></i></button> ';
                //instructable += '<a href="/d2l/lp/profile/profile_edit.d2l?ou='+orgUnitId+'" target="_top"><img class="echsprofileimg" src="/d2l/common/viewprofileimage.d2l?oi=6606&ui='+thisinstructor.Identifier+'&s=160&t='+tstamp+'"></a>';
            }
            instructable += '</div>';
            instructable += '<div class="form-check form-check-inline mb-3"><input class="form-check-input visible-profilepic" type="checkbox" id="visible-profilepic-'+thisinstructor.Identifier+'"><label class="form-check-label" for="visible-profilepic-'+thisinstructor.Identifier+'">Display Profile Picture</label></div>';     
            instructable += '</div>';
            
            instructable += '</div>';
            instructable += '<div class="row"><div class="col-12 btn-instructor-save"><p><button class="cc-button ml-2 d-block" onClick="saveInstructorInfo('+thisinstructor.Identifier+')">Save <span class="mobile-hide"> Settings for '+thisinstructor.FirstName + '</span></button></p></div></div>';
            instructable += '<p id="savemsg-instructor-'+thisinstructor.Identifier+'">&nbsp;</p>';
            instructable += '</div>';
            instructable += '<hr>';            
            $('#pills-instructors').append(instructable);
        }
    }
    
    $('.settings-instructor .form-check-input.visible-instructor').prop('checked',true);
    $('.settings-instructor .form-check-input.visible-instructor').on('change',function(){
        var instructorid = $(this).attr('id').split('-')[2];
        if($(this).prop('checked') === false) {
            $('#primary-instructor-'+instructorid).prop('checked',false);
            $('#primary-profilepic-'+instructorid).prop('checked',false);
        }
    });
    $('.settings-instructor .form-check-input.primary-instructor').on('change',function(){
        var instructorid = $(this).attr('id').split('-')[2];
        if($(this).prop('checked') === true) {
            $('.primary-instructor').prop('checked',false);
            $(this).prop('checked',true);
            $('#visible-instructor-'+instructorid).prop('checked',true);
        }
    });    
    
    $('.wysiwyg-instructor').trumbowyg({
        btns: [
            ['viewHTML'],
            ['undo', 'redo'], // Only supported in Blink browsers
            ['formatting'],
            ['strong', 'em', 'del'],
            ['superscript', 'subscript'],
            ['link'],
            ['insertImage'],
            ['justifyLeft', 'justifyCenter', 'justifyRight', 'justifyFull'],
            ['unorderedList', 'orderedList'],
            ['horizontalRule'],
            ['removeformat']
        ],
        semantic: false,
        tagsToRemove: ['script', 'link', 'style'],
        defaultLinkTarget: '_blank'
    });    
    
    if(alldata.CustomSettings !== null) {
        if(alldata.CustomSettings.Instructor !== undefined) {
            for(var csi=0; csi<alldata.CustomSettings.Instructor.length; csi++) {
                for(var i=0; i<alldata.Instructors.Objects.length; i++) {
                    if(alldata.CustomSettings.Instructor[csi].Identifier === parseInt(alldata.Instructors.Objects[i].Identifier)) {
                        if(!alldata.CustomSettings.Instructor[csi].Visibility.Visible) {
                            $('#visible-instructor-'+alldata.CustomSettings.Instructor[csi].Identifier).prop('checked',false);
                        }
                        if(alldata.CustomSettings.Instructor[csi].Visibility.Primary) {
                            $('#primary-instructor-'+alldata.CustomSettings.Instructor[csi].Identifier).prop('checked',true);
                        }
                        if(alldata.CustomSettings.Instructor[csi].Visibility.Profile) {
                            $('#visible-profilepic-'+alldata.CustomSettings.Instructor[csi].Identifier).prop('checked',true);
                        }
                        if(alldata.CustomSettings.Instructor[csi].Availability !== '') {
                            $('#settings-instructor-'+alldata.CustomSettings.Instructor[csi].Identifier+' .wysiwyg-instructor').trumbowyg('html',alldata.CustomSettings.Instructor[csi].Availability);
                        }
                    }
                }
            }
        }
    }
}

function confirmImportSettings(ismanual) {
    //console.log("confirm");
    
    if(alldata.CustomSettings === null) {
        alldata.CustomSettings = {};
    }
    
    if(ismanual === undefined) {
        $('#importset-checkconfirm').prop('disabled',true);
        $('#importset-confirmbtn').prop('disabled', true);

        $('#importset-widgetselect input[type=checkbox]:checked').each(function(){
             if($(this).attr('id') === "importsettextbook") {
                alldata.CustomSettings.Textbook = alldata.CustomImport.CustomSettings.Textbook;
                updateTextbookLink();
             }
             if($(this).attr('id') === "importsetlinklist") {
                alldata.CustomSettings.LinkList = alldata.CustomImport.CustomSettings.LinkList;
                initializeLinkListCustom();
                addLinkEditButtons();             
             }
             if($(this).attr('id') === "importsetinstruct") {
                //console.log(alldata.CustomImport.CustomSettings.Instructor);

                if(alldata.CustomImport.CustomSettings.Instructor !== null) {
                    if(alldata.CustomImport.CustomSettings.Instructor.length > 0) {
                        for(var ci=0; ci<alldata.CustomImport.CustomSettings.Instructor.length; ci++) {
                            var thisinstruct = alldata.CustomImport.CustomSettings.Instructor[ci];
                            if(thisinstruct.Identifier === parseInt(alldata.WhoAmI.Identifier)) {
                                if(alldata.CustomSettings !== null) {
                                    if(alldata.CustomSettings.Instructor !== undefined) {
                                        var instructorfound = false;
                                        for(var idata=0; idata<alldata.CustomSettings.Instructor.length; idata++) {
                                            if(alldata.CustomSettings.Instructor[idata].Identifier === parseInt(alldata.WhoAmI.Identifier)) {
                                                alldata.CustomSettings.Instructor[idata].Availability = thisinstruct.Availability;
                                                instructorfound = true;
                                                break;
                                            }
                                        }
                                        if(!instructorfound) {
                                            alldata.CustomSettings.Instructor.push({
                                                Availability: thisinstruct.Availability,
                                                Identifier: parseInt(alldata.WhoAmI.Identifier),
                                                Visibility: {
                                                    Visible: true,
                                                    Primary: false,
                                                    Profile: false
                                                } 
                                            });
                                        }                                    
                                    }
                                    else {
                                        alldata.CustomSettings.Instructor = [{
                                            Availability: thisinstruct.Availability,
                                            Identifier: parseInt(alldata.WhoAmI.Identifier),
                                            Visibility: {
                                                Visible: true,
                                                Primary: false,
                                                Profile: false
                                            }
                                        }]
                                    }
                                }
                                else {
                                    alldata.CustomSettings = {
                                        Instructor: {
                                            Availability: thisinstruct.Availability,
                                            Identifier: parseInt(alldata.WhoAmI.Identifier),
                                            Visibility: {
                                                Visible: true,
                                                Primary: false,
                                                Profile: false
                                            }
                                        }
                                    }
                                }

                                $('#settings-instructor-'+parseInt(alldata.WhoAmI.Identifier) + ' .wysiwyg-instructor').trumbowyg('html',thisinstruct.Availability);
                                saveInstructorInfo(parseInt(alldata.WhoAmI.Identifier));
                                break;
                            }
                        }
                    }
                }
            }
            if($(this).attr('id') === "importsetmeetings") {
                alldata.CustomSettings.Meeting = alldata.CustomImport.CustomSettings.Meeting;
                if(alldata.CustomSettings.Meeting.CalendarTag !== undefined) {
                    $('#editmeettag').val(alldata.CustomSettings.Meeting.CalendarTag);
                }
                if(alldata.CustomSettings.Meeting.Info !== undefined) {
                    $('#editmeettitle').val(alldata.CustomSettings.Meeting.Info.Title);
                    $('#editmeetbody').val(alldata.CustomSettings.Meeting.Info.Body);
                }
                if(alldata.CustomSettings.Meeting.Option !== undefined) {
                    console.log($('#editmeetform .form-check-input[value='+alldata.CustomSettings.Meeting.Option+']'));
                    $('#editmeetform .form-check-input[value='+alldata.CustomSettings.Meeting.Option+']').prop('checked',true).change();
                }
                saveMeetingSetting(true);
            }

            if($(this).attr('id') === "importsetatrisk") {
                //console.log(alldata.CustomImport.CustomSettings.Dashboard.AtRisk);
                alldata.CustomSettings.Dashboard.AtRisk = alldata.CustomImport.CustomSettings.Dashboard.AtRisk;

                $('#setLastAccessed').val(alldata.CustomSettings.Dashboard.AtRisk.AccessLast);
                $('#setGradeAvg').val(alldata.CustomSettings.Dashboard.AtRisk.GradeAvgNow);
                $('#setGradeMax').val(alldata.CustomSettings.Dashboard.AtRisk.GradeValueMax);
                $('#setContentViewed').val(alldata.CustomSettings.Dashboard.AtRisk.ContentViewed);
                $('#setLateAssess').val(alldata.CustomSettings.Dashboard.AtRisk.LateAssess);
            }
            if($(this).attr('id') === "importsetassess") {
                //console.log(alldata.CustomImport.CustomSettings.Dashboard.Assessment);
                //console.log(alldata.CustomImport.CustomSettings.Dashboard.GradeDates);
                alldata.CustomSettings.Dashboard.Assessment = alldata.CustomImport.CustomSettings.Dashboard.Assessment;
                alldata.CustomSettings.Dashboard.GradeDates = alldata.CustomImport.CustomSettings.Dashboard.GradeDates;

                $('#setGradeValueMin').val(alldata.CustomSettings.Dashboard.Assessment.AverageMin);
                $('#setGradeValueMax').val(alldata.CustomSettings.Dashboard.Assessment.AverageMax);
                $('#setFailRateMax').val(alldata.CustomSettings.Dashboard.Assessment.FailRate);
                $('#setGradeWeightMin').val(alldata.CustomSettings.Dashboard.Assessment.WeightMin);
                $('#setGradeCompleteMin').val(alldata.CustomSettings.Dashboard.Assessment.CompleteMin);
                $('#setGradeDateMax').val(alldata.CustomSettings.Dashboard.GradeDates.DayCountMax);            
            }
        });
    }
    else {
        if(alldata.CustomImport.CustomSettings !== null) {
            if(alldata.CustomImport.CustomSettings.Textbook !== undefined) {
                alldata.CustomSettings.Textbook = alldata.CustomImport.CustomSettings.Textbook;
                updateTextbookLink();            
            }

            if(alldata.CustomImport.CustomSettings.LinkList !== undefined) {
                for(var lli=0; lli<alldata.CustomImport.CustomSettings.LinkList.Items.length; lli++) {
                    var thislink = alldata.CustomImport.CustomSettings.LinkList.Items[lli];
                    if(thislink.URL.indexOf(alldata.ImportOrgId) > -1) {
                        thislink.URL = thislink.URL.replace(alldata.ImportOrgId, orgUnitId);
                    }
                }        
                initializeLinkListCustom();
                addLinkEditButtons();           
                alldata.CustomSettings.LinkList = alldata.CustomImport.CustomSettings.LinkList;
                initializeLinkListCustom();
                addLinkEditButtons();       
            }

            if(alldata.CustomImport.CustomSettings.Instructor !== undefined) {
                if(alldata.CustomImport.CustomSettings.Instructor !== null) {
                    if(alldata.CustomImport.CustomSettings.Instructor.length > 0) {
                        for(var ci=0; ci<alldata.CustomImport.CustomSettings.Instructor.length; ci++) {
                            var thisinstruct = alldata.CustomImport.CustomSettings.Instructor[ci];
                            if(alldata.CustomSettings !== null) {
                                if(alldata.CustomSettings.Instructor !== undefined) {
                                    var instructorfound = false;
                                    for(var idata=0; idata<alldata.CustomSettings.Instructor.length; idata++) {
                                        if(alldata.CustomSettings.Instructor[idata].Identifier === parseInt(alldata.WhoAmI.Identifier)) {
                                            alldata.CustomSettings.Instructor[idata].Availability = thisinstruct.Availability;
                                            instructorfound = true;
                                            break;
                                        }
                                    }
                                    if(!instructorfound) {
                                        alldata.CustomSettings.Instructor.push({
                                            Availability: thisinstruct.Availability,
                                            Identifier: parseInt(alldata.WhoAmI.Identifier),
                                            Visibility: {
                                                Visible: true,
                                                Primary: false,
                                                Profile: false
                                            } 
                                        });
                                    }                                    
                                }
                                else {
                                    alldata.CustomSettings.Instructor = [{
                                        Availability: thisinstruct.Availability,
                                        Identifier: parseInt(alldata.WhoAmI.Identifier),
                                        Visibility: {
                                            Visible: true,
                                            Primary: false,
                                            Profile: false
                                        }
                                    }]
                                }
                            }
                            else {
                                alldata.CustomSettings = {
                                    Instructor: {
                                        Availability: thisinstruct.Availability,
                                        Identifier: parseInt(alldata.WhoAmI.Identifier),
                                        Visibility: {
                                            Visible: true,
                                            Primary: false,
                                            Profile: false
                                        }
                                    }
                                }
                            }
                        }
                    }
                }     
            }
            
            if(alldata.CustomImport.CustomSettings.Meeting !== undefined) {
                alldata.CustomSettings.Meeting = alldata.CustomImport.CustomSettings.Meeting;
                if(alldata.CustomSettings.Meeting.CalendarTag !== undefined) {
                    $('#editmeettag').val(alldata.CustomSettings.Meeting.CalendarTag);
                }
                if(alldata.CustomSettings.Meeting.Info !== undefined) {
                    $('#editmeettitle').val(alldata.CustomSettings.Meeting.Info.Title);
                    $('#editmeetbody').val(alldata.CustomSettings.Meeting.Info.Body);
                }
                if(alldata.CustomSettings.Meeting.Option !== undefined) {
                    console.log($('#editmeetform .form-check-input[value='+alldata.CustomSettings.Meeting.Option+']'));
                    $('#editmeetform .form-check-input[value='+alldata.CustomSettings.Meeting.Option+']').prop('checked',true).change();
                }
                saveMeetingSetting(true);
            }

            if(alldata.CustomSettings.Dashboard !== undefined) {
                alldata.CustomSettings.Dashboard.AtRisk = alldata.CustomImport.CustomSettings.Dashboard.AtRisk;

                $('#setLastAccessed').val(alldata.CustomSettings.Dashboard.AtRisk.AccessLast);
                $('#setGradeAvg').val(alldata.CustomSettings.Dashboard.AtRisk.GradeAvgNow);
                $('#setGradeMax').val(alldata.CustomSettings.Dashboard.AtRisk.GradeValueMax);
                $('#setContentViewed').val(alldata.CustomSettings.Dashboard.AtRisk.ContentViewed);
                $('#setLateAssess').val(alldata.CustomSettings.Dashboard.AtRisk.LateAssess);  

                alldata.CustomSettings.Dashboard.Assessment = alldata.CustomImport.CustomSettings.Dashboard.Assessment;
                alldata.CustomSettings.Dashboard.GradeDates = alldata.CustomImport.CustomSettings.Dashboard.GradeDates;

                $('#setGradeValueMin').val(alldata.CustomSettings.Dashboard.Assessment.AverageMin);
                $('#setGradeValueMax').val(alldata.CustomSettings.Dashboard.Assessment.AverageMax);
                $('#setFailRateMax').val(alldata.CustomSettings.Dashboard.Assessment.FailRate);
                $('#setGradeWeightMin').val(alldata.CustomSettings.Dashboard.Assessment.WeightMin);
                $('#setGradeCompleteMin').val(alldata.CustomSettings.Dashboard.Assessment.CompleteMin);
                $('#setGradeDateMax').val(alldata.CustomSettings.Dashboard.GradeDates.DayCountMax);               
            }
            //console.log(alldata.CustomSettings);
        }
    }
    
    putCustomWidgetData(CustomWidgetH1, "Import");
    
}

function startImportSettings() {
    
    $('#importset-startbtn').attr('disabled','disabled');
    
    $('#importset-confirmmsg').html('<div class="custom-control custom-checkbox"><input type="checkbox" class="custom-control-input" id="importset-checkconfirm"><label class="custom-control-label" for="importset-checkconfirm">By checking this box I acknowledge that once the Settings Import is complete, the action cannot be undone and any previous settings in this course shell that are replaced cannot be recovered.</p></label></div>');
    $('#importset-importcomplete').removeClass('d-none');
    
    $('#importset-checkconfirm').on('change', function() {
        //console.log($('#importset-checkconfirm'));
        if($('#importset-checkconfirm').prop('checked') === true) {
            $('#importset-confirmbtn').removeAttr('disabled');
        }
        else {
            $('#importset-confirmbtn').attr('disabled','disabled');
        }
    });
    
}

function validateImportSelect() {
    
    //console.log(alldata.ImportOrgId);
    
    $('#importset-widgetselect input[type=checkbox]').attr('disabled','disabled');
    $('#importset-validbtn').attr('disabled','disabled');
    
    $('#importset-widgetselect input[type=checkbox]:checked').each(function(){
         if($(this).attr('id') === "importsetassess") {
             //console.log(alldata.CustomImport.CustomSettings.Dashboard.Assessment);
             //console.log(alldata.CustomImport.CustomSettings.Dashboard.GradeDates);
         }
         if($(this).attr('id') === "importsetatrisk") {
             //console.log(alldata.CustomImport.CustomSettings.Dashboard.AtRisk);
         }
         if($(this).attr('id') === "importsetlinklist") {             
             for(var lli=0; lli<alldata.CustomImport.CustomSettings.LinkList.Items.length; lli++) {
                 var thislink = alldata.CustomImport.CustomSettings.LinkList.Items[lli];
                 if(thislink.URL.indexOf(alldata.ImportOrgId) > -1) {
                     thislink.URL = thislink.URL.replace(alldata.ImportOrgId, orgUnitId);
                 }
             }
             //console.log(alldata.CustomImport.CustomSettings.LinkList);             
             //console.log(alldata.CustomImport.CustomSettings.Textbook);
         }
         if($(this).attr('id') === "importsetinstruct") {
             //console.log(alldata.CustomImport.CustomSettings.Instructor);
         }
    });
    
    $('#importset-messagevalid').append('<p>Check complete. No issues found.</p>');
    
    $('#importset-startbtn').removeAttr('disabled');
    $('#importset-importstart').removeClass('d-none');
    
}

function processCustomSettingsImport(importorgid, ismanual) {
    
    alldata.ImportOrgId = importorgid;
    //console.log(alldata.CustomImport);
    
    var setassess = false;
    var setatrisk = false;
    var setgrades = false;
    var setlinklist = false;
    var settextbook = false;
    var setinstruct = false;
    var setmeetings = false;
    
    if(alldata.CustomImport.CustomSettings !== null) {
        if(alldata.CustomImport.CustomSettings.Dashboard !== undefined) {
            if(alldata.CustomImport.CustomSettings.Dashboard !== null) {
                if(alldata.CustomImport.CustomSettings.Dashboard.Assessment !== undefined) {
                    setassess = true;
                }
                if(alldata.CustomImport.CustomSettings.Dashboard.AtRisk !== undefined) {
                    setatrisk = true;
                }
                if(alldata.CustomImport.CustomSettings.Dashboard.GradeDates !== undefined) {
                    setgrades = true;
                }
            }
        }
        if(alldata.CustomImport.CustomSettings.LinkList !== undefined) {
            if(alldata.CustomImport.CustomSettings.LinkList !== null) {
                if(alldata.CustomImport.CustomSettings.LinkList.Items !== undefined) {
                    if(alldata.CustomImport.CustomSettings.LinkList.Items.length > 0) {
                        setlinklist = true;   
                    }
                }
            }
        }
        if(alldata.CustomImport.CustomSettings.Textbook !== undefined) {
            if(alldata.CustomImport.CustomSettings.Textbook !== null) {
                settextbook = true;
            }
        }
        if(alldata.CustomImport.CustomSettings.Instructor !== undefined) {
            if(alldata.CustomImport.CustomSettings.Instructor !== null) {
                if(alldata.CustomImport.CustomSettings.Instructor.length > 0) { 
                    for(var ci=0; ci<alldata.CustomImport.CustomSettings.Instructor.length; ci++) {
                        var thisinstruct = alldata.CustomImport.CustomSettings.Instructor[ci];
                        if(thisinstruct.Identifier === parseInt(alldata.WhoAmI.Identifier)) {
                            setinstruct = true;
                        }
                    }
                }
            }
        }
        if(alldata.CustomImport.CustomSettings.Meeting !== undefined) {
            if(alldata.CustomImport.CustomSettings.Meeting !== null) {
                setmeetings = true;
            }
        }
    }
    
    if(ismanual) {
        var importchecks = '';
        importchecks += '<div class="mb-3">';
        importchecks += '<div class="form-check">';
        if(settextbook) {
            importchecks += '<input class="form-check-input" type="checkbox" value="" id="importsettextbook">';
        }
        else {
            importchecks += '<input class="form-check-input" type="checkbox" value="" id="importsettextbook" disabled>';
        }
        importchecks += '<label class="form-check-label" for="importsettextbook">'
        importchecks += 'Textbook Link Override</label>';
        importchecks += '</div>';

        importchecks += '<div class="form-check">';
        if(setlinklist) {
            importchecks += '<input class="form-check-input" type="checkbox" value="" id="importsetlinklist">';
        }
        else {
            importchecks += '<input class="form-check-input" type="checkbox" value="" id="importsetlinklist" disabled>';
        }
        importchecks += '<label class="form-check-label" for="importsetlinklist">'
        importchecks += 'Custom Course Links</label>';
        importchecks += '</div>';

        importchecks += '<div class="form-check">';
        if(setinstruct) {
            importchecks += '<input class="form-check-input" type="checkbox" value="" id="importsetinstruct">';
        }
        else {
            importchecks += '<input class="form-check-input" type="checkbox" value="" id="importsetinstruct" disabled>';
        }
        importchecks += '<label class="form-check-label" for="importsetinstruct">'
        importchecks += 'Instructor Availability</label>';
        importchecks += '</div>';

        importchecks += '<div class="form-check">';
        if(setmeetings) {
            importchecks += '<input class="form-check-input" type="checkbox" value="" id="importsetmeetings">';
        }
        else {
            importchecks += '<input class="form-check-input" type="checkbox" value="" id="importsetmeetings" disabled>';
        }
        importchecks += '<label class="form-check-label" for="importsetmeetings">'
        importchecks += 'Meetings Presentation</label>';
        importchecks += '</div>';

        importchecks += '<div class="form-check">';
        if(setatrisk) {
            importchecks += '<input class="form-check-input" type="checkbox" value="" id="importsetatrisk">';
        }
        else {
            importchecks += '<input class="form-check-input" type="checkbox" value="" id="importsetatrisk" disabled>';
        }
        importchecks += '<label class="form-check-label" for="importsetatrisk">'
        importchecks += 'At-Risk Students Criteria</label>';
        importchecks += '</div>';    

        importchecks += '<div class="form-check">';
        if(setassess || setgrades) {
            importchecks += '<input class="form-check-input" type="checkbox" value="" id="importsetassess">';
        }
        else {
            importchecks += '<input class="form-check-input" type="checkbox" value="" id="importsetassess" disabled>';
        }
        importchecks += '<label class="form-check-label" for="importsetassess">'
        importchecks += 'Assessment Analysis Criteria</label>';
        importchecks += '</div>';
        importchecks += '</div>';
        $('#importset-widgetselect').append(importchecks);

        $('#importset-widgetselect input[type=checkbox]').on('change',function(){
            var setchecks = $('#importset-widgetselect input[type=checkbox]:checked');
            if(setchecks.length > 0) {
                $('#importset-validbtn').removeAttr('disabled');
            }
            else {
                $('#importset-validbtn').attr('disabled','disabled');
            }
        });    

        if(alldata.CustomImport.CustomSettings === null) {
            $('#importset-widgetselect').append('<p>There were no Custom Homepage Settings found within the selected course.</p>');
        }
    }
    else {
        confirmImportSettings(ismanual);
    }
}

function populateImportList() {
    
    if(alldata.CustomImport.Enrolls.Items.length > 0) {
        for(var cs=0; cs<alldata.CustomImport.Enrolls.Items.length; cs++) {            
            if(alldata.CustomImport.Enrolls.Items[cs].OrgUnit.Id !== parseInt(orgUnitId)) {
                $('#course-select-import').append('<option value="' + alldata.CustomImport.Enrolls.Items[cs].OrgUnit.Id + '">' + alldata.CustomImport.Enrolls.Items[cs].OrgUnit.Name + '</option>');
            }            
        } 

        $('#course-select-import').selectpicker();

        $('#course-select-import').on('change', function () {
            $('#course-select-import').prop('disabled', true);
            $('#course-select-import').selectpicker('refresh');
            var inputorgid = $('#course-select-import').val();
            //console.log(inputorgid);
            getCustomWidgetData(CustomWidgetH1, true, inputorgid);
            
            $('#importset-widgetdata').removeClass('d-none');
            $('#importset-importvalid').removeClass('d-none');
        });
        
        $('#importset-select').removeClass('d-none');
    }
}

function checkImportEnrollsDone() {
    var allchecked = true;
    for(var ri=0; ri<alldata.CustomImport.RolesNeeded.length; ri++) {
        if(alldata.CustomImport.RolesChecked.indexOf(alldata.CustomImport.RolesNeeded[ri]) === -1) {
            allchecked = false;
            getUserEnroll('import',alldata.CustomImport.RolesNeeded[ri]);
            break;
        }
    }
    
    if(allchecked) {
        //console.log(alldata.CustomImport);
        alldata.CustomImport.Enrolls.Items.reverse();
        populateImportList();
    }
}

function getImportEnroll() {

    if(adminroles.indexOf(alldata.CurrentRole) > -1) {
        
        alldata.CustomImport = {};
        
        $('#button-admin-load-import').on('click',function(){
            
            $('#admin-load-import input').prop('disabled', true);
            $('#button-admin-load-import').prop('disabled', true);
            
            var inputorgid = $('#admin-load-import input').val();
            //console.log(inputorgid);
            
            getCustomWidgetData(CustomWidgetH1, true, inputorgid);
            
            $('#importset-widgetdata').removeClass('d-none');
            $('#importset-importvalid').removeClass('d-none');            
            
        });
        $('#admin-load-import').removeClass('d-none');
    }
    else {
        alldata.CustomImport = {
            RolesNeeded: [102,114,135],
            RolesChecked: [],
            Enrolls: {
                Items: []
            }
        }

        checkImportEnrollsDone();        
    }
    
    $('#importset-coursescan').text("Start Again");
    $('#importset-coursescan').attr('onClick',"initializeImportSettings()");

}

function initializeImportSettings() {    
    
    $('#pills-importset').html('');
    
    var importsethtml = '';
    
    importsethtml += '<p>This process allows you to copy your homepage settings from another course into this one. You will be able to select from any of the following if they are present: </p>';
    importsethtml += '<ul>';
    importsethtml += '<li>Textbook Link Override</li>';
    importsethtml += '<li>Custom Course Links</li>';
    importsethtml += '<li>Instructor Availability</li>';
    importsethtml += '<li>Meetings Presentation</li>';
    importsethtml += '<li>At-Risk Student Criteria</li>';
    importsethtml += '<li>Assessment Analysis Criteria</li>';
    importsethtml += '</ul>'
    
    importsethtml += '<button class="cc-button btn-alert btn-alt d-block ml-auto mr-auto mb-3" id="importset-coursescan" onClick="getImportEnroll()">Get Started</button><hr>';
    importsethtml += '<div class="d-none" id="importset-select"><div><strong>Step 1: Select Course</strong></div><select id="course-select-import" data-live-search="true" data-size="10" data-width="100%" title="Your Courses"></select><hr></div>';
    importsethtml += '<div class="mt-3 mb-3 d-none" id="admin-load-import"><div><strong>Step 1: Select Course</strong></div><div class="input-group"><input type="number" class="form-control" placeholder="Org Unit ID" aria-label="Org Unit ID" aria-describedby="button-admin-load-import"><button class="btn btn-outline-secondary" type="button" id="button-admin-load-import">Check</button></div><hr></div>';
    importsethtml += '<div class="d-none" id="importset-widgetdata"><div><strong>Step 2: Select Settings to Import</strong></div><div id="importset-widgetselect"></div><hr></div>';
    importsethtml += '<div class="d-none" id="importset-importvalid"><button class="cc-button btn-alert btn-alt" id="importset-validbtn" onClick="validateImportSelect()" disabled>Step 3: Check for Issues</button><div id="importset-widgetvalid"></div><div id="importset-messagevalid"></div><hr></div>';
    importsethtml += '<div class="d-none" id="importset-importstart"><button class="cc-button btn-alert btn-alt" id="importset-startbtn" onClick="startImportSettings()" disabled>Step 4: Start Import Settings</button><div id="importset-confirmmsg"></div><hr></div>';
    importsethtml += '<div class="d-none" id="importset-importcomplete"><button class="cc-button btn-alert btn-alt" id="importset-confirmbtn" onClick="confirmImportSettings()" disabled>Step 5: Complete Import Settings</button><div id="importset-completemsg"></div><hr></div>';
    
    $('#pills-importset').append(importsethtml);
}

function initializeDashboardSettings() {
    
    var allowdashboardsetting = false;
    if(alldata.GradeCategories !== undefined) {
        if(alldata.GradeCategories.length > 0) {
            allowdashboardsetting = true;
        }
    }
    
    //console.log(alldata.GradeCategories);
    //console.log(allowdashboardsetting);
    if(allowdashboardsetting) {
        var dashsettinghtml = ''
        dashsettinghtml += '<p><strong>Student Grade Display</strong></p>';
        dashsettinghtml += '<p>Because this course is configured with Grade Categories, you have the option to prevent students from seeing their Current Average Grade.</p>';
        dashsettinghtml += '<div class="form-check form-check-inline mb-3"><input class="form-check-input visible-studentaverage" type="checkbox" id="visible-studentaverage"><label class="form-check-label" for="visible-studentaverage">Allow Students to see Current Average Grade</label></div>';
        dashsettinghtml += '<p><button id="editcurrentaverage" class="cc-button" onclick="saveDashboardSetting()">Save Dashboard Settings</button></p>';
        dashsettinghtml += '<p id="savemsg-dashboard-setting">&nbsp;</p>';
        
        $('#pills-dashboard').append(dashsettinghtml);
        
        var allowdashon = true;
        if(alldata.CustomSettings !== undefined) {
            if(alldata.CustomSettings.Dashboard !== undefined) {
                if(alldata.CustomSettings.Dashboard.Display !== undefined) {
                    if(alldata.CustomSettings.Dashboard.Display.CurrentAverage !== undefined) {
                        if(alldata.CustomSettings.Dashboard.Display.CurrentAverage === false) {
                            allowdashon = false;
                        }
                    }
                }
            }
        }
        
        if(allowdashon) {
            $('#visible-studentaverage').prop('checked',true);
        }
        
        $('#pills-dashboard-tab').removeClass('d-none');
        
    }
    
}

