function getAPIVersionInfo() {
    var versionsurl = "/d2l/api/(productCode)/versions/";
    var versionsurl_le = versionsurl.replace("(productCode)","le");
    $.ajax({
        method: "GET",
        url: versionsurl_le,
        dataType: 'json',
        success: function (version_le_tmp) {
            alldata.APIVersions.LE = version_le_tmp;
            checkVersionsDone();
        } //end success
    }) //end ajax

    var versionsurl_lp = versionsurl.replace("(productCode)","lp");
    $.ajax({
        method: "GET",
        url: versionsurl_lp,
        dataType: 'json',
        success: function (version_lp_tmp) {
            alldata.APIVersions.LP = version_lp_tmp;
            checkVersionsDone();
        } //end success
    }) //end ajax
}

var versionsdone = false;
function checkVersionsDone() {
    if((alldata.APIVersions.LE !== undefined) && (alldata.APIVersions.LP !== undefined)) {
        versionsdone = true;
        
        getCustomWidgetData(CustomWidgetH1);
        getCustomWidgetData(CustomWidgetMS);
        getCustomWidgetData(CustomWidgetEE);
        getCustomWidgetData(CustomWidgetAN);
        
    }
}

function fixCustomWidgetData(dobj) {
    
    if(dobj !== null) {
        if(dobj.Dashboard !== undefined) {
            if(dobj.Dashboard !== null) {
                if(dobj.Dashboard.Assessment !== undefined) {
                    if(dobj.Dashboard.Assessment.WeightMin === undefined) {
                        dobj.Dashboard.Assessment.WeightMin = JSON.parse(JSON.stringify(dashboard_data_template.Assessment.WeightMin)); 
                    }
                    if(dobj.Dashboard.Assessment.CompleteMin === undefined) {
                        dobj.Dashboard.Assessment.CompleteMin = JSON.parse(JSON.stringify(dashboard_data_template.Assessment.CompleteMin)); 
                    }
                    if(dobj.Dashboard.Assessment.AverageMin === undefined) {
                        dobj.Dashboard.Assessment.AverageMin = JSON.parse(JSON.stringify(dashboard_data_template.Assessment.AverageMin)); 
                    }
                    if(dobj.Dashboard.Assessment.AverageMax === undefined) {
                        dobj.Dashboard.Assessment.AverageMax = JSON.parse(JSON.stringify(dashboard_data_template.Assessment.AverageMax)); 
                    }
                    if(dobj.Dashboard.Assessment.FailRate === undefined) {
                        dobj.Dashboard.Assessment.FailRate = JSON.parse(JSON.stringify(dashboard_data_template.Assessment.FailRate)); 
                    } 
                }
                else {
                    dobj.Dashboard.Assessment = JSON.parse(JSON.stringify(dashboard_data_template.Assessment));
                }

                if(dobj.Dashboard.AtRisk !== undefined) {
                    if(dobj.Dashboard.AtRisk.AccessLast === undefined) {
                        dobj.Dashboard.AtRisk.AccessLast = JSON.parse(JSON.stringify(dashboard_data_template.AtRisk.AccessLast)); 
                    }
                    if(dobj.Dashboard.AtRisk.ContentViewed === undefined) {
                        dobj.Dashboard.AtRisk.ContentViewed = JSON.parse(JSON.stringify(dashboard_data_template.AtRisk.ContentViewed)); 
                    }
                    if(dobj.Dashboard.AtRisk.GradeValueMax === undefined) {
                        dobj.Dashboard.AtRisk.GradeValueMax = JSON.parse(JSON.stringify(dashboard_data_template.AtRisk.GradeValueMax)); 
                    }
                    if(dobj.Dashboard.AtRisk.GradeAvgNow === undefined) {
                        dobj.Dashboard.AtRisk.GradeAvgNow = JSON.parse(JSON.stringify(dashboard_data_template.AtRisk.GradeAvgNow)); 
                    }
                    if(dobj.Dashboard.AtRisk.LateAssess === undefined) {
                        dobj.Dashboard.AtRisk.LateAssess = JSON.parse(JSON.stringify(dashboard_data_template.AtRisk.LateAssess)); 
                    } 
                }
                else {
                    dobj.Dashboard.AtRisk = JSON.parse(JSON.stringify(dashboard_data_template.AtRisk));
                }

                if(dobj.Dashboard.GradeDates !== undefined) {
                    if(dobj.Dashboard.GradeDates.DayCountMax === undefined) {
                        dobj.Dashboard.GradeDates.DayCountMax = JSON.parse(JSON.stringify(dashboard_data_template.GradeDates.DayCountMax)); 
                    }
                    if(dobj.Dashboard.GradeDates.CompleteMax === undefined) {
                        dobj.Dashboard.GradeDates.CompleteMax = JSON.parse(JSON.stringify(dashboard_data_template.GradeDates.CompleteMax)); 
                    }
                }
                else {
                    dobj.Dashboard.GradeDates = JSON.parse(JSON.stringify(dashboard_data_template.GradeDates));
                }            
            }
        }
        if(dobj.Delivery !== undefined) {
            if(dobj.Delivery !== null) {
                if(dobj.Delivery.Standard === undefined) {
                    dobj.Delivery = JSON.parse(JSON.stringify(EEScanTemplate.Delivery));
                }
            }
        }
    }
}

function getCustomWidgetData(cwidgid, ismanual, importorgid) {
    var cwidgurl;
    if(importorgid !== undefined) {
        cwidgurl = "/d2l/api/lp/" + alldata.APIVersions.LP.LatestVersion + "/" + importorgid + "/widgetdata/" + cwidgid;
    }
    else {
        cwidgurl = "/d2l/api/lp/" + alldata.APIVersions.LP.LatestVersion + "/" + orgUnitId + "/widgetdata/" + cwidgid;
    }
    
    $.ajax({
        method: "GET",
        url: cwidgurl,
        dataType: 'json',
        success: function (cwidget_tmp) {
            if(importorgid !== undefined) {
                if(cwidgid === CustomWidgetH1) {
                    alldata.CustomImport.CustomSettings = JSON.parse(cwidget_tmp.Data);
                    processCustomSettingsImport(importorgid, ismanual);                    
                }
                else if(cwidgid === CustomWidgetUC) {
                    for(var m=0; m<alldata.Readiness.Result[0].MatchingModels.length; m++) {
                        var thismodel = alldata.Readiness.Result[0].MatchingModels[m];
                        if(thismodel.OrgUnitId === importorgid) {
                            thismodel.ReadyDate = JSON.parse(cwidget_tmp.Data);
                        }
                    }
                    alldata.Readiness.Result[0].EmptyCheck.ReadyDates++;
                    processModelMatchesEmpty();
                }
            }
            else {
                if(cwidgid === CustomWidgetH1) {
                    alldata.CustomSettings = JSON.parse(cwidget_tmp.Data);
                    if(alldata.CustomSettings.Dashboard === undefined) {
                        getCustomWidgetData(CustomWidgetPS);
                    }
                    else {                    
                        fixCustomWidgetData(alldata.CustomSettings);          
                        alldone.WidgetData1 = true;
                        checkCustomWidgetDataDone();
                    }  
                }
                else if(cwidgid === CustomWidgetPS) {
                    //console.log(cwidget_tmp);
                    if(alldata.CustomSettings !== null) {
                        alldata.CustomSettings.Dashboard = JSON.parse(cwidget_tmp.Data);
                    }
                    else {
                        alldata.CustomSettings = {
                            Dashboard: JSON.parse(cwidget_tmp.Data)
                        }
                    }
                    fixCustomWidgetData(alldata.CustomSettings);   
                    alldone.WidgetData1 = true;
                    checkCustomWidgetDataDone();
                }
                else if(cwidgid === CustomWidgetMS) {
                    alldata.MSTeams = JSON.parse(cwidget_tmp.Data);
                    alldone.WidgetData2 = true;
                    checkCustomWidgetDataDone();
                }
                else if(cwidgid === CustomWidgetEE) {
                    alldata.EEScanner = JSON.parse(cwidget_tmp.Data);
                    fixCustomWidgetData(alldata.EEScanner);
                    alldone.WidgetData3 = true;
                    checkCustomWidgetDataDone();
                }
                else if(cwidgid === CustomWidgetCL) {
                    alldata.CourseLaunch = JSON.parse(cwidget_tmp.Data);
                    //console.log("cldone");
                    
                    if(ismanual) {
                        courseLaunchLoad();
                    }
                    else {
                        if(!courselaunch) {
                            if(alldata.CourseLaunch.StartDate === undefined) {
                                if (alldata.CourseLaunch.Status !== undefined) {
                                    if (alldata.CourseLaunch.Status.Complete === false) {
                                        if (alldata.CourseLaunch.Status.Started === true) {
                                            $('#courseLaunchStartDate').modal('show');
                                        }                                        
                                    }
                                }
                            }                                
                        }
                        else {
                            guidedCopyLoad();
                        }
                    }
                }
                else if(cwidgid === CustomWidgetGC) {
                    alldata.GuidedCopy = JSON.parse(cwidget_tmp.Data);
                    //console.log("gcdone");
                    if(!ismanual) {                        
                        guidedCopyLoad();                        
                    }
                    else {                        
                        if(guidedcopy) {
                            //console.log("Copy already appears to be in progress");
                            eCPlusCheckCopyStatus();
                            exitGuidedCopyProcess();
                        }
                        else {
                            if(alldata.GuidedCopy !== null) {
                                alldata.GuidedCopy.Datasets = {}
                                eCPlusDatasetsAssign(alldata.GuidedCopy.Model);
                                eCPlusDatasetsIA(alldata.GuidedCopy.Model);
                            }
                            else {
                                checkCourseIntelligentAgents();
                            }
                        }
                    }
                }
                else if(cwidgid === CustomWidgetMC) {
                    alldata.MessageConfirm = JSON.parse(cwidget_tmp.Data);
                    //console.log("mcdone");
                    guidedCopyLoad();                
                }
                else if(cwidgid === CustomWidgetUC) {
                    alldata.UnderConstruction = JSON.parse(cwidget_tmp.Data);
                    underConstructionLoad()
                }
                else if(cwidgid === CustomWidgetAN) {
                    alldata.AdminNotes = JSON.parse(cwidget_tmp.Data);
                    alldone.WidgetData4 = true;
                    checkCustomWidgetDataDone();                    
                }
            }             
        }, //end success
        error: function (xhr, ajaxOptions, thrownError) {
            if(importorgid !== undefined) {
                if(cwidgid === CustomWidgetH1) {
                    alldata.CustomImport.CustomSettings = null;
                    processCustomSettingsImport(importorgid, ismanual);
                }
                else {
                    for(var m=0; m<alldata.Readiness.Result[0].MatchingModels.length; m++) {
                        var thismodel = alldata.Readiness.Result[0].MatchingModels[m];
                        if(thismodel.OrgUnitId === importorgid) {
                            thismodel.ReadyDate = null;
                        }
                    }
                    alldata.Readiness.Result[0].EmptyCheck.ReadyDates++;
                    processModelMatchesEmpty();
                }
            }
            else {
                if(cwidgid === CustomWidgetH1) {
                    alldata.CustomSettings = null;
                    getCustomWidgetData(CustomWidgetPS);
                }
                else if(cwidgid === CustomWidgetPS) {
                    if(alldata.CustomSettings !== null) {
                        alldata.CustomSettings.Dashboard = JSON.parse(JSON.stringify(dashboard_data_template));
                    }
                    else {
                        alldata.CustomSettings = {
                            Dashboard:JSON.parse(JSON.stringify(dashboard_data_template))
                        }
                    }
                    fixCustomWidgetData(alldata.CustomSettings);
                    alldone.WidgetData1 = true;                
                    checkCustomWidgetDataDone();

                }
                else if(cwidgid === CustomWidgetMS) {
                    alldata.MSTeams = null;
                    alldone.WidgetData2 = true;
                    checkCustomWidgetDataDone();
                }
                else if(cwidgid === CustomWidgetEE) {
                    alldata.EEScanner = null;
                    alldone.WidgetData3 = true;
                    checkCustomWidgetDataDone();
                }
                else if(cwidgid === CustomWidgetCL) {
                    alldata.CourseLaunch = null;
                    if(ismanual) {
                        courseLaunchLoad();
                    }
                    else {
                        if(!courselaunch) {
                            //do nothing, checklist was not started.
                        }
                        else {
                            guidedCopyLoad();                            
                        }                        
                    }
                }
                else if(cwidgid === CustomWidgetGC) {
                    alldata.GuidedCopy = null;
                    if(!ismanual) {
                        guidedCopyLoad(); 
                    }
                    else {
                        if(guidedcopy) {
                            addModelCopyToQueueConfirmed();
                        }
                        else {
                            checkCourseIntelligentAgents();
                        }
                    }
                }
                else if(cwidgid === CustomWidgetMC) {
                    alldata.MessageConfirm = null;
                    guidedCopyLoad();
                }
                else if(cwidgid === CustomWidgetUC) {
                    alldata.UnderConstruction = null;
                    underConstructionLoad();
                }
                else if(cwidgid === CustomWidgetAN) {
                    alldata.AdminNotes = null;
                    alldone.WidgetData4 = true;
                    checkCustomWidgetDataDone();                    
                }
            }

        }
    }) //end ajax
}

function checkCustomWidgetDataDone() {
    if(alldone.WidgetData1 && alldone.WidgetData2 && alldone.WidgetData3 && alldone.WidgetData4) {
        
        if(alldata.CustomSettings !== null) {
            if(alldata.CustomSettings.Textbook !== undefined) {
                if(alldata.CustomSettings.Textbook.Option === "text-displaynone") {
                    $('.link-textbookinfo a').removeAttr('href');
                    $('.link-textbookinfo a').addClass('disabled');   
                    $('.link-textbookinfo .link-ico').addClass('disabled');               

                    $('.instructor-content .links-container-display .link-textbookinfo').addClass('d-none');
                    $('.student-content .links-container .link-textbookinfo').addClass('d-none');
                }
            }
        }
        
        getWhoAmI();  
        
    }
}

function deleteCustomWidgetData(cwidgid) {
    var token;
    $.ajax({
        method: "GET",
        url: "/d2l/lp/auth/xsrf-tokens",
        success: function(ltoken) {
            token = ltoken;
            //console.log(token);
            
            var cwidgurl = "/d2l/api/lp/" + alldata.APIVersions.LP.LatestVersion + "/" + orgUnitId + "/widgetdata/" + cwidgid;
            //console.log(cwidgurl);
            
            $.ajax({
                beforeSend: function(request) {
                    request.setRequestHeader("X-Csrf-Token", token.referrerToken);
                },
                url: cwidgurl,
                type: 'DELETE',
                success: function (data, textStatus, xhr) {
                    //console.log(data);
                    
                    if(cwidgid === CustomWidgetUC) {
                        underConstructionLoad();
                    }
                    else if(cwidgid === CustomWidgetAN) {
                        $('#btn-adminnotes').addClass('btn-primary');
                        $('#btn-adminnotes').removeClass('btn-success');
                        $('#notesModal').modal('hide'); 
                    }
                },
                error: function (xhr, textStatus, errorThrown) {
                    console.log(xhr);
                    console.log(textStatus);
                    console.log(errorThrown);
                }
            });      
            
        }
    });
}

function putCustomWidgetData(cwidgid, type, id) {
    var token;
    $.ajax({
        method: "GET",
        url: "/d2l/lp/auth/xsrf-tokens",
        success: function(ltoken) {
            token = ltoken;
            //console.log(token);
            
            var cwidgurl = "/d2l/api/lp/" + alldata.APIVersions.LP.LatestVersion + "/" + orgUnitId + "/widgetdata/" + cwidgid;
            var cwidgput;
            
            if((cwidgid === CustomWidgetH1) || (cwidgid === CustomWidgetPS)) {
                cwidgput = {
                    Data: JSON.stringify(alldata.CustomSettings)
                }
            }
            else if((cwidgid === CustomWidgetMS)) {
                cwidgput = {
                    Data: JSON.stringify(alldata.MSTeams)
                }
            }
            else if((cwidgid === CustomWidgetEE)) {
                cwidgput = {
                    Data: JSON.stringify(alldata.EEScanner)
                }
            }
            else if((cwidgid === CustomWidgetCL)) {
                cwidgput = {
                    Data: JSON.stringify(alldata.CourseLaunch)
                }
            }
            else if((cwidgid === CustomWidgetGC)) {
                cwidgput = {
                    Data: JSON.stringify(alldata.GuidedCopy)
                }
            }
            else if((cwidgid === CustomWidgetMC)) {
                cwidgput = {
                    Data: JSON.stringify(alldata.MessageConfirm)
                }
            }
            else if((cwidgid === CustomWidgetUC)) {
                cwidgput = {
                    Data: JSON.stringify(alldata.UnderConstruction)
                }
            }
            else if((cwidgid === CustomWidgetAN)) {
                cwidgput = {
                    Data: JSON.stringify(alldata.AdminNotes)
                }        
            }

            //console.log(cwidgurl);
            //console.log(cwidgput);
            
            $.ajax({
                beforeSend: function(request) {
                    request.setRequestHeader("X-Csrf-Token", token.referrerToken);
                },
                url: cwidgurl,
                type: 'PUT',
                dataType: 'json',
                data: JSON.stringify(cwidgput),
                success: function (data, textStatus, xhr) {
                    //console.log(data);
                    if(type !== undefined) {
                        if(type === "Instructors") {                            
                            $('#savemsg-instructor-'+id).html("Settings Saved Successfully");
                            setTimeout(function(){
                                $('#savemsg-instructor-'+id).html("&nbsp;");
                            },4000);
                        }
                        else if(type === "AtRisk") {
                            $('#savemsg-progress-atrisk').html("Settings Saved Successfully");
                            setTimeout(function(){
                                $('#savemsg-progress-atrisk').html("&nbsp;");
                            },4000);
                        }
                        else if(type === "Assess") {
                            $('#savemsg-progress-assess').html("Settings Saved Successfully");
                            setTimeout(function(){
                                $('#savemsg-progress-assess').html("&nbsp;");
                            },4000);
                        }
                        else if(type === "Textbook") {
                            $('#savemsg-textbook-custom').html("Settings Saved Successfully");
                            setTimeout(function(){
                                $('#savemsg-textbook-custom').html("&nbsp;");
                            },4000);
                        }
                        else if(type === "Meeting") {                            
                            updateMeetingDisplay();
                            updateMeetingPreview();
                            $('#savemsg-meeting-custom').html("Settings Saved Successfully");
                            setTimeout(function(){
                                $('#savemsg-meeting-custom').html("&nbsp;");
                            },4000);
                        }
                        else if(type === "CurrentAverage") {
                            $('#savemsg-dashboard-setting').html("Settings Saved Successfully");
                            setTimeout(function(){
                                $('#savemsg-dashboard-setting').html("&nbsp;");
                            },4000);
                        }
                        else if(type === "Import") {
                            var importsethtml = '<div id="importset-success"><p>The settings have been imported successfully.</p><hr></div>';
                            $('#pills-importset').append(importsethtml);
                        }
                        else if(type === "ChecklistDone") {
                            toggleDashboardDisplay();              
                            
                            $('.course-readiness-block').addClass('d-none');

                            $('.essential-elements-block').removeClass('d-none');
                            $('.course-checklist-callout-container').removeClass('d-none');
                            $('.instructor-content .links-container-display').removeClass('d-none');
                            $('.instructor-content .updates-container').removeClass('d-none');
                            
                            $('#launchChecklistComplete').modal('hide');
                            
                        } 
                        else if(type === "GuidedCopyQueued") {
                        }
                        else if(type === "GuidedCopyDone") {
                            if(courselaunch) {
                                var url = window.location.href;
                                var checklisturl = url + '?tab=Checklist';
                                window.location.href = checklisturl;                                
                            }
                            else {
                                var url = window.location.href;
                                window.location.href = url;
                            }
                        }
                        else if(type === "UnderConstructionSet") {
                            $('.under-construction-notice-user').text(alldata.UnderConstruction.User.FirstName + ' ' + alldata.UnderConstruction.User.LastName);
                            var getdate = new Date(alldata.UnderConstruction.ReadyDate).toLocaleDateString('en-us', { weekday:"long", year:"numeric", month:"long", day:"numeric"});
                            //console.log(getdate);
                            $('.under-construction-notice-date span').text(getdate);
                            
                            underConstructionLoad();
                            $('#modelUnderConstruction').modal('hide');
                        }
                        else if(type === "CourseLaunchStart") {
                            $('#courseLaunchStartDate').modal('hide');
                        }
                        else if(type === "AdminNotes") {
                            $('#notesModal').modal('hide'); 
                        }
                    }
                },
                error: function (xhr, textStatus, errorThrown) {
                    console.log(xhr);
                    console.log(textStatus);
                    console.log(errorThrown);
                }
            });      
            
        }
    });
}

function getWhoAmI() {
    var whoamiurl = "/d2l/api/lp/" + alldata.APIVersions.LP.LatestVersion + "/users/whoami";
    $.ajax({
        method: "GET",
        url: whoamiurl,
        dataType: 'json',
        success: function (whoamiresponse_tmp) {
            
            alldata.WhoAmI = whoamiresponse_tmp;
            
            getClasslist();
            getCourseOffering();
            
            
        } //end success
    }) //end ajax
}

function sort_by_key(array, key) {
    return array.sort(function(a, b){
        var x = a[key]; var y = b[key];
        return ((x < y) ? -1 : ((x > y) ? 1 : 0));
    });
}

function getClasslist() {
    var classlisturl = "/d2l/api/le/" + alldata.APIVersions.LE.LatestVersion + "/" + orgUnitId + "/classlist/";
    $.ajax({
        method: "GET",
        url: classlisturl,
        dataType: 'json',
        success: function (classlistresponse_tmp) {
            alldata.ClasslistAll = {
                Objects:classlistresponse_tmp
            }
            alldata.Classlist = {
                Objects:[]
            }
            alldata.Instructors = {
                Objects:[]
            }

            for(var cl=0; cl<alldata.ClasslistAll.Objects.length; cl++) {
                var thisuser = alldata.ClasslistAll.Objects[cl];
                if(thisuser.RoleId === 103) {
                    alldata.Classlist.Objects.push(thisuser);
                }
                else if ((thisuser.RoleId === 102) || (thisuser.RoleId === 115)) {
                    if(thisuser.Email !== null) {
                        alldata.Instructors.Objects.push(thisuser);
                    }
                }
            }

            for(var i=0; i<alldata.Instructors.Objects.length; i++) {
                if(alldata.Instructors.Objects[i].Email !== null) {
                    alldata.Instructors.Objects[i].Contact = 'mailto:'+alldata.Instructors.Objects[i].Email;
                }
            } 

            alldata.Classlist.Objects = sort_by_key(alldata.Classlist.Objects,"LastName");

            findRoleInOrgUnit();          
            
        } //end success
    }) //end ajax    
}

function findRoleInOrgUnit() {
    var rolefound = false;
    for(var c=0; c<alldata.ClasslistAll.Objects.length; c++) {
        var thisuser = alldata.ClasslistAll.Objects[c];
        if(thisuser.Identifier === alldata.WhoAmI.Identifier) {
            rolefound = true;
            alldata.CurrentRole = thisuser.ClasslistRoleDisplayName;
            alldata.WhoAmI.OrgDefinedId = thisuser.OrgDefinedId;
            
            if((pagetype === "preview") || (pagetype === "testing")) {
                alldata.CurrentRoleId = thisuser.RoleId;  
            }            
            else {
                if(parent.roleName !== alldata.CurrentRole) {
                    alldata.CurrentRole = parent.roleName;
                }
                else {
                    alldata.CurrentRoleId = thisuser.RoleId;                
                }
            }
            
            alldone.Classlist = true;
            processCourseType();
            
        }
    }
    if(!rolefound) {
        var thisenrollmenturl = "/d2l/api/lp/" + alldata.APIVersions.LP.LatestVersion + "/enrollments/myenrollments/" + orgUnitId;
        $.ajax({
            method: "GET",
            url: thisenrollmenturl,
            dataType: 'json',
            success: function (this_enroll_temp) {
                //console.log(this_enroll_temp);
                alldata.OrgUnitRole = this_enroll_temp.Access.ClasslistRoleName;
                alldata.CurrentRole = this_enroll_temp.Access.ClasslistRoleName;
                
                if((pagetype !== "preview") && (pagetype !== "testing")) {
                    if(parent.roleName !== alldata.CurrentRole) {
                        alldata.CurrentRole = parent.roleName;
                    } 
                }

                alldone.Classlist = true;
                processCourseType();

            } //end success
        }) //end ajax
    }
}

function tempSwitchRole() {
    ecplusClient.econestoga.setTempRole(alldata.WhoAmI.Identifier, orgUnitId).then(function (resp) {
        if (resp.isSuccess) {
            //console.log(resp);
            $('#observer-switch-msg').html('<p>Success! Reload this homepage to experience the <strong>Student</strong> role for 10 minutes.</p>');
        }
        else {
            console.log(resp);
        }
    });
}

