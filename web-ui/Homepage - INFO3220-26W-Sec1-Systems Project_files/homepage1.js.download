function getGroupCategories() {
    var groupcatsurl = "/d2l/api/lp/" + alldata.APIVersions.LP.LatestVersion + "/" + orgUnitId + "/groupcategories/";
    $.ajax({
        method: "GET",
        url: groupcatsurl,
        dataType: 'json',
        success: function (groupcats_tmp) {
            
            alldata.GroupsAll = {
                Objects:groupcats_tmp
            }
            if(alldata.GroupsAll.Objects.length > 0) {
                alldata.GroupsAll.Done = 0;
                getGroupDataAll();
            }
            else {
                
                alldone.Groups = true;
                //console.log("ad39");
                checkAllDone();
            }
            
        }, //end success
        error: function (xhr, ajaxOptions, thrownError) {
            //console.log(xhr.status);
            if(xhr.status === 404) {
                alldata.GroupsAll = {
                    Objects:[]
                }
                
                alldone.Groups = true;
                //console.log("ad40");
                checkAllDone();
            }
        }
    }) //end ajax    
}

function getGroupDataAll() {
    for(var g=0; g<alldata.GroupsAll.Objects.length; g++) {
        getGroupData(alldata.GroupsAll.Objects[g].GroupCategoryId);
    }
}

function getGroupData(groupcatid) {
    var groupdataurl = "/d2l/api/lp/" + alldata.APIVersions.LP.LatestVersion + "/" + orgUnitId + "/groupcategories/" + groupcatid + "/groups/";
    $.ajax({
        method: "GET",
        url: groupdataurl,
        dataType: 'json',
        success: function (groupdata_tmp) {
            
            for(var g=0; g<alldata.GroupsAll.Objects.length; g++) {
                if(alldata.GroupsAll.Objects[g].GroupCategoryId === groupcatid) {
                    alldata.GroupsAll.Objects[g].GroupsData = groupdata_tmp;
                    break;
                }
            }
            
            alldata.GroupsAll.Done++;
            if(alldata.GroupsAll.Done === alldata.GroupsAll.Objects.length) {
                
                alldone.Groups = true;
                //console.log("ad41");
                checkAllDone();
            }
            
        } //end success
    }) //end ajax    
}

function getAssignmentSubmitted(fid, uid) {
    ecplusClient.api.checkAssignmentSubmitted(orgUnitId, fid, uid).then(function (resp) {
        if (resp.isSuccess) {
            var usersubmitted = resp.Result;
            //console.log(usersubmitted);

            if(usersubmitted) {
                for(var a=0; a<alldata.AssignmentsAll.Objects.length; a++) {
                    if(alldata.AssignmentsAll.Objects[a].Id === fid) {
                        alldata.AssignmentsAll.Objects[a].Submissions = [
                            {
                                Entity: {
                                    EntityId: parseInt(uid)
                                },
                                Submissions: [
                                    {
                                        Files:[]
                                    }
                                ]
                            }
                        ];
                        break;
                    }
                }
            }

            alldata.AssignmentsAll.SubmissionsDone++;
            if(alldata.AssignmentsAll.SubmissionsDone === alldata.AssignmentsAll.Objects.length) {

                alldone.Assignments = true;
                //console.log("ad42");
                checkAllDone();
            }
        } else {
            //console.log('error');
        }
    });
}

function getQuizAttempted(qid, uid) {
    ecplusClient.api.checkQuizCompleted(orgUnitId, qid, uid).then(function (resp) {
        if (resp.isSuccess) {
            var wasattempted = resp.Result;
            //console.log(wasattempted);

            if(wasattempted) {
                for(var q=0; q<alldata.QuizzesAll.Objects.length; q++) {
                    if(alldata.QuizzesAll.Objects[q].QuizId === qid) {
                        alldata.QuizzesAll.Objects[q].Attempts = {
                            Objects: [
                                {
                                    QuizId: parseInt(qid),
                                    UserId: parseInt(uid)
                                }
                            ]
                        }
                        break;
                    }
                }
            }

            alldata.QuizzesAll.AttemptsDone++;
            if(alldata.QuizzesAll.AttemptsDone === alldata.QuizzesAll.Objects.length) {

                alldone.Quizzes = true;
                //console.log("ad43");
                checkAllDone();
            }
        } else {
            //console.log('error');
        }
    });
}

function getMergeComponents() {
    ecplusClient.merge.get(orgUnitId).then(function (resp) {
        if (resp.isSuccess) {
            var data = resp.Result;
            //console.log(data);
            alldata.MergeComponents = data;
            if(alldata.MergeComponents !== null) {
                if(alldata.MergeComponents.SourceCourses.length > 0) {
                    alldata.MergeComponents.SourcesDone = 0;
                    for(var sc=0; sc<alldata.MergeComponents.SourceCourses.length; sc++) {
                        getCourseOffering(alldata.MergeComponents.SourceCourses[sc].OrgUnitId);
                    }
                }
            }
            else {
                alldone.Merges = true;
                processCourseOffering();
            }
        } else {
            alldata.MergeComponents = null;
            alldone.Merges = true;
            processCourseOffering();
            //console.log('error');
        }
    });
}

function getMergeRecords() {
    ecplusClient.merge.getRelated(orgUnitId).then(function (resp) {
        if (resp.isSuccess) {
            var data = resp.Result;
            //console.log(data);
            alldata.MergeRecords = data;
        } else {
            alldata.MergeRecords = null;
            //console.log('error');
        }

        alldone.Merges = true;
        processCourseOffering();
    });
}

function getCourseSections() {
    var sectiondataurl = "/d2l/api/lp/" + alldata.APIVersions.LP.LatestVersion + "/" + orgUnitId + "/sections/";
    $.ajax({
        method: "GET",
        url: sectiondataurl,
        dataType: 'json',
        success: function (sectiondata_tmp) {
            
            alldata.Sections = sectiondata_tmp;
            alldone.Sections = true;
            
            processCourseOffering();
            
        }, //end success
        error: function (xhr, ajaxOptions, thrownError) {
            
            alldata.Sections = null;
            alldone.Sections = true;
            
            processCourseOffering();
        }
    }) //end ajax  
}

function getCourseOffering(sourceid) {

    var id = (sourceid === undefined) ? orgUnitId : sourceid;

    ecplusClient.courses.getOffering(id).then(function(resp) {

        if(resp.isSuccess) {
            var data = resp.Result;
            if(sourceid === undefined) {
                alldata.CourseOffering = data;
            }
            else {
                var attributeobj;
                for(var sc=0; sc<alldata.MergeComponents.SourceCourses.length; sc++) {
                    var thissource = alldata.MergeComponents.SourceCourses[sc];
                    if(thissource.OrgUnitId === sourceid) {
                        thissource.CourseOffering = data;
                        attributeobj = getSourceAttributes(data);
                        thissource.Attributes = attributeobj;
                        break;
                    }
                }

                if(attributeobj !== undefined) {
                    getSourceInfo(attributeobj.Code, attributeobj.Ver, attributeobj.Sem, attributeobj.Sec, sourceid);
                }
                else {
                    alldata.MergeComponents.SourcesDone++;
                    if(alldata.MergeComponents.SourcesDone === alldata.MergeComponents.SourceCourses.length) {
                        alldone.Merges = true;
                        processCourseOffering();
                    }
                }

            }

        } else {
            if(sourceid === undefined) {
                alldata.CourseOffering = null;
            }
            else {
                for(var sc=0; sc<alldata.MergeComponents.SourceCourses.length; sc++) {
                    var thissource = alldata.MergeComponents.SourceCourses[sc];
                    if(thissource.OrgUnitId === sourceid) {
                        thissource.CourseOffering = null;
                        break;
                    }
                }
            }
        }

        if(sourceid === undefined) {
            getCalendarData();
            if(alldata.CourseOffering !== null) {
                if(alldata.CourseOffering.Code.indexOf("MERGED") > -1) {
                    getCourseSections();
                    alldata.MergeRecords = null;
                    getMergeComponents();
                }
                else {
                    alldata.Sections = null;
                    alldone.Sections = true;
                    alldata.MergeComponents = null;
                    getMergeRecords();
                }
                if(alldata.CourseOffering.Code.indexOf("Model-") > -1) {
                    ecPlusGetAncestors(orgUnitId, 105);
                }
                else {
                    alldata.Ancestors = [];
                    alldone.Ancestors = true;
                    processCourseOffering();
                }
            }
        }

    });
}

function getSourceAttributes(offering) {
    
    var courseobj;
    var code_split = offering.Code.replace(/ /g, "").split("_");
    
    if (code_split.length === 7) {
        if (code_split[3] !== "X") {
            if (code_split[5].indexOf("SEC") > -1) {
                codeformatok = true;
                courseobj = {
                    "Code": code_split[4],
                    "Dep": code_split[3],
                    "Sem": code_split[1],
                    "Sec": parseInt(code_split[0].split("-")[3]),
                    "Ver": code_split[0].split("-")[1]
                }
            }
        }
    }
    
    return courseobj;
}

function processCourseOffering() {
    
    if((alldone.Sections) && (alldone.Merges) && (alldone.Ancestors)) {
        var thiscourse = alldata;
        thiscourse.OfficialModel = false;

        if ((alldata.CourseOffering.StartDate !== null) && (alldata.CourseOffering.EndDate !== null)) {
            alldata.DateRange = true;
        } else {
            alldata.DateRange = false;
        }    
        //console.log(thiscourse.CourseOffering);

        var code_split = alldata.CourseOffering.Code.replace(/ /g, "").split("_");
        var name_split = alldata.CourseOffering.Name.split("-");
        var thistitle;
        if (name_split.length > 3) {
            var buildtitle = '';
            for (var b = 3; b < name_split.length; b++) {
                buildtitle += name_split[b];
            }
            thistitle = buildtitle;
        } else {
            thistitle = alldata.CourseOffering.Name;
        }
        //console.log(code_split);
        var courseobj = {};
        var termfound = false;
        var codeformatok = false;
        var isofficialmodel = false;

        //console.log(code_split);
        if (code_split.length === 7) {
            if (code_split[3] !== "X") {
                if (code_split[5].indexOf("SEC") > -1) {
                    codeformatok = true;
                    courseobj = {
                        "Code": [code_split[4]],
                        "Dep": code_split[3],
                        "Sem": code_split[1],
                        "Sec": [parseInt(code_split[0].split("-")[3])],
                        "Title": thistitle,
                        "Ver": code_split[0].split("-")[1]
                    }
                }
            }
        } else {
            if (code_split.length === 1) {
                if (code_split[0].indexOf("MERGED") > -1) {

                    var codes = [];
                    var secnums = [];
                    var semstring = '';
                    var usesections = false;
                    if(thiscourse.Sections !== undefined) {
                        if(thiscourse.Sections !== null) {
                            if(thiscourse.Sections.length > 1) {
                                var codeformatok = false;
                                for(var cs=0; cs<thiscourse.Sections.length; cs++) {
                                    var thissec = thiscourse.Sections[cs].Code;
                                    var thissecsplittest = thissec.split("_")
                                    if(thissecsplittest.length === 3){
                                        if(thissecsplittest[2].toLowerCase().indexOf("sec") > -1) {
                                            usesections = true;
                                            break;
                                        }
                                    }   
                                }                            
                            }
                        }
                    }
                                        
                    if(usesections) {
                        for(var cs=0; cs<thiscourse.Sections.length; cs++) {
                            var thissec = thiscourse.Sections[cs].Code;
                            if(thissec.indexOf("Manual") === -1) {
                                var thissecsplit = thissec.split("_");
                                if(thissecsplit.length === 3) {
                                    if(thissecsplit[2].toLowerCase().indexOf("sec") > -1) {
                                        var thisseccode = thissecsplit[0];
                                        var thissecnum = parseInt(thissecsplit[2].slice(3));
                                        if(codes.indexOf(thisseccode) === -1) {
                                            codes.push(thisseccode);
                                        }
                                        if(secnums.indexOf(thissecnum) === -1) {
                                            secnums.push(thissecnum);
                                        }

                                        if(semstring === '') {
                                            semstring = thissecsplit[1];
                                        }
                                    }
                                }
                            }
                        }
                        
                        secnums.sort((a,b) => a-b)
                        
                    }
                    else {
                        var merged_split = alldata.CourseOffering.Name.replace(/ /g, "").split("-");
                        semstring = merged_split[1];
                        //console.log(merged_split);
                        
                        var secstring = merged_split[2];
                        if(secstring !== undefined) {
                            secstring = secstring.slice(3);

                            var sec_split = [];
                            var multisec = false;
                            if (secstring.indexOf("&") > -1) {
                                multisec = true;
                                sec_split = secstring.split("&");
                                for (var s = 0; s < sec_split.length; s++) {
                                    secnums.push(parseInt(sec_split[s]));
                                }
                            }
                            if (secstring.indexOf("to") > -1) {
                                multisec = true;
                                sec_split = secstring.split("to");
                                var sec_min = parseInt(sec_split[0]);
                                var sec_max = parseInt(sec_split[1]);
                                for (var s = sec_min; s <= sec_max; s++) {
                                    secnums.push(s);
                                }
                            }

                            if (sec_split.length === 0) {
                                if (isNaN(parseInt(secstring))) {

                                } else {
                                    secnums.push(parseInt(secstring));
                                }
                                if (merged_split.length > 4) {
                                    for (var t = 3; t < merged_split.length; t++) {
                                        var checkval = parseInt(merged_split[t]);
                                        if (!isNaN(checkval)) {
                                            secnums.push(checkval);
                                        }
                                    }
                                }
                            }
                            //console.log(secnums);
                            //console.log(merged_split);
                            if (merged_split[0].indexOf("&") > -1) {
                                var merged_code_split = merged_split[0].split("&");
                                var firstDigit = merged_code_split[0].match(/\d/) // will give you the first digit in the string
                                indexed = merged_code_split[0].indexOf(firstDigit);

                                var codeletters = merged_code_split[0].slice(0, indexed);
                                var codenum1 = merged_code_split[0].slice(indexed);
                                var codenum2 = merged_code_split[1];
                                //console.log(codeletters);
                                //console.log(codenum1);

                                codes = [(codeletters + codenum1), (codeletters + codenum2)];
                            } else {
                                codes = [merged_split[0]];
                            }

                            if(secnums.length > 1) {
                                if(alldata.Sections !== null) {
                                    var secmerged = [];
                                    for(var ads=0; ads<alldata.Sections.length; ads++) {
                                        var thiscodesplit = alldata.Sections[ads].Code.split("_");
                                        for(var tcs=0; tcs<thiscodesplit.length; tcs++) {
                                            if(thiscodesplit[tcs].toLowerCase().indexOf("sec") === 0) {
                                                var mergedsecnum = parseInt(thiscodesplit[tcs].slice(3));
                                                if(!isNaN(mergedsecnum)) {
                                                    secmerged.push(mergedsecnum);           
                                                    break;
                                                }                           
                                            }
                                        }
                                    }
                                    if(secmerged.length > 0) {
                                        secnums = secmerged.sort((a,b) => a-b)
                                    }
                                }
                            }

                            /*
                            if ((codes.length > 1) && (secnums.length > 1)) {
                                if (codes.length === secnums.length) {
                                    var secnumorder = []
                                    var code_split_dash = alldata.CourseOffering.Code.split("-");
                                    for (var c1 = 0; c1 < codes.length; c1++) {
                                        for (var s1 = 0; s1 < code_split_dash.length; s1++) {
                                            if (codes[c1] === code_split_dash[s1]) {
                                                var thissec;
                                                if (s1 === 0) {
                                                    thissec = parseInt(code_split_dash[(s1 + 3)]);
                                                } else {
                                                    thissec = parseInt(code_split_dash[(s1 + 1)]);
                                                }
                                                if (!isNaN(thissec)) {
                                                    secnumorder.push(thissec);
                                                }
                                            }
                                        }
                                    }

                                    if (secnumorder.length === secnums.length) {
                                        secnums = secnumorder;
                                    }
                                }
                            } else {
                                if (secnums.length > 1) {
                                    var secnumorder = []
                                    var code_split_dash = alldata.CourseOffering.Code.split("-");
                                    for (var s1 = 3; s1 < code_split_dash.length; s1++) {
                                        var thissec = parseInt(code_split_dash[s1]);
                                        if (!isNaN(thissec)) {
                                            secnumorder.push(thissec);
                                        } else {
                                            break;
                                        }
                                    }

                                    if (secnumorder.length < secnums.length) {
                                        secnums = secnumorder;
                                    }
                                }
                            }
                            */

                            //console.log(merged_split);
                        }
                    }
                    
                    codeformatok = true;
                    courseobj = {
                        "Code": codes,
                        "Dep": "MERGE",
                        "Sem": semstring,
                        "Sec": secnums,
                        "Title": thistitle,
                        "Ver": code_split[0].split("-")[1]
                    }                    
                    
                    //console.log(courseobj);

                } else if (code_split[0].indexOf("Model-") > -1) {
                    if(alldata.Ancestors !== undefined) {
                        if(alldata.Ancestors.length > 0) {
                            for(var a=0; a<alldata.Ancestors.length; a++) {
                                if(alldata.Ancestors[a].Name.toLowerCase() === "model shells"){
                                    isofficialmodel = true;
                                    break;
                                }
                            }
                        }
                    }

                    if(isofficialmodel) {
                        var model_split = alldata.CourseOffering.Code.split("-");
                        var model_title;
                        if(name_split.length === 6) {
                            model_title = name_split[name_split.length - 1];
                        }
                        else {
                            model_title = alldata.CourseOffering.Name;
                        }
                        //console.log(model_split);
                        courseobj = {
                            "Code": [model_split[1]],
                            "Dep": "MODEL",
                            "Sem": null,
                            "Sec": null,
                            "Title": model_title,
                            "Ver": model_split[2]
                        }
                        thiscourse.Offering = courseobj;
                    }
                }
                else {
                    var old_split = alldata.CourseOffering.Code.split("-");
                    if (old_split.length === 4) {
                        if(old_split[2].length === 3) {
                            var semchar = old_split[2].slice(2);
                            //console.log(semchar);
                            if((semchar === "F") || (semchar === "W") || (semchar === "S")) {
                                codeformatok = true;
                                courseobj = {
                                    "Code": [old_split[0]],
                                    "Dep": "OLD",
                                    "Sem": old_split[2],
                                    "Sec": [old_split[3]],
                                    "Title": name_split[name_split.length - 1],
                                    "Ver": old_split[1]
                                }
                            }
                        }
                    }
                }
            }
        }
        if (codeformatok) {

            //console.log(courseobj.Sem);
            if(courseobj.Sem.indexOf("&") > -1) {
                courseobj.SemOrig = JSON.parse(JSON.stringify(courseobj.Sem));
                courseobj.Sem = courseobj.Sem.split("&")[0];
            }

            var thisyear = courseobj.Sem.slice(0, 2);
            var thisterm = courseobj.Sem.slice(2);

            var goodyear = false;
            var goodterm = false;

            thisyear = parseInt(thisyear);
            if (thisyear > 11) {
                goodyear = true
            } else {
                //console.log(thisyear);
            }

            if (thisterm === "W" || thisterm === "S" || thisterm === "F") {
                goodterm = true;
            }

            if (goodyear && goodterm) {
                thiscourse.Semester = {
                    Year: thisyear,
                    Term: thisterm,
                    Display: courseobj.Sem
                }
            }
            else {
                //console.log(thisyear);
                //console.log(thisterm);
            }
            thiscourse.Offering = courseobj

            var d = new Date();
            //console.log(courseobj);
            //console.log(thiscourse.Offering);

            var termyear = 2000 + parseInt(thiscourse.Offering.Sem.slice(0, 2));
            var termletter = thiscourse.Offering.Sem.slice(2);
            //console.log(termyear);
            //console.log(termletter);
            if (termletter !== "F") {
                termyear = termyear - 1;
            }

            thiscourse.Code = {
                String: thiscourse.Offering.Code[0],
                Year: termyear
            }

            thiscourse.NotSection = false;
            getCourseInfo(thiscourse.Offering.Code[0], thiscourse.Offering.Ver, thiscourse.Offering.Sem, thiscourse.Offering.Sec[0]);
            getCourseOutline(termyear, thiscourse.Offering.Code[0], thiscourse.Offering.Ver);

        } else {
            thiscourse.NotSection = true;
            thiscourse.SIS = null;
            alldone.SIS = true;
            coursedeliverydone = true;
            updateWidgetDataAuto();            
            
            if(isofficialmodel) {
                
                var tdate = getServerTime();
                var tmonth = tdate.getMonth();
                var termyear = 1900 + tdate.getYear();
                if(tmonth < 5) {
                    termyear = termyear - 1;
                }
                
                //console.log(termyear);
                getCourseOutline(termyear, thiscourse.Offering.Code[0], thiscourse.Offering.Ver);
            }
            else {                
                thiscourse.Offering = null;                
                thiscourse.Outline = [];
                alldone.Outline = true;
            }

            //console.log("ad45");
            checkAllDone();

        }   

        alldone.Offering = true;
        processCourseType();         
    }
}

function getChecklistsAll(bookmark) {
    var checklisturl = "/d2l/api/le/" + alldata.APIVersions.LE.LatestVersion + "/" + orgUnitId + "/checklists/";
    if(bookmark !== undefined) {
        checklisturl = bookmark;
    }
    
    $.ajax({
        method: "GET",
        url: checklisturl,
        dataType: 'json',
        success: function (checklists_tmp) {
            
            if(alldata.ChecklistsAll === undefined) {
                alldata.ChecklistsAll = checklists_tmp;
            }
            else {
                alldata.ChecklistsAll.Objects = alldata.ChecklistsAll.Objects.concat(checklists_tmp.Objects);
            }
            
            if(checklists_tmp.Next !== null) {
                getChecklistsAll(bookmark);
            }
            else {
                if(alldata.ChecklistsAll.Objects.length > 0) {
                    alldata.ChecklistsAll.Done = 0;
                    getChecklistItemsAll();
                }
                else {

                    alldone.Checklists = true;
                    //console.log("ad46");
                    checkAllDone();                    
                }
            }
        }, //end success
        error: function (checklists_tmp) {
            alldata.ChecklistsAll = {
                Objects: []
            }
            alldone.Checklists = true;
            //console.log("ad47");
            checkAllDone();
        }
    }) //end ajax    
}

function getChecklistItemsAll() {
    for(var cl=0; cl<alldata.ChecklistsAll.Objects.length; cl++) {
        var thischeck = alldata.ChecklistsAll.Objects[cl];
        getChecklistItem(thischeck.ChecklistId);
    }
}

function getChecklistItem(checkid, bookmark) {
    var checklistitemurl = "/d2l/api/le/" + alldata.APIVersions.LE.LatestVersion + "/" + orgUnitId + "/checklists/" + checkid + "/items/";
    if(bookmark !== undefined) {
        checklistitemurl = bookmark;
    }
    $.ajax({
        method: "GET",
        url: checklistitemurl,
        dataType: 'json',
        success: function (checklistitem_tmp) {

            if(checklistitem_tmp.Objects.length > 0) {
                for(var cl=0; cl<alldata.ChecklistsAll.Objects.length; cl++) {
                    if(checklistitem_tmp.Objects[0].ChecklistId === alldata.ChecklistsAll.Objects[cl].ChecklistId) {
                        var thischeck = alldata.ChecklistsAll.Objects[cl];
                        if(thischeck.Items === undefined) {
                            thischeck.Items = checklistitem_tmp;
                        }
                        else {
                            thischeck.Items.Objects = thischeck.Items.Objects.concat(checklistitem_tmp.Objects);
                        }
                    }
                }
            }

            if(checklistitem_tmp.Next !== null) {
                getChecklistItem(checkid);
            }
            else {
                alldata.ChecklistsAll.Done++;
                if(alldata.ChecklistsAll.Done === alldata.ChecklistsAll.Objects.length) {
                    
                    alldone.Checklists = true;
                    //console.log("ad48");
                    checkAllDone();                    
                }
            }
        } //end success
    }) //end ajax    
}

