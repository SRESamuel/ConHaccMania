        announcetabs += '<li class="nav-item">';
        announcetabs += '<a class="nav-link" id="announce-upcoming-tab" data-toggle="pill" href="#announce-upcoming" role="tab" aria-controls="announce-upcoming" aria-selected="false">Upcoming</a>';
        announcetabs += '</li>';
        announcetabs += '<li class="nav-item">';
        announcetabs += '<a class="nav-link" id="announce-expired-tab" data-toggle="pill" href="#announce-expired" role="tab" aria-controls="announce-expired" aria-selected="false">Expired</a>';
        announcetabs += '</li>';
        announcetabs += '<li class="nav-item">';
        announcetabs += '<a class="nav-link" id="announce-draft-tab" data-toggle="pill" href="#announce-draft" role="tab" aria-controls="announce-draft" aria-selected="false">Draft</a>';
