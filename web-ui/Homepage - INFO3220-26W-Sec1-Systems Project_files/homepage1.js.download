function getDiscussionPostsAll() {
    alldata.DiscussionsAll.TopicsTotal = 0;
    for(var df=0; df<alldata.DiscussionsAll.Objects.length; df++) {
        for(var dt=0; dt<alldata.DiscussionsAll.Objects[df].Topics.length; dt++) {
            alldata.DiscussionsAll.TopicsTotal++;
        }
    }
    for(var df=0; df<alldata.DiscussionsAll.Objects.length; df++) {
        for(var dt=0; dt<alldata.DiscussionsAll.Objects[df].Topics.length; dt++) {
            
            var thistopic = alldata.DiscussionsAll.Objects[df].Topics[dt]
            getDiscussionPosts(thistopic.ForumId, thistopic.TopicId);
        }
    }    
}

function getDiscussionPosts(dforumid, dtopicid) {
    var discussposturl = "/d2l/api/le/" + alldata.APIVersions.LE.LatestVersion + "/" + orgUnitId + "/discussions/forums/" + dforumid + "/topics/" + dtopicid + "/posts/";
    $.ajax({
        method: "GET",
        url: discussposturl,
        dataType: 'json',
        success: function (discussposts_tmp) {
            
            for(var df=0; df<alldata.DiscussionsAll.Objects.length; df++) {
                if(alldata.DiscussionsAll.Objects[df].ForumId === dforumid) {
                    for(var dt=0; dt<alldata.DiscussionsAll.Objects[df].Topics.length; dt++) {
                        if(alldata.DiscussionsAll.Objects[df].Topics[dt].TopicId === dtopicid) {
                            alldata.DiscussionsAll.Objects[df].Topics[dt].Posts = discussposts_tmp;
                        }
                    }                    
                }
            }              
            alldata.DiscussionsAll.PostsDone++;
            if(alldata.DiscussionsAll.PostsDone === alldata.DiscussionsAll.TopicsTotal) {
                
                alldone.Discussions = true;
                //console.log("ad19");
                checkAllDone(); 
            }
            
        } //end success
    }) //end ajax
}

