function announceStyleConfirm(announceid) {
    var thisiconclass = $('.select-announce-icons .active').attr('class').split(/\s+/)[4];
    var thiscolorclass = $('.select-announce-colors .active').attr('class').split(/\s+/)[3];
    
    //console.log(announceid);
    //console.log(thisiconclass);
    //console.log(thiscolorclass);
    
    $('.announcement-'+announceid + ' .announcement-icon').html('<div class="cc-icon '+thiscolorclass+' '+thisiconclass+'"></div>');

    var saveobj = {
        ID: announceid,
        Color: thiscolorclass,
        Icon: thisiconclass
    }
    //console.log(saveobj);
    
    if(alldata.CustomSettings === null) {
        alldata.CustomSettings = {
            Announce: {
                Pins:[],
                Icons:[saveobj]
            }
        }
    }
    else {
        if(alldata.CustomSettings.Announce === undefined) {
            alldata.CustomSettings.Announce = {
                Pins:[],
                Icons:[saveobj]
            }
        }
        else {
            var datafound = false;
            if(alldata.CustomSettings.Announce.Icons !== undefined) {
                for(var ai=0; ai<alldata.CustomSettings.Announce.Icons.length; ai++) {
                    var thisicon = alldata.CustomSettings.Announce.Icons[ai];
                    if(thisicon.ID === announceid) {
                        datafound = true;
                        thisicon.Color = saveobj.Color;
                        thisicon.Icon = saveobj.Icon;
                    }
                }
            }
            if(!datafound) {
                if(alldata.CustomSettings.Announce.Icons !== undefined) {
                    alldata.CustomSettings.Announce.Icons.push(saveobj)
                }
                else {
                    alldata.CustomSettings.Announce.Icons = [saveobj]
                }
            }
        }
    }
    
    //console.log(alldata.CustomSettings);
    putCustomWidgetData(CustomWidgetH1);
    
    $('#announceStyleModal').modal('hide');

}

function selectAnnounceStyle(type, announceid, itemind) {
    if(type === "icon") {
        $('.select-announce-icons .cc-icon').removeClass('active');
        var selecticon = announcestyles.Icons[itemind];
        var selectoricon = '.select-announce-icons .'+selecticon.Class;

        $(selectoricon).addClass("active");        
    }
    if(type === "color") {
        $('.select-announce-colors .cc-icon').removeClass('active');
        var selecticon = announcestyles.Colors[itemind];
        var selectoricon = '.select-announce-colors .'+selecticon.Class;

        $(selectoricon).addClass("active");
    }
}

var announcestyles;
function announceStyle(announceid) {
    $.getJSON('assets/json/homepage1-icons-announce.json', function(data) {
        
        announcestyles = data;
        
        var stylebody = '';
        stylebody += '<p>Select the icon image you would like displayed next to your Announcement:</p>';
        stylebody += '<div class="row select-announce-icons">';
        for(var ai=0; ai<data.Icons.length; ai++) {
            var thisicon = data.Icons[ai];
            stylebody += '<div class="col-md-3 col-sm-6 col-xs-12 mt-2 mb-2">';
            stylebody += '<a href="javascript:selectAnnounceStyle(\'icon\', '+announceid+','+ai+')"><div class="m-auto mx-auto cc-icon white-bg '+thisicon.Class+'" title="Select Announcement Icon: '+thisicon.Text+'"></div></a>';
            stylebody += '</div>';
        };
        stylebody += '</div>';
        stylebody += '<hr>';
        stylebody += '<p>Select the icon colour you would like displayed next to your Announcement:</p>';
        stylebody += '<div class="row select-announce-colors">';
        for(var ac=0; ac<data.Colors.length; ac++) {
            var thiscol = data.Colors[ac];
            stylebody += '<div class="col-md-3 col-sm-6 col-xs-12 mt-2 mb-2">';
            stylebody += '<a href="javascript:selectAnnounceStyle(\'color\', '+announceid+','+ac+')" title="Select Announcement Icon Colour: '+thiscol.Text+'"><div class="m-auto mx-auto cc-icon '+thiscol.Class+'"></div></a>';
            stylebody += '</div>';            
        }
        stylebody += '</div>';
        
        $('#announceStyleModal .modal-body').html(stylebody);
        
        var existicon = $('.announcement-'+announceid+' .cc-icon').attr('class').split(/\s+/);
        //console.log(existicon);
        $('.select-announce-icons .'+existicon[2]).addClass("active");
        $('.select-announce-colors .'+existicon[1]).addClass("active");
        
        $('#announceStyleModal .modal-footer .btn-confirm').attr('onClick','announceStyleConfirm('+announceid+')');
        
        $('#announceStyleModal').modal('show');

        
    });
}

function updateTextbookLink() {
    var textbookcustom = false;
    if(alldata.CustomSettings !== null) {
        if(alldata.CustomSettings.Textbook !== undefined) {
            if(alldata.CustomSettings.Textbook.Option !== "text-defaultlink") {
                textbookcustom = true;
            }
        }
    }
    if(!textbookcustom) {
        $('.instructor-content .links-container-display .link-textbookinfo').removeClass('d-none');
        $('.student-content .links-container .link-textbookinfo').removeClass('d-none');
        $('.link-textbookinfo a').attr('target','_blank');
        
        var etextfound = false;
        if(alldata.SIS !== null) {
            if(alldata.SIS.eText) {
                if(alldata.SIS.eTextAmount !== null) {
                    if(alldata.SIS.eTextAmount > 0) {
                        var etextlinks = [];
                        for(var et=0; et<alldata.EText.length; et++) {
                            if(alldata.EText[et].Search.length > 0) {
                                for(var ets=0; ets<alldata.EText[et].Search.length; ets++) {
                                    var thistop = alldata.EText[et].Search[ets].Topic;
                                    if(!thistop.IsHidden) {
                                        etextlinks.push(thistop.Url);
                                        break;
                                    }
                                }
                            }                            
                        }
                        //console.log(etextlinks);
                        if(etextlinks.length > 0) {
                            etextfound = true;
                            if(etextlinks.length === 1) {
                                $('.link-textbookinfo a').attr('href',etextlinks[0]);
                                $('.link-textbookinfo a').removeClass('disabled');   
                                $('.link-textbookinfo .link-ico').removeClass('disabled');                                
                            }
                            else {                                
                                $('.link-textbookinfo a').attr('href',"javascript:openLinkTextbook('etextmulti')");
                                $('.link-textbookinfo a').removeAttr('target');
                                $('.link-textbookinfo a').removeClass('disabled');   
                                $('.link-textbookinfo .link-ico').removeClass('disabled');                                
                            }
                        }
                    }
                }
            }
        }
        if(!etextfound) {
            if(alldata.Outline.length > 0) {
                if(alldata.Outline[0].StudentResources.length > 0) {
                    //console.log(alldata.Outline[0].StudentResources);
                    var booklist = [];
                    for(var sr=0; sr<alldata.Outline[0].StudentResources.length; sr++) {
                        var thisresource = alldata.Outline[0].StudentResources[sr];
                        if(thisresource.Book !== undefined) {
                            if(thisresource.Book !== null) {
                                booklist.push(thisresource);
                            }
                        }
                    }
                    alldata.BookList = booklist;
                    if(booklist.length > 0) {
                        $('.link-textbookinfo a').attr('href',"javascript:openLinkTextbook('outline')");
                        $('.link-textbookinfo a').removeAttr('target');
                        $('.link-textbookinfo a').removeClass('disabled');   
                        $('.link-textbookinfo .link-ico').removeClass('disabled');
                    }
                }
            }
        }        
    }
    else {
        //console.log("custom found");
        if(alldata.CustomSettings.Textbook.Option === "text-displaynone") {
            
            $('.link-textbookinfo a').removeAttr('href');
            $('.link-textbookinfo a').addClass('disabled');   
            $('.link-textbookinfo .link-ico').addClass('disabled');               
            
            $('.instructor-content .links-container-display .link-textbookinfo').addClass('d-none');
            $('.student-content .links-container .link-textbookinfo').addClass('d-none');

        }
        else if(alldata.CustomSettings.Textbook.Option === "text-customurl") {
            $('.instructor-content .links-container-display .link-textbookinfo').removeClass('d-none');
            $('.student-content .links-container .link-textbookinfo').removeClass('d-none');
            $('.link-textbookinfo a').attr('href',alldata.CustomSettings.Textbook.URL);
            $('.link-textbookinfo a').attr('target','_blank');
            $('.link-textbookinfo a').removeClass('disabled');   
            $('.link-textbookinfo .link-ico').removeClass('disabled');
        }
        else if(alldata.CustomSettings.Textbook.Option === "text-physicalinfo") {
            $('.instructor-content .links-container-display .link-textbookinfo').removeClass('d-none');
            $('.student-content .links-container .link-textbookinfo').removeClass('d-none');
            $('.link-textbookinfo a').attr('href',"javascript:openLinkTextbook('custom')");
            $('.link-textbookinfo a').removeAttr('target');
            $('.link-textbookinfo a').removeClass('disabled');   
            $('.link-textbookinfo .link-ico').removeClass('disabled');
        }
    }
}

function updateTextbookInputs() {
    
    $('#edittexturl').val(alldata.CustomSettings.Textbook.URL);
    $('.textinfo-title').val(alldata.CustomSettings.Textbook.Info.Title);
    $('.textinfo-author').val(alldata.CustomSettings.Textbook.Info.Author);
    $('.textinfo-publisher').val(alldata.CustomSettings.Textbook.Info.Publisher);
    $('.textinfo-isbn').val(alldata.CustomSettings.Textbook.Info.ISBN);    
    
    var textbookval = alldata.CustomSettings.Textbook.Option;
    $("input[type=radio][value="+textbookval+"]").prop("checked",true).change();
    
}

