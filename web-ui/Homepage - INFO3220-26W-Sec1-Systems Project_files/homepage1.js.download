    var zoomblock = false;
    var haszoom = false;
    var hasteams = false;
    var zoomstring = '';
    if(alldata.SIS !== null) {
        if(alldata.SIS.DeliveryMode.Code === "ON-S") {
            zoomblock = true;
        }
    }
    if(alldata.Synchronous !== undefined) {
        if(alldata.Synchronous.length > 0) {
            zoomblock = true;
            for(var ons=0; ons<alldata.Synchronous.length; ons++) {
                if(alldata.Synchronous[ons].href.indexOf("conestogac.zoom") > -1) {
                    haszoom = true;
                }
                if(alldata.Synchronous[ons].href.indexOf("teams.microsoft") > -1) {
                    hasteams = true;
                }
            }
        }
    }
    if(zoomblock) {
        if(haszoom || hasteams) {
            var onlinesynchtool = '';
            if(haszoom && hasteams) {
                onlinesynchtool = 'Zoom and Teams';
            }
            else {
                if(haszoom) {
                    onlinesynchtool = 'Zoom';
                }
                if(hasteams) {
                    onlinesynchtool += 'Teams';
                }
            }
            
            $('.onlinesynch-tool-name').text(onlinesynchtool);
            zoomstring += '<p>Your course will use <strong>' + onlinesynchtool + '</strong> for online classes.</p>';
            
            var upcomingfound = false;
            if(alldata.CalendarZoom !== undefined) {
                if(alldata.CalendarZoom.Items.length > 0) {
                    upcomingfound = true;
                    zoomstring += '<p>The next online meeting is scheduled for <strong>';
                    var dateobj = zoomDateInfo(alldata.CalendarZoom.Items[0].event);
                    zoomstring += dateobj.DateString + ', ' + dateobj.TimeRange;            
                    zoomstring += '.</strong></p>';
                    zoomstring += '<p>A button to open the meeting will appear at the top of the course homepage a few minutes before the meeting starts.</p>';                    
                }
            }
            if(!upcomingfound) {
                zoomstring += '<p>There are no upcoming online classes scheduled at this time, but your Instructor may add some.</p>'
            }

        }
        else {
            zoomstring += '<p>Your course will probably use Zoom or Teams for online classes, but your instructor may not have posted the meeting details yet. [E-mail your instructor] to ask them to post the link to your online class.</p>';
        }
        $('#contact-us-zoom-instructor').prepend(zoomstring);
        $('#contact-us-zoom-student').prepend(zoomstring);
        $('a[href="#contact-us-zoom-instructor"]').parent('li').removeClass('d-none');
        $('#contact-us-zoom-instructor').removeClass('d-none');
        $('a[href="#contact-us-zoom-student"]').parent('li').removeClass('d-none');
        $('#contact-us-zoom-student').removeClass('d-none');       
    }
    else {
        $('a[href="#contact-us-zoom-instructor"]').parent('li').remove();
        $('#contact-us-zoom-instructor').remove();
        $('a[href="#contact-us-zoom-student"]').parent('li').remove();
        $('#contact-us-zoom-student').remove();
    }
    

    var etextblock = false;
    var etextfound = false;
    var etextlinks = [];
    var etextstring = '';
    if((alldata.CourseType === "Standard") || (alldata.CourseType === "High Capacity")) {
        if(alldata.SIS !== null) {
            if(alldata.SIS.eText) {
                if(alldata.SIS.eTextAmount !== null) {
                    if(alldata.SIS.eTextAmount > 0) {
                        etextblock = true;
                    }
                }
            }
        }
        for(var et=0; et<alldata.EText.length; et++) {
            if(alldata.EText[et].Search.length > 0) {
                for(var ets=0; ets<alldata.EText[et].Search.length; ets++) {
                    var thistop = alldata.EText[et].Search[ets].Topic;
                    if(!thistop.IsHidden) {
                        etextlinks.push(thistop);
                    }
                }
            }                            
        }
        if(etextlinks.length > 0) {
            etextblock = true;
            etextfound = true;
        }     
    }    
    if(etextblock) {
        var etextstring = '';
        if(etextfound) {
            etextstring += '<p>Your should be able to access your <strong>eText</strong> through the following link(s): </p>';
            for(var etl=0; etl<etextlinks.length; etl++) {
                //console.log(etextlinks[etl]);
                etextstring += '<p><strong><a href="'+etextlinks[etl].Url+'" target="_blank">' + etextlinks[etl].Title + ' <i class="fas fa-external-link" aria-hidden="true"></i><span class="sr-only">Opens in a new tab</span></a></strong></p>';
            }
            var showtexidium = false;
            var showvitalsource = false;
            for(var et=0; et<alldata.EText.length; et++) {
                if(alldata.EText[et].Search.length > 0) {
                    if((alldata.EText[et].LinkID === etextltilist_24S[0].LinkID[0]) || (alldata.EText[et].LinkID === etextltilist_24S[1].LinkID[0])) {
                        showtexidium = true;
                    }
                    if((alldata.EText[et].LinkID === etextltilist_24S[2].LinkID[0]) || (alldata.EText[et].LinkID === etextltilist_24S[2].LinkID[1])){
                        showvitalsource = true;
                    }
                }
            }
            if(showtexidium) {
                etextstring += '<p>If you are having trouble accessing your online <strong>Texidium</strong> resources, please <a href="mailto:eText@conestogac.on.ca">contact eText Support <i class="far fa-envelope" aria-hidden="true"></i><span class="sr-only">Compose e-mail</span></a>.</p>';                
            }
            if(showvitalsource) {
                etextstring += '<p>If you are having trouble accessing your online <strong>VitalSource</strong> resources, please visit the <a href="https://support.vitalsource.com/hc/en-us" target="_blank">VitalSource Support website <i class="fas fa-external-link" aria-hidden="true"></i><span class="sr-only">Opens in a new tab</span></a>.</p>';
            }
        }
        else {
            etextstring += '<p>Your course may use an online textbook, but your instructor may not have created a link to it yet. Please contact your instructor and let them know that you can’t find the link to your eText.</p>';         
        }
        $('#contact-us-etext-instructor').html(etextstring);     
        $('#contact-us-etext-student').html(etextstring);
        $('a[href="#contact-us-etext-instructor"]').parent('li').removeClass('d-none');
        $('#contact-us-etext-instructor').removeClass('d-none');
        $('a[href="#contact-us-etext-student"]').parent('li').removeClass('d-none');
        $('#contact-us-etext-student').removeClass('d-none');
    }
    else {
        $('a[href="#contact-us-etext-instructor"]').parent('li').remove();
        $('#contact-us-etext-instructor').remove();
        $('a[href="#contact-us-etext-student"]').parent('li').remove();
        $('#contact-us-etext-student').remove();
    }
    
    var publisherfound = false;
    var publisherlist = [];
    var publisherstring = '';
    if(alldata.Publishers !== undefined) {
        for(var adp=0; adp<alldata.Publishers.length; adp++) {
            var thispub = alldata.Publishers[adp];
            if(thispub.active === "true") {
                thispub.Display = [];
                if(thispub.Found !== undefined) {
                    for(var tpf=0; tpf<thispub.Found.length; tpf++) {
                        if(thispub.Found[tpf].Topics.length > 0) {
                            publisherfound = true;
                            thispub.Display.push({
                                Topic:thispub.Found[tpf].Topics,
                                Title:thispub.links[tpf].platformName
                            })
                        }
                    }
                    if(thispub.Display.length > 0) {
                        publisherlist.push(thispub);
                    }
                }
            }
        }
    }
    if(publisherfound) {
        //console.log(publisherlist);
        if(publisherlist.length === 1) {
            var thispub = publisherlist[0];
            $('.cc-icon.publisher-dynamic').removeClass('publisher');
            $('.cc-icon.publisher-dynamic').css({
                "filter":'invert(0)',
                "background-color":thispub.logoBG,
                "background-image":'url(\'assets/icons/publisher/'+thispub.logoFile+'\')'
            });
            $('.publisher-dynamic').parent('a').find('.contact-us-label').text(thispub.supportName);
        }
        
        for(var pl=0; pl<publisherlist.length; pl++) {
            var thispub = publisherlist[pl];
            
            if(thispub.Display.length > 0) {
                if(thispub.Display.length === 1) {
                    publisherstring += '<p>This course uses <strong>' + thispub.Display[0].Title + '</strong> resources, which you should be able to access through the following link:</p>';
                    publisherstring += '<p><strong><a href="' + thispub.Display[0].Topic[0].Topic.Url + '" target="_blank"> ' + thispub.Display[0].Topic[0].Topic.Title + ' <i class="fas fa-external-link" aria-hidden="true"></i><span class="sr-only">Opens in a new tab</span></a></strong></p>';
                }
                else {
                    publisherstring += '<p>This course uses <strong>' + thispub.companyName + '</strong> resources, which you should be able to access through the following links:</p>';
                    for(var tpd=0; tpd<thispub.Display.length; tpd++) {
                        publisherstring += '<p><strong><a href="' + thispub.Display[tpd].Topic[0].Topic.Url + '" target="_blank"> ' + thispub.Display[tpd].Topic[0].Topic.Title + ' <i class="fas fa-external-link" aria-hidden="true"></i><span class="sr-only">Opens in a new tab</span></a></strong></p>';
                    }
                }
            }
            
            if(thispub.supportEmail !== "") {
                publisherstring += '<p>If you are having trouble accessing your online <strong>' + thispub.companyName + '</strong> resources, please <a href="mailto:' + thispub.supportEmail + '">contact ' + thispub.supportName + ' <i class="far fa-envelope" aria-hidden="true"></i><span class="sr-only">Compose e-mail</span></a>.</p>';
            }
            else {
                if(thispub.supportURL !== "") {
                    publisherstring += '<p>If you are having trouble accessing your online <strong>' + thispub.companyName + '</strong> resources, please visit the <a href="' + thispub.supportURL + '" target="_blank">' + thispub.supportName + ' website <i class="fas fa-external-link" aria-hidden="true"></i><span class="sr-only">Opens in a new tab</span></a>.</p>';
                }
            }
            if(pl < (publisherlist.length - 1)) {
                publisherstring += '<hr>';
            }
        }
        
        $('#contact-us-publisher-instructor').html(publisherstring);
        $('#contact-us-publisher-student').html(publisherstring);
        $('a[href="#contact-us-publisher-instructor"]').parent('li').removeClass('d-none');
        $('#contact-us-publisher-instructor').removeClass('d-none');
        $('a[href="#contact-us-publisher-student"]').parent('li').removeClass('d-none');
        $('#contact-us-publisher-student').removeClass('d-none');           
    }
    else {
        $('a[href="#contact-us-publisher-instructor"]').parent('li').remove();
        $('#contact-us-publisher-instructor').remove();
        $('a[href="#contact-us-publisher-student"]').parent('li').remove();
        $('#contact-us-publisher-student').remove();
    }
    
    var respondusblock = false;
    if(alldata.QuizzesAll.Objects.length > 0) {
        for(var qa=0; qa<alldata.QuizzesAll.Objects.length; qa++) {
            if(alldata.QuizzesAll.Objects[qa].Name.indexOf("Requires Respondus") > -1) {
                respondusblock = true;
                break;
            }
        }
    }
    if(respondusblock) {
        $('a[href="#contact-us-respondus-instructor"]').parent('li').removeClass('d-none');
        $('#contact-us-respondus-instructor').removeClass('d-none');
        $('a[href="#contact-us-respondus-student"]').parent('li').removeClass('d-none');
        $('#contact-us-respondus-student').removeClass('d-none');
    }
    else {
        $('a[href="#contact-us-respondus-instructor"]').parent('li').remove();
        $('#contact-us-respondus-instructor').remove();
        $('a[href="#contact-us-respondus-student"]').parent('li').remove();
        $('#contact-us-respondus-student').remove();
    }
    
    var panoptoblock = false;
    var top_panopto = [];
    if(alldata.Content.Modules.length > 0) {
        for (var m = 0; m < alldata.Content.Modules.length; m++) {                
            findContentTopicsAll('ToolItemId', 141470, alldata.Content.Modules[m], top_panopto);
        }
    }
    if(top_panopto.length > 0) {
        panoptoblock = true;
    }
    if(panoptoblock) {
        $('a[href="#contact-us-panopto-instructor"]').parent('li').removeClass('d-none');
        $('#contact-us-panopto-instructor').removeClass('d-none');
        $('a[href="#contact-us-panopto-student"]').parent('li').removeClass('d-none');
        $('#contact-us-panopto-student').removeClass('d-none');
    }
    else {
        $('a[href="#contact-us-panopto-instructor"]').parent('li').remove();
        $('#contact-us-panopto-instructor').remove();
        $('a[href="#contact-us-panopto-student"]').parent('li').remove();
        $('#contact-us-panopto-student').remove();
    }
    
    document.querySelectorAll('.contact-us-container').forEach((container) => initContactUsNav(container));
    //document.querySelectorAll('.cc-search').forEach((container) => initSearchBar(container));   
    if (searchData === undefined) {
        fetchSupport();
    }    

}

function mailFeedback() {
    var mailtodetails = 'mailto:eConestoga@conestogac.on.ca';
    mailtodetails += '?Subject=Course Homepage Pilot';
    mailtodetails += '&Body=';
    mailtodetails += 'Sent By: ' + alldata.WhoAmI.FirstName + ' ' + alldata.WhoAmI.LastName;
    if(alldata.WhoAmI.OrgDefinedId !== undefined) {
        mailtodetails += ' ('+alldata.WhoAmI.OrgDefinedId+')';
    }
    mailtodetails += '%0D%0A';
    mailtodetails += 'Role: ' + alldata.CurrentRole;
    mailtodetails += '%0D%0A';
    mailtodetails += 'Course Info: ';
    mailtodetails += alldata.CourseOffering.Name;
    mailtodetails += '%0D%0A';
    mailtodetails += 'Course Link: https://conestoga.desire2learn.com/d2l/home/' + orgUnitId;
    mailtodetails += '%0D%0A';
    mailtodetails += '%0D%0A';
    mailtodetails += 'Message: ';
    mailtodetails += '%0D%0A';
    
    window.top.location = mailtodetails;
    
}

function checkContentSearchDone() {
    
    /*
    console.log(alldata.InstructionalPlan);
    console.log(alldata.EText);
    console.log(alldata.Publishers);
    */
    
    if((alldata.InstructionalPlan !== undefined) && (alldata.EText !== undefined) && (alldata.Publishers !== undefined)) {
        
        if(alldata.InstructionalPlan.Data !== undefined) {
            if(alldata.Displayed.LinkList1 === false) {
                alldata.Displayed.LinkList1 = true;
                initializeLinkList();
            }
            
            processCustomDates();
            //processProgress();
            processGradeMatching();
            processGrades();
            
            if(alldata.CourseType === "Standard") {
                processDateAssess();
                calculateStudents();
            }
            else if(alldata.CourseType === "High Capacity") {
                if(studentroles.indexOf(alldata.CurrentRole) > -1) {
                    processDateAssess();
                    calculateStudents();
                }    
            }

            buildCourseDates();
            
            //console.log(JSON.parse(JSON.stringify(alldata)));
            if(alldata.CourseType === "Standard") {
                if(observeroles.indexOf(alldata.CurrentRole) === -1) {
                    if(studentroles.indexOf(alldata.CurrentRole) > -1) {
                        buildStudentDashboard();
                    }
                    else {
                        buildStudentPreview();
                        buildProgressSnapshot();
                        eTextCheck();
                    }
                }
            }
            else if(alldata.CourseType === "High Capacity") {
                if(observeroles.indexOf(alldata.CurrentRole) === -1) {
                    if(studentroles.indexOf(alldata.CurrentRole) > -1) {
                        buildStudentDashboard();
                    }
                    else {
                        eTextCheck();
                    }                    
                }
            }
            
            //console.log(alldata);     
            alldone.ContentProcess = true;
        }
    }
}

function checkAllDone() {
    
    /*
    console.log(alldone.Announcements);
    console.log(alldone.Ancestors);
    console.log(alldone.Assignments);
    console.log(alldone.AssignmentsUser);
    console.log(alldone.Calendar);
    console.log(alldone.Checklists);
    console.log(alldone.Classlist);
    console.log(alldone.Content);
    console.log(alldone.CopyLogs);
    console.log(alldone.Discussions);
    console.log(alldone.Enrollment);
    console.log(alldone.Grades);
    console.log(alldone.Groups);
    console.log(alldone.Merges);
    console.log(alldone.Notifications);
    console.log(alldone.Outline);
    console.log(alldone.Offering);
    console.log(alldone.Progress);
    console.log(alldone.Quizzes);
    console.log(alldone.QuizzesUser);
    console.log(alldone.Sections);
    console.log(alldone.SIS);
    console.log(alldone.Updates);
    console.log(alldone.Values);
    console.log(alldone.ProfileImageCrop);
    */
    
    if(!alldata.Displayed.Initial) {
        if((alldone.Ancestors) && (alldone.Classlist) && (alldone.Outline) && (alldone.SIS) && (alldone.Merges) && (alldone.Offering) && (alldone.Sections) && (alldone.ProfileImageCrop)) {
            
            //console.log(alldata.CourseType);
            alldata.Displayed.Initial = true;
            initializeHomepageDisplay();
            
            checkAllDisplayed();
            
        }        
    }
    
    if(!alldata.Displayed.NextMeeting) {
        var nextonline = true;
        if(alldata.CustomSettings.Meeting !== undefined) {
            if(alldata.CustomSettings.Meeting.Option === "meet-displaynone") {
                //$('.course-image-overlay').removeClass('displayed');
                $('.meeting-title').addClass('d-none');
                $('.meeting-block').addClass('d-none');
                $('.sec-next-meeting').addClass('d-none');
                nextonline = false;
                alldata.Displayed.NextMeeting = true;
                checkAllDisplayed();                       
            }
            else if(alldata.CustomSettings.Meeting.Option === "meet-manualinfo") {
                //$('.course-image-overlay').addClass('displayed');
                $('.meeting-title').html(alldata.CustomSettings.Meeting.Info.Title);
                $('.meeting-block .meeting-custom').html('<p>'+alldata.CustomSettings.Meeting.Info.Body+'</p>');
                $('.meeting-block .meeting-custom').removeClass("d-none");
                $('.meeting-block .cc-icon').addClass("d-none");
                $('.meeting-details').addClass("d-none");
                $('.meeting-controls').addClass("d-none");
                $('.meeting-block').removeClass("invisible");
                nextonline = false;
                alldata.Displayed.NextMeeting = true;
                checkAllDisplayed();   
            }
            else if(alldata.CustomSettings.Meeting.Option === "meet-customtag") {
                nextonline = false;
                if(alldone.Calendar) {
                    initializeNextTagged(alldata.CustomSettings.Meeting.CalendarTag);
                    alldata.Displayed.NextMeeting = true;
                    checkAllDisplayed();   
                }
            }     
        }        
        if(nextonline) {
            if(alldone.Calendar) {
                initializeNextOnline();
                alldata.Displayed.NextMeeting = true;
                checkAllDisplayed();
            }
        }
    }
    
    if(alldone.Classlist) {
        if((studentroles.indexOf(alldata.CurrentRole) === -1) && (observeroles.indexOf(alldata.CurrentRole) === -1)) {
            if(alldata.Displayed.ProgressEnroll === false) {
                if(alldone.Enrollment) {
                    alldata.Displayed.ProgressEnroll = true;
                    initializeEnrollmentDisplay();

                    checkAllDisplayed();

                }
            }

            if(!alldata.Displayed.Updates) {
                if(alldone.Updates) {
                    alldata.Displayed.Updates = true;
                    initializeCourseUpdates();

                    checkAllDisplayed();
                }
            }
        }
    }
    
    if(!alldata.Displayed.Announcements) {
        if(alldone.Announcements) {
            alldata.Displayed.Announcements = true;
            
            processPinnedAnnounce();
            initializeAnnouncements();
            
            checkAllDisplayed();
            
        }
    }
    
    if(alldone.Announcements && alldone.Ancestors && alldone.Assignments && alldone.AssignmentsUser && alldone.Calendar && alldone.Checklists && alldone.Content && alldone.CopyLogs && alldone.Discussions && alldone.Grades && alldone.Groups && alldone.Merges && alldone.Outline && alldone.Offering && alldone.Progress && alldone.Quizzes && alldone.QuizzesUser && alldone.Sections && alldone.SIS && alldone.Values && alldone.ProfileImageCrop && alldone.Notifications) {

        processAssignmentData();
        processQuizzesData();
        
        //console.log(alldata);
        
        if((studentroles.indexOf(alldata.CurrentRole) === -1) && (observeroles.indexOf(alldata.CurrentRole) === -1)) {
            processCourseReadiness();
        }
        
        if(alldata.OfficialModel) {
            processUserSubscriptions();
        }
        
        if(!alldata.Displayed.Dashboards) {
            alldata.Displayed.Dashboards = true;
            
            initializeMeetingSettings();  
            initializeDashboardSettings();
            initializeImportSettings();
            
            buildGrades();
            
            
            if(alldata.CourseType === "Standard") {
                
                if(!alldone.ContentProcess) {
                    processContentData();
                }
                else {
                    if((studentroles.indexOf(alldata.CurrentRole) === -1) && (observeroles.indexOf(alldata.CurrentRole) === -1)) {
                        processDateAssess();
                        calculateStudents();
                        buildStudentPreview();
                        buildProgressSnapshot();           
                    }               
                }

                if((studentroles.indexOf(alldata.CurrentRole) === -1) && (observeroles.indexOf(alldata.CurrentRole) === -1)) {
                    initializeAtRiskSettings();
                    initializeAssessSettings();
                }      
                checkAllDisplayed();
                
                $('a[href="#pills-progress"]').parent('li').removeClass('d-none');           
                $('a[href="#pills-assessment"]').parent('li').removeClass('d-none');                
                
                $('#update-stuatrisk').removeClass('d-none');
                $('#update-flaggedassess').removeClass('d-none');
                
                if(guidedcopy) {
                    getMergeCandidateInfo();
                }
                else {
                    alldata.EnrollmentOther = null;
                }
                
                if((studentroles.indexOf(alldata.CurrentRole) === -1) && (observeroles.indexOf(alldata.CurrentRole) === -1)) {
                    getCustomWidgetData(CustomWidgetCL);
                    getCustomWidgetData(CustomWidgetMC);
                    getCustomWidgetData(CustomWidgetGC);
                }
                    
                if (!courselaunch) {
                    $('#cc-dashboard .essential-dash-section').removeClass('d-none');
                    $('.instructor-dash-summary').removeClass('d-none');
                    $('.management-container').removeClass('d-none');
                    
                    $('#pills-importset-tab').removeClass('d-none');

                    $('#high-cap-message').addClass('d-none');      
                }                                 
            }            
            else if (alldata.CourseType === "High Capacity") {
                $('a[href="#pills-progress"]').parent('li').addClass('d-none');           
                $('a[href="#pills-assessment"]').parent('li').addClass('d-none');
                processContentData();
                
                alldata.Displayed.ProgressStudents = true
                alldata.Displayed.ProgressAssess = true;
                alldata.Displayed.Dashboards = true;        
				
				if(guidedcopy) {                    
                    getMergeCandidateInfo();
				}
                else {
                    alldata.EnrollmentOther = null;
                }

                if((studentroles.indexOf(alldata.CurrentRole) === -1) && (observeroles.indexOf(alldata.CurrentRole) === -1)) {
                    getCustomWidgetData(CustomWidgetCL);
                    getCustomWidgetData(CustomWidgetMC);        
                    getCustomWidgetData(CustomWidgetGC);
                }
                
				if (!courselaunch) {
					$('#highcap-dash-load-text').removeClass('d-none');
					$('#highcap-dash-load-btn').removeClass('d-none');			
				}
				
                checkAllDisplayed();
                
            }
            else {
                
                $('a[href="#pills-progress"]').parent('li').remove();            
                $('a[href="#pills-assessment"]').parent('li').remove();               

                alldata.InstructionalPlan = {
                    Data: null
                }
                buildCourseDates();            

                alldata.Displayed.EEScanner = true;
                alldata.Displayed.ProgressStudents = true
                alldata.Displayed.ProgressAssess = true;
                alldata.Displayed.Dashboards = true;    
                alldata.Displayed.LinkList2 = true;
                
                checkAllDisplayed();
            }
        }

        if(alldone.Enrollment && alldone.Updates) {
            if(alldata.CurrentRoleId !== undefined) {
                loadtime_data_ecplus.UserId = parseInt(alldata.WhoAmI.Identifier);
                loadtime_data_ecplus.RoleId = alldata.CurrentRoleId;
                loadtime_data_ecplus.OrgUnitId = parseInt(orgUnitId);

                var datefinished = new Date();
                var timefinished = datefinished.getTime();
                var timepassed = timefinished - timestarted;                 

                loadtime_data_ecplus.DateTime = datefinished.toISOString();
                loadtime_data_ecplus.TotalTime = timepassed;

                //console.log(loadtime_data_ecplus);
                //console.log(JSON.stringify(loadtime_data_ecplus));
                postLoadTimes();  
            }
        }
        
        //console.log(JSON.stringify(alldata));
        //putCustomWidgetData(CustomWidgetH1);
        
    }
}


function checkAllDisplayed() {
    
    /*
    console.log(alldata.Displayed.Initial);
    console.log(alldata.Displayed.NextMeeting);
    console.log(alldata.Displayed.EEScanner);
    console.log(alldata.Displayed.ProgressStudents);
    console.log(alldata.Displayed.ProgressAssess);
    console.log(alldata.Displayed.ProgressEnroll);
    console.log(alldata.Displayed.Updates);
    console.log(alldata.Displayed.LinkList2);
    console.log(alldata.Displayed.Announcements);
    console.log(alldata.Displayed.Dashboards);
    */
    
    if((studentroles.indexOf(alldata.CurrentRole) > -1) || (observeroles.indexOf(alldata.CurrentRole) > -1)) {
        if(alldata.Displayed.Initial && alldata.Displayed.NextMeeting && alldata.Displayed.LinkList2 && alldata.Displayed.Announcements && alldata.Displayed.Dashboards) {

            if(alldata.CourseCalendar.length > 0) {
                initCalendar(alldata.CourseDates);
            }
            else {
                $('.thisweek-management-cards').addClass('d-none');
                $('.calendarzone').addClass('p-5');
                $('.calendarzone .cc-calendar').addClass('d-none');
                $('.calendarzone').append('<p>The calendar view is not currently displayed because no course dates were found, but may be added by an Instructor in the future.</p>')
            }
            initSupportLinks();

        }
    }
    else {
        if(alldata.Displayed.Initial && alldata.Displayed.NextMeeting && alldata.Displayed.EEScanner && alldata.Displayed.ProgressStudents && alldata.Displayed.ProgressAssess && alldata.Displayed.ProgressEnroll && alldata.Displayed.Updates && alldata.Displayed.LinkList2 && alldata.Displayed.Announcements && alldata.Displayed.Dashboards) {

            if(alldata.CourseCalendar.length > 0) {
                initCalendar(alldata.CourseDates);
            }
            else {
                $('.thisweek-management-cards').addClass('d-none');
                $('.calendarzone').addClass('p-5');
                $('.calendarzone .cc-calendar').addClass('d-none');
                $('.calendarzone').append('<p>The calendar view is not currently displayed because no course dates were found, but may be added by an Instructor in the future.</p>')
            }
            initSupportLinks();

        }        
    }
}


var timestarted;
var frameloop;
var cropper;
var croppable = false;
$(document).ready(function(){

    orgUnitId = parent.ouID;
    userId = parent.userID;
    //console.log(orgUnitId);
    //console.log(userId);    
    
    var lastFocus;
    $('.modal').on('show.bs.modal', function (e) {
        lastFocus = $(':focus');
    });
    $('.modal').on('hidden.bs.modal', function (e) {
        if(lastFocus)
            lastFocus.focus();
    });
    
    if((pagetype === "preview") || (pagetype === "testing")) {
        $('#admin-load input').val(orgUnitId);
    }
    
    $('.collapseThisWeek').on('hidden.bs.collapse', function () {
        clearInterval(frameloop);
        frameloop = false;
        //frameHeight();
    });
    $('.collapseThisWeek').on('shown.bs.collapse', function () {
        clearInterval(frameloop);
        frameloop = false;
        //frameHeight();
    });
    $('.collapseThisWeek').on('show.bs.collapse', function () {
        frameloop = setInterval(function(){
            //frameHeight();
        },1);        
    });
    
    $('#accordionHelp .collapse').on('hidden.bs.collapse', function () {
        clearInterval(frameloop);
        frameloop = false;
        //frameHeight();
    });
    $('#accordionHelp .collapse').on('shown.bs.collapse', function () {
        clearInterval(frameloop);
        frameloop = false;
        //frameHeight();
    });    
    $('#accordionHelp .collapse').on('show.bs.collapse', function () {
        frameloop = setInterval(function(){
            //frameHeight();
        },1);   
    });
    
    $('#cc-settings a[data-toggle="pill"]').on('shown.bs.tab', function (e) {
        e.target // newly activated tab
        e.relatedTarget // previous active tab
        window.dispatchEvent(new Event('resize'));
    })
    
    $('.modal').on('show.bs.modal', function (e) {
    // do something...        
        window.parent.scroll(0,0);
        window.dispatchEvent(new Event('resize'));
    })
    
    $('#profileImageEdit').on('shown.bs.modal', function (e) {
        
        var tstamp = new Date().getTime();
        var profileimagecropper = '<div><img id="instructorprofilecrop" src="/d2l/common/viewprofileimage.d2l?oi=6606&ui='+alldata.WhoAmI.Identifier+'&s=700&t='+tstamp+'"></div>';

        $('#profileImageEdit .modal-body').html(profileimagecropper);
        var image = document.getElementById('instructorprofilecrop');
        
        var cropdata;
        for(var i=0; i<alldata.Instructors.Objects.length; i++) {
            if(parseInt(alldata.Instructors.Objects[i].Identifier) === parseInt(alldata.WhoAmI.Identifier)) {
                if(alldata.Instructors.Objects[i].ProfileImageCrop !== undefined) {
                    cropdata = alldata.Instructors.Objects[i].ProfileImageCrop;
                }
                break;
            }
        }
        
        //console.log(cropdata);
        if(cropdata !== undefined) {
            cropper = new Cropper(image, {
                viewMode: 2,
                aspectRatio: 1,
                data: cropdata,
                ready: function () {
                    croppable = true;
                },            
            });            
        }
        else {
            cropper = new Cropper(image, {
                viewMode: 2,
                aspectRatio: 1,
                ready: function () {
                    croppable = true;
                },            
            });   
        }

        window.dispatchEvent(new Event('resize'));
    });
    
    $('#profileImageEdit .modal-footer .btn-confirm').attr('onClick','profileImageEditConfirm()');
    
    var redirectfound = false
    for (var crc=0; crc<CourseRedirectContent.length; crc++) {
        if(CourseRedirectContent[crc].OrgUnitId === orgUnitId) {
            top.location.href = CourseRedirectContent[crc].ContentURL;
            redirectfound = true;
            break;
        }
    }
    if(!redirectfound) {
        initializePreviewSelect();
    }
    
});

