    $('.announcement-wrapper').html('');
    
    //console.log(alldata.Announcements);
    var announceindex = 0;
    var announcedisplayed = 0;
    var announcemax = 5;
    
    var tdate = new Date();
    
    var studenthtml = '';
    var releasedhtml = '';
    var upcominghtml = '';
    var expiredhtml = '';
    var drafthtml = '';
    
    var pinnedlist = [];
    
    /*
    if(alldata.CustomSettings !== null) {
        if(alldata.CustomSettings.Announce !== undefined) {
            if(alldata.CustomSettings.Announce.Pins !== undefined) {
                alldata.CustomSettings.Announce.Pins.sort((a, b) => (a.Time < b.Time) ? 1 : -1);
            }
            else {
                alldata.CustomSettings.Announce.Pins = []
            }
            //console.log(alldata.CustomSettings.Announce.Pins);
            
            for(var ap=0; ap<alldata.CustomSettings.Announce.Pins.length; ap++) {
