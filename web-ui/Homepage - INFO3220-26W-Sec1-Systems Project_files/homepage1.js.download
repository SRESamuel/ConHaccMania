var loadtime_data_ecplus = { 
  "UserId": -1, 
  "RoleId": -1, 
  "OrgUnitId": -1, 
  "TotalTime": -1, 
  "DateTime": "", 
  "SessionLoadTime": []
}

function addLoadTimeItem(id,source,label) {
    var timefinished = new Date().getTime();
    var timepassed = timefinished - timestarted;     
    loadtime_data_ecplus.SessionLoadTime.push({
        "LoadId":id,
        "Source":source,
        "Label":label,
        "LoadTime":timepassed
    });
}

function postLoadTimes() {
    ecplusClient.performance.log(loadtime_data_ecplus).then(function (resp) {
        if (resp.isSuccess) {
            //console.log(resp);
        }
    });
}

var AdminShowTiming = false;
function AdminLoadTime(desc) {
    if(AdminShowTiming) {
        var timefinished = new Date().getTime();
        var timepassed = timefinished - timestarted;     
        console.log(desc + " Done: " + timepassed + " ms"); 
    }    
}

function ecPlusGetUserNotifications() {
    ecplusClient.subscriptions.getUser(alldata.WhoAmI.Identifier).then(function (resp) {
        if (resp.isSuccess) {
            //console.log(resp);
            alldata.UserNotifications = resp.Result;
        } else {
            alldata.UserNotifications = [];
        }
        alldone.Notifications = true;
        checkAllDone();
    });
}

function ecPlusGetAncestors(ouID, ouType) {
    ecplusClient.courses.getAncestors(ouID).then(function(resp) {
        if (resp.isSuccess) {
            alldata.Ancestors = resp.Result;
        } else {
            alldata.Ancestors = [];
        }
        alldone.Ancestors = true;
        processCourseOffering();
    });
}

function ecPlusAddModelToCopyQueue(queuedata) {
    console.log(queuedata);

    ecplusClient.courseReadiness.initiateCopy(queuedata.OrgID, queuedata.ToOrgID, queuedata.UserID).then(function (resp) {
        if (resp.isSuccess) {

            alldata.GuidedCopy = {
                Model: alldata.Readiness.Selected.OrgUnitId,
                JobToken: resp.Result
            }

            courseempty = false;
            copystarted = true;
            eCPlusCheckCopyStatus();
            putCustomWidgetData(CustomWidgetGC, "GuidedCopyQueued");

            var pbarsections = $('.course-copy-progress-bar .step');
            //console.log(pbarsections);
            $(pbarsections[0]).addClass('filled');
            $(pbarsections[1]).addClass('filled');
            $(pbarsections[2]).addClass('filled');

            $('#course-copy-added-access-link').attr('href','#');
            $('#course-copy-added-access').addClass('d-none');
            if(alldata.Readiness.Selected.AccessEnrolled !== undefined) {
                if(alldata.Readiness.Selected.AccessEnrolled === true) {
                    $('#course-copy-added-access-link').attr('href','/d2l/home/'+alldata.Readiness.Selected.OrgUnitId);
                    $('#course-copy-added-access').removeClass('d-none');
                }
            }

            $('.course-copy-screen').addClass('d-none');
            $('#course-copy-added-queue').removeClass('d-none');
        }
        else {
            console.log("ECPlus Error");
            console.log(resp);
            $('#course-copy-error-queue').removeClass('d-none');
        }
    });
}

function processModelMatchMulti() {
    
    //console.log("process multi");
    //console.log(alldata.Readiness.Result);
    
    alldata.Readiness.Matches = {
        Exact: [],
        Close: []
    }
    
    var sdate = new Date(alldata.CourseOffering.StartDate);
    var edate = new Date(alldata.CourseOffering.EndDate);

    var nweeks;
    nweeks = nWeeks(sdate, edate);    

    if(alldata.Readiness.Result.length === 1) {
        for(var m=0; m<alldata.Readiness.Result[0].MatchingModels.length; m++) {
            var thismodel = alldata.Readiness.Result[0].MatchingModels[m];
            if(thismodel.IsModelCreated) {
                if(thismodel.OrgUnitId !== parseInt(orgUnitId)) {
                    if(thismodel.CopiedFromName.toLowerCase().indexOf("-model-") > -1) {
                        alldata.Readiness.Matches.Close.push(thismodel);
                        if((thismodel.Length === nweeks) || (thismodel.Length-1) === nweeks) {
                            alldata.Readiness.Matches.Exact.push(thismodel);
                        }
                    }
                }
            }
        }
        if(alldata.Readiness.Matches.Exact.length > 0) {
            alldata.Readiness.Result[0].MatchingModels = alldata.Readiness.Matches.Exact;
        }
        else {
            alldata.Readiness.Result[0].MatchingModels = alldata.Readiness.Matches.Close;
        }     
        
        //console.log(emptycheckdone);
        if(!emptycheckdone) {
            if(alldata.Readiness.Result[0].MatchingModels.length === 0) {
                displayModelMatchResults();
            }
            else {
                checkModelMatchesEmpty();
            }
        }
    }
}

function checkModelMatch(deliverydata) {
    console.log(JSON.stringify([deliverydata]));

    ecplusClient.courseReadiness.modelSearch([deliverydata]).then(function (resp) {
        if (resp.isSuccess) {
            //displayModelMatchResults();
            console.log(resp);
            if(alldata.Readiness.Result[0].MatchingModels.length === 0) {
                alldata.Readiness.Result[0].MatchingModels = resp.Result[0].MatchingModels;
            }
            else {
                for(var r=0; r<resp.Result[0].MatchingModels.length; r++) {
                    var isunique = true;
                    for(var mm=0; mm<alldata.Readiness.Result[0].MatchingModels.length; mm++) {
                        if(resp.Result[0].MatchingModels[r].OrgUnitId === alldata.Readiness.Result[0].MatchingModels[mm].OrgUnitId) {
                            isunique = false;
                            break;
                        }
                    }
                    //console.log(isunique);
                    if(isunique) {
                        alldata.Readiness.Result[0].MatchingModels.push(resp.Result[0].MatchingModels[r]);
                    }
                }
            }
            //guidedCopyLoad();
        }
        alldata.Readiness.SearchDone++;

        //console.log(alldata.Readiness.SearchStart);
        //console.log(alldata.Readiness.SearchDone);
        if(alldata.Readiness.SearchStart === alldata.Readiness.SearchDone) {
            processModelMatchMulti();
        }
    });
}

function checkModelUserAccess(accessdata) {
    var myenrollmenturl = "/d2l/api/lp/" + alldata.APIVersions.LP.LatestVersion + "/enrollments/myenrollments/" + accessdata.OrgID + "/access";
    //console.log(myenrollmenturl);
    $.ajax({
        method: "GET",
        url: myenrollmenturl,
        dataType: 'json',
        success: function (responseJSON) {
            //console.log(responseJSON);
                if(responseJSON.Access.ClasslistRoleName === null) {
                    modelEnrollCopyAccess(accessdata);
                }
                else {
                    for(var m=0; m<alldata.Readiness.Result[0].MatchingModels.length; m++) {
                        var thismodel = alldata.Readiness.Result[0].MatchingModels[m];
                        if(thismodel.OrgUnitId === accessdata.OrgID) {
                            thismodel.AccessConfirmed = true;
                            break;
                        }
                    }                    
                    alldata.Readiness.Result[0].EmptyCheck.Access++;
                    processModelMatchesAccess();         
                }

        }, //end success
        error: function (xhr, ajaxOptions, thrownError) {
            
            if (adminroles.indexOf(alldata.CurrentRole) > -1) {
                for(var m=0; m<alldata.Readiness.Result[0].MatchingModels.length; m++) {
                    var thismodel = alldata.Readiness.Result[0].MatchingModels[m];
                    if(thismodel.OrgUnitId === accessdata.OrgID) {
                        thismodel.AccessConfirmed = false;
                        thismodel.NotFound = true;
                        break;
                    }
                }
                alldata.Readiness.Result[0].EmptyCheck.Access++;
                processModelMatchesAccess();                         
            }
            else {
                modelEnrollCopyAccess(accessdata);
            }                    
        }
            
    }) //end ajax
}

