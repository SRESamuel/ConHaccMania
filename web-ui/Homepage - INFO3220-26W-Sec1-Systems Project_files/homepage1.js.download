function validateTextInfo() {

    var validtitle = false;
    
    var titletext;
    var titleclean;
    
    var authortext;
    var authorclean;
    
    var publishertext;
    var publisherclean;
    
    var isbntext;
    var isbnclean;
    
    titletext = $(".textinfo-title").val();
    titleclean = cleanTextInput(titletext);
    $(".textinfo-title").val(titleclean);
    
    authortext = $(".textinfo-author").val();
    authorclean = cleanTextInput(authortext);
    $(".textinfo-author").val(authorclean);
    
    publishertext = $(".textinfo-publisher").val();
    publisherclean = cleanTextInput(publishertext);
    $(".textinfo-publisher").val(publisherclean);
    
    isbntext = $(".textinfo-isbn").val();
    isbnclean = cleanTextInput(isbntext);
    $(".textinfo-isbn").val(isbnclean);
    
    //console.log(titleclean);
    if(titleclean.length > 3) {
        validtitle = true;
    }
    
    if(validtitle) {
        $('#edittextsave').removeAttr('disabled');
    }
    else {
        $('#edittextsave').attr('disabled','disabled');
    }
    
}

function validateTextLink() {
    var validurl = false;

    if(/^(http|https|ftp):\/\/[a-z0-9]+([\-\.]{1}[a-z0-9]+)*\.[a-z]{2,5}(:[0-9]{1,5})?(\/.*)?$/i.test($("#edittexturl").val())){        
        validurl = true;
    }
    
    if(validurl) {
        $('#edittextsave').removeAttr('disabled');
    }
    else {
        $('#edittextsave').attr('disabled','disabled');
    }

}

function validateNewLink(type) {
    
    //console.log(type);
    
    var validurl = false;
    var validlabel = false;
    var validicon = false;
    
    var labeltext;
    var labelclean;
    var iconactive;
    
    var urlval;
    
    if(type === "new") {
        urlval = $("#newlinkurl").val();
        if(/^(http|https|ftp):\/\/[a-z0-9]+([\-\.]{1}[a-z0-9]+)*\.[a-z]{2,5}(:[0-9]{1,5})?(\/.*)?$/i.test(urlval)){
            validurl = true;
        }
        labeltext = $("#newlinklabel").val();
        labelclean = cleanTextInput(labeltext);
        $("#newlinklabel").val(labelclean);
        
        iconactive = $('#newlinkform .select-linklist-icons .cc-icon.active');
    }
    else if(type === "edit") {
        urlval = $("#editlinkurl").val();
        if(/^(http|https|ftp):\/\/[a-z0-9]+([\-\.]{1}[a-z0-9]+)*\.[a-z]{2,5}(:[0-9]{1,5})?(\/.*)?$/i.test(urlval)){
            validurl = true;
        }
        labeltext = $("#editlinklabel").val();
        labelclean = cleanTextInput(labeltext);
        $("#editlinklabel").val(labelclean);
        
        iconactive = $('#editlinkform .select-linklist-icons .cc-icon.active');
    }
    if(!validurl) {
        if(urlval.indexOf("/quickLink/") > -1) {
            //console.log(urlval);
            validurl = true;
        }
    }

    if(labeltext.length >= 3) {
        validlabel = true;
    }
    
    if(iconactive.length === 1) {
        validicon = true;
    }
    
    //console.log(validurl);
    //console.log(validlabel);
    //console.log(validicon);
    if(validurl && validlabel && validicon) {
        if(type === "new") {
            $('#newlinksave').removeAttr('disabled');
        }
        else if(type === "edit") {
            $('#editlinksave').removeAttr('disabled');
        }
    }
    else {
        if(type === "new") {
            $('#newlinksave').attr('disabled','disabled');
        }
        else if(type === "edit") {
            $('#editlinksave').attr('disabled','disabled');
        }
    }
    
}

function buildEditLinkForm() {
    
    var formstring = '';
    formstring += '<div class="form-group">';
    formstring += '<label for="editlinkurl">Link address (URL)</label>';
    formstring += '<input type="url" class="form-control" id="editlinkurl" placeholder="https://example.com" autocomplete="off">';
    formstring += '</div>';
    
    formstring += '<div class="form-group">';
    formstring += '<label for="editlinklabel">Link label</label>';
    formstring += '<input type="text" class="form-control" id="editlinklabel" placeholder="Useful resource" autocomplete="off">';
    formstring += '</div>';    
    
    formstring += '<div class="form-group">';
    formstring += '<label for="editlinklabel">Link icon</label>';
    formstring += '<div class="row select-linklist-icons">';
    for(var lli=0; lli<linkliststyles.Icons.length; lli++) {
        var thisicon = linkliststyles.Icons[lli];
        formstring += '<div class="col-4 col-sm-3 col-md-2 mt-2 mb-2">';
        formstring += '<a href="javascript:selectLinkIcon(\''+thisicon.Class+'\', \'edit\')"><div class="m-auto mx-auto cc-icon white-bg '+thisicon.Class+'"></div></a>';
        formstring += '</div>';
    }
    formstring += '</div>';
    formstring += '</div>';
    
    return formstring;
    
}

function buildNewLinkForm() {
    
    var formstring = '';
    formstring += '<div class="form-group">';
    formstring += '<label for="newlinkurl">Link address (URL)</label>';
    formstring += '<input type="url" class="form-control" id="newlinkurl" placeholder="https://example.com" autocomplete="off">';
    formstring += '</div>';
    
    formstring += '<div class="form-group">';
    formstring += '<label for="newlinklabel">Link label</label>';
    formstring += '<input type="text" class="form-control" id="newlinklabel" placeholder="Useful resource" autocomplete="off">';
    formstring += '</div>';    
    
    formstring += '<div class="form-group">';
    formstring += '<label for="newlinklabel">Link icon</label>';
    formstring += '<div class="row select-linklist-icons">';
    for(var lli=0; lli<linkliststyles.Icons.length; lli++) {
        var thisicon = linkliststyles.Icons[lli];
        formstring += '<div class="col-4 col-sm-3 col-md-2 mt-2 mb-2">';
        formstring += '<a href="javascript:selectLinkIcon(\''+thisicon.Class+'\', \'new\')"><div class="m-auto mx-auto cc-icon white-bg '+thisicon.Class+'"></div></a>';
        formstring += '</div>';
    };
    formstring += '</div>';
    formstring += '</div>';
    
    return formstring;
    
}

function selectLinkIcon(cname, type) {
    $('.select-linklist-icons .cc-icon').removeClass('active');
    $('.select-linklist-icons .cc-icon.'+cname).addClass('active');
    
    validateNewLink(type);
}

function addLinkEditButton(index) {
    
    $('.instructor-content .links-container-edit .link-custom[data-llindex="'+index+'"]').prepend('<button type="button" class="btn btn-light btn-link-right" onClick="moveNewLink('+index+',\'right\')" title="Move Link Right"><i class="fas fa-arrow-right"></i></button>');
    $('.instructor-content .links-container-edit .link-custom[data-llindex="'+index+'"]').prepend('<button type="button" class="btn btn-light btn-link-left" onClick="moveNewLink('+index+',\'left\')" title="Move Link Left"><i class="fas fa-arrow-left"></i></button>');
    
    $('.instructor-content .links-container-edit .link-custom[data-llindex="'+index+'"]').append('<button type="button" class="btn btn-light" onClick="editNewLink('+index+')" title="Edit Link"><i class="fas fa-pencil"></i></button>');
    $('.instructor-content .links-container-edit .link-custom[data-llindex="'+index+'"]').append('<button type="button" class="btn btn-light" onClick="deleteNewLink('+index+')" title="Delete Link"><i class="fas fa-trash"></i></button>');
    
}

function addLinkEditButtons() {
    
    $('.instructor-content .links-container-edit .link-custom').each(function(){
        var thisindex = parseInt($(this).attr('data-llindex'));
        var thisitem = alldata.CustomSettings.LinkList.Items[thisindex];
        //console.log(thisitem);
        
        addLinkEditButton(thisindex);
        
    });
    
    $('.instructor-content .links-container-edit .link-custom:first .btn-link-left').attr('disabled','disabled');
    $('.instructor-content .links-container-edit .link-custom:last .btn-link-right').attr('disabled','disabled');
    
}

function buildNewLinkString(linkaddress, labeltext, iconclass, index) {
    
    var linkaddress_lower = linkaddress.toLowerCase();
    if(linkaddress_lower.indexOf("{orgunitid}") > -1) {
        linkaddress = linkaddress.toLowerCase().replace("{orgunitid}", orgUnitId);
    }

    //console.log(linkaddress);
    
    var labelclean = cleanTextInput(labeltext);
    
    var newlinkstring = '';
    newlinkstring += '<div class="link-item link-custom text-center" data-llindex="'+index+'"> ';
    newlinkstring += '<a href="'+linkaddress+'"';
    
    if(index > -1) {
        newlinkstring += ' target="_blank">';
    }
    else {
        newlinkstring += ' id="btn-add-link">';
    }    
    newlinkstring += '<div class="link-ico"> <div class="m-auto mx-auto cc-icon '+iconclass+'"></div></div>';
    newlinkstring += '<div class="link-label"> '+labelclean+' </div>';    
    
    if(index > -1) {
        newlinkstring += ' <span class="sr-only">Opens in a new tab</span>';
    }    
    newlinkstring += '</a>';
    newlinkstring += '</div>';  
    
    return newlinkstring;
}

function editNewLink(index) {
    
    if(index > -1) {
        var thislink = alldata.CustomSettings.LinkList.Items[index];
        //console.log(thislink);

        $('#editlinkurl').val(thislink.URL);
        $('#editlinklabel').val(thislink.Label);

        $('.select-linklist-icons .cc-icon').removeClass("active");
        $('.select-linklist-icons .cc-icon.'+thislink.Icon).addClass("active");

        $('#editlinksave').attr("onClick", 'saveEditLink('+index+')');
        validateNewLink("edit");

        $('#collapseEditLink #editlinkcancel').attr('onClick', 'cancelEditLink('+index+')')
        
        $('#collapseEditLink').collapse('show');  
        $('#collapseEditLink #editlinkcancel').focus();
    }
    else {
        $('#collapseEditText').collapse('show'); 
        $('#collapseEditText #edittextcancel').focus();
    }
    
}

function cancelEditText() {
    $('#collapseEditText').collapse('hide');
    $('.links-container-edit button[onclick="editNewLink(-1)"]').focus();
}

function cancelEditLink(index) {
    $('#collapseEditLink').collapse('hide');
    
    if(index !== undefined) {
        $('.links-container-edit button[onclick="editNewLink('+index+')"]').focus();
    }
    
}

function moved(array, from, to, on = 1) {
    return array = array.slice(), array.splice(to, 0, ...array.splice(from, on)), array;
}

function moveNewLink(index, direction) {
    var newindex;
    if(direction === 'left') {
        newindex = index--;
    }
    else if(direction === 'right') {
        newindex = index++;
    }
    var neworder = moved(alldata.CustomSettings.LinkList.Items, index, newindex, 1);
    //console.log(neworder);
    
    alldata.CustomSettings.LinkList.Items = neworder;
    putCustomWidgetData(CustomWidgetH1);
    
    initializeLinkListCustom();
    addLinkEditButtons();
    
    if(direction === 'left') {
        $('.link-custom[data-llindex='+index+'] .btn-link-right').focus();
    }
    else if(direction === 'right') {
        $('.link-custom[data-llindex='+index+'] .btn-link-left').focus();
    }

}

function deleteNewLink(index) {
    
    if(index > -1) {
        alldata.CustomSettings.LinkList.Items.splice(index,1);
        //console.log(alldata.CustomSettings);
        putCustomWidgetData(CustomWidgetH1);   

        initializeLinkListCustom();
        addLinkEditButtons();        
    }
    else {
        
        alldata.MSTeams.TeamsConnected = false;
        alldata.MSTeams.LastUpdated.Date = getServerTime().toISOString();
        alldata.MSTeams.LastUpdated.User = {
            "FirstName": alldata.WhoAmI.FirstName,
            "LastName": alldata.WhoAmI.LastName
        };
        alldata.MSTeams.MoreInformation = {
            "Dismissed":false,
            "Date":null
        }
        
        putCustomWidgetData(CustomWidgetMS); 
        $('.links-container .scrollable-wrapper .link-msteams').remove();
        
    }
    
}

function saveEditLink(index) {
    
    var linkaddress = $("#editlinkurl").val();
    var labeltext = $("#editlinklabel").val();
    var iconclass = $('#editlinkform .select-linklist-icons .cc-icon.active').attr('class').split(/\s+/)[4];    
    
    var thislink = alldata.CustomSettings.LinkList.Items[index];
    
    thislink.URL = linkaddress;
    thislink.Label = labeltext;
    thislink.Icon = iconclass;

    //console.log(thislink);
    //console.log(alldata.CustomSettings);
    putCustomWidgetData(CustomWidgetH1);  

    initializeLinkListCustom();
    addLinkEditButtons();
    
    $('#collapseEditLink').collapse('hide');
    
}

function saveTextbookSetting() {
    
    var TextbookSaveObj;
    if(alldata.CustomSettings.Textbook !== undefined) {
        TextbookSaveObj = JSON.parse(JSON.stringify(alldata.CustomSettings.Textbook));
    }
    else {
        TextbookSaveObj = JSON.parse(JSON.stringify(textbook_setting_template));
    }
    
    var textbookval = $('.form-check-textbook .form-check-input:checked').val();
    
    TextbookSaveObj.Option = textbookval;
    //console.log(textbookval);
    
    if(textbookval === "text-customurl") {
        var validurl = false;

        if(/^(http|https|ftp):\/\/[a-z0-9]+([\-\.]{1}[a-z0-9]+)*\.[a-z]{2,5}(:[0-9]{1,5})?(\/.*)?$/i.test($("#edittexturl").val())){        
            validurl = true;
        }

        if(validurl) {
            TextbookSaveObj.URL = $("#edittexturl").val();
            //console.log("save");
        }
        else {
            //console.log("no save");
        }
    }
    else if (textbookval === "text-physicalinfo") {
        var validtitle = false;

        var titletext;
        var titleclean;

        var authortext;
        var authorclean;

        var publishertext;
        var publisherclean;

        var isbntext;
        var isbnclean;

        titletext = $(".textinfo-title").val();
        titleclean = cleanTextInput(titletext);
        $(".textinfo-title").val(titleclean);

        authortext = $(".textinfo-author").val();
        authorclean = cleanTextInput(authortext);
        $(".textinfo-author").val(authorclean);

        publishertext = $(".textinfo-publisher").val();
        publisherclean = cleanTextInput(publishertext);
        $(".textinfo-publisher").val(publisherclean);

        isbntext = $(".textinfo-isbn").val();
        isbnclean = cleanTextInput(isbntext);
        $(".textinfo-isbn").val(isbnclean);

        //console.log(titleclean);
        if(titleclean.length > 3) {
            validtitle = true;
        }

        if(validtitle) {
            TextbookSaveObj.Info = {
                Title: titleclean,
                Author: authorclean,
                Publisher: publisherclean,
                ISBN: isbnclean
            }
            //console.log("save");
        }
        else {
            //console.log("no save");
        }
    }
    else {
        //console.log("save");
    }

    //console.log(TextbookSaveObj);
    alldata.CustomSettings.Textbook = TextbookSaveObj;
    putCustomWidgetData(CustomWidgetH1,"Textbook"); 
    
    updateTextbookLink();
    $('#collapseEditText').collapse('hide');    
    
}

function saveNewLink() {

    var linkaddress = $("#newlinkurl").val();
    var labeltext = $("#newlinklabel").val();
    var iconclass = $('#newlinkform .select-linklist-icons .cc-icon.active').attr('class').split(/\s+/)[4];
    
    var labelclean = cleanTextInput(labeltext);
    $("#newlinklabel").val(labelclean);
    
    var saveobj = {
        URL: linkaddress,
        Label: labelclean,
        Icon: iconclass
    }
    //console.log(saveobj);
    
    if(alldata.CustomSettings === null) {
        alldata.CustomSettings = {
            LinkList: {
                Items: [saveobj]
            }
        }
    }
    else {
        if(alldata.CustomSettings.LinkList === undefined) {
            alldata.CustomSettings.LinkList = {
                Items: [saveobj]
            }
        }
        else {
            alldata.CustomSettings.LinkList.Items.push(saveobj)
        }
    }
    
    //console.log(alldata.CustomSettings);
    putCustomWidgetData(CustomWidgetH1);    
    
    initializeLinkListCustom();
    addLinkEditButtons();
    
    $('#collapseNewLink').collapse('hide');
    
}

function saveDashboardSetting() {

    var saveobj = $('#visible-studentaverage').prop('checked');
    
    if(alldata.CustomSettings !== undefined) {
        if(alldata.CustomSettings !== null) {
            if(alldata.CustomSettings.Dashboard !== undefined) {
                if(alldata.CustomSettings.Dashboard !== null) {
                    if(alldata.CustomSettings.Dashboard.Display !== undefined) {
                        if(alldata.CustomSettings.Dashboard.Display === null) {
                            alldata.CustomSettings.Dashboard.Display = JSON.parse(JSON.stringify(dashboard_data_template.Display));
                        }
                    }
                    else {
                        alldata.CustomSettings.Dashboard.Display = JSON.parse(JSON.stringify(dashboard_data_template.Display));
                    }
                }
                else {
                    alldata.CustomSettings.Dashboard = JSON.parse(JSON.stringify(dashboard_data_template));
                }
            }
            else {
                alldata.CustomSettings.Dashboard = JSON.parse(JSON.stringify(dashboard_data_template));
            }
        }
    }

    alldata.CustomSettings.Dashboard.Display.CurrentAverage = saveobj;
    console.log(alldata.CustomSettings);
    
    putCustomWidgetData(CustomWidgetH1,"CurrentAverage");
    
}

function announcePin(announceid) {
    
    var pincontent = '<p>Note that pinning this Announcement will move it to the top of the Announcement list view for yourself and your students. You can unpin at any time. Any End Date set in the future will still automatically remove a pinned announcement from the list view.</p>';
    $('#announcePinModal .modal-body').html(pincontent);
    
    $('#announcePinModal .modal-footer .btn-confirm').attr('onClick','announcePinConfirm('+announceid+')');
    
    $('#announcePinModal').modal('show');
}

function announceUnPin(announceid) {
    var unpincontent = '<p>Note that unpinning this Announcement will move it back into the natural sort order of the Announcement list view for yourself and your students. You can re-pin at any time.</p>';
    $('#announceUnPinModal .modal-body').html(unpincontent);
    
    $('#announceUnPinModal .modal-footer .btn-confirm').attr('onClick','announceUnPinConfirm('+announceid+')');
    
    $('#announceUnPinModal').modal('show');
}

function announceDismiss(announceid) {
    $('#announceDismissModal').modal('show');
}

function announceDeleteConfirm(announceid) {
    //console.log(announceid);
    deleteAnnouncementItem(announceid);
    
    $('#announceDeleteModal').modal('hide');
}

function announceDelete(announceid) {
    var deletecontent = '<p>Note that deleting this Announcement remove it from the Announcement list view for yourself and your students. The option to restore deleted Announcements can be accessed by going to Course Admin > Announcements.</p>';
    $('#announceDeleteModal .modal-body').html(deletecontent);    
    
    $('#announceDeleteModal .modal-footer .btn-confirm').attr('onClick','announceDeleteConfirm('+announceid+')');
    
    $('#announceDeleteModal').modal('show');
    
}


function frameHeight(optionaladd) {
    if(!preventresize) {
        var bodyheight = $("html").outerHeight();
        var newheight;

        if(frameloop) {
            newheight = bodyheight + 100;
        }
        else {
            newheight = bodyheight + 10;
        }

        if(optionaladd !== undefined) {
            newheight += optionaladd;
        }

        window.parent.$('#CourseImageBannerPlaceholderId').css('display','none');

        //console.log(newheight);
        window.parent.$("#homepage1_widget iframe").css("height", (newheight + "px"));

        window.parent.$("#homepage1_widget").closest(".d2l-widget").css({
            "overflow-y": "hidden",
            "height": newheight + "px",
            "margin-top": "30px",
        });
    }
}

$(window).resize(function () {
    //console.log("resize");
    //frameHeight();
});

