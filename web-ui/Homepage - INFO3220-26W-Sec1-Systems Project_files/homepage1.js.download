    var modalbody = '';
    //modalbody += '<p><strong>Availability Information for '+thisinstructor.FirstName +' ' + thisinstructor.LastName + '</strong></p>';
    if(thisinstructor.Availability !== '') {
        hasavail = true;
        //instructorstring += '<h3 class="sec-title">Availability</h3>';

        var availhtml = thisinstructor.Availability;
        
        //var availclean = cleanTextInput(availhtml);
        //console.log(availclean);

        modalbody += '<p>' + availhtml + '</p>';    
    }
