function eTextCheck() {
    
    var addetext = false;
    if(checkAddEtext()) {
        addetext = true;
    }
    
    //console.log(addetext);
    var tstamp = new Date().getTime();
    if(addetext) {
        getExcelData('/shared/CustomTools/eText-Mapping/VitalSource-Mapping.xlsx?t='+tstamp);
    }
    else {
        alldone.ETextMap = true;
        checkCourseScores();
    }
    
}


function checkAddEtext() {
    
    thiscourse = alldata;
    
    //console.log(thiscourse);
    var addetext = false;
                  
    if(!thiscourse.NotSection) {
        if(thiscourse.Semester !== undefined) {
            //console.log(thiscourse.Semester);
            if(thiscourse.Semester.Year > 24) {    
                if(thiscourse.SIS !== null) {
                    if(thiscourse.SIS.eText) {
                        if(alldata.SIS.eTextAmount !== null) {
                            if(alldata.SIS.eTextAmount > 0) {                        
                                addetext = true;
                            }
                        }
                    }                    
                }
            }
            else if(thiscourse.Semester.Year === 24) {
                if(thiscourse.Semester.Term === 'F') {
                    if(thiscourse.SIS !== null) {
                        if(thiscourse.SIS.eText) {
                            if(alldata.SIS.eTextAmount !== null) {
                                if(alldata.SIS.eTextAmount > 0) {                        
                                    addetext = true;
                                }
                            }
                        }                    
                    }
                }
            }
        }
    }
    else {
        // Models will need to be checked
        addetext = true;
    }
    
    //console.log(addetext);
    return addetext;
}


function checkExcelEtext(thiscourse) {
    //console.log(thiscourse);
    //console.log(etextmapping);
    var excelfound = false;
    
    for(var ee=0; ee<etextmapping.length; ee++) {
        thiscode = etextmapping[ee][colname_code].trim();

        if(thiscourse.CourseOffering.Code.indexOf(thiscode) > -1) {       
            excelfound = true;                                 
        }
    }
    
    //console.log(excelfound);
    return (excelfound);
    
}


function excelDataLoadInit(e, req) {
	var data = new Uint8Array(req.response);
	etextworkbook = XLSX.read(data, {
		type: "array"
	});

	sheetname = etextworkbook.Workbook.Sheets[0].name;
	etextmapping = XLSX.utils.sheet_to_json(etextworkbook.Sheets[sheetname]);
    colname_code = etextworkbook.Sheets[sheetname].A1.h;
    //console.log(colname_code);
    //colname_cat1 = etextworkbook.Sheets[sheetname].B1.h;
    //colname_cat2 = etextworkbook.Sheets[sheetname].C1.h;
    //colname_cat3 = etextworkbook.Sheets[sheetname].D1.h;
    //colname_other = etextworkbook.Sheets[sheetname].E1.h;

    alldone.ETextMap = true;
    checkCourseScores();
}

function getExcelData(filepath) {
	/* set up async GET request */
	var req = new XMLHttpRequest();
	req.open("GET", filepath, true);
	req.responseType = "arraybuffer";
	req.onload = function (e) {
        
        //console.log(req);
		if(req.status == 200) {
			excelDataLoadInit(e, req);
		}

		/* DO SOMETHING WITH workbook HERE */
	}
	req.send();
}


function ltiSearchTOC() {
    
    var eTextSearch = JSON.parse(JSON.stringify(etextltilist_24S));
    for(var et=0; et<eTextSearch.length; et++) {
        var top_etext = [];
        if(alldata.Content.Modules.length > 0) {
            for(var li=0; li< eTextSearch[et].LinkID.length; li++) {
                for (var m = 0; m < alldata.Content.Modules.length; m++) {
                    top_etext = findContentTopicsAll("ToolItemId", eTextSearch[et].LinkID[li], alldata.Content.Modules[m], top_etext);
                }
            }            
            eTextSearch[et].Search = top_etext;
        }
        else {
            eTextSearch[et].Search = [];
        }            
    }
    
    alldata.EText = eTextSearch;
    var tstamp = new Date().getTime();
    
    $.getJSON('assets/json/homepage1-publisher-support.json?t=' + tstamp, function(data) {
        //console.log(data);   
        
        var tstart = new Date().getTime();
        //console.log(tstart);
        for(pub=0; pub<data.length; pub++) {
            if(data[pub].links.length > 0) {
                for(var publ=0; publ < data[pub].links.length; publ++) {
                    if(data[pub].links[publ].linkID !== '') {
                        var top_thispub = [];
                        if(alldata.Content.Modules.length > 0) {
                            for (var m = 0; m < alldata.Content.Modules.length; m++) {                
                                findContentTopicsAll('ToolItemId', parseInt(data[pub].links[publ].linkID), alldata.Content.Modules[m], top_thispub);
                            }
                        }
                        if(data[pub].Found === undefined) {
                            data[pub].Found = [{linkID: data[pub].links[publ].linkID, Topics:top_thispub}];
                        }
                        else {
                            data[pub].Found.push({linkID: data[pub].links[publ].linkID, Topics:top_thispub});
                        }
                    }
                }
            }
        }
        var tend = new Date().getTime();
        //console.log(tend);
        //console.log(tend - tstart);
        alldata.Publishers = data;
        
        checkContentSearchDone();
        
        //console.log(alldata.Publishers);
    });
    
    checkContentSearchDone();
}


function processCustomDates() {
    
    if(alldata.InstructionalPlan.Data !== null) {
        if(alldata.InstructionalPlan.Data.Grades !== undefined) {
            for(var i=0; i<alldata.InstructionalPlan.Data.Grades.length; i++) {            
                var thisip = alldata.InstructionalPlan.Data.Grades[i];            
                for(var g=0; g<alldata.GradeItems.Objects.length; g++) {
                    var thisgrade = alldata.GradeItems.Objects[g];
                    if(thisip.Id === thisgrade.Id) {
                        thisgrade.EndDate = thisip.EndDateTime;
                        thisgrade.DateFromIP = true;
                        
                        if(thisgrade.AssociatedTool !== null) {
                            if(thisgrade.AssociatedTool.ToolId === 3000) {
                                for(var d=0; d<alldata.DiscussionsAll.Objects.length; d++) {
                                    var thisforum = alldata.DiscussionsAll.Objects[d];
                                    for(var dt=0; dt<thisforum.Topics.length; dt++) {
                                        var thistopic = thisforum.Topics[dt];
                                        if(thistopic.TopicId === thisgrade.AssociatedTool.ToolItemId) {
                                            if(thisip.StartDateTime !== undefined) {
                                                if(thisip.StartDateTime !== null) {
                                                    thistopic.StartDate = thisip.StartDateTime;
                                                }
                                            }
                                            if(thisip.EndDateTime !== undefined) {
                                                if(thisip.EndDateTime !== null) {
                                                    thistopic.EndDate = thisip.EndDateTime;
                                                }
                                            }
                                            break;
                                        }
                                    }
                                }       
                            }
                        }    
                        break;
                    }
                }
            }
        }    
    }
}


