function findInstructionalPlan() {
    var top_ipdw = [];
    for (var m = 0; m < alldata.Content.Modules.length; m++) {
        top_ipdw = findContentTopicsAll("Url", "ipdw_", alldata.Content.Modules[m], top_ipdw);
    }
    
    var top_other = [];
    for (var m = 0; m < alldata.Content.Modules.length; m++) {
        top_other = findContentTopicsAll("Title", "instructional plan", alldata.Content.Modules[m], top_other);
    }
    
    //console.log(top_ipdw);
    //console.log(top_other);
    
    alldata.InstructionalPlan = {
        Topics: {
            Dynamic: top_ipdw,
            Other: top_other
        }
    }

    if(top_ipdw.length > 0) {
        processInstructionalPlan(top_ipdw);
    }
    else {
        alldata.InstructionalPlan.Data = null;
        checkContentSearchDone();
        // No Instructional Plan found, or too many Instructional Plans found.
    }
}


function updateWidgetDataAuto() {
    
    if((coursedatesdone===true) && (coursescoredone===true) && (coursegradesdone===true) && (coursedeliverydone===true)) {
        
        var numstudents = alldata.Classlist.Objects.length;
        var minpublished = 0.6;
        var weightpublished = 0;
        
        var catchecks = [];
        
        //console.log(omissing);
        //console.log(alldata.Outline[0].ListOutcomes.length);
        //console.log(alldata.GradeItems);

        for(var gi=0; gi<alldata.GradeItems.Objects.length; gi++) {
            var thisgrade = alldata.GradeItems.Objects[gi];
            if(!thisgrade.IsBonus) {
                var gradepercent = (thisgrade.NumEvals / numstudents);
                if(gradepercent >= minpublished) {
                    if(thisgrade.CategoryId === 0) {
                        weightpublished += thisgrade.WeightCalc;
                    }
                    else {
                        catchecks.push(thisgrade);
                    }
                }
            }
        }
        
        for(var gc=0; gc<alldata.GradeCategories.length; gc++) {
            var thiscat = alldata.GradeCategories[gc];
            thiscat.Published = 0;
            for(var gi=0; gi<thiscat.Grades.length; gi++) {
                var thisgrade = thiscat.Grades[gi];
                for(var cc=0; cc<catchecks.length; cc++) {
                    if(thisgrade.Id === catchecks[cc].Id) {
                        thiscat.Published += catchecks[cc].WeightCalc;
                    }
                }
            }
            if(thiscat.Published > thiscat.Weight) {
                weightpublished += thiscat.Weight;
            }
            else {
                weightpublished += thiscat.Published;
            }
        }        
        
        //console.log(alldata.CurrentWeek);
        //console.log(weightpublished.toFixed(2));
        
        var cweek = null;
        if(alldata.CurrentWeek !== undefined) {
            cweek = alldata.CurrentWeek;
        }
        
        alldata.EEScanner.Grades = {
            CurrentWeek: cweek,
            PublishedWeight: parseFloat(weightpublished.toFixed(2))
        }
        
        var ototal = 0;
        if(alldata.Outline !== undefined) {
            if(alldata.Outline !== null) {
                if(alldata.Outline.length > 0) {
                    ototal = alldata.Outline[0].ListOutcomes.length
                }
            }
        }
        
        alldata.EEScanner.Outcomes = {
            Total: ototal,
            Missing: omissing.length
        }
        
        if(alldata.SIS !== undefined) {
            if(alldata.SIS !== null) {
                alldata.EEScanner.DeliveryMode = alldata.SIS.DeliveryMode
            }
        }
        
        putCustomWidgetData(CustomWidgetEE);
    }
    
}

