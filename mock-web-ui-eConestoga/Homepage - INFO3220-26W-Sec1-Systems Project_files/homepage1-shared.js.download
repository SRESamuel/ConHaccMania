// JavaScript Document

function dhm(ms){
    days = Math.floor(ms / (24*60*60*1000));
    daysms=ms % (24*60*60*1000);
    hours = Math.floor((daysms)/(60*60*1000));
    hoursms=ms % (60*60*1000);
    minutes = Math.floor((hoursms)/(60*1000));
    minutesms=ms % (60*1000);
    sec = Math.floor((minutesms)/(1000));
    return days+"d "+hours+"h "+minutes+"m "+sec+"s";
}


Array.prototype.indexOfObject = function arrayObjectIndexOf(property, value) {
    for (var i = 0, len = this.length; i < len; i++) {
        if (this[i][property] === value) return i;
    }
    return -1;
}


function insertSpaces(str) {
    str = str
        .replace(/(_|-)/g, ' ')
        .trim()
        .replace(/\w\S*/g, function (str) {
            return str.charAt(0).toUpperCase() + str.substr(1)
        })
        .replace(/([a-z])([A-Z])/g, '$1 $2')
        .replace(/([A-Z])([A-Z][a-z])/g, '$1 $2')
    return str;
}


function processProgressTOC(Module) {

   var fileExtPattern = /\.[0-9a-z]+$/i;
   var linkPieces = [];

   // Create the Progress object for the module
   Module.Progress = {
      'Read': 0,
      'Total': 0,
      'Percentage': 0
   }

   // Check for submodules
   if (Module.Modules !== undefined) {
      for (var i = 0; i < Module.Modules.length; i++) {
         Module.Modules[i] = processProgressTOC(Module.Modules[i]);
         Module.Progress.Total += Module.Modules[i].Progress.Total;
         Module.Progress.Read += Module.Modules[i].Progress.Read;
      }
   } else {
      // Create an empty array for Modules if undefined so it won't cause headaches later
      Module.Modules = [];
   }

   // Parse topics to determine type and source
   if (Module.Topics !== undefined) {
      for (var j = 0; j < Module.Topics.length; j++) {
         // Increment the progress counters
         Module.Progress.Total++;
         if (Module.Topics[j].Unread == false) {
            Module.Progress.Read++;
         }
         // TypeIdentifier = 'Link' => check for D2L tool types first
         if ((Module.Topics[j].TypeIdentifier == 'Link') && (Module.Topics[j].Url.substr(0, 4) == '/d2l')) {
            if (Module.Topics[j].Url.indexOf('&type=discuss&') > -1) {
               Module.Topics[j].Type = 'Discussion';
            } else if (Module.Topics[j].Url.indexOf('&type=dropbox&') > -1) {
               Module.Topics[j].Type = 'Dropbox';
            } else if (Module.Topics[j].Url.indexOf('&type=quiz&') > -1) {
               Module.Topics[j].Type = 'Quiz';
            } else if (Module.Topics[j].Url.indexOf('&type=checklist&') > -1) {
               Module.Topics[j].Type = 'Checklist';
            } else if (Module.Topics[j].Url.indexOf('&type=selfassess&') > -1) {
               Module.Topics[j].Type = 'SelfAssessment';
            } else if (Module.Topics[j].Url.indexOf('&type=survey&') > -1) {
               Module.Topics[j].Type = 'Survey';
            }

            Module.Topics[j].Source = 'Internal';
         }
         // TypeIdentifier = 'Link' => check external link types
         else if (Module.Topics[j].TypeIdentifier == 'Link') {
            Module.Topics[j].Type = Module.Topics[j].Url.substr((~-Module.Topics[j].Url.lastIndexOf(".") >>> 0) + 2);
            Module.Topics[j].Source = 'External';
         }
         // TypeIdentifier = 'File' => check the file extension
         else if (Module.Topics[j].TypeIdentifier == 'File') {
            if (Module.Topics[j].Url !== null) {
               Module.Topics[j].Type = Module.Topics[j].Url.substr((~-Module.Topics[j].Url.lastIndexOf(".") >>> 0) + 2);
               Module.Topics[j].Source = 'Internal';
            }
         } else {
            Module.Topics[j].Type = 'unknown';
            Module.Topics[j].Source = 'unknown';
         }
      }
   } else {
      // Create an empty array for Topics if undefined so it won't cause headaches later
      Module.Topics = [];
   }

   // Update the progress percentage
   Module.Progress.Percentage = (Module.Progress.Total == 0) ? 0 : Module.Progress.Read / Module.Progress.Total * 100;

   return Module;
};


function findModulesByAtt(att, term, module, modarray) {
    var allmods = modarray;

    if (module[att] !== null) {

        if (term === "notnull") {
            var robj = {
                Module: module
            }
            allmods.push(robj);
        } else {
            if (jQuery.type(module[att]) === "string") {
                if (module[att].toLowerCase().indexOf(term.toLowerCase()) > -1) {
                    var robj = {
                        Module: module
                    }
                    allmods.push(robj);
                }
            } else {
                if (module[att] === term) {
                    var robj = {
                        Module: module
                    }
                    allmods.push(robj);
                }
            }
        }
    }


    if (module.Modules.length > 0) {
        for (var s = 0; s < module.Modules.length; s++) {
            allmods = findModulesByAtt(att, term, module.Modules[s], allmods);
        }
    }

    return allmods;
}


function findModulesAll(term, results, module, parentids) {
    
    //console.log(module);
    //console.log(parentids);
    
    if (module.Title.toLowerCase().indexOf(term.toLowerCase()) > -1) {
        if(parentids !== undefined) {
            module.Parents = parentids;
        }
        results.push(JSON.parse(JSON.stringify(module)));
    }

    if (module.Modules.length > 0) {
        for (var s = 0; s < module.Modules.length; s++) {
            var parentidsend;
            if(parentids === undefined) {
                parentidsend = [module.ModuleId];
            }
            else {
                parentidsend = parentids;
                parentidsend.push(module.ModuleId);
            }
            findModulesAll(term, results, module.Modules[s], parentidsend);
        }
    }

    return results;

}


function findModuleItems(module, topicarray) {
    var alltopics = topicarray;

    if (module.Topics.length > 0) {
        alltopics = alltopics.concat(module.Topics);
    }

    if (module.Modules.length > 0) {
        for (var s = 0; s < module.Modules.length; s++) {
            alltopics = findModuleItems(module.Modules[s], alltopics);
        }
    }

    return alltopics;
}


function findModule(term, exact, module) {

    var modulefound;
    if (exact) {
        if (module.Title.toLowerCase() === term.toLowerCase()) {
            modulefound = module;
        }
    } else {
        if (module.Title.toLowerCase().indexOf(term.toLowerCase()) > -1) {
            modulefound = module;
        }
    }

    if (modulefound === undefined) {
        if (module.Modules.length > 0) {
            for (var s = 0; s < module.Modules.length; s++) {
                modulefound = findModule(term, exact, module.Modules[s]);
                if (modulefound !== undefined) {
                    break;
                }
            }
        }
    }
    return modulefound;
}


function findContentTopicsAll(att, term, module, topicarray) {
    var alltopics = topicarray;

    if (module.Topics.length > 0) {
        for (var t = 0; t < module.Topics.length; t++) {
            if (module.Topics[t][att] !== null) {

                if (term === "notnull") {
                    var robj = {
                        Module: module,
                        Topic: module.Topics[t]
                    }
                    alltopics.push(robj);
                } else {
                    if (jQuery.type(module.Topics[t][att]) === "string") {
                        if (module.Topics[t][att].toLowerCase().indexOf(term.toLowerCase()) > -1) {
                            var robj = {
                                Module: module,
                                Topic: module.Topics[t]
                            }
                            alltopics.push(robj);
                        }
                    } else {
                        if (module.Topics[t][att] === term) {
                            var robj = {
                                Module: module,
                                Topic: module.Topics[t]
                            }

                            alltopics.push(robj);
                        }
                    }
                }
            }
        }
    }

    if (module.Modules.length > 0) {
        for (var s = 0; s < module.Modules.length; s++) {
            alltopics = findContentTopicsAll(att, term, module.Modules[s], alltopics);
        }
    }

    return alltopics;

}


function findContentTopic(att, term, module) {

    var topicfound;
    if (module.Modules.length > 0) {
        for (var s = 0; s < module.Modules.length; s++) {
            topicfound = findContentTopic(att, term, module.Modules[s]);
            if (topicfound !== undefined) {
                break;
            }
        }
    }

    if (topicfound === undefined) {
        for (var t = 0; t < module.Topics.length; t++) {
            if (module.Topics[t][att] !== null) {

                if (jQuery.type(module.Topics[t][att]) === "string") {
                    if (module.Topics[t][att].toLowerCase().indexOf(term.toLowerCase()) > -1) {
                        topicfound = module.Topics[t];
                        break;
                    }
                } else {
                    if (module.Topics[t][att] === term) {
                        topicfound = module.Topics[t];
                        break;
                    }
                }
            }
        }
    }
    return topicfound;
}


function findModuleDates(module, modulearray) {
    var datemodules = modulearray;

    if ((module.StartDateTime !== null) || (module.EndDateTime !== null)) {
        datemodules.push(module);
    }

    if (module.Modules.length > 0) {
        for (var s = 0; s < module.Modules.length; s++) {
            datemodules = findModuleDates(module.Modules[s], datemodules);
        }
    }

    return datemodules;

}


function findContentTopicDates(module, topicarray, parents) {

    var pmod = parents;
    var datetopics = topicarray;
    if (module.Topics.length > 0) {
        for (var t = 0; t < module.Topics.length; t++) {
            if ((module.Topics[t].StartDateTime !== null) || (module.Topics[t].EndDateTime !== null)) {

                //if(module.Topics[t].)
                var robj = {
                    Parents: pmod,
                    Topic: module.Topics[t]
                }

                datetopics.push(robj);

            }
        }
    }

    if (module.Modules.length > 0) {
        for (var s = 0; s < module.Modules.length; s++) {
            var psub = [...pmod];
            psub.push(module.Modules[s]);
            datetopics = findContentTopicDates(module.Modules[s], datetopics, psub);
        }
    }

    return datetopics;

}


