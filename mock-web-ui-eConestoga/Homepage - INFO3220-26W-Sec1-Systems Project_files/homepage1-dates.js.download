                    datearray.push('<strong>Due Date: (' + getItemWeekNum(assessitem.UnlockEndDate) + ') ' + dstring + '</strong>');
                } else {
                    var dstring = assessitem.UnlockEndDate.toLocaleDateString('en-us', { weekday:"long", year:"numeric", month:"long", day:"numeric"}) + ", " + formatAMPM(assessitem.UnlockEndDate);
                    
                    if(assessitem.UnlockEndDate < wobj.StartDate) {
                        datearray.push('Due Date: (Previous Week) ' + dstring);
                    }
                    else {
                        datearray.push('Due Date: (Upcoming Week) ' + dstring);
                    }
                }
            }
        }
    }
    if (assessitem.Type === 'GradeItem') {
        if (assessitem.EndDate !== null) {
            if (sortdate === undefined) {
                sortdate = assessitem.EndDate;
            }
            var dstring = assessitem.EndDate.toLocaleDateString('en-us', { weekday:"long", year:"numeric", month:"long", day:"numeric"}) + ", " + formatAMPM(assessitem.EndDate);
            datearray.push('<strong>Due Date: ' + dstring + '</strong>');
        }
    }

    if (datearray.length > 0) {
        assessstring += '<ul>';
        for (var da = 0; da < datearray.length; da++) {
            assessstring += '<li>' + datearray[da] + '</li>';
        }
        assessstring += '</ul>';
    }
    assessstring += '</p>';
    assessstring += '</div>';
    assessstring += '</td></tr>';

    var robj = {
        HTML: assessstring,
        StartDateTime: sortdate
    }
    return robj;
}


function processDateTypes() {

    if (alldata.Schedule !== undefined) {
        for (var s = 0; s < alldata.Schedule.length; s++) {
            alldata.Schedule[s].Associations.SortByDate = [];
            alldata.Schedule[s].Associations.IsGraded = [];
            alldata.Schedule[s].Associations.Activity = [];
            alldata.Schedule[s].Associations.IsDiscussion = [];
            if (alldata.Schedule[s].Associations.Assessment.length > 0) {
                for (var aa = 0; aa < alldata.Schedule[s].Associations.Assessment.length; aa++) {
                    var assessitem = alldata.Schedule[s].Associations.Assessment[aa];

                    var gid = -1;
                    if (assessitem.Data.gradeItemId !== undefined) {
                        if (assessitem.Data.gradeItemId !== null) {
                            gid = assessitem.Data.gradeItemId;
                        }
                    }
                    if (assessitem.Data.GradeItemId !== undefined) {
                        if (assessitem.Data.GradeItemId !== null) {
                            gid = assessitem.Data.GradeItemId;
                        }
                    }
                    if (assessitem.Type === 'GradeItem') {
                        gid = assessitem.ItemId;
                    }

                    if (gid > -1) {
                        var assesshtml = generateAssessString(assessitem, alldata.Schedule[s], true);
                    } else {
                        var assesshtml = generateAssessString(assessitem, alldata.Schedule[s], false);
                    }

                    alldata.Schedule[s].Associations.SortByDate.push(assesshtml);

                    if (gid > -1) {
                        alldata.Schedule[s].Associations.IsGraded.push(assesshtml);
                    } else {
                        alldata.Schedule[s].Associations.Activity.push(assesshtml);
                    }

                }
            }
            if (alldata.Schedule[s].Associations.Communication.length > 0) {
                for (var ac = 0; ac < alldata.Schedule[s].Associations.Communication.length; ac++) {
                    var thiscomm = alldata.Schedule[s].Associations.Communication[ac];
                    var issynch = false;
                    var synchdex = -1;
                    for (var sy = 0; sy < alldata.Synchronous.length; sy++) {
                        if (thiscomm.ItemId === alldata.Synchronous[sy].event.CalendarEventId) {
                            issynch = true;
                            synchdex = sy;
                            break;
                        }
                    }

                    if (!issynch) {
                        var commobj = generateCommString(thiscomm);
                        if (commobj.IsDiscussion) {
                            alldata.Schedule[s].Associations.IsDiscussion.push(commobj);
                        } else {
                            alldata.Schedule[s].Associations.SortByDate.push(commobj);
                        }
                    }
                }
            }

            if (alldata.Schedule[s].Synchronous.length > 0) {
                for (var z = 0; z < alldata.Schedule[s].Synchronous.length; z++) {
                    var dateobj = zoomDateInfo(alldata.Schedule[s].Synchronous[z].event);
                    //console.log(dateobj);

                    var om_html = '';
                    om_html += '<tr class="scheduledateitem">';
                    //om_html += '<th class="tdlabel d-none d-md-table-cell">Online Meeting</th>';
                    om_html += '<td class="tdcontent">';
                    om_html += '<div class="assessbox assesstype-CalendarEvent">'
                    om_html += '<p><a href="' + alldata.Schedule[s].Synchronous[z].href + '" target="_blank">' + alldata.Schedule[s].Synchronous[z].event.Title + ' <i class="fas fa-external-link" aria-hidden="true"></i><span class="sr-only">Opens in a new tab</span></a></p>';
                    om_html += '<ul>';
                    om_html += '<li><strong>Online Meeting: ' + dateobj.DateString + ', ' + dateobj.TimeRange + '</strong></li>';
                    om_html += '</ul>';
                    om_html += '</div>';
                    om_html += '</td>';

                    var robj = {
                        HTML: om_html,
                        StartDateTime: alldata.Schedule[s].Synchronous[z].event.StartDateTime
                    }
                    alldata.Schedule[s].Associations.SortByDate.push(robj);

                }
            }

            alldata.Schedule[s].Associations.SortByDate.sort(dateSort);
            alldata.Schedule[s].Associations.IsGraded.sort(dateSort);
            alldata.Schedule[s].Associations.Activity.sort(dateSort);
            //console.log(alldata.Schedule[s].Associations.SortByDate);
        }
    }

}


function processCalendarDesc() {

    alldata.Synchronous = [];

    for (var c = 0; c < alldata.CalendarAll.length; c++) {

        var withincourse = true;
        if (alldata.CourseOffering.StartDate !== null) {
            var checkstart = new Date(alldata.CourseOffering.StartDate);
            if (alldata.CalendarAll[c].EndDateTime < checkstart) {
                withincourse = false;
            }
        }

        if (alldata.CourseOffering.EndDate !== null) {
            var checkend = new Date(alldata.CourseOffering.EndDate);
            if (alldata.CalendarAll[c].EndDateTime > checkend) {
                withincourse = false;
            }
        }

        if (withincourse) {
            if (alldata.CalendarAll[c].Description !== "") {
                var thishtml = $.parseHTML(alldata.CalendarAll[c].Description);
                //console.log(thishtml);

                var afound = $(thishtml).find("a");
                //console.log(afound);

                var azoomhref = "";
                for (var a = 0; a < afound.length; a++) {
                    if ((afound[a].href.indexOf("conestogac.zoom.us/j/") > -1) ||
                        (afound[a].href.indexOf("conestogac.zoom.us/s/") > -1) ||
                        (afound[a].href.indexOf("conestogac.zoom.us%2Fj%2F") > -1) ||
                        (afound[a].href.indexOf("conestogac.zoom.us/my/") > -1) ||
                        (afound[a].href.indexOf("conestogac.zoom.us/meeting/") > -1) ||
                        ((afound[a].href.indexOf("teams.microsoft.com") > -1) && (afound[a].href.indexOf("meetup-join") > -1))
                    ) {
                        if(afound[a].href.indexOf("/ics?") === -1) {
                            azoomhref = afound[a].href;
                            break;
                        }
                    }
                }

                if (azoomhref !== "") {
                    var zoomlink = {
                        "href": azoomhref,
                        "event": alldata.CalendarAll[c]
                    }
                    alldata.Synchronous.push(zoomlink);
                }
            }
        }
    }
}


function processGradeMatching() {
    for(var gi=0; gi<alldata.GradeItems.Objects.length; gi++) {
        var thisgradeitem = alldata.GradeItems.Objects[gi];
        if(thisgradeitem.AssociatedTool === null) {
            var titletopics = [];
            for (var m = 0; m < alldata.Content.Modules.length; m++) {
                titletopics = findContentTopicsAll("Title", thisgradeitem.Name, alldata.Content.Modules[m], titletopics);
            }
            if(titletopics.length > 0) {
                for(var tt=0; tt<titletopics.length; tt++) {
                    //only watch exact title matches
                    if(titletopics[tt].Topic.Title === thisgradeitem.Name) {
                        var hasdates = false;
                        if(titletopics[tt].Topic.StartDateTime !== null) {
                            hasdates = true;
                        }
                        if(titletopics[tt].Topic.EndDateTime !== null) {
                            hasdates = true;
                        }
                        if(titletopics[tt].Topic.DueDateTime !== undefined) {
                            if(titletopics[tt].Topic.DueDateTime !== null) {
                                hasdates = true;
                                titletopics[tt].Topic.EndDateTime = titletopics[tt].Topic.DueDateTime;
                            }
                        }
                        if(hasdates) {
                            thisgradeitem.AssociatedTool = {
                                ToolId: titletopics[tt].Topic.ToolId,
                                ToolItemId: titletopics[tt].Topic.ToolItemId
                            }
                            titletopics[tt].Topic.GradeItemId = thisgradeitem.Id
                            break;
                        }                        
                    }
                }
            }
            //console.log(titletopics);
        }
    }
}


var thispagedata;
var omissing = [];
var coursedatesdone = false;
function buildCourseDates() {

    //console.log("processing");

    var manualweeks = -1;
    if (alldata.InstructionalPlan.Data !== null) {

        thispagedata = alldata.InstructionalPlan.Data;

        if (thispagedata.StartDateMod !== undefined) {

            var dataok_week = false;
            var dataok_num = false;
            if (thispagedata.StartDateMod.WeekDate !== undefined) {

                var checkdate_s = new Date(alldata.CourseOffering.StartDate);
                var checkdate_e = new Date(alldata.CourseOffering.EndDate);
                var checkdate = new Date(thispagedata.StartDateMod.WeekDate);
                if ((checkdate >= checkdate_s) && (checkdate <= checkdate_e)) {
                    dataok_week = true;
                    alldata.CourseOffering.StartDate = thispagedata.StartDateMod.WeekDate;
                }
            }

            if (dataok_week) {
                if (thispagedata.StartDateMod.WeekNum !== undefined) {
                    // Need to add extra check to make sure Weeks doesn't run past end date of course.
                    if (thispagedata.StartDateMod.WeekNum > -1) {
                        dataok_num = true;
                        manualweeks = thispagedata.StartDateMod.WeekNum;
                    }
                }
            }
        }
    }
    
    omissing = [];
    //console.log(alldata.Outline);
    if (alldata.Outline.length > 0) {
        alldata.Outline[0].ListOutcomes = [];

        //console.log(alldata.Outline);
        alldata.Outline[0].UnitOutcomes.sort(compareOutcomes);
        for (var o1 = 0; o1 < alldata.Outline[0].UnitOutcomes.length; o1++) {
            var thisoutcome = alldata.Outline[0].UnitOutcomes[o1];
            processOutcomeData(thisoutcome, thisoutcome.Description, o1);
        }
    }    
    

    processCalendarDesc();
    processCourseDates();

    if (manualweeks > -1) {
        processCourseSchedule(manualweeks);
    } else {
        processCourseSchedule();
    }
    processDateTypes();
 

    var tdate = new Date();
    var thisweek;

    if (alldata.Schedule !== undefined) {
        for (var cs = 0; cs < alldata.Schedule.length; cs++) {

            var weekcheck = alldata.Schedule[cs];
            if ((tdate >= weekcheck.StartDate) && (tdate < weekcheck.EndDate)) {
                thisweek = weekcheck;
                break;
            }
        }
    }

    if (thisweek !== undefined) {
        displayCourseDates(thisweek);
        alldata.CurrentWeek = thisweek.WeekNum;
    }
    else {
        if(alldata.Schedule.length > 0) {
            displayCourseDates(alldata.Schedule[0]);
            alldata.CurrentWeek = alldata.Schedule[0].WeekNum; 
        }
    }
    
    //console.log(omissing);
    coursedatesdone = true;
    updateWidgetDataAuto();

    $('.weekly-carousel-controls .carousel-previous').attr('onClick', 'weekNavPrev()');
    $('.weekly-carousel-controls .carousel-next').attr('onClick', 'weekNavNext()');
    $('.weekly-carousel-controls .carousel-previous').removeAttr('disabled');
    $('.weekly-carousel-controls .carousel-next').removeAttr('disabled');

}


function showThisWeekActivities() {
    
    var activepanel = $('.cc-homepage-content.active');
    //console.log(activepanel);
    
    var activeclass;
    if($(activepanel).hasClass('instructor-content')) {
        activeclass = "instructor-content";
    }
    if($(activepanel).hasClass('student-content')) {
        activeclass = "student-content";
    }

    var thisweek;
    if (alldata.CurrentWeek !== undefined) {
        for (var s = 0; s < alldata.Schedule.length; s++) {
            if (alldata.Schedule[s].WeekNum === alldata.CurrentWeek) {
                thisweek = alldata.Schedule[s];
            }
        }

        var thisweekdates = "";

        thisweekdates += "<table>";
        thisweekdates += "<tbody>";

        for (var twd = 0; twd < thisweek.Associations.SortByDate.length; twd++) {
            thisweekdates += thisweek.Associations.SortByDate[twd].HTML;
        }

        thisweekdates += "</tbody>";
        thisweekdates += "</table>";

        $('.' + activeclass + ' .collapseThisWeekActivities .card-body').html(thisweekdates);
        $('.' + activeclass + ' .collapseThisWeekActivities').collapse('toggle');

        var currentstate = $('.comingup-weekdatesall .management-button').attr('aria-expanded');
        //console.log(currentstate);
        if (currentstate === "false") {
            $('.' + activeclass + ' .comingup-weekdatesall .management-button').attr('aria-expanded', 'true');
        } else {
            $('.' + activeclass + ' .comingup-weekdatesall .management-button').attr('aria-expanded', 'false');
        }

    }

    //frameHeight();

}

function showThisWeekOutcomes() {

    var thisweek;
    if (alldata.CurrentWeek !== undefined) {
        for (var s = 0; s < alldata.Schedule.length; s++) {
            if (alldata.Schedule[s].WeekNum === alldata.CurrentWeek) {
                thisweek = alldata.Schedule[s];
            }
        }

        var thisweekoutcomes = "";
        thisweekoutcomes += "<ul>";
        thisweekoutcomes += thisweek.Outcomes.ohtml;
        thisweekoutcomes += "</ul>";

        $('#unitOutcomesModal .modal-body').html(thisweekoutcomes);
        $('#unitOutcomesModal').modal('toggle');

    }

    //frameHeight();
}

function displayCourseDates(thisweek) {

    //console.log(thisweek);
    var weektitle = '';

    $('.thisweek-start').text("Start: " + thisweek.StartDate.toLocaleDateString('en-us', { weekday: "long", year: "numeric", month: "long", day: "numeric" }));
    $('.thisweek-start').attr('data-date', thisweek.StartDate.toISOString());
    $('.thisweek-end').text("End: " + thisweek.EndDate.toLocaleDateString('en-us', { weekday: "long", year: "numeric", month: "long", day: "numeric" }));
    $('.thisweek-end').attr('data-date', thisweek.EndDate.toISOString());

    var weekdatecount = thisweek.Associations.SortByDate.length;
    $('.comingup-weekdatesall .management-count').text(weekdatecount);

    if (weekdatecount > 0) {
        $('.comingup-weekdatesall').attr('href', 'javascript:showThisWeekActivities()');
        $('.comingup-weekdatesall').removeAttr('disabled');
        $('.comingup-weekdatesall').addClass('active');
    } else {
        $('.comingup-weekdatesall').removeAttr('href');
        $('.comingup-weekdatesall').attr('disabled', 'disabled');
        $('.comingup-weekdatesall').removeClass('active');
    }

    $('.thisweek-events').removeClass('d-none');
    
    /*
    $('.thisweek-isgraded .week-tile-badge').text(thisweek.Associations.IsGraded.length);
    if(thisweek.Associations.IsGraded.length > 0) {
        $('.thisweek-isgraded').attr('href','javascript:showThisWeekGraded()');
        $('.thisweek-isgraded').removeAttr('disabled');
    }
    else {
        $('.thisweek-isgraded').removeAttr('href');
        $('.thisweek-isgraded').attr('disabled','disabled');
    }
    
    $('.thisweek-activity .week-tile-badge').text(thisweek.Associations.Activity.length);
    if(thisweek.Associations.Activity.length > 0) {
        $('.thisweek-activity').attr('href','javascript:showThisWeekActivities()');
        $('.thisweek-activity').removeAttr('disabled');
    }
    else {
        $('.thisweek-activity').removeAttr('href');
        $('.thisweek-activity').attr('disabled','disabled');
    }    
    */

    $('.thisweek-desc').html('');
    $('.thisweek-content-links').html('');
    $('.thisweek-content-progress').html('');
    $('.thisweek-delivery').addClass('d-none');
    $('.thisweek-outcomes').addClass('d-none');

    var thisdata;
    var dynamicmodule = false;
    if (alldata.InstructionalPlan.Data !== null) {
        for (var ips = 0; ips < alldata.InstructionalPlan.Data.Schedule.length; ips++) {
            var ipweekcheck = alldata.InstructionalPlan.Data.Schedule[ips];
            if (ipweekcheck.WeekNum === thisweek.WeekNum) {
                thisdata = ipweekcheck;
                break;
            }
        }
    }
    if (thisdata !== undefined) {
        if (thisdata.Delivery.length > 0) {
            var deliverytext = 'Delivery: ';
            for (var tdd = 0; tdd < thisdata.Delivery.length; tdd++) {
                var thisdelivery = thisdata.Delivery[tdd];
                deliverytext += thisdelivery;
                if (tdd < (thisdata.Delivery.length - 1)) {
                    deliverytext += ', ';
                }
            }
            $('.thisweek-delivery').text(deliverytext);
            $('.thisweek-delivery').removeClass('d-none');
        }                
        if (thisdata.Outcomes.length > 0) {
            var ofound = false;
            thisweek.Outcomes = generateOutcomeString(thisweek.WeekNum);
            if(thisweek.Outcomes !== undefined) {
                if(thisweek.Outcomes !== null) {
                    if(thisweek.Outcomes.ofound > 0) {
                        ofound = true;
                        $('.comingup-outcomesall .management-count').text(thisdata.Outcomes.length);
                        $('.comingup-outcomesall').attr('href', 'javascript:showThisWeekOutcomes()');
                        $('.comingup-outcomesall').removeAttr('disabled');
                        $('.comingup-outcomesall').addClass('active');                                    
                        $('.thisweek-outcomes').removeClass('d-none');
                    }
                }
            }
            if(!ofound) {
                $('.comingup-outcomesall').removeAttr('href');
                $('.comingup-outcomesall').attr('disabled', 'disabled');
                $('.comingup-outcomesall').removeClass('active');                
            }
        } else {
            thisweek.Outcomes = null;
            $('.comingup-outcomesall').removeAttr('href');
            $('.comingup-outcomesall').attr('disabled', 'disabled');
            $('.comingup-outcomesall').removeClass('active');
        }

        if(alldata.InstructionalPlan.Data.ToolSwitch !== undefined) {
            if(alldata.InstructionalPlan.Data.ToolSwitch.ModuleDescription !== undefined) {
                if(alldata.InstructionalPlan.Data.ToolSwitch.ModuleDescription === false) {
                    if (thisdata.Description !== '') {
                        $('.thisweek-desc').html(thisdata.Description);
                    }                    
                }
                else {
                    dynamicmodule = true;
                }
            }
        }
    }

    if (thisweek.Modules.length > 0) {
        
        var thisweeknoparent = [];
        
        for (var twm = 0; twm < thisweek.Modules.length; twm++) {
            var thismod = thisweek.Modules[twm];
            if(thismod.Parents === undefined) {
                thisweeknoparent.push(thismod);
            }
        }
        
        if(thisweeknoparent.length === 0) {
            for (var twm = 0; twm < thisweek.Modules.length; twm++) {
                var thismod = thisweek.Modules[twm];
                if(thismod.Parents !== undefined) {
                    var foundparent = false;
                    for(var twnp=0; twnp < thisweeknoparent.length; twnp++) {
                        if(thismod.Parents.indexOf(thisweeknoparent[twnp].ModuleId) > -1) {
                            foundparent = true;
                        }
                    }
                    if(!foundparent) {
                        thisweeknoparent.push(thismod);
                    }
                }
            }
        }
        
        //console.log(thisweeknoparent);
        if(thisweeknoparent.length > 0) {
            $('.thisweek-content').removeClass('d-none');
            for(var twnp=0; twnp < thisweeknoparent.length; twnp++) {
                var thismod = thisweeknoparent[twnp];
                var newrow = '';
                newrow += '<div class="row">';
                newrow += '<div class="col-12">';
                var newlink = '';
                newlink += '<p><a href="/d2l/le/content/' + orgUnitId + '/Home?itemIdentifier=D2L.LE.Content.ContentObject.ModuleCO-' + thismod.ModuleId + '" class="cc-file" target="_blank">' + thismod.Title + ' <i class="fas fa-external-link" aria-hidden="true"></i><span class="sr-only">Opens in a new tab</span></a></p>';
                newrow += newlink;
                newrow += '</div>';
                newrow += '<div class="col-12 text-center">';
                var newprogress = '';  
                if(alldata.CurrentRole === "Student") {                     
                    var tdate = new Date();
                    var mdate = new Date(thismod.StartDateTime);
                    if(mdate <= tdate) {
                        newprogress += '<div class="progress"><div class="progress-bar" role="progressbar" style="width: ' + thismod.Progress.Percentage + '%;" aria-valuenow="' + thismod.Progress.Percentage + '" aria-valuemin="0" aria-valuemax="100"></div></div>';
                        newprogress += '<p class="mt-1">' + thismod.Progress.Read + ' out of ' + thismod.Progress.Total + ' content pages viewed</p>';
                    }
                    else {
                        newprogress += '<p>This weekly content is not currently available to students.</p>';
                    }
                }
                else {
                    //newprogress += '<p>Students will see their content progress here.</p>';
                }
                newrow += newprogress;
                newrow += '</div>';
                $('.thisweek-content-links').append(newrow);
                
            }
            
            if (thisweeknoparent.length === 1) {
                weektitle = '<span class="mobile-show">Week ' + thisweek.WeekNum + '</span><span class="mobile-hide">' + thisweeknoparent[0].Title + '</span>';
                
                if (dynamicmodule === true) {
                    if (thisweeknoparent[0].Description !== null) {
                        if (thisweeknoparent[0].Description.Text !== "") {
                            var cleandesc = thisweek.Modules[0].Description.Html.replace(/(?:<style>((?:.*?\r?\n?)*)<\/style>)+|(?:<script>((?:.*?\r?\n?)*)<\/script>)+|(style=\"[^\"]*\")/g,"");
                            //console.log(cleandesc);
                            $('.thisweek-desc').html(cleandesc);
                            $('.thisweek-desc img').each(function() {
                                var oheight = $(this).attr('height');
                                var owidth = $(this).attr('width');
                                
                                if(oheight !== undefined) {
                                    if($.isNumeric(oheight)) {
                                        if(oheight < 200) {
                                            $(this).css({
                                                "height":oheight+"px"
                                            });
                                        }
                                    }
                                }
                                $(this).removeAttr("height");
                                $(this).removeAttr("width");
                            })

                            //$('.thisweek-desc').html(thisweek.Modules[0].Description.Html);
                        }
                    }
                }
            }
            else {
                weektitle = 'Week ' + thisweek.WeekNum;
            }
        }

    } else {
        $('.thisweek-content').addClass('d-none');
        weektitle = 'Week ' + thisweek.WeekNum;
    }
    
    $('.week-header').html(weektitle) 
    
    var thisindex = -1;
    for(var w=0; w<alldata.Schedule.length; w++) {
        if(alldata.Schedule[w].WeekNum === thisweek.WeekNum) {
            thisindex = w;
        }
    }
    
    //console.log(thisindex);
    if(thisindex === 0) {
        $('.weekly-carousel-controls .carousel-previous').addClass('disabled');
        $('.weekly-carousel-controls .carousel-previous').attr('aria-disabled','true');
    }
    else {
        $('.weekly-carousel-controls .carousel-previous').removeClass('disabled');
        $('.weekly-carousel-controls .carousel-previous').removeAttr('aria-disabled');
    }
    if(thisindex === (alldata.Schedule.length-1)) {
        $('.weekly-carousel-controls .carousel-next').addClass('disabled');
        $('.weekly-carousel-controls .carousel-next').attr('aria-disabled','true');
    }
    else {
        $('.weekly-carousel-controls .carousel-next').removeClass('disabled');
        $('.weekly-carousel-controls .carousel-next').removeAttr('aria-disabled');
    }
 
}

function weekNavNext() {

    $('.collapseThisWeekGraded').collapse('hide');
    $('.collapseThisWeekGraded .card-body').html('');
    $('.collapseThisWeekActivities').collapse('hide');
    $('.collapseThisWeekActivities .card-body').html('');

    if (alldata.Schedule !== undefined) {
        for (var s = 0; s < alldata.Schedule.length; s++) {
            if (alldata.Schedule[s].WeekNum === alldata.CurrentWeek) {
                if (s < (alldata.Schedule.length - 1)) {
                    var weekshow = alldata.Schedule[s + 1];
                    //console.log(weekshow);
                    displayCourseDates(weekshow);
                    alldata.CurrentWeek = weekshow.WeekNum;
                }
                break;
            }
        }
    }

    //frameHeight();
}

function weekNavPrev() {

    $('.collapseThisWeekGraded').collapse('hide');
    $('.collapseThisWeekGraded .card-body').html('');
    $('.collapseThisWeekActivities').collapse('hide');
    $('.collapseThisWeekActivities .card-body').html('');

    for (var s = 0; s < alldata.Schedule.length; s++) {
        if (alldata.Schedule[s].WeekNum === alldata.CurrentWeek) {
            if (s > 0) {
                var weekshow = alldata.Schedule[s - 1];
                //console.log(weekshow);
                displayCourseDates(weekshow);
                alldata.CurrentWeek = weekshow.WeekNum;
            }
            break;
        }
    }

    //frameHeight();
}

function wtd_date_sort(a, b) {
    return new Date(a.DueDate).getTime() - new Date(b.DueDate).getTime();
}

var MonthAbbreviations_WTD = [
	"Jan",
	"Feb",
	"Mar",
	"Apr",
	"May",
	"Jun",
	"Jul",
	"Aug",
	"Sep",
	"Oct",
	"Nov",
	"Dec"
]

function initWorkToDo() {
    
    var tdate = new Date();
    alldata.WorkToDo = [];
    
    for(var cd=0; cd<alldata.CourseCalendar.length; cd++) {
        var thisitem = alldata.CourseCalendar[cd];
        if(thisitem.Type === "Assignment") {
            //if(!thisitem.Data.Submissions) {
                var edata = getEndDate("Assignments", thisitem.Data);
                var edate = edata.date;
                if(edate !== null) {
                    if(edate > tdate) {
                        alldata.WorkToDo.push({
                            DueDate: edate,
                            DateLabel: edata.label,
                            Type: "Assign",
                            Object: thisitem.Data,
                            Name: thisitem.Name,
                            URL: thisitem.URL
                        });
                    }
                }
            //}
        }
        else if(thisitem.Type === "Quiz") {
            //if(!thisitem.Data.Attempts) {
                var edata = getEndDate("Quizzes", thisitem.Data);
                var edate = edata.date;
                if(edate !== null) {
                    if(edate > tdate) {
                        alldata.WorkToDo.push({
                            DueDate: edate,
                            DateLabel: edata.label,
                            Type: "Quiz",
                            Object: thisitem.Data,
                            Name: thisitem.Name,
                            URL: thisitem.URL
                        })
                    }
                }
            //}
        }
        /*
        else if((thisitem.Type === "ContentTopic") || (thisitem.Type === "ContentModule")) {
            var edate = thisitem.EndDate;
            if(edate !== null) {
                if(edate > tdate) {
                    alldata.WorkToDo.push({
                        DueDate: edate,
                        Type: "Content",
                        Object: thisitem.Data,
                        Name: thisitem.Name,
                        URL: thisitem.URL
                    })
                }
            }
        }
        */
        else if((thisitem.Type === "DiscussionForum") || (thisitem.Type === "DiscussionTopic")) {
        //else if(thisitem.Type === "DiscussionTopic") {
            var edate = thisitem.EndDate;
            if(edate !== null) {
                if(edate > tdate) {
                    alldata.WorkToDo.push({
                        DueDate: edate,
                        DateLabel: "Ends",
                        Type: "Discuss",
                        Object: thisitem.Data,
                        Name: thisitem.Name,
                        URL: thisitem.URL
                    })
                }
            }
        }
        else if(thisitem.Type === "ChecklistItem") {
            var edate = thisitem.DueDate;
            if(edate !== null) {
                if(edate > tdate) {
                    alldata.WorkToDo.push({
                        DueDate: edate,                        
                        DateLabel: "Due",
                        Type: "Check",
                        Object: thisitem.Data,
                        Name: thisitem.Name,
                        URL: thisitem.URL
                    })
                }
            }
        }
        else if(thisitem.Type === "GradeItem") {
            var edate = thisitem.EndDate;
            if(edate !== null) {
                if(edate > tdate) {
                    alldata.WorkToDo.push({
                        DueDate: edate,                        
                        DateLabel: "Ends",
                        Type: "Grade",
                        Object: thisitem.Data,
                        Name: thisitem.Name,
                        URL: thisitem.URL
                    })
                }
            }
        }
    }
    
    alldata.WorkToDo.sort(wtd_date_sort);
    //console.log(alldata.WorkToDo);
    $('.upcoming-item-full').on('click', function(){
        $('a[data-target="#cc-coming-up-student"]')[0].click();
    });
    $('.upcoming-item-full').removeClass('d-none');
    
    $('.student-upcoming-items').html('');
    
    if(alldata.WorkToDo.length > 0) {
        var wtd_num_to_show = Math.min(alldata.WorkToDo.length, 6);
        
        $('.upcoming-badge').text(wtd_num_to_show);
        if(wtd_num_to_show > 1) {
            $('.student-upcoming').addClass('view-more-mobile');
            if(wtd_num_to_show > 2) {
                $('.student-upcoming').addClass('view-more-tablet');
            }
        }
        
        for(var wtd=0; wtd<wtd_num_to_show; wtd++) {
            var thisitem = alldata.WorkToDo[wtd];
            var wtdhtml = '';
            wtdhtml += '<div class="upcoming-item">';
            wtdhtml += '<div class="upcoming-item-icon">';
            if(thisitem.Type === "Quiz") {
                wtdhtml += '<div class="cc-icon blue-bg calendar-quiz"></div>';
            }
            else if (thisitem.Type === "Assign") {
                wtdhtml += '<div class="cc-icon blue-bg calendar-assignment"></div>';
            }
            else if (thisitem.Type === "Grade") {
                wtdhtml += '<div class="cc-icon blue-bg calendar-grade"></div>';
            }
            else if (thisitem.Type === "Content") {
                wtdhtml += '<div class="cc-icon blue-bg calendar-content"></div>';
            }
            else if (thisitem.Type === "Discuss") {
                wtdhtml += '<div class="cc-icon blue-bg calendar-discussion"></div>';
            }
            else if (thisitem.Type === "Check") {
                wtdhtml += '<div class="cc-icon blue-bg calendar-checklist"></div>';
            }
            wtdhtml += '</div>';
            wtdhtml += '<div class="upcoming-item-content">';
            
            if(thisitem.URL !== '') {
                wtdhtml += '<a href="'+thisitem.URL+'" class="upcoming-item-title" target="_blank">'+thisitem.Name+'</a>';
            }
            else {
                wtdhtml += '<span><strong>'+thisitem.Name+'</strong></span>';
            }            
            
            var datestring = MonthAbbreviations_WTD[thisitem.DueDate.getMonth()] + " " + thisitem.DueDate.getDate() + " " + thisitem.DueDate.getFullYear();
            wtdhtml += '<span class="upcoming-item-date">'+thisitem.DateLabel+' '+datestring+'</span>';
            wtdhtml += '</div>';
            wtdhtml += '</div>';

            $('.student-upcoming-items').append(wtdhtml);
        }
        
        $('.upcoming-item-show-more').on('click',function() {
            $('.upcoming-item').each(function(){
                $(this).addClass('show-item');
            })
            $('.upcoming-item-show-more').addClass('d-none');
        });
    }
    else {
        $('.student-upcoming-items').html('<p>There are no upcoming items to display at this time.</p>');
    }
    
    $('#student-upcoming .info-badge').on('click',function(){
        $('#workToDoInfo').modal('show');
    });        
    
    

    /*
        <div class="upcoming-item">
            <div class="upcoming-item-icon">
                <div class="cc-icon blue-bg calendar-quiz"></div>
            </div>
            <div class="upcoming-item-content">
                <a href="" class="upcoming-item-title">Measurement Quiz</a>
                <span class="upcoming-item-date">Due Jan 12 2024</span>
            </div>
        </div>   
    */
    
}