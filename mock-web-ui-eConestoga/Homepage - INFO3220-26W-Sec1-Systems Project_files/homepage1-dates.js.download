        if (datemodules[z].EndDateTime !== null) {
            cmedate = new Date(datemodules[z].EndDateTime);
        }

        if (cmsdate !== null) {
            if ((cmsdate < csdate) || (cmsdate > cedate)) {
                isoutside = true;
            }
            else {
                incalendar = true;
            }
        }
        if (cmedate !== null) {
            if ((cmedate < csdate) || (cmedate > cedate)) {
