    for (var ce = 0; ce < alldata.CalendarAll.length; ce++) {

        var isoutside = false;
        var ispast = false;
        var cesdate = null;
        var ceedate = null;
        var isvisible = true;
        var incalendar = false;

        if(!alldata.CalendarAll[ce].ContentMatched) {
            if (alldata.CalendarAll[ce].AssociatedEntity === null) {
                if (alldata.CalendarAll[ce].StartDateTime !== null) {
                    cesdate = new Date(alldata.CalendarAll[ce].StartDateTime);
                }
				else {
					if(alldata.CalendarAll[ce].StartDay !== null) {
						cesdate = new Date(alldata.CalendarAll[ce].StartDay);
					}
				}
                if (alldata.CalendarAll[ce].EndDateTime !== null) {
                    ceedate = new Date(alldata.CalendarAll[ce].EndDateTime);
                }
                else {
                    if(alldata.CalendarAll[ce].EndDay !== null) {
                        ceedate = new Date(alldata.CalendarAll[ce].EndDay);
                    }
                }

                if (ceedate !== null) {
                    if (ceedate < csdate) {
                        isoutside = true;
                        ispast = true;
                    }
                    else {
                        incalendar = true;
                    }
                    if (ceedate > cedate) {
                        isoutside = true;
                    }
                    else {
                        incalendar = true;
                    }
                }

                var dobj = {
                    Type: 'CalendarEvent',
                    Data: alldata.CalendarAll[ce],
                    Name: alldata.CalendarAll[ce].Title,
                    ItemId: alldata.CalendarAll[ce].CalendarEventId,
                    StartDate: cesdate,
                    EndDate: ceedate,
                    IsPast: ispast,
                    InCalendar: incalendar,                
                    IsOutside: isoutside,
                    IsVisible: isvisible,
                    URL: ''
                }

                var sdaynum = cesdate.getDate();
                var smonthnum = cesdate.getMonth() + 1;
                var syearnum = cesdate.getFullYear();
                dobj.URL = '/d2l/le/calendar/' + orgUnitId + '/home/list?year=' + syearnum + '&month=' + smonthnum + '&day=' + sdaynum;

                alldates.push(dobj);
                if(incalendar) {
                    caldates.push(dobj);
                }
            } else {
                if (alldata.CalendarAll[ce].AssociatedEntity.AssociatedEntityType === 'D2L.LE.Content.ContentObject.TopicCO') {
                    if (alltopicids.indexOf(alldata.CalendarAll[ce].AssociatedEntity.AssociatedEntityId) > -1) {
                        var gradetopics = [];
                        for (var m = 0; m < alldata.Content.Modules.length; m++) {
                            gradetopics = findContentTopicsAll("TopicId", alldata.CalendarAll[ce].AssociatedEntity.AssociatedEntityId, alldata.Content.Modules[m], gradetopics);
                        }

                        if (gradetopics.length === 1) {
                            //console.log(gradetopics);
                            if (gradetopics[0].Topic.Type !== undefined) {
                                if (gradetopics[0].Topic.Type === "Discussion") {
                                    for (var ad = 0; ad < alldates.length; ad++) {
                                        if (alldates[ad].Type === "DiscussionTopic") {
                                            if (alldates[ad].ItemId === gradetopics[0].Topic.ToolItemId) {
                                                //console.log(alldata.CalendarAll[ce]);
                                                //console.log(alldates[ad]);

                                                var onetime = false;
                                                if (alldata.CalendarAll[ce].StartDateTime.getTime() === alldata.CalendarAll[ce].EndDateTime.getTime()) {
                                                    onetime = true;
                                                }

                                                //console.log(onetime);

                                                if ((alldates[ad].StartDate === null) && (alldates[ad].UnlockStartDate === null)) {
                                                    if ((alldates[ad].EndDate === null) && (alldates[ad].UnlockEndDate === null)) {
                                                        if (onetime) {
                                                            alldates[ad].EndDate = alldata.CalendarAll[ce].EndDateTime;
                                                        } else {
                                                            alldates[ad].StartDate = alldata.CalendarAll[ce].StartDateTime;
                                                            alldates[ad].EndDate = alldata.CalendarAll[ce].EndDateTime;
                                                        }
                                                    } else {

                                                        var dedate = null;
                                                        if (alldates[ad].EndDate !== null) {
                                                            dedate = new Date(alldates[ad].EndDate);
                                                        }
                                                        if (alldates[ad].UnlockEndDate !== null) {
                                                            dedate = new Date(alldates[ad].UnlockEndDate);
                                                        }

                                                        if (alldata.CalendarAll[ce].StartDateTime.getTime() < dedate.getTime()) {
                                                            alldates[ad].StartDate = alldata.CalendarAll[ce].StartDateTime;
                                                        }

                                                    }
                                                } else {
                                                    if ((alldates[ad].EndDate === null) && (alldates[ad].UnlockEndDate === null)) {

                                                        var dsdate = null
                                                        if (alldates[ad].StartDate !== null) {
                                                            dsdate = new Date(alldates[ad].StartDate);
                                                        }
                                                        if (alldates[ad].UnlockStartDate !== null) {
                                                            dsdate = new Date(alldates[ad].UnlockStartDate);
                                                        }

                                                        if (alldata.CalendarAll[ce].EndDateTime.getTime() > dsdate) {
                                                            alldates[ad].EndDate = alldata.CalendarAll[ce].EndDateTime;
                                                        }
                                                    }
                                                }

                                                break;
                                            }
                                        }
                                    }
                                }
                            }
                        }

                        if (alldata.CalendarAll[ce].StartDateTime !== null) {
                            cesdate = new Date(alldata.CalendarAll[ce].StartDateTime);
                        }
                        if (alldata.CalendarAll[ce].EndDateTime !== null) {
                            ceedate = new Date(alldata.CalendarAll[ce].EndDateTime);
                        }
                        else {
                            if(alldata.CalendarAll[ce].EndDay !== null) {
                                ceedate = new Date(alldata.CalendarAll[ce].EndDay);
                            }
                        }

                        if (ceedate !== null) {
                            if (ceedate < csdate) {
                                isoutside = true;
                                ispast = true;
                            }
                            else {
                                incalendar = true;
                            }
                            if (ceedate > cedate) {
                                isoutside = true;
                            }
                            else {
                                incalendar = true;
                            }
                        }

                        var dobj = {
                            Type: 'CalendarEvent',
                            Data: alldata.CalendarAll[ce],
                            Name: alldata.CalendarAll[ce].Title,
                            ItemId: alldata.CalendarAll[ce].CalendarEventId,
                            StartDate: cesdate,
                            EndDate: ceedate,
                            IsPast: ispast,
                            InCalendar: incalendar,
                            IsOutside: isoutside,
                            IsVisible: isvisible,
                            URL: alldata.CalendarAll[ce].AssociatedEntity.Link
                        }

                        alldates.push(dobj);
                        if(incalendar) {
                            caldates.push(dobj);
                        }
                    }
                }
            }
        }
    }

    if (alldata.InstructionalPlan.Data !== null) {
        if (thispagedata.Grades.length > 0) {
            for (var g = 0; g < thispagedata.Grades.length; g++) {

                var gradefound = false;
                var hasassoc = false;
                for (var gi = 0; gi < alldata.GradeItems.Objects.length; gi++) {
                    var thisgrade = alldata.GradeItems.Objects[gi];
                    if (thisgrade.Id === thispagedata.Grades[g].Id) {
                        gradefound = true;
                        if (thisgrade.AssociatedTool !== null) {
                            hasassoc = true;
                            break;
                        }
                    }
                }

                if (gradefound) {
                    if (!hasassoc) {
                        thispagedata.Grades[g].HasAssociation = false;
                        var dateobj = {
                            Type: "GradeItem",
                            Data: thispagedata.Grades[g],
                            Name: thispagedata.Grades[g].Name,
                            ItemId: thispagedata.Grades[g].Id,
                            StartDate: null,
                            EndDate: null,
                            InCalendar: incalendar,                
                            IsOutside: false,
                            IsVisible: true,
                            URL: "/d2l/lms/grades/index.d2l?ou=" + orgUnitId
                        }

                        var addobj = false;
                        if (thispagedata.Grades[g].StartDateTime !== undefined) {
                            addobj = true;
                            dateobj.StartDate = new Date(thispagedata.Grades[g].StartDateTime);
                        }
                        if (thispagedata.Grades[g].EndDateTime !== undefined) {
                            addobj = true;
                            dateobj.EndDate = new Date(thispagedata.Grades[g].EndDateTime);
                        }

                        if (addobj) {
                            
                            for(var gi=0; gi<alldata.GradeItems.Objects.length; gi++) {
                                var thisgradeitem = alldata.GradeItems.Objects[gi];
                                if(thispagedata.Grades[g].Id === thisgradeitem.Id) {
                                    dateobj.Name = thisgradeitem.Name;
                                    break;
                                }
                            }
                            
                            alldates.push(dateobj);
                            caldates.push(dateobj);
                        }
                    } else {
                        thispagedata.Grades[g].HasAssociation = true;
                    }
                }
            }
        }
    }

    //console.log(alldates);
    alldata.CourseDates = alldates;
    alldata.CourseCalendar = caldates;

    /*
    alldata.CalendarBuild = [];
    for (var cd = 0; cd < alldata.CourseDates.length; cd++) {

        var itemstart;
        var itemend;
        if (alldata.CourseDates[cd].StartDate !== null) {
            itemstart = alldata.CourseDates[cd].StartDate;
        }
        if (alldata.CourseDates[cd].EndDate !== null) {
            itemend = alldata.CourseDates[cd].EndDate;
        }

        if ((itemstart !== undefined) || (itemend !== undefined)) {

            if (itemstart === undefined) {
                itemstart = itemend;
            }
            if (itemend === undefined) {
                itemend === itemstart;
            }

            var newobj = {
                start: itemstart,
                end: itemend,
                title: alldata.CourseDates[cd].Name
            }
            alldata.CalendarBuild.push(newobj);
        }
    }
    
    if(alldata.CalendarBuild.length > 0) {
        //initCalendar(alldata.CourseDates);
    }
    else {
        $('.thisweek-management-cards').addClass('d-none');
        $('.calendarzone').addClass('d-none');
    }    
    */
    
    initWorkToDo();

}


function generateOutcomeString(weeknum) {

    var s = -1;
    for (var w = 0; w < thispagedata.Schedule.length; w++) {
        if (thispagedata.Schedule[w].WeekNum === weeknum) {
            s = w;
        }
    }

    //console.log(s);
    var ofound = 0;
    var outcome_html = '';

    if (thispagedata.Schedule[s] !== undefined) {
        if (thispagedata.Schedule[s].Outcomes.length > 0) {

            for (var o = 0; o < thispagedata.Schedule[s].Outcomes.length; o++) {
                var thisoutcome = thispagedata.Schedule[s].Outcomes[o];
                var efound = {
                    Exact: [],
                    Loose: []
                };
                if (alldata.Outline.length > 0) {
                    for (var o1 = 0; o1 < alldata.Outline[0].UnitOutcomes.length; o1++) {
                        efound = getOutcomeEnum(thisoutcome, alldata.Outline[0].UnitOutcomes[o1], efound);
                        if (efound.Exact.length > 0) {
                            break;
                        }
                    }
                    if (efound.Exact.length > 0) {
                        ofound++;
                        outcome_html += '<li class="list-group-item iphighlight">' + thisoutcome.Enum + ': ' + thisoutcome.Desc + '</li>';
                    } else {
                        if (efound.Loose.length > 0) {
                            ofound++;
                            if (efound.Loose.length === 1) {
                                outcome_html += '<li class="list-group-item iphighlight">' + efound.Loose[0] + ': ' + thisoutcome.Desc + '</li>';
                            } else {
                                outcome_html += '<li class="list-group-item iphighlight">' + thisoutcome.Desc + '</li>';
                            }
                        }
                    }
                } else {
                    ofound++;
                    outcome_html += '<li class="list-group-item iphighlight">' + thisoutcome.Desc + '</li>';
                }
            }
        }
    }

    var robj = {
        ofound: ofound,
        ohtml: outcome_html
    }
    return robj;
}


function getItemWeekNum(itemdate) {
    
    //console.log(itemdate);
    var idate = new Date(itemdate); 
    
    if(alldata.Schedule !== undefined) {
        var weekstring = '';
        
        for(var s=0; s<alldata.Schedule.length; s++) {
            var wstart = new Date(alldata.Schedule[s].StartDate);
            var wend = new Date(alldata.Schedule[s].EndDate);

            if((idate >= wstart) && (idate < wend)) {
                weekstring = 'Week ' + alldata.Schedule[s].WeekNum;
                break;
            }
        }
        
        if(weekstring === '') {
            var cstart = new Date(alldata.Schedule[0].StartDate);
            var cend = new Date(alldata.Schedule[(alldata.Schedule.length-1)].EndDate);
            if(idate < cstart) {
                weekstring = 'Week ' + alldata.Schedule[0].WeekNum;
            }
            if(idate > cend) {
                weekstring = 'Week ' + alldata.Schedule[(alldata.Schedule.length-1)].WeekNum;
            }
        }
        
        return weekstring;
        
    }
    else {
        return null;
    }
    
}

function generateCommString(commitem) {

    var sortdate;

    //console.log(commitem);
    var cname = commitem.Name;

    if (commitem.Type === "CalendarEvent") {
        if (cname === "") {
            cname = "Calendar Item";
        }
        if (commitem.Data.IsAllDayEvent) {
            cname += " (All Day Event)";
        }
    }

    var commstring = '';
    var isactivity = false;
    var isevaluation = false;
    var isdiscussion = false;

    if (commitem.Type === 'CalendarEvent') {

        //console.log(commitem);

        if (commitem.Data.AssociatedEntity !== null) {
            if (commitem.Data.AssociatedEntity.AssociatedEntityType === 'D2L.LE.Content.ContentObject.TopicCO') {
                isactivity = true;

                var gradetopics = [];
                for (var m = 0; m < alldata.Content.Modules.length; m++) {
                    gradetopics = findContentTopicsAll("TopicId", commitem.Data.AssociatedEntity.AssociatedEntityId, alldata.Content.Modules[m], gradetopics);
                }

                if (gradetopics.length === 1) {
                    if (gradetopics[0].Topic.Type !== undefined) {
                        if (gradetopics[0].Topic.Type === "Discussion") {
                            isdiscussion = true;
                        }
                    }

                    if (gradetopics[0].Topic.GradeItemId !== null) {
                        //console.log(gradetopics[0])
                        isevaluation = true;
                    }

                    //console.log(gradetopics[0]);

                }
            }
        }
    }

    commstring += '<tr class="scheduledateitem displayblock-' + commitem.Type + '">';

    //console.log(commitem);

    if (isactivity) {
        if (isevaluation) {
            //commstring += '<th class="tdlabel d-none d-md-table-cell">Evaluation</th>';
        } else {
            //commstring += '<th class="tdlabel d-none d-md-table-cell">Activity</th>'; 
        }

    } else {
        //commstring += '<th class="tdlabel d-none d-md-table-cell">Communication</th>';
    }

    commstring += '<td class="tdcontent">';

    if (isactivity) {
        commstring += '<div class="assessbox assesstype-ContentTopic">';
    } else {
        commstring += '<div class="assessbox assesstype-' + commitem.Type + '">';
    }

    commstring += '<p>';
    if (commitem.URL !== "") {
        commstring += '<a href="' + commitem.URL + '" target="_blank">' + cname + ' <i class="fas fa-external-link" aria-hidden="true"></i><span class="sr-only">Opens in a new tab</span></a>';
    } else {
        commstring += cname;
    }

    commstring += '<ul>';

    if (commitem.Type === 'Announcement') {
        if (sortdate === undefined) {
            sortdate = commitem.StartDate;
        }
        commstring += '<li>Posted: ' + commitem.StartDate + '</li>';
    }
    if (commitem.Type === 'CalendarEvent') {

        var onetime = false;
        if ((commitem.StartDate !== null) && (commitem.EndDate !== null)) {
            if (commitem.StartDate.getTime() === commitem.EndDate.getTime()) {
                onetime = true;
            }
        }

        if (onetime) {
            sortdate = commitem.EndDate;
            if (commitem.URL !== "") {
                var dstring = commitem.EndDate.toLocaleDateString('en-us', { weekday:"long", year:"numeric", month:"long", day:"numeric"}) + ", " + formatAMPM(commitem.EndDate);
                
                commstring += '<li><strong>Due Date: ' + dstring + '</strong></li>';
            } else {
                var dstring = commitem.EndDate.toLocaleDateString('en-us', { weekday:"long", year:"numeric", month:"long", day:"numeric"}) + ", " + formatAMPM(commitem.EndDate);
                
                commstring += '<li><strong>Date: ' + dstring + '</strong></li>';
            }
        } else {
            if (commitem.StartDate !== null) {
                if (sortdate === undefined) {
                    sortdate = commitem.StartDate;
                }
                var dstring = commitem.StartDate.toLocaleDateString('en-us', { weekday:"long", year:"numeric", month:"long", day:"numeric"}) + ", " + formatAMPM(commitem.StartDate);
                commstring += '<li>Start Date: ' + dstring + '</li>';
            }
            if (commitem.EndDate !== null) {
                if (sortdate === undefined) {
                    sortdate = commitem.EndDate;
                }
                var dstring = commitem.EndDate.toLocaleDateString('en-us', { weekday:"long", year:"numeric", month:"long", day:"numeric"}) + ", " + formatAMPM(commitem.EndDate);
                commstring += '<li>Due Date: ' + dstring + '</li>';
            }
        }

    }
    commstring += '</ul>';
    commstring += '</div>';
    commstring += '</td>';
    commstring += '</tr>';

    if (isdiscussion) {
        var robj = {
            HTML: commstring,
            StartDateTime: sortdate,
            IsDiscussion: isdiscussion,
            GradeItem: gradetopics[0].Topic.GradeItemId
        }
    } else {
        var robj = {
            HTML: commstring,
            StartDateTime: sortdate,
            IsDiscussion: isdiscussion,
        }
    }

    return robj;
}


