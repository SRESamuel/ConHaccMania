function checkLastAccessed() {

    var checkfirst;
    var checklast;
    var okayfirst = false;
    var okaylast = false;

    if(alldata.CourseOffering.StartDate !== null) {
        checkfirst = new Date(alldata.CourseOffering.StartDate);
    }
    else {
        okayfirst = true;
    }

    if(alldata.CourseOffering.EndDate !== null) {
        checklast = new Date(alldata.CourseOffering.EndDate);
    }
    else {
        okaylast = true;
    }

    var daystoadd = 5;
    if(alldata.CustomSettings !== null) {
        if(alldata.CustomSettings.Dashboard !== null) {
            if(alldata.CustomSettings.Dashboard.AtRisk !== undefined) {
                if(alldata.CustomSettings.Dashboard.AtRisk.AccessLast !== undefined) {
                    daystoadd = alldata.CustomSettings.Dashboard.AtRisk.AccessLast;
                }
            }
        }
    }

    //console.log(checkfirst);
    if(checkfirst !== undefined) {
        checkfirst = checkfirst.addDays(daystoadd);

        var tdate = new Date();
        if(tdate > checkfirst) {
            okayfirst = true;
        }

        if(tdate < checklast) {
            okaylast = true;
        }
    }


    //console.log(checkfirst);
    //console.log(checklast);
    //console.log(okayfirst);
    //console.log(okaylast);

    if(okayfirst && okaylast) {
        if(alldata.Classlist.Objects.length > 0) {
            var noaccessnum = 0;
            var tdate = new Date();

            for(var u=0; u < alldata.Classlist.Objects.length; u++) {

                var useradded = false;
                if(alldata.Classlist.Objects[u].LastAccessed === null) {
                    noaccessnum++;
                    atrisk_list.AccessLast.push(alldata.Classlist.Objects[u]);
                    useradded = true;
                }
                else {
                    var ladate = new Date(alldata.Classlist.Objects[u].LastAccessed);
                    numdays = daysBetween(tdate, ladate);
                    if(numdays > daystoadd) {
                        noaccessnum++;
                        atrisk_list.AccessLast.push(alldata.Classlist.Objects[u]);
                        useradded = true;
                    }
                }
                if(useradded) {
                    if(atrisk_list.AllItems.indexOf(alldata.Classlist.Objects[u].Identifier) === -1) {
                        atrisk_list.AllItems.push(alldata.Classlist.Objects[u].Identifier);
                    }
                }
            }
            
            var noaccesstext = "<strong>"+noaccessnum;
            if(noaccessnum === 1) {
                noaccesstext += " student</strong> has "
            }
            else {
                noaccesstext += " students</strong> have ";
            }
            $('#snapshot-noaccesslist').html(noaccesstext);
            $("#widget_data_accesslast").text(alldata.CustomSettings.Dashboard.AtRisk.AccessLast);     
            
            $('#snapshot-instructor-accesslast').addClass('display');
            
        }
    }
}

function checkContentViewed() {
    
    var percentcheck = 10;
    if(alldata.CustomSettings !== null) {
        if(alldata.CustomSettings.Dashboard !== null) {
            if(alldata.CustomSettings.Dashboard.AtRisk !== undefined) {
                if(alldata.CustomSettings.Dashboard.AtRisk.ContentViewed !== undefined) {
                    percentcheck = alldata.CustomSettings.Dashboard.AtRisk.ContentViewed;
                }
            }
        }
    }
    
    if(alldata.Classlist.Objects.length > 0) {
        var contentviewnum = 0;
        var contotal_percent = 0;
        var contotal_time = 0;

        for(var u=0; u < alldata.Classlist.Objects.length; u++) {

            if(alldata.Classlist.Objects[u].Progress !== undefined) {
                if(alldata.Classlist.Objects[u].Progress.RequiredItems > 0) {
                    contotal_percent += (alldata.Classlist.Objects[u].Progress.CompletedItems / alldata.Classlist.Objects[u].Progress.RequiredItems) * 100;
                }
            }

            if(alldata.Classlist.Objects[u].TotalTime !== undefined) {
                contotal_time += alldata.Classlist.Objects[u].TotalTime;
            }

        }

        var conavg_percent = (contotal_percent / alldata.Classlist.Objects.length);
        var conavg_time = (contotal_time / alldata.Classlist.Objects.length);

        var conavg_time_format = dhm(conavg_time*1000);

        for(var u=0; u < alldata.Classlist.Objects.length; u++) {
            var constu_percent = 0;

            if(alldata.Classlist.Objects[u].Progress !== undefined) {
                constu_percent = (alldata.Classlist.Objects[u].Progress.CompletedItems / alldata.Classlist.Objects[u].Progress.RequiredItems) * 100;
            }

            //console.log(conavg_percent);
            //console.log(constu_percent);
            if((conavg_percent - constu_percent) >= percentcheck) {
                contentviewnum++;
                atrisk_list.ContentViewed.push(alldata.Classlist.Objects[u]);
                if(atrisk_list.AllItems.indexOf(alldata.Classlist.Objects[u].Identifier) === -1) {
                    atrisk_list.AllItems.push(alldata.Classlist.Objects[u].Identifier);
                }
            }
        }
        
        $('#snapshot-instructor-clink').attr('href','/d2l/lms/content/reports/statistics_course.d2l?ou='+ orgUnitId);
        $('#snapshot-content-views').text(conavg_percent.toFixed(0));
        $('#snapshot-content-time').text(conavg_time_format);
        var contentviewtext = "<strong>"+contentviewnum;
        if(contentviewnum === 1) {
            contentviewtext += " student</strong> has "
        }
        else {
            contentviewtext += " students</strong> have ";
        }
        $('#snapshot-contentlist').html(contentviewtext);
        $('#widget_data_contentviews').text(alldata.CustomSettings.Dashboard.AtRisk.ContentViewed);

        $('#snapshot-instructor-content').addClass('display');       
        
    }
}


function checkGradeLevels() {
    
    var GradeValueMax = 70;
	var GradeAvgNow = 50;
    
    if(alldata.CustomSettings !== null) {
        if(alldata.CustomSettings.Dashboard !== null) {
            if(alldata.CustomSettings.Dashboard.AtRisk !== undefined) {
                if(alldata.CustomSettings.Dashboard.AtRisk.GradeAvgNow !== undefined) {
                    GradeAvgNow = alldata.CustomSettings.Dashboard.AtRisk.GradeAvgNow;
                }
                if(alldata.CustomSettings.Dashboard.AtRisk.GradeValueMax !== undefined) {
                    GradeValueMax = alldata.CustomSettings.Dashboard.AtRisk.GradeValueMax;
                }
            }
        }
    }    

    
    if ((alldata.GradeSetup.GradingSystem === "Weighted") || (alldata.GradeSetup.GradingSystem === "Points")) {

        if(alldata.Classlist.Objects.length > 0) {
            var grademaxnum = 0;
            var gradeavgnum = 0;
            var gradetotal_drop = 0;
            var gradetotal_all = 0;

            for(var u=0; u < alldata.Classlist.Objects.length; u++) {

                var useradded = false;
                //console.log(alldata.Classlist.Objects[u]);
                gradetotal_drop += alldata.Classlist.Objects[u].Calculated.CurrentAverage;
                gradetotal_all += alldata.Classlist.Objects[u].Calculated.CurrentEarned;

                var atleastonegrade = false;
                if(alldata.Classlist.Objects[u].Values.length > 0) {
                    for(var v=0; v<alldata.Classlist.Objects[u].Values.length; v++) {
                        if(alldata.Classlist.Objects[u].Values[v].GradeObjectType === 1 || alldata.Classlist.Objects[u].Values[v].GradeObjectType === 2) {
                            atleastonegrade = true;
                        }
                    }
                }

                if(atleastonegrade) {
                    if(alldata.Classlist.Objects[u].Calculated.CurrentAverage <= GradeAvgNow) {
                        gradeavgnum++;
                        atrisk_list.GradeAvgNow.push(alldata.Classlist.Objects[u]);
                        useradded = true;
                    }
                    if(alldata.Classlist.Objects[u].Calculate100.CurrentEarned <= GradeValueMax){
                        grademaxnum++;
                        atrisk_list.GradeValueMax.push(alldata.Classlist.Objects[u]);
                        useradded = true;
                    }
                }
                
                if(useradded) {
                    if(atrisk_list.AllItems.indexOf(alldata.Classlist.Objects[u].Identifier) === -1) {
                        atrisk_list.AllItems.push(alldata.Classlist.Objects[u].Identifier);
                    }
                }                    
            }

            var gradeavg_drop = (gradetotal_drop / alldata.Classlist.Objects.length);
            var gradeavg_all = (gradetotal_all / alldata.Classlist.Objects.length);
            
            $('#snapshot-instructor-glink').attr('href','/d2l/lms/grades/index.d2l?ou='+ orgUnitId);

            $('#snapshot-gradeavg-drop').text(gradeavg_drop.toFixed(2) + '%');
            $('#snapshot-gradeavg-all').text(gradeavg_all.toFixed(2) + '%');

            var gradeavgtext = "<strong>"+gradeavgnum;
            if(gradeavgnum === 1) {
                gradeavgtext += " student</strong> has "
            }
            else {
                gradeavgtext += " students</strong> have ";
            }
            $('#snapshot-avggradelist').html(gradeavgtext);
            $("#widget_data_gradeavg").text(alldata.CustomSettings.Dashboard.AtRisk.GradeAvgNow);

            var grademaxtext = "<strong>"+grademaxnum;
            if(grademaxnum === 1) {
                grademaxtext += " student</strong> has "
            }
            else {
                grademaxtext += " students</strong> have ";
            }
            $('#snapshot-maxgradelist').html(grademaxtext);
            $("#widget_data_grademax").text(alldata.CustomSettings.Dashboard.AtRisk.GradeValueMax);

            $('#snapshot-instructor-grades').addClass('display');          
            
        }
    }
}


function checkLateAssess() {
    
    var latecheck = 1;
    
    if(alldata.CustomSettings !== null) {
        if(alldata.CustomSettings.Dashboard !== null) {
            if(alldata.CustomSettings.Dashboard.AtRisk !== undefined) {
                if(alldata.CustomSettings.Dashboard.AtRisk.LateAssess !== undefined) {
                    latecheck = alldata.CustomSettings.Dashboard.AtRisk.LateAssess;
                }
            }
        }
    }

    var numlate = 0;
    
    if(alldata.Classlist.Objects.length > 0) {
        for(var s=0; s<alldata.Classlist.Objects.length; s++) {
            var thisuser = alldata.Classlist.Objects[s];
            //console.log(thisuser.LateAssess);

            if(thisuser.LateAssess.length >= latecheck) {
                atrisk_list.LateAssess.push(thisuser);
                numlate++;
                if(atrisk_list.AllItems.indexOf(thisuser.Identifier) === -1) {
                    atrisk_list.AllItems.push(thisuser.Identifier);
                }
            }
        }
    
        var latetext = "<strong>"+numlate;
        if(numlate === 1) {
            latetext += " student</strong> is "
        }
        else {
            latetext += " students</strong> are ";
        }
        $('#snapshot-latelist').html(latetext);
        $("#widget_data_lateassess").text(alldata.CustomSettings.Dashboard.AtRisk.LateAssess);            

        $("#snapshot-instructor-lateassess").addClass('display');
    }
}


function checkAssessResults() {
    
    var tdate = new Date();

    var WeightMin = 2;
    var CompleteMin = 40;
    var AverageMin = 55;
    var AverageMax = 90;
    var FailRate = 20;
    
    var CompleteMax = 50;
    var DayCountMax = 15;
    
    if(alldata.CustomSettings !== null) {
        if(alldata.CustomSettings.Dashboard !== null) {
            if(alldata.CustomSettings.Dashboard.Assessment !== undefined) {
                if(alldata.CustomSettings.Dashboard.Assessment.WeightMin !== undefined) {
                    WeightMin = alldata.CustomSettings.Dashboard.Assessment.WeightMin;
                }
                if(alldata.CustomSettings.Dashboard.Assessment.CompleteMin !== undefined) {
                    CompleteMin = alldata.CustomSettings.Dashboard.Assessment.CompleteMin;
                }
                if(alldata.CustomSettings.Dashboard.Assessment.AverageMin !== undefined) {
                    AverageMin = alldata.CustomSettings.Dashboard.Assessment.AverageMin;
                }
                if(alldata.CustomSettings.Dashboard.Assessment.AverageMax !== undefined) {
                    AverageMax = alldata.CustomSettings.Dashboard.Assessment.AverageMax;
                }
                if(alldata.CustomSettings.Dashboard.Assessment.FailRate !== undefined) {
                    FailRate = alldata.CustomSettings.Dashboard.Assessment.FailRate;
                }
            }
            if(alldata.CustomSettings.Dashboard.GradeDates !== undefined) {
                if(alldata.CustomSettings.Dashboard.GradeDates.CompleteMax !== undefined) {
                    CompleteMax = alldata.CustomSettings.Dashboard.GradeDates.CompleteMax;
                }
                if(alldata.CustomSettings.Dashboard.GradeDates.DayCountMax !== undefined) {
                    DayCountMax = alldata.CustomSettings.Dashboard.GradeDates.DayCountMax;
                }            
            }
        }

    }
    
    
    for(var gi=0; gi<alldata.GradeItems.Objects.length; gi++) {
        
        var thisgrade = alldata.GradeItems.Objects[gi];
        
        var weightokay = false;
        if(thisgrade.WeightCalc > WeightMin) {
            weightokay = true;
        }

        var completepercent = ((thisgrade.NumEvals / alldata.Classlist.Objects.length)*100);
        var completeokay = false;
        if(completepercent > CompleteMin) {
            completeokay = true;
        }

        //console.log(thisgrade.Name);
        //console.log(thisgrade.Id);
        //console.log(weightokay);
        //console.log(completeokay);

        if(weightokay && completeokay) {
            if(thisgrade.Statistics !== undefined) {
                if(thisgrade.Statistics !== null) {
                    if(thisgrade.Statistics.Average !== null) {
                        if(thisgrade.Statistics.Average <= AverageMin) {
                            assess_list.AverageMin.push(thisgrade.Id);
                            if(assess_list.AllItems.indexOf(thisgrade.Id) === -1) {
                                assess_list.AllItems.push(thisgrade.Id);
                            }
                        }
                        if(thisgrade.Statistics.Average >= AverageMax) {
                            assess_list.AverageMax.push(thisgrade.Id);
                            if(assess_list.AllItems.indexOf(thisgrade.Id) === -1) {
                                assess_list.AllItems.push(thisgrade.Id);
                            }
                        }
                    }
                    //console.log(thisgrade.Statistics.FailRate);
                    //console.log(FailRate);
                    if(thisgrade.Statistics.FailRate !== null) {
                        if(thisgrade.Statistics.FailRate >= FailRate) {
                            assess_list.FailRate.push(thisgrade.Id);
                            if(assess_list.AllItems.indexOf(thisgrade.Id) === -1) {
                                assess_list.AllItems.push(thisgrade.Id);
                            }
                        }
                    }
                }
            }
        }

        var completelow = false;
        if(completepercent < CompleteMax) {
            completelow = true;
        }
        
        //console.log(completelow);
        if(completelow) {
            if(thisgrade.EndDate !== undefined) {
                if(thisgrade.EndDate !== null) {                    
                    var edate = new Date(thisgrade.EndDate);
                    if(edate < tdate) {
                        var dbetween = daysBetween(thisgrade.EndDate, tdate);
                        //console.log(dbetween);
                        //console.log(DayCountMax);
                        if(dbetween > DayCountMax) {
                            assess_list.UngradedNow.push(thisgrade.Id);
                            if(assess_list.AllItems.indexOf(thisgrade.Id) === -1) {
                                assess_list.AllItems.push(thisgrade.Id);
                            }
                        }
                    }                
                }                
            }
        }
    }
}


function validateInput(val, min, max) {
	
	var setval = val;
	if((val >= min) && (val <= max)){
		
	}
	else {
		if(val < min) {
			setval = min;
		}
		if(val > max) {
			setval = max;
		}
	}
	return setval;
}


function saveAtRiskSettings() {
    
    var saveobj = {
        AtRisk: {
            AccessLast:parseInt($('#setLastAccessed').val()),
            ContentViewed:parseInt($('#setContentViewed').val()),
            GradeAvgNow:parseInt($('#setGradeAvg').val()),
            GradeValueMax:parseInt($('#setGradeMax').val()),
            LateAssess:parseInt($('#setLateAssess').val())
        }
    }
    
    if(alldata.CustomSettings !== null) {
        if(alldata.CustomSettings.Dashboard !== null) {
            alldata.CustomSettings.Dashboard.AtRisk = saveobj.AtRisk;
        }
        else {
            alldata.CustomSettings.Dashboard = {
                AtRisk: saveobj.AtRisk
            }
        }
    }
    else {
        alldata.CustomSettings = {
            Dashboard: {
                AtRisk: saveobj.AtRisk
            }
        }
    }
    
    //console.log(alldata.CustomSettings);
    putCustomWidgetData(CustomWidgetH1,"AtRisk");

}


function saveAssessSettings() {
    var saveobj = {
        Assessment: {
            AverageMax:parseInt($('#setGradeValueMax').val()),
            AverageMin:parseInt($('#setGradeValueMin').val()),
            CompleteMin:parseInt($('#setGradeCompleteMin').val()),
            FailRate:parseInt($('#setFailRateMax').val()),
            WeightMin:parseInt($('#setGradeWeightMin').val())
        },
        GradeDates: {
            CompleteMax:parseInt($('#setGradeCompleteMax').val()),
            DayCountMax:parseInt($('#setGradeDateMax').val())
        }
    }
    
    if(alldata.CustomSettings !== null) {
        if(alldata.CustomSettings.Dashboard !== null) {
            alldata.CustomSettings.Dashboard.Assessment = saveobj.Assessment;
            alldata.CustomSettings.Dashboard.GradeDates = saveobj.GradeDates;
        }
        else {
            alldata.CustomSettings.Dashboard = {
                Assessment: saveobj.Assessment,
                GradeDates: saveobj.GradeDates
            }
        }
    }
    else {
        alldata.CustomSettings = {
            Dashboard: {
                Assessment: saveobj.Assessment,
                GradeDates: saveobj.GradeDates
            }
        }
    }
    
    //console.log(alldata.CustomSettings);
    putCustomWidgetData(CustomWidgetH1,"Assess");
    
}


function initializeAtRiskSettings() {
	//console.log(alldata.CustomSettings.Dashboard);
	
	//var settingsHTML = '<p>Here you can configure your preferences for the presentation of this tool.</p>';
	var settingsHTML = '<p>These settings are unique to each of your course shells and <strong>will not be automatically applied to other sections</strong>.</p>';
    
	settingsHTML += '<p><strong>Course Last Accessed</strong></p>';
	settingsHTML += '<form class="form-horizontal form-atrisk" role="form"><div class="form-group"><div class="col-sm-2"><input type="number" class="form-control input-atrisk" id="setLastAccessed" min="1" max="14" step="1"></div><label for="setLastAccessed" class="col-sm-10 control-label"># days since student last accessed this course shell (min:1 and max:14)</label></div><div class="clearfix"></div></form>';
	settingsHTML += '<hr>';
	settingsHTML += '<p><strong>Grade Progress</strong></p>';
	settingsHTML += '<p>Calculations will include grade items that are not hidden from students, and which have values entered for that particular student. All grade items which have no values filled in will be ignored so we strongly recommend entering a value of “0” for late or missed assignments.</p>';
	settingsHTML += '<p>Note that students must have at least one grade value recorded before they will be considered for any at risk criteria below.</p>';
	settingsHTML += '<form class="form-horizontal form-atrisk" role="form"><div class="form-group"><div class="col-sm-2"><input type="number" class="form-control input-atrisk" id="setGradeAvg" min="50" max="100" step="5"></div><label for="setGradeAvg" class="col-sm-10 control-label">% current average grade drops below this value (min:50 and max:100)</label></div><div class="clearfix"></div>';
	settingsHTML += '<div class="form-group"><div class="col-sm-2"><input type="number" class="form-control input-atrisk" id="setGradeMax" min="50" max="100" step="5"></div><label for="setGradeMax" class="col-sm-10 control-label">% max achievable final grade drops below this value (min:50 and max:100)</label></div><div class="clearfix"></div></form>';
	settingsHTML += '<hr>';
	settingsHTML += '<p><strong>Content Progress</strong></p>';
	settingsHTML += '<form class="form-horizontal form-atrisk" role="form"><div class="form-group"><div class="col-sm-2"><input type="number" class="form-control input-atrisk" id="setContentViewed" min="5" max="100" step="1"></div><label for="setContentViewed" class="col-sm-10 control-label">% content viewed below the average of the full classlist (min:5 and max:100)</label></div><div class="clearfix"></div></form>';
	settingsHTML += '<hr>';
	settingsHTML += '<p><strong>Late Assessments</strong></p>';
	settingsHTML += '<form class="form-horizontal form-atrisk" role="form"><div class="form-group"><div class="col-sm-2"><input type="number" class="form-control input-atrisk" id="setLateAssess" min="1" max="3" step="1"></div><label for="setLateAssess" class="col-sm-10 control-label"># late assessments based on programmed End Dates (min:1 and max:3)</label></div><div class="clearfix"></div></form>';
	    
    settingsHTML += '<hr>';
    settingsHTML += '<p><button class="cc-button" onClick="saveAtRiskSettings()">Save At-Risk Student Criteria</button></p>';
    settingsHTML += '<p id="savemsg-progress-atrisk">&nbsp;</p>';
    
    $('#cc-settings #pills-progress').html(settingsHTML);
    
    if(alldata.CustomSettings !== null) {
        if(alldata.CustomSettings.Dashboard !== undefined) {
            if(alldata.CustomSettings.Dashboard !== null) {
                $('#setLastAccessed').val(alldata.CustomSettings.Dashboard.AtRisk.AccessLast);
                $('#setGradeAvg').val(alldata.CustomSettings.Dashboard.AtRisk.GradeAvgNow);
                $('#setGradeMax').val(alldata.CustomSettings.Dashboard.AtRisk.GradeValueMax);
                $('#setContentViewed').val(alldata.CustomSettings.Dashboard.AtRisk.ContentViewed);
                $('#setLateAssess').val(alldata.CustomSettings.Dashboard.AtRisk.LateAssess);
                
                
            }
        }
    }
    
    $("#cc-settings #pills-progress .input-atrisk").on('change',function(){
        var val = $(this)[0].valueAsNumber;
        var min = parseInt($(this)[0].min);
        var max = parseInt($(this)[0].max);
        var setval = validateInput(val, min, max);
        if(isNaN(setval)){
            setval = min;
        }
        $(this).val(setval);
    });        
    
}


