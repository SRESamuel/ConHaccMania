function calculateStudents() {

    if(observeroles.indexOf(alldata.CurrentRole) === -1) {
        if (alldata.GradeSetup.GradingSystem === "Weighted") {
            for (var u = 0; u < alldata.Classlist.Objects.length; u++) {

                var currentaverage = 0;
                var currentearned = 0;

                var weightearned_drop = alldata.Classlist.Objects[u].Calculated.NumeratorDrop;
                var weightearned_zero = alldata.Classlist.Objects[u].Calculated.NumeratorZero;
                var weightassigned = alldata.Classlist.Objects[u].Calculated.DenominatorDrop;
                var weighttotal = alldata.Classlist.Objects[u].Calculated.DenominatorZero;

                if (weightassigned !== 0) {
                    currentaverage = (weightearned_drop / weightassigned) * 100;
                }
                if (weighttotal !== 0) {
                    currentearned = (weightearned_zero / weighttotal) * 100;
                }

                if (currentaverage > 100) {
                    currentaverage = 100;
                }
                if (currentearned > 100) {
                    currentearned = 100;
                }

                var currentearned_max = 0;
                var weightearned_zero_max = alldata.Classlist.Objects[u].Calculate100.NumeratorZero;
                var weighttotal_max = alldata.Classlist.Objects[u].Calculate100.DenominatorZero;

                if (weighttotal_max !== 0) {
                    currentearned_max = (weightearned_zero_max / weighttotal_max) * 100;
                }

                if (currentearned_max > 100) {
                    currentearned_max = 100;
                }

                alldata.Classlist.Objects[u].Calculated.CurrentEarned = currentearned;
                alldata.Classlist.Objects[u].Calculated.CurrentAverage = currentaverage;
                alldata.Classlist.Objects[u].Calculate100.CurrentEarned = currentearned_max;

            }
        } else if (alldata.GradeSetup.GradingSystem === "Points") {
            for (var u = 0; u < alldata.Classlist.Objects.length; u++) {

                var currentaverage = 0;
                var currentearned = 0;

                var pointsearned_drop = alldata.Classlist.Objects[u].Calculated.NumeratorDrop;
                var pointsearned_zero = alldata.Classlist.Objects[u].Calculated.NumeratorZero;
                var pointsassigned = alldata.Classlist.Objects[u].Calculated.DenominatorDrop;
                var pointstotal = alldata.Classlist.Objects[u].Calculated.DenominatorZero;

                if (pointsassigned !== 0) {
                    currentaverage = (pointsearned_drop / pointsassigned) * 100;
                }
                if (pointstotal !== 0) {
                    currentearned = (pointsearned_zero / pointstotal) * 100;
                }

                if (currentaverage > 100) {
                    currentaverage = 100;
                }
                if (currentearned > 100) {
                    currentearned = 100;
                }

                var currentearned_max = 0;
                var pointsearned_zero_max = alldata.Classlist.Objects[u].Calculate100.NumeratorZero;
                var pointstotal_max = alldata.Classlist.Objects[u].Calculate100.DenominatorZero;

                if (pointstotal_max !== 0) {
                    currentearned_max = (pointsearned_zero_max / pointstotal_max) * 100;
                }

                if (currentearned_max > 100) {
                    currentearned_max = 100;
                }

                alldata.Classlist.Objects[u].Calculated.CurrentEarned = currentearned;
                alldata.Classlist.Objects[u].Calculated.CurrentAverage = currentaverage;
                alldata.Classlist.Objects[u].Calculate100.CurrentEarned = currentearned_max;

            }
        }          
    }
}


function openSummary_StuAtRisk() {
    
	var atrisklisthtml = '';
    atrisklisthtml += '<p><a href="/d2l/le/content/6606/fullscreen/8123011/View?oid='+orgUnitId+'&rolename='+alldata.CurrentRole+'" target="_blank">View the full Students At-Risk Report in a new window <i class="fas fa-external-link" aria-hidden="true"></i><span class="sr-only">Opens in a new tab</span></a>.</p><hr>'; 
	
	if(atrisk_list.AllItems.length > 0) {
		for(var a=0; a<atrisk_list.AllItems.length; a++) {

			var uindex = -1;
			for(var u=0; u<alldata.Classlist.Objects.length; u++) {
				if(alldata.Classlist.Objects[u].Identifier === atrisk_list.AllItems[a]) {
					uindex = u;
				}
			}

			//console.log(alldata.Classlist.Objects[uindex]);
            if(uindex > -1) {
                var thisuser = alldata.Classlist.Objects[uindex];
                var atriskstu = '';

                atriskstu += '<div class="table-responsive-sm">';
                atriskstu += '<table class="table table-bordered"><tbody><tr class="danger">';
                if(alldata.Classlist.Objects[uindex].Email !== null) {
                    atriskstu += '<td style="width:32px; text-align:center"><a href="mailto:'+alldata.Classlist.Objects[uindex].Email+'" title="Send Email" target="_blank"><i class="fa fa-envelope" aria-hidden="true"></i></a></td>';
                }
                else {
                    atriskstu += '<td style="width:32px; text-align:center"><i class="fa fa-envelope" aria-hidden="true"></i></td>';
                }

                atriskstu += '<td>' + thisuser.FirstName + ' ' + thisuser.LastName + ' (' + thisuser.OrgDefinedId + ') </td>';
                atriskstu += '</tr>';

                for(var a1=0; a1<atrisk_list.AccessLast.length; a1++) {
                    if(atrisk_list.AccessLast[a1].Identifier === thisuser.Identifier) {
                        atriskstu += '<tr><td colspan="2"><i class="fa fa-exclamation-circle" aria-hidden="true"></i> <a href="/d2l/le/userprogress/'+alldata.Classlist.Objects[uindex].Identifier+'/'+orgUnitId+'/CourseAccess/Details?searchString=&sortField=LastName&classListFilterKey=all&sortDirection=0" target="_blank" title="View Course Last Accessed Details">Course was last accessed: ';
                        if(alldata.Classlist.Objects[uindex].LastAccessed !== null) {
                            atriskstu += new Date(alldata.Classlist.Objects[uindex].LastAccessed).toISOString().substring(0, 10);
                        }
                        else {
                            atriskstu += "Never";
                        }
                        atriskstu += ' <i class="fas fa-external-link" aria-hidden="true"></i><span class="sr-only">Opens in a new tab</span>';
                        atriskstu += '</a></td></tr>';
                    }
                }
                for(var a1=0; a1<atrisk_list.GradeAvgNow.length; a1++) {
                    if(atrisk_list.GradeAvgNow[a1].Identifier === thisuser.Identifier) {
                        atriskstu += '<tr><td colspan="2"><i class="fa fa-exclamation-circle" aria-hidden="true"></i> <a href="/d2l/le/classprogress/userprogress/'+alldata.Classlist.Objects[uindex].Identifier+'/'+orgUnitId+'/Grades/Details?searchString=&sortField=LastName&classListFilterKey=all&sortDirection=0" target="_blank" title="Current Grade Details">Current average grade value is: '+alldata.Classlist.Objects[uindex].Calculated.CurrentAverage.toFixed(2)+'% <i class="fas fa-external-link" aria-hidden="true"></i><span class="sr-only">Opens in a new tab</span></a></td></tr>';
                    }
                }
                for(var a1=0; a1<atrisk_list.GradeValueMax.length; a1++) {
                    if(atrisk_list.GradeValueMax[a1].Identifier === thisuser.Identifier) {
                        atriskstu += '<tr><td colspan="2"><i class="fa fa-exclamation-circle" aria-hidden="true"></i> <a href="/d2l/le/content/6606/fullscreen/8123012/View?oid=' + orgUnitId + '&uid='+alldata.Classlist.Objects[uindex].Identifier+'" target="_blank" title="Achievable Grade Details">Maximum achievable grade value is: '+alldata.Classlist.Objects[uindex].Calculate100.CurrentEarned.toFixed(2)+'% <i class="fas fa-external-link" aria-hidden="true"></i><span class="sr-only">Opens in a new tab</span></a></td></tr>';
                    }
                }
                for(var a1=0; a1<atrisk_list.ContentViewed.length; a1++) {
                    if(atrisk_list.ContentViewed[a1].Identifier === thisuser.Identifier) {

                        var contentpercent = (alldata.Classlist.Objects[uindex].Progress.CompletedItems / alldata.Classlist.Objects[uindex].Progress.RequiredItems) * 100;

                        atriskstu += '<tr><td colspan="2"><i class="fa fa-exclamation-circle" aria-hidden="true"></i> <a href="/d2l/le/userprogress/'+alldata.Classlist.Objects[uindex].Identifier+'/'+orgUnitId+'/Content/Details?searchString=&sortDirection=0&sortField=LastName&classListFilterKey=all" target="_blank" title="View Content Progress Details">Content viewed: '+alldata.Classlist.Objects[uindex].Progress.CompletedItems+' / '+alldata.Classlist.Objects[uindex].Progress.RequiredItems+' ('+contentpercent.toFixed(2)+'%) <i class="fas fa-external-link" aria-hidden="true"></i><span class="sr-only">Opens in a new tab</span></a></td></tr>';
                    }
                }
                for(var a1=0; a1<atrisk_list.LateAssess.length; a1++) {
                    if(atrisk_list.LateAssess[a1].Identifier === thisuser.Identifier) {

                        atriskstu += '<tr><td colspan="2"><i class="fa fa-exclamation-circle" aria-hidden="true"></i> Late assessments: ' + alldata.Classlist.Objects[uindex].LateAssess.length + '</td></tr>';                    
                    }
                }

                atriskstu += '</tbody></table>';
                atriskstu += '</div>';
                atrisklisthtml += atriskstu;                
            }

		}
	}
	else {
		atrisklisthtml += '<p>There are currently no students considered at risk based on your criteria.</p>';
	}
	
	$('#snapshotAtRiskStudents .modal-body').html(atrisklisthtml);    
    $('#snapshotAtRiskStudents').modal('toggle');  
}

function openSummary_AssessAnalysis() {
    
	var assesslisthtml = '';
    assesslisthtml += '<p><a href="/d2l/le/content/6606/fullscreen/14134468/View?oid='+orgUnitId+'&rolename='+alldata.CurrentRole+'" target="_blank">View the full Assessment Analysis Report in a new window <i class="fas fa-external-link" aria-hidden="true"></i><span class="sr-only">Opens in a new tab</span></a>.</p><hr>'
    
	if(assess_list.AllItems.length > 0) {
        
        for(var i=0; i<assess_list.AllItems.length; i++) {
            
            for(var g=0; g<alldata.GradeItems.Objects.length; g++) {
                if(alldata.GradeItems.Objects[g].Id === assess_list.AllItems[i]) {
                    var thisgrade = alldata.GradeItems.Objects[g];
                    //console.log(thisgrade);
                    var assessflag = '';
                    assessflag += '<div class="table-responsive-sm">';
                    assessflag += '<table class="table table-bordered"><tbody>';
                    assessflag += '<tr class="danger">';
                    assessflag += '<td style="width:50%">';
                    assessflag += '<strong>'+thisgrade.Name+'</strong>';
                    assessflag += '</td>';
                    assessflag += '<td style="width:50%">';
                    if(thisgrade.AssociatedTool !== null) {
                        if(thisgrade.Tool !== undefined) {
                            if(thisgrade.Tool.Link !== "") {
                                assessflag += 'Tool: <a href="'+thisgrade.Tool.Link+'" target="_blank">'+thisgrade.AssociatedTool.DisplayName+' <i class="fas fa-external-link" aria-hidden="true"></i><span class="sr-only">Opens in a new tab</span></a>';
                            }
                        }
                    }
                    else {
                        assessflag += 'Tool: <a href="/d2l/lms/grades/admin/enter/grade_item_edit.d2l?objectId='+thisgrade.Id+'&ou='+orgUnitId+'" target="_blank">Grades <i class="fas fa-external-link" aria-hidden="true"></i><span class="sr-only">Opens in a new tab</span></a>';
                    }
                    assessflag += '</td>';
                    assessflag += '</tr>';
                    assessflag += '<tr class="danger">';
                    assessflag += '<td style="width:50%">Overall Weight: '+(Math.round(thisgrade.WeightCalc * 100) / 100)+'%</td>';
                    var scoredpercent = ((thisgrade.NumEvals / alldata.Classlist.Objects.length)*100);
                    assessflag += '<td style="width:50%">Scores Published: ' + thisgrade.NumEvals + ' / ' + alldata.Classlist.Objects.length + ' (' +(Math.round(scoredpercent * 100) / 100)+'%)</td>';
                    assessflag += '</tr>';
                    
                    assessflag += '<tr>';
                    if((assess_list.AverageMin.indexOf(thisgrade.Id) > -1) || (assess_list.AverageMax.indexOf(thisgrade.Id) > -1)) {
                        assessflag += '<td colspan="2"><i class="fa fa-exclamation-circle" aria-hidden="true"></i> This grade item has an <a href="/d2l/lms/grades/admin/enter/grade_statistics.d2l?objectId='+thisgrade.Id+'&gradesArea=2&ou='+orgUnitId+'" target="_blank">average score of '+(Math.round(thisgrade.Statistics.Average * 100) / 100)+'% <i class="fas fa-external-link" aria-hidden="true"></i><span class="sr-only">Opens in a new tab</span></a>';

                        if(assess_list.AverageMin.indexOf(thisgrade.Id) > -1) {
                            assessflag += ', <strong>which is less than the desired minimum ('+alldata.CustomSettings.Dashboard.Assessment.AverageMin+'%)</strong>.</td>';
                        }
                        if(assess_list.AverageMax.indexOf(thisgrade.Id) > -1) {
                            assessflag += ', <strong>which is more than the desired maximum ('+alldata.CustomSettings.Dashboard.Assessment.AverageMax+'%)</strong>.</td>';
                        }
                    }
                    assessflag += '</tr>';
                    
                    assessflag += '<tr>';
                    if(assess_list.FailRate.indexOf(thisgrade.Id) > -1) {
                        assessflag += '<td colspan="2"><i class="fa fa-exclamation-circle" aria-hidden="true"></i> This grade item has a fail rate of '+(Math.round(thisgrade.Statistics.FailRate * 100) / 100)+'%, which is <strong>more than the desired maximum ('+alldata.CustomSettings.Dashboard.Assessment.FailRate+'%)</strong>.</tr>';
                    }
                    
                    if(assess_list.UngradedNow.indexOf(thisgrade.Id) > -1) {
                        assessflag += '<td colspan="2"><i class="fa fa-exclamation-circle" aria-hidden="true"></i> This grade item has an end date of '+thisgrade.EndDate.toLocaleDateString()+' and '+thisgrade.NumEvals+' student scores have been published. Ideally all <strong>grades values should be released to students less than ' + alldata.CustomSettings.Dashboard.GradeDates.DayCountMax + ' days after the assessment end date</strong>.';
                    }
                    assessflag += '</tr>';
                    
                    assessflag += '</tbody></table>';
                    assessflag += '</div>';
                    assesslisthtml += assessflag;
                }
            }

        }
                
	}
	else {
		assesslisthtml += '<p>There are currently no grade items flagged based on your criteria.</p>';
	}
	
	$('#snapshotFlaggedAssessments .modal-body').html(assesslisthtml);    
    $('#snapshotFlaggedAssessments').modal('toggle');  
}

