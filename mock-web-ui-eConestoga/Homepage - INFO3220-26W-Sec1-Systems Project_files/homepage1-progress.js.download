// JavaScript Document

function isValidDate(d) {
    return d instanceof Date && !isNaN(d);
}


function getEndDate(type, item) {
    //console.log(type);
    //console.log(item);
    
    var datereturn = {
        date: null,
        label: ""
    };
    
    if(type === "Discussions") {
        if(item.UnlockEndDate !== null) {
            datereturn.date = new Date(item.UnlockEndDate);
        }
        else {
            if(item.EndDate !== null) {
                datereturn.date = new Date(item.EndDate);
            }
        }
        datereturn.label = "Ends";
    }
    else if(type === "Quizzes") {
        if(item.DueDate !== null) {
            datereturn.date = new Date(item.DueDate);
            datereturn.label = "Due";
        }
        else {
            if(item.EndDate !== null) {
                datereturn.date = new Date(item.EndDate);
                datereturn.label = "Ends";
            }
        }
    }
    else if(type === "Assignments") {
        if(item.DueDate !== null) {
            datereturn.date = new Date(item.DueDate);
            datereturn.label = "Due";
        }
        else {
            if(item.Availability !== null) {
                if(item.Availability.EndDate !== null) {
                    datereturn.date = new Date(item.Availability.EndDate);
                    datereturn.label = "Ends";
                }
            }
        }
    }
    
    return datereturn;
    
}


function processDateAssess() {
    
    if(observeroles.indexOf(alldata.CurrentRole) === -1) {
        var tdate = new Date();

        for(var s=0; s<alldata.Classlist.Objects.length; s++) {
            var checkdate = false;

            if(studentroles.indexOf(alldata.CurrentRole) > -1) {
                if(alldata.Classlist.Objects[s].Identifier === alldata.WhoAmI.Identifier) {
                    checkdate = true;
                }
            }
            else {
                checkdate = true;
            }

            if(checkdate) {
                alldata.Classlist.Objects[s].LateAssess = [];
                alldata.Classlist.Objects[s].Overdue = {
                    GradeZero:0,
                    Quizzes:0,
                    Assignments:0,
                    Other:0,
                    Total:0
                }
                for(var g=0; g<alldata.GradeItems.Objects.length; g++) {
                    var thisgrade = alldata.GradeItems.Objects[g];
                    //console.log(thisgrade);
                    if(thisgrade.EndDate !== undefined) {
                        if(thisgrade.EndDate !== null) {
                            var edate = new Date(thisgrade.EndDate);
                            //if(edate < tdate) {
                                var currentlyzero = true;
                                if(studentroles.indexOf(alldata.CurrentRole) > -1) {
                                    if(thisgrade.Values.Objects.length > 0) {
                                        if(thisgrade.Values.Objects[0].PointsNumerator !== 0) {
                                            currentlyzero = false;
                                        }
                                        else {
                                            alldata.Classlist.Objects[s].Overdue.GradeZero++;
                                        }
                                    }
                                }
                                else {
                                    //console.log(JSON.parse(JSON.stringify(thisgrade.Values)));
                                    for(var v=0; v<thisgrade.Values.Objects.length; v++) {
                                        if(thisgrade.Values.Objects[v].User.Identifier === alldata.Classlist.Objects[s].Identifier) {
                                            //console.log(thisgrade.Values.Objects[v].GradeValue);
                                            if(thisgrade.Values.Objects[v].GradeValue !== null) {
                                                if(thisgrade.Values.Objects[v].GradeValue.PointsNumerator !== 0) {
                                                    currentlyzero = false;
                                                }
                                            }
                                        }
                                    }
                                }

                                if(currentlyzero) {
                                    if(thisgrade.AssociatedTool !== null) {
                                        if(thisgrade.AssociatedTool.DisplayName === "Quizzes") {
                                            for(var q=0; q<alldata.QuizzesAll.Objects.length; q++) {
                                                if(alldata.QuizzesAll.Objects[q].QuizId === thisgrade.AssociatedTool.ToolItemId) {
                                                    var thisquiz = alldata.QuizzesAll.Objects[q];
                                                    var attemptfound = false;
                                                    if(thisquiz.Attempts !== undefined) {
                                                        for(var qa=0; qa<thisquiz.Attempts.Objects.length; qa++) {
                                                            if(thisquiz.Attempts.Objects[qa].UserId === parseInt(alldata.Classlist.Objects[s].Identifier)) {
                                                                attemptfound = true;
                                                            }
                                                        }
                                                    }
                                                    if(!attemptfound) {
                                                        if(edate < tdate) {
                                                            alldata.Classlist.Objects[s].LateAssess.push(thisgrade.Id);
                                                            alldata.Classlist.Objects[s].Overdue.Quizzes++;
                                                            alldata.Classlist.Objects[s].Overdue.Total++;       
                                                        }
                                                    }
                                                }
                                            }
                                        }
                                        else if(thisgrade.AssociatedTool.DisplayName === "Assignments") {
                                            //console.log(alldata.AssignmentsAll);
                                            for(var a=0; a<alldata.AssignmentsAll.Objects.length; a++) {
                                                if(alldata.AssignmentsAll.Objects[a].Id === thisgrade.AssociatedTool.ToolItemId) {
                                                    var thisassign = alldata.AssignmentsAll.Objects[a];
                                                    var attemptfound = false;

                                                    //console.log(thisassign);
                                                    if(thisassign.Submissions !== undefined) {
                                                        if(thisassign.Submissions.length > 0) {
                                                            if(studentroles.indexOf(alldata.CurrentRole) > -1) {
                                                                // Submission found earlier from ECPlus.
                                                                attemptfound = true;
                                                            }
                                                            else {
                                                                for(var as=0; as<thisassign.Submissions.length; as++) {
                                                                    if(parseInt(thisassign.DropboxType) === 1) {
                                                                        //console.log("group");
                                                                        for(var gc=0; gc<alldata.GroupsAll.Objects.length; gc++) {
                                                                            for(var gd=0; gd<alldata.GroupsAll.Objects[gc].GroupsData.length; gd++) {
                                                                                var thisgroup = alldata.GroupsAll.Objects[gc].GroupsData[gd];
                                                                                if(thisassign.Submissions[as].Entity.EntityId === thisgroup.GroupId) {
                                                                                    for(var ge=0; ge<thisgroup.Enrollments.length; ge++) {
                                                                                        if(thisgroup.Enrollments[ge] === parseInt(alldata.Classlist.Objects[s].Identifier)) {
                                                                                            if(thisassign.Submissions[as].Submissions.length > 0) {
                                                                                                attemptfound = true;
                                                                                            }
                                                                                            else {
                                                                                                if(thisassign.Submissions[as].Feedback !== null) {
                                                                                                    if(thisassign.Submissions[as].Feedback.Score !== null) {
                                                                                                        if(thisassign.Submissions[as].Feedback.Score !== 0) {
                                                                                                            attemptfound = true;
                                                                                                        }                                                                    
                                                                                                    }                                       
                                                                                                }     
                                                                                            }  
                                                                                        }
                                                                                    }
                                                                                }
                                                                            }
                                                                        }                                                        
                                                                    }
                                                                    if(parseInt(thisassign.DropboxType) === 2) {
                                                                        if(thisassign.Submissions[as].Entity.EntityId === parseInt(alldata.Classlist.Objects[s].Identifier)) {
                                                                            //console.log(thisassign.Submissions[as]);
                                                                            if(thisassign.Submissions[as].Submissions.length > 0) {
                                                                                attemptfound = true;
                                                                            }
                                                                            else {
                                                                                if(thisassign.Submissions[as].Feedback !== null) {
                                                                                    if(thisassign.Submissions[as].Feedback.Score !== null) {
                                                                                        if(thisassign.Submissions[as].Feedback.Score !== 0) {
                                                                                            attemptfound = true;
                                                                                        }                                                                    
                                                                                    }                                       
                                                                                }     
                                                                            }                                           
                                                                        }
                                                                        //console.log(attemptfound);
                                                                    }
                                                                }                                                            
                                                            }
                                                        }
                                                    }
                                                    if(!attemptfound) {
                                                        if(edate < tdate) {
                                                            alldata.Classlist.Objects[s].LateAssess.push(thisgrade.Id);
                                                            alldata.Classlist.Objects[s].Overdue.Assignments++;
                                                            alldata.Classlist.Objects[s].Overdue.Total++;
                                                        }
                                                    }
                                                }
                                            }
                                        }
                                    }
                                    else {
                                        if(studentroles.indexOf(alldata.CurrentRole) > -1) {
                                            //console.log(alldata.Classlist.Objects[s]);
                                            //console.log(thisgrade);
                                            if(thisgrade.Values.Objects.length > 0) {
                                                if(edate < tdate) {
                                                    alldata.Classlist.Objects[s].LateAssess.push(thisgrade.Id);
                                                    alldata.Classlist.Objects[s].Overdue.Other++;
                                                    alldata.Classlist.Objects[s].Overdue.Total++;
                                                }
                                            }
                                        }
                                        else {
                                            var nonzerofound = false;
                                            if(thisgrade.Values.Objects.length > 0) {
                                                for(var v2=0; v2<thisgrade.Values.Objects.length; v2++) {
                                                    if(thisgrade.Values.Objects[v2].GradeValue !== null) {
                                                        if(thisgrade.Values.Objects[v2].GradeValue.PointsNumerator !== 0) {
                                                            nonzerofound = true;
                                                            break;
                                                        }
                                                    }
                                                }
                                                if(nonzerofound) {
                                                    var attemptfound = false;
                                                    for(var uv=0; uv<alldata.Classlist.Objects[s].Values.length; uv++) {
                                                        if(parseInt(alldata.Classlist.Objects[s].Values[uv].GradeObjectIdentifier) === thisgrade.Id) {
                                                            attemptfound = true;
                                                        }
                                                    }
                                                    if(!attemptfound) {
                                                        if(edate < tdate) {
                                                            alldata.Classlist.Objects[s].LateAssess.push(thisgrade.Id);
                                                            alldata.Classlist.Objects[s].Overdue.Other++;
                                                            alldata.Classlist.Objects[s].Overdue.Total++;
                                                        }
                                                    }
                                                }
                                            }                                        
                                        }
                                    }
                                }
                            //}    
                        }
                    }
                }
            }
        }        
    }
}


function processProgress() {
	
	for (var p = 0; p < alldata.ContentViews.Objects.length; p++) {
		for (var u = 0; u < alldata.Classlist.Objects.length; u++) {
			if (parseInt(alldata.Classlist.Objects[u].Identifier) === alldata.ContentViews.Objects[p].UserId) {
				if (alldata.Classlist.Objects[u].TotalTime === undefined) {
					alldata.Classlist.Objects[u].TotalTime = alldata.ContentViews.Objects[p].TotalTime;
				} else {
					alldata.Classlist.Objects[u].TotalTime += alldata.ContentViews.Objects[p].TotalTime;
				}

				if(alldata.ContentViews.Objects[p].Visited) {
					if (alldata.Classlist.Objects[u].TopicsViewed === undefined) {
						alldata.Classlist.Objects[u].TopicsViewed = 1;
					} else {
						alldata.Classlist.Objects[u].TopicsViewed++;
					}
				}
			}
		}
	}
}

var coursegradesdone = false;
function processGrades() {
    
    var tdate = new Date();    
    var gradeidlist = [];
    var toolidlist = [];    
    
    var pointstotal = 0;
    if (alldata.GradeSetup.GradingSystem === "Points") {
        var catdroptotal = 0;
        var catdroplist = [];
        for(var gc=0; gc<alldata.GradeCategories.length; gc++) {
            var numdroptotal = alldata.GradeCategories[gc].NumberOfHighestToDrop + alldata.GradeCategories[gc].NumberOfLowestToDrop;
            if(numdroptotal > 0) {
                catdroplist.push(alldata.GradeCategories[gc].Id);
                catdroptotal += (numdroptotal*alldata.GradeCategories[gc].MaxPoints);
            }
        }        
        for(var g=0; g<alldata.GradeItems.Objects.length; g++) {
            pointstotal += alldata.GradeItems.Objects[g].MaxPoints;
            if(alldata.GradeItems.Objects[g].CategoryId !== null) {
                if(catdroplist.indexOf(alldata.GradeItems.Objects[g].CategoryId) > -1) {
                    alldata.GradeItems.Objects[g].WeightDrop = true;
                }
            }
        }

        pointstotal = pointstotal - catdroptotal;
    }
    
    var thispassval = 55;
    var thispassfound = false;
    if(alldata.Outline !== undefined) {
        if(alldata.Outline !== null) {
            if(alldata.Outline.length > 0) {
                if(alldata.Outline[0].MinimumGrade !== undefined) {
                    if(!isNaN(alldata.Outline[0].MinimumGrade)) {
                        thispassfound = true;
                        if(alldata.Outline[0].MinimumGrade > thispassval) {
                            thispassval = alldata.Outline[0].MinimumGrade;
                        }       
                    }
                }
            }
        }
    }
    
    for(var g=0; g<alldata.GradeItems.Objects.length; g++) {
        var thisgrade = alldata.GradeItems.Objects[g];      
        var numevals = 0;
        //numevals2 a different way of counting num scored, depends on student values being pulled earlier to determine 0 vs. ungraded.
        var numevals2 = 0;        
        
        if((studentroles.indexOf(alldata.CurrentRole) === -1) && (observeroles.indexOf(alldata.CurrentRole) === -1)) {
            if(thisgrade.Values !== undefined) {
                if((thisgrade.GradeType === "Numeric") || (thisgrade.GradeType === "PassFail") || (thisgrade.GradeType === "SelectBox")) {

                    var numeratotal = 0;
                    for(var gv=0; gv<thisgrade.Values.Objects.length; gv++) {
                        var thisval = thisgrade.Values.Objects[gv];
                        if(thisval.GradeValue !== null) {
                            //console.log(thisval.GradeValue);
                            numevals++;
                            if(thisval.GradeValue.PointsNumerator > 0) {
                                numeratotal += thisval.GradeValue.PointsNumerator;
                                numevals2++
                            }
                            else {                                
                                if(thisval.GradeValue.IsZero) {
                                    numevals2++;
                                }
                            }
                        }
                    }                

                    if(thisgrade.Statistics !== undefined) {
                        if(thisgrade.Statistics !== null) {
                            if(thisgrade.Statistics.Average !== null) {                
                                //console.log(numeratotal);
                                var thismeans = ((numeratotal / numevals) / thisgrade.MaxPoints) * 100;
                                //console.log(thismeans);
                                if(thismeans !== thisgrade.Statistics.Average) {
                                    var newnumevals = Math.round((numeratotal / (thisgrade.MaxPoints * thisgrade.Statistics.Average)) * 100);
                                    if(newnumevals <= alldata.Classlist.Objects.length) {
                                        numevals = newnumevals;
                                    }
                                }
                            }
                        }
                    }                
                }

                //console.log(numevals);
                //console.log(numevals2);
                thisgrade.NumEvals = numevals;            

                var numvalues = 0;
                var numfails = 0;
                var numzero = 0;
                var numfailsnonzero = 0;
                var totalnumerator = 0;

                thisgrade.LastGraded = null;           

                if(thisgrade.Values.Objects !== undefined) {
                    for(var v=0; v<thisgrade.Values.Objects.length; v++) {

                        //console.log(thisgrade.Values.Objects[v].GradeValue);
                        if(thisgrade.Values.Objects[v].GradeValue !== null) {

                            totalnumerator += thisgrade.Values.Objects[v].GradeValue.PointsNumerator;
                            if(thisgrade.Values.Objects[v].GradeValue.PointsNumerator !== 0) {
                                currentlyzero = false;
                                numvalues++;
                                var thispercent = ((thisgrade.Values.Objects[v].GradeValue.PointsNumerator / thisgrade.Values.Objects[v].GradeValue.PointsDenominator) * 100);

                                if(thispercent < thispassval) {
                                    numfails++;
                                    numfailsnonzero++;
                                }                        
                            }
                            else {
                                var zerofound = false;
                                for(var s2=0; s2<alldata.Classlist.Objects.length; s2++) {
                                    if(alldata.Classlist.Objects[s2].Identifier === thisgrade.Values.Objects[v].Identifier) {
                                        var thisuser = alldata.Classlist.Objects[s2];
                                        for(var v2=0; v2<thisuser.Values.length; v2++) {
                                            if(thisuser.Values[v2].GradeObjectIdentifier === thisgrade.Values.Objects[v].GradeValue.GradeObjectIdentifier) {
                                                thisgrade.Values.Objects[v].GradeValue.IsZero = true;
                                                zerofound = true;
                                                numvalues++;
                                                numfails++;                                        
                                            }
                                        }
                                    }
                                }
                                if(!zerofound) {
                                    thisgrade.Values.Objects[v].GradeValue.IsZero = false;
                                }
                                else {
                                    if(thisgrade.GradeType === "PassFail") {
                                        numfailsnonzero++
                                    }
                                    else {
                                        numzero++; 
                                    }
                                }
                            }

                            var ignoreungraded = false;
                            if(thisgrade.Values.Objects[v].GradeValue.PointsNumerator === 0) {
                                if(!thisgrade.Values.Objects[v].GradeValue.IsZero) {
                                    ignoreungraded = true;
                                }
                            }

                            if(!ignoreungraded) {
                                if(thisgrade.Values.Objects[v].GradeValue.LastModified !== null) {
                                    var thisdate = new Date(thisgrade.Values.Objects[v].GradeValue.LastModified);
                                    if(thisgrade.LastGraded !== null) {
                                        if(thisdate > thisgrade.LastGraded) {
                                            thisgrade.LastGraded = thisdate;
                                        }
                                    }
                                    else {
                                        thisgrade.LastGraded = thisdate;
                                    }
                                }
                            }                        
                        }
                    }                 
                }

                //console.log(thisgrade.NumEvals);
                //console.log(numvalues);

                if(thisgrade.NumEvals > numvalues) {
                    numfails += (thisgrade.NumEvals - numvalues);
                    numzero++;
                }

                if(thisgrade.NumEvals > 0) {
                    if(thisgrade.Statistics !== undefined) {
                        if(thisgrade.Statistics !== null) {
                            var thisfailrate = (numfails / thisgrade.NumEvals) * 100;
                            thisgrade.Statistics.FailRate = thisfailrate;
                            thisgrade.Statistics.FailNum = numfails;

                            thisgrade.Statistics.Zero = {
                                ZeroCount: numzero,
                                FailNum: numfailsnonzero,
                                FailRate: (numfailsnonzero / (thisgrade.NumEvals - numzero) * 100),
                                Average: (totalnumerator / ((thisgrade.NumEvals - numzero) * thisgrade.MaxPoints) * 100)
                            }

                            /*
                            console.log(thisgrade);
                            console.log(numzero);
                            console.log(numfailsnonzero);
                            console.log("Total Non Zero: " + (thisgrade.NumEvals - numzero));
                            console.log("Total Numerator: " + totalnumerator);
                            console.log("Avg Non Zero: " + (totalnumerator / ((thisgrade.NumEvals - numzero) * thisgrade.MaxPoints) * 100));
                            */
                        }
                    }
                }
                else {
                    if(thisgrade.Statistics !== undefined) {
                        if(thisgrade.Statistics !== null) {
                            thisgrade.Statistics.FailRate = null;
                            thisgrade.Statistics.FailNum = null;
                            thisgrade.Statistics.Zero = {
                                ZeroCount: null,
                                FailNum: null,
                                FailRate: null,
                                Average: null
                            }
                        }
                    }
                }                 
            }
        }       
        
        if((thisgrade.GradeType === "Numeric") || (thisgrade.GradeType === "PassFail") || (thisgrade.GradeType === "SelectBox")) {
            
            gradeidlist.push(thisgrade.Id);
            
            if(thisgrade.AssociatedTool !== null) {
                toolidlist.push(thisgrade.AssociatedTool.ToolItemId);

                for (var ti = 0; ti < d2l_tools.Items.length; ti++) {
                    if (thisgrade.AssociatedTool.ToolId === parseInt(d2l_tools.Items[ti].ToolId)) {
                        var thistool = d2l_tools.Items[ti];
                        thisgrade.AssociatedTool.DisplayName = thistool.DisplayName;
                        if(thistool.DisplayName === "External Learning Tools") {
                            thisgrade.AssociatedTool.DisplayName = "External";
                        }
                    }
                }
                
                var thisdate = null;
                var thislink = '';
                
                if(thisgrade.AssociatedTool.DisplayName !== undefined) {
                    if(thisgrade.AssociatedTool.DisplayName === "Quizzes") {
                        
                        thislink = '/d2l/lms/quizzing/admin/mark/quiz_mark_users.d2l?qi='+thisgrade.AssociatedTool.ToolItemId+'&ou='+orgUnitId;
                        
                        for(var q=0; q<alldata.QuizzesAll.Objects.length; q++) {
                            var thisquiz = alldata.QuizzesAll.Objects[q];
                            if(thisquiz.QuizId === thisgrade.AssociatedTool.ToolItemId) {
                                thisdate = getEndDate(thisgrade.AssociatedTool.DisplayName, thisquiz).date;
                            }
                        }
                    }
                    else if(thisgrade.AssociatedTool.DisplayName === "Assignments") {
                        
                        thislink = '/d2l/lms/dropbox/admin/mark/folder_submissions_users.d2l?db='+thisgrade.AssociatedTool.ToolItemId+'&ou='+orgUnitId;
                        
                        for(var a=0; a<alldata.AssignmentsAll.Objects.length; a++) {
                            var thisassign = alldata.AssignmentsAll.Objects[a];
                            if(thisassign.Id === thisgrade.AssociatedTool.ToolItemId) {
                                thisdate = getEndDate(thisgrade.AssociatedTool.DisplayName, thisassign).date;
                            }
                        }
                    }
                    else if(thisgrade.AssociatedTool.DisplayName === "Discussions") {
                        
                        thislink = '/d2l/lms/discussions/admin/assess_topic_user.d2l?ou='+orgUnitId+'&topicId='+thisgrade.AssociatedTool.ToolItemId;
                            
                        for(var d=0; d<alldata.DiscussionsAll.Objects.length; d++) {
                            for(var t=0; t<alldata.DiscussionsAll.Objects[d].Topics.length; t++) {
                                var thisdiscuss = alldata.DiscussionsAll.Objects[d].Topics[t];
                                if(thisdiscuss.TopicId === thisgrade.AssociatedTool.ToolItemId) {
                                    thisdate = getEndDate(thisgrade.AssociatedTool.DisplayName, thisdiscuss).date;
                                }
                            }
                        }
                    }
                    else {
                    }
                }
                else {
                }
                
                thisgrade.Tool = {
                    Link: thislink,
                };
                if(thisdate !== null) {
                    thisgrade.EndDate = thisdate;
                }
                else {
                    if(thisgrade.EndDate === undefined) {
                        thisgrade.EndDate = null;
                    }
                }
            }
            else {
            }

            var thisweight = thisgrade.Weight
            if (alldata.GradeSetup.GradingSystem === "Points") {
                thisweight = (thisgrade.MaxPoints / pointstotal) * 100;
            }
            else {
                if(thisgrade.CategoryId !== 0) {
                    for(var gc=0; gc<alldata.GradeCategories.length; gc++) {
                        if(alldata.GradeCategories[gc].Id === thisgrade.CategoryId) {

                            if (alldata.GradeSetup.GradingSystem === "Weighted") {
                                var thiscat = alldata.GradeCategories[gc];
                                if(thiscat.WeightDistributionType !== 1) {
                                    var totalcat = 100;
                                    if(thiscat.WeightDistributionType === 2) {
                                        totalcat = 0;
                                        for(var g2=0; g2<thiscat.Grades.length; g2++) {
                                            totalcat += thiscat.Grades[g2].Weight;
                                        }
                                    }                         
                                    thisweight = (thisgrade.Weight / totalcat) * thiscat.Weight;   
                                }
                                else {
                                    // Some items may be dropped. If so, increase overall weight.

                                    if(!thisgrade.IsBonus) {
                                        if((thiscat.NumberOfHighestToDrop > 0) || (thiscat.NumberOfLowestToDrop > 0)){
                                            //console.log(thiscat);
                                            var numnonbonus = 0;
                                            for(var gci=0; gci<thiscat.Grades.length; gci++) {
                                                if(!thiscat.Grades[gci].IsBonus) {
                                                    numnonbonus++;
                                                }
                                            }
                                            var numforfinal = numnonbonus - thiscat.NumberOfHighestToDrop - thiscat.NumberOfLowestToDrop;

                                            thisweight = (1 / numforfinal) * thiscat.Weight;
                                            thisgrade.WeightDrop = true;

                                        }
                                    }
                                    else {
                                        thisweight = (thisgrade.Weight / 100) * thiscat.Weight;  
                                    }
                                }
                            }
                            break;
                        }
                    }
                }
            }

            thisgrade.WeightCalc = thisweight;

        }
    }
    
    var nodatecount = 0;
    for(var g=0; g<alldata.GradeItems.Objects.length; g++) {
        var thisgrade = alldata.GradeItems.Objects[g];
        
        if((thisgrade.GradeType === "Numeric") || (thisgrade.GradeType === "PassFail") || (thisgrade.GradeType === "SelectBox")) {        
            var datefound = false;

            if(thisgrade.EndDate !== undefined) {
                if(thisgrade.EndDate !== null) {
                    datefound = true;
                }
            }
            if(!datefound) {
                nodatecount++;
            }
        }
    }
    
    //console.log(nodatecount);
    //console.log(assess_list);
    
    coursegradesdone = true;
    updateWidgetDataAuto();
    
}


function sortByKey(array, key) {
	return array.sort(function (a, b) {
		var x = a[key];
		var y = b[key];
		return ((x < y) ? -1 : ((x > y) ? 1 : 0));
	});
};


function sortByKey2(array, key1, key2) {
	return array.sort(function (a, b) {
		var x = a[key1][key2];
		var y = b[key1][key2];
		return ((x < y) ? -1 : ((x > y) ? 1 : 0));
	});
};


function setFutureCustom() {
	
	var whatif_setval = $('#whatif_setany').val();
	if(whatif_setval !== "") {
		setFutureValues('Calculator',parseInt(whatif_setval),true);
	}
	else {

	}
	
}


function setFutureValues(attr, val, updateinputs, uindex) {

	if (uindex === undefined) {
		uindex = whatif_userindex;
	}

	for (var c = 0; c < alldata.Classlist.Objects[uindex][attr].Categories.length; c++) {
		for (var g = 0; g < alldata.Classlist.Objects[uindex][attr].Categories[c].Grades.length; g++) {
			if (!alldata.Classlist.Objects[uindex][attr].Categories[c].Grades[g].Earned) {
				alldata.Classlist.Objects[uindex][attr].Categories[c].Grades[g].PointsNumerator = (val / 100) * alldata.Classlist.Objects[uindex][attr].Categories[c].Grades[g].PointsDenominator;

				if (updateinputs) {
					$('#GradeInput-' + alldata.Classlist.Objects[uindex][attr].Categories[c].Grades[g].Id).val(alldata.Classlist.Objects[uindex][attr].Categories[c].Grades[g].PointsNumerator);
					$('input[link-to=GradeInput-' + alldata.Classlist.Objects[uindex][attr].Categories[c].Grades[g].Id + ']').val(alldata.Classlist.Objects[uindex][attr].Categories[c].Grades[g].PointsNumerator);
				}

			}
		}

		dropFromCategory(attr, uindex, c);
		recalculateWhatIf(attr, uindex, c);

	}
	for (var o = 0; o < alldata.Classlist.Objects[uindex][attr].Uncategorized.Grades.length; o++) {
		if (!alldata.Classlist.Objects[uindex][attr].Uncategorized.Grades[o].Earned) {
			alldata.Classlist.Objects[uindex][attr].Uncategorized.Grades[o].PointsNumerator = (val / 100) * alldata.Classlist.Objects[uindex][attr].Uncategorized.Grades[o].PointsDenominator;

			if (updateinputs) {
				$('#GradeInput-' + alldata.Classlist.Objects[uindex][attr].Uncategorized.Grades[o].Id).val(alldata.Classlist.Objects[uindex][attr].Uncategorized.Grades[o].PointsNumerator);
				$('input[link-to=GradeInput-' + alldata.Classlist.Objects[uindex][attr].Uncategorized.Grades[o].Id + ']').val(alldata.Classlist.Objects[uindex][attr].Uncategorized.Grades[o].PointsNumerator);
			}
		}
	}

	alldata.Classlist.Objects[uindex][attr].Uncategorized.UngradedZero.Numerator = 0;
	for (var o = 0; o < alldata.Classlist.Objects[uindex][attr].Uncategorized.Grades.length; o++) {

		var userearned;
		if (alldata.GradeSetup.GradingSystem === "Weighted") {
			userearned = ((alldata.Classlist.Objects[uindex][attr].Uncategorized.Grades[o].PointsNumerator / alldata.Classlist.Objects[uindex][attr].Uncategorized.Grades[o].PointsDenominator) * alldata.Classlist.Objects[uindex][attr].Uncategorized.Grades[o].Weight);
			alldata.Classlist.Objects[uindex][attr].Uncategorized.UngradedZero.Numerator += userearned;

		} else if (alldata.GradeSetup.GradingSystem === "Points") {
			userearned = alldata.Classlist.Objects[uindex][attr].Uncategorized.Grades[o].PointsNumerator;
			if (!alldata.Classlist.Objects[uindex][attr].Uncategorized.Grades[o].ExcludeFromFinalGradeCalculation) {
				alldata.Classlist.Objects[uindex][attr].Uncategorized.UngradedZero.Numerator += userearned;
			}
		}
	}

	//console.log(alldata.Classlist.Objects[uindex]);
	//console.log(updateinputs);

	if (updateinputs) {
		whatIfInputs();
	}

}


function dropFromCategory(attr, u, c) {

	if ((alldata.Classlist.Objects[u][attr].Categories[c].WeightDistributionType === 1) || alldata.Classlist.Objects[u][attr].Categories[c].AutoPoints) {
		if (alldata.Classlist.Objects[u][attr].Categories[c].NumberOfLowestToDrop > 0) {
			var dropindex = [];

			for (var g = 0; g < alldata.Classlist.Objects[u][attr].Categories[c].Grades.length; g++) {
				alldata.Classlist.Objects[u][attr].Categories[c].Grades[g].IsDropped = false;
				var gradeval = {
					index: g,
					value: (alldata.Classlist.Objects[u][attr].Categories[c].Grades[g].PointsNumerator / alldata.Classlist.Objects[u][attr].Categories[c].Grades[g].PointsDenominator)
				}
				dropindex.push(gradeval);
			}

			dropindex = sortByKey(dropindex, "value");
			var numdropped = 0;

			for (var i = 0; i < dropindex.length; i++) {
				if (!alldata.Classlist.Objects[u][attr].Categories[c].Grades[dropindex[i].index].IsBonus) {

                    var setdropped = false;
                    if (alldata.GradeSetup.GradingSystem === "Points") {
                        if (!alldata.Classlist.Objects[u][attr].Categories[c].Grades[dropindex[i].index].ExcludeFromFinalGradeCalculation) {
                            setdropped = true;   
                        }
                    }
                    else {
                        setdropped = true;
                    }
                    
					if (setdropped) {
						alldata.Classlist.Objects[u][attr].Categories[c].Grades[dropindex[i].index].IsDropped = true;
						alldata.Classlist.Objects[u][attr].Categories[c].Grades[dropindex[i].index].Weight = 0;
						numdropped++;
					}
				}

				if (numdropped === alldata.Classlist.Objects[u][attr].Categories[c].NumberOfLowestToDrop) {
					break;
				}
			}
		}

		if (alldata.GradeSetup.GradingSystem === "Weighted") {
			var nondroppednonbonus = 0;
			for (var g = 0; g < alldata.Classlist.Objects[u][attr].Categories[c].Grades.length; g++) {
				if (!alldata.Classlist.Objects[u][attr].Categories[c].Grades[g].IsDropped && !alldata.Classlist.Objects[u][attr].Categories[c].Grades[g].IsBonus) {
					nondroppednonbonus++;
				}
			}

			for (var g = 0; g < alldata.Classlist.Objects[u][attr].Categories[c].Grades.length; g++) {
				if (!alldata.Classlist.Objects[u][attr].Categories[c].Grades[g].IsDropped && !alldata.Classlist.Objects[u][attr].Categories[c].Grades[g].IsBonus) {
					alldata.Classlist.Objects[u][attr].Categories[c].Grades[g].Weight = (100 / nondroppednonbonus);
				}
			}
		}
	}
}


function recalculateValues(attr, u, c) {

	alldata.Classlist.Objects[u][attr].Categories[c].UngradedDrop = {
		Numerator: 0,
		Denominator: 0
	};
	alldata.Classlist.Objects[u][attr].Categories[c].UngradedZero = {
		Numerator: 0,
		Denominator: 0
	};

	if (alldata.GradeSetup.GradingSystem === "Weighted") {

		for (var g = 0; g < alldata.Classlist.Objects[u][attr].Categories[c].Grades.length; g++) {

			if (!alldata.Classlist.Objects[u][attr].Categories[c].Grades[g].IsDropped) {

				if (!alldata.Classlist.Objects[u][attr].Categories[c].Grades[g].IsBonus) {
					alldata.Classlist.Objects[u][attr].Categories[c].UngradedZero.Denominator += alldata.Classlist.Objects[u][attr].Categories[c].Grades[g].Weight;
				}

				if (alldata.Classlist.Objects[u][attr].Categories[c].Grades[g].Earned) {

					var userearned = (alldata.Classlist.Objects[u][attr].Categories[c].Grades[g].PointsNumerator / alldata.Classlist.Objects[u][attr].Categories[c].Grades[g].PointsDenominator) * alldata.Classlist.Objects[u][attr].Categories[c].Grades[g].Weight;

					alldata.Classlist.Objects[u][attr].Categories[c].UngradedDrop.Numerator += userearned;
					alldata.Classlist.Objects[u][attr].Categories[c].UngradedZero.Numerator += userearned;

					if (!alldata.Classlist.Objects[u][attr].Categories[c].Grades[g].IsBonus) {
						alldata.Classlist.Objects[u][attr].Categories[c].UngradedDrop.Denominator += alldata.Classlist.Objects[u][attr].Categories[c].Grades[g].Weight;
					}
				}
			}
		}
	} else if (alldata.GradeSetup.GradingSystem === "Points") {
		for (var g = 0; g < alldata.Classlist.Objects[u][attr].Categories[c].Grades.length; g++) {

			if (!alldata.Classlist.Objects[u][attr].Categories[c].Grades[g].ExcludeFromFinalGradeCalculation) {
				if (!alldata.Classlist.Objects[u][attr].Categories[c].Grades[g].IsDropped) {
					if (!alldata.Classlist.Objects[u][attr].Categories[c].Grades[g].IsBonus) {
						alldata.Classlist.Objects[u][attr].Categories[c].UngradedZero.Denominator += alldata.Classlist.Objects[u][attr].Categories[c].Grades[g].PointsDenominator;
					}

					if (alldata.Classlist.Objects[u][attr].Categories[c].Grades[g].Earned) {

						var userearned = alldata.Classlist.Objects[u][attr].Categories[c].Grades[g].PointsNumerator;

						alldata.Classlist.Objects[u][attr].Categories[c].UngradedDrop.Numerator += userearned;
						alldata.Classlist.Objects[u][attr].Categories[c].UngradedZero.Numerator += userearned;

						if (!alldata.Classlist.Objects[u][attr].Categories[c].Grades[g].IsBonus) {
							alldata.Classlist.Objects[u][attr].Categories[c].UngradedDrop.Denominator += alldata.Classlist.Objects[u][attr].Categories[c].Grades[g].PointsDenominator;
						}
					}
				}
			}
		}
	}
}


function recalculateWhatIf(attr, u, c) {

	alldata.Classlist.Objects[u][attr].Categories[c].UngradedDrop = {
		Numerator: 0,
		Denominator: 0
	};
	alldata.Classlist.Objects[u][attr].Categories[c].UngradedZero = {
		Numerator: 0,
		Denominator: 0
	};

	if (alldata.GradeSetup.GradingSystem === "Weighted") {

		for (var g = 0; g < alldata.Classlist.Objects[u][attr].Categories[c].Grades.length; g++) {

			if (!alldata.Classlist.Objects[u][attr].Categories[c].Grades[g].IsDropped) {

				if (!alldata.Classlist.Objects[u][attr].Categories[c].Grades[g].IsBonus) {
					alldata.Classlist.Objects[u][attr].Categories[c].UngradedZero.Denominator += alldata.Classlist.Objects[u][attr].Categories[c].Grades[g].Weight;
				}

				var userearned = (alldata.Classlist.Objects[u][attr].Categories[c].Grades[g].PointsNumerator / alldata.Classlist.Objects[u][attr].Categories[c].Grades[g].PointsDenominator) * alldata.Classlist.Objects[u][attr].Categories[c].Grades[g].Weight;

				alldata.Classlist.Objects[u][attr].Categories[c].UngradedDrop.Numerator += userearned;
				alldata.Classlist.Objects[u][attr].Categories[c].UngradedZero.Numerator += userearned;

				if (!alldata.Classlist.Objects[u][attr].Categories[c].Grades[g].IsBonus) {
					alldata.Classlist.Objects[u][attr].Categories[c].UngradedDrop.Denominator += alldata.Classlist.Objects[u][attr].Categories[c].Grades[g].Weight;
				}

			}
		}
	} else if (alldata.GradeSetup.GradingSystem === "Points") {
		for (var g = 0; g < alldata.Classlist.Objects[u][attr].Categories[c].Grades.length; g++) {

			if (!alldata.Classlist.Objects[u][attr].Categories[c].Grades[g].ExcludeFromFinalGradeCalculation) {
				if (!alldata.Classlist.Objects[u][attr].Categories[c].Grades[g].IsDropped) {
					if (!alldata.Classlist.Objects[u][attr].Categories[c].Grades[g].IsBonus) {
						alldata.Classlist.Objects[u][attr].Categories[c].UngradedZero.Denominator += alldata.Classlist.Objects[u][attr].Categories[c].Grades[g].PointsDenominator;
					}

					var userearned = alldata.Classlist.Objects[u][attr].Categories[c].Grades[g].PointsNumerator;

					alldata.Classlist.Objects[u][attr].Categories[c].UngradedDrop.Numerator += userearned;
					alldata.Classlist.Objects[u][attr].Categories[c].UngradedZero.Numerator += userearned;

					if (!alldata.Classlist.Objects[u][attr].Categories[c].Grades[g].IsBonus) {
						alldata.Classlist.Objects[u][attr].Categories[c].UngradedDrop.Denominator += alldata.Classlist.Objects[u][attr].Categories[c].Grades[g].PointsDenominator;
					}

				}
			}
		}
	}
}


function calculatePoints(attr, u) {

	var pointsearned_drop = 0;
	var pointsearned_zero = 0;
	var pointsassigned = 0;
	var pointstotal = 0;

	for (var c = 0; c < alldata.Classlist.Objects[u][attr].Categories.length; c++) {

		if (!alldata.Classlist.Objects[u][attr].Categories[c].ExcludeFromFinalGrade) {
			pointstotal += alldata.Classlist.Objects[u][attr].Categories[c].UngradedZero.Denominator;
			pointsearned_zero += alldata.Classlist.Objects[u][attr].Categories[c].UngradedZero.Numerator;

			if (alldata.Classlist.Objects[u][attr].Categories[c].UngradedDrop.Numerator > 0) {
				pointsearned_drop += alldata.Classlist.Objects[u][attr].Categories[c].UngradedDrop.Numerator;
				pointsassigned += alldata.Classlist.Objects[u][attr].Categories[c].UngradedDrop.Denominator;
			}
		}
	}

	pointsearned_drop += alldata.Classlist.Objects[u][attr].Uncategorized.UngradedDrop.Numerator;
	pointsearned_zero += alldata.Classlist.Objects[u][attr].Uncategorized.UngradedZero.Numerator;
	pointsassigned += alldata.Classlist.Objects[u][attr].Uncategorized.UngradedDrop.Denominator;
	pointstotal += alldata.Classlist.Objects[u][attr].Uncategorized.UngradedZero.Denominator;

	alldata.Classlist.Objects[u][attr].NumeratorDrop = pointsearned_drop;
	alldata.Classlist.Objects[u][attr].NumeratorZero = pointsearned_zero;
	alldata.Classlist.Objects[u][attr].DenominatorDrop = pointsassigned;
	alldata.Classlist.Objects[u][attr].DenominatorZero = pointstotal;
	alldata.Classlist.Objects[u][attr].CoursePercent = (pointsassigned / pointstotal) * 100;

}


function calculateWeights(attr, u) {

	var weightearned_drop = 0;
	var weightearned_zero = 0;
	var weightassigned = 0;
	var weighttotal = 0;
	var weighttotal_earned = 0;

	for (var c = 0; c < alldata.Classlist.Objects[u][attr].Categories.length; c++) {

		weighttotal += alldata.Classlist.Objects[u][attr].Categories[c].Weight;

		if (alldata.Classlist.Objects[u][attr].Categories[c].UngradedDrop.Denominator !== 0) {
			
			weighttotal_earned += (alldata.Classlist.Objects[u][attr].Categories[c].UngradedDrop.Denominator / alldata.Classlist.Objects[u][attr].Categories[c].UngradedZero.Denominator) * alldata.Classlist.Objects[u][attr].Categories[c].Weight;

			weightearned_drop += (alldata.Classlist.Objects[u][attr].Categories[c].UngradedDrop.Numerator / alldata.Classlist.Objects[u][attr].Categories[c].UngradedDrop.Denominator) * alldata.Classlist.Objects[u][attr].Categories[c].Weight;

			weightearned_zero += (alldata.Classlist.Objects[u][attr].Categories[c].UngradedZero.Numerator / alldata.Classlist.Objects[u][attr].Categories[c].UngradedZero.Denominator) * alldata.Classlist.Objects[u][attr].Categories[c].Weight;

			weightassigned += alldata.Classlist.Objects[u][attr].Categories[c].Weight;

		} else {
            
		}
	}

	weightearned_drop += alldata.Classlist.Objects[u][attr].Uncategorized.UngradedDrop.Numerator;
	weightearned_zero += alldata.Classlist.Objects[u][attr].Uncategorized.UngradedZero.Numerator;
	weightassigned += alldata.Classlist.Objects[u][attr].Uncategorized.UngradedDrop.Denominator;
	weighttotal += alldata.Classlist.Objects[u][attr].Uncategorized.UngradedZero.Denominator;
	weighttotal_earned += alldata.Classlist.Objects[u][attr].Uncategorized.UngradedDrop.Denominator;

	alldata.Classlist.Objects[u][attr].NumeratorDrop = weightearned_drop;
	alldata.Classlist.Objects[u][attr].NumeratorZero = weightearned_zero;
	alldata.Classlist.Objects[u][attr].DenominatorDrop = weightassigned;
	alldata.Classlist.Objects[u][attr].DenominatorZero = weighttotal;
	alldata.Classlist.Objects[u][attr].CoursePercent = weighttotal_earned;

}



function buildGrades() {
    
    alldata.GradesAll = {
        Categories: [],
        Uncategorized: []
    }
    
    if(alldata.GradeItems !== undefined) {
        for (var a = 0; a < alldata.GradeItems.Objects.length; a++) {
            if (alldata.GradeItems.Objects[a].CategoryId === 0) {
                alldata.GradesAll.Uncategorized.push(alldata.GradeItems.Objects[a]);
            }
        }
    }

    if(alldata.GradeSetup !== undefined) {
        if (alldata.GradeSetup.GradingSystem === "Weighted") {
            for (var c = 0; c < alldata.GradeCategories.length; c++) {
                var ctotalweight = 0;

                if (alldata.GradeCategories[c].WeightDistributionType === 1) {
                    var nonbonus = 0;
                    for (var g = 0; g < alldata.GradeCategories[c].Grades.length; g++) {
                        if (!alldata.GradeCategories[c].Grades[g].IsBonus) {
                            nonbonus++;
                        }
                    }
                    var gradedist = 100 / nonbonus;
                    for (var g = 0; g < alldata.GradeCategories[c].Grades.length; g++) {
                        if (!alldata.GradeCategories[c].Grades[g].IsBonus) {
                            alldata.GradeCategories[c].Grades[g].Weight = gradedist;
                        }
                    }

                    ctotalweight = 100;
                } else {
                    for (var g = 0; g < alldata.GradeCategories[c].Grades.length; g++) {
                        ctotalweight += alldata.GradeCategories[c].Grades[g].Weight;
                    }
                }

                alldata.GradeCategories[c].GradesTotalWeight = ctotalweight;

            }
        } else if (alldata.GradeSetup.GradingSystem === "Points") {
            for (var c = 0; c < alldata.GradeCategories.length; c++) {
                var ctotalpoints = 0;

                for (var g = 0; g < alldata.GradeCategories[c].Grades.length; g++) {
                    ctotalpoints += alldata.GradeCategories[c].Grades[g].MaxPoints;
                }

                alldata.GradeCategories[c].GradesTotalPoints = ctotalpoints;

            }
        }
    }
    
    if(alldata.GradeCategories !== undefined) {
        alldata.GradesAll.Categories = JSON.parse(JSON.stringify(alldata.GradeCategories));
    }
    
    /*
    for(var gi=0; gi<alldata.GradeItems.Objects.length; gi++) {
        var thisgradeitem = alldata.GradeItems.Objects[gi];
        for(var giv=0; giv<thisgradeitem.Values.Objects.length; giv++) {
            var thisgradeitemvalue = thisgradeitem.Values.Objects[giv];
            
            for(var cl=0; cl<alldata.Classlist.Objects.length; cl++) {
                var thisuser = alldata.Classlist.Objects[cl];
                if(thisgradeitemvalue.User.Identifier === thisuser.Identifier) {
                    if(thisuser.Values === undefined) {
                        thisuser.Values = [thisgradeitemvalue.GradeValue];
                    }
                    else {
                        thisuser.Values.push(thisgradeitemvalue.GradeValue);
                    }
                }
            }
        }
    }
    */
    
    for(var cl=0; cl<alldata.Classlist.Objects.length; cl++) {
        buildValues(cl)
    }

}


function buildValues(u) {
    if(alldata.GradeSetup !== undefined) {
        if (alldata.GradeSetup.GradingSystem === "Weighted") {

            alldata.Classlist.Objects[u].Calculated = {
                NumeratorDrop: 0,
                NumeratorZero: 0,
                DenominatorDrop: 0,
                DenominatorZero: 0,
                CoursePercent: 0,
                Categories: [],
                Uncategorized: {
                    UngradedDrop: {
                        Numerator: 0,
                        Denominator: 0
                    },
                    UngradedZero: {
                        Numerator: 0,
                        Denominator: 0
                    },
                    Grades: []
                }
            }

            alldata.Classlist.Objects[u].Categories = JSON.parse(JSON.stringify(alldata.GradesAll.Categories));
            alldata.Classlist.Objects[u].Uncategorized = JSON.parse(JSON.stringify(alldata.GradesAll.Uncategorized));

            if(alldata.Classlist.Objects[u].Values !== undefined) {
                for (var v = 0; v < alldata.Classlist.Objects[u].Values.length; v++) {
                    var valfound = false;
                    for (var c = 0; c < alldata.Classlist.Objects[u].Categories.length; c++) {

                        if (alldata.Classlist.Objects[u].Categories[c].Id === parseInt(alldata.Classlist.Objects[u].Values[v].GradeObjectIdentifier)) {
                            alldata.Classlist.Objects[u].Categories[c].PointsNumerator = alldata.Classlist.Objects[u].Values[v].PointsNumerator;
                            alldata.Classlist.Objects[u].Categories[c].PointsDenominator = alldata.Classlist.Objects[u].Values[v].PointsDenominator;
                            alldata.Classlist.Objects[u].Categories[c].WeightedNumerator = alldata.Classlist.Objects[u].Values[v].WeightedNumerator;
                            alldata.Classlist.Objects[u].Categories[c].WeightedDenominator = alldata.Classlist.Objects[u].Values[v].WeightedDenominator;
                            alldata.Classlist.Objects[u].Categories[c].DisplayedGrade = alldata.Classlist.Objects[u].Values[v].DisplayedGrade;
                            alldata.Classlist.Objects[u].Categories[c].LastModified = alldata.Classlist.Objects[u].Values[v].LastModified;
                        }

                        if (valfound) {
                            break;
                        }

                        for (var g = 0; g < alldata.Classlist.Objects[u].Categories[c].Grades.length; g++) {

                            if (valfound) {
                                break;
                            }

                            if (alldata.Classlist.Objects[u].Categories[c].Grades[g].Id === parseInt(alldata.Classlist.Objects[u].Values[v].GradeObjectIdentifier)) {
                                valfound = true;
                                alldata.Classlist.Objects[u].Categories[c].Grades[g].PointsNumerator = alldata.Classlist.Objects[u].Values[v].PointsNumerator;
                                alldata.Classlist.Objects[u].Categories[c].Grades[g].PointsDenominator = alldata.Classlist.Objects[u].Values[v].PointsDenominator;
                                alldata.Classlist.Objects[u].Categories[c].Grades[g].WeightedNumerator = alldata.Classlist.Objects[u].Values[v].WeightedNumerator;
                                alldata.Classlist.Objects[u].Categories[c].Grades[g].WeightedDenominator = alldata.Classlist.Objects[u].Values[v].WeightedDenominator;
                                alldata.Classlist.Objects[u].Categories[c].Grades[g].DisplayedGrade = alldata.Classlist.Objects[u].Values[v].DisplayedGrade;
                                alldata.Classlist.Objects[u].Categories[c].Grades[g].LastModified = alldata.Classlist.Objects[u].Values[v].LastModified;
                            }
                        }
                    }

                    if (!valfound) {
                        for (var o = 0; o < alldata.Classlist.Objects[u].Uncategorized.length; o++) {
                            if (alldata.Classlist.Objects[u].Uncategorized[o].Id === parseInt(alldata.Classlist.Objects[u].Values[v].GradeObjectIdentifier)) {
                                valfound = true;
                                alldata.Classlist.Objects[u].Uncategorized[o].PointsNumerator = alldata.Classlist.Objects[u].Values[v].PointsNumerator;
                                alldata.Classlist.Objects[u].Uncategorized[o].PointsDenominator = alldata.Classlist.Objects[u].Values[v].PointsDenominator;
                                alldata.Classlist.Objects[u].Uncategorized[o].WeightedNumerator = alldata.Classlist.Objects[u].Values[v].WeightedNumerator;
                                alldata.Classlist.Objects[u].Uncategorized[o].WeightedDenominator = alldata.Classlist.Objects[u].Values[v].WeightedDenominator;
                                alldata.Classlist.Objects[u].Uncategorized[o].DisplayedGrade = alldata.Classlist.Objects[u].Values[v].DisplayedGrade;
                                alldata.Classlist.Objects[u].Uncategorized[o].LastModified = alldata.Classlist.Objects[u].Values[v].LastModified;
                            }
                        }
                    }
                }
            }

