}


function buildStudentDashboard(userid) {
    
    var displaycurrentaverage = true;
    if(alldata.CustomSettings !== undefined) {
        if(alldata.CustomSettings !== null) {
            if(alldata.CustomSettings.Dashboard !== undefined) {
                if(alldata.CustomSettings.Dashboard !== null) {
                    if(alldata.CustomSettings.Dashboard.Display !== undefined) {
                        if(alldata.CustomSettings.Dashboard.Display !== null) {
                            if(alldata.CustomSettings.Dashboard.Display.CurrentAverage !== undefined) {
                                displaycurrentaverage = alldata.CustomSettings.Dashboard.Display.CurrentAverage;
                            }
                        }
                    }
                }
            }
        }
    }
    
    if(displaycurrentaverage) {
        $('.student-current-average').removeClass('d-none');
    }
    else {
        $('.student-current-average').addClass('d-none');
    }
    
    var gradedall = 0;
	if (alldata.GradeSetup.GradingSystem === "Weighted") {
        
        for(var c=0; c<alldata.GradesAll.Categories.length; c++) {
            gradedall += alldata.GradesAll.Categories[c].Weight;
        }
        for(var u=0; u<alldata.GradesAll.Uncategorized.length; u++) {
            if(!alldata.GradesAll.Uncategorized[u].IsBonus) {
                if (alldata.GradesAll.Uncategorized[u].GradeType === "Numeric" || alldata.GradesAll.Uncategorized[u].GradeType === "SelectBox" || alldata.GradesAll.Uncategorized[u].GradeType === "PassFail") {
                    gradedall += alldata.GradesAll.Uncategorized[u].Weight;
                }
            }
        }
    }    
    //console.log(gradedall);
    var uindex = -1;
    for(var cl=0; cl<alldata.Classlist.Objects.length; cl++) {
        var thisuser = alldata.Classlist.Objects[cl];
        if(userid !== undefined) {
            if(thisuser.Identifier === userid) {
                uindex = cl;
                break;
            }
        }
        else {
            if(thisuser.Identifier === alldata.WhoAmI.Identifier) {
                uindex = cl;
                break;
            }            
        }
    }
    
    if(uindex > -1) {
        thisuser = alldata.Classlist.Objects[uindex];
        
        $('#dashboard-student-currentavg').text(thisuser.Calculated.CurrentAverage.toFixed(2)+'%');
        $('#dashboard-student-totalearned').text(thisuser.Calculated.CurrentEarned.toFixed(2)+'%');

        var gradedtotal = 0;
        var gradedzero = 0;
        for(var v=0; v<thisuser.Values.length; v++) {
            if(thisuser.Values[v].GradeObjectType === 1 || thisuser.Values[v].GradeObjectType === 2) {
                gradedtotal++;

                if(thisuser.Values[v].PointsNumerator === 0) {
                    gradedzero++;
                }
            }
        }

        $('#dashboard-student-numevaluated').text(gradedtotal);
        $('#dashboard-student-percentevaluated').text(parseFloat(thisuser.Calculated.CoursePercent).toFixed(2)+'%');

        $('#dashboard-student-gradetool').prop("onclick", null).off("click");
        $('#dashboard-student-gradetool').on('click',function(){
            window.open('/d2l/le/classprogress/userprogress/'+thisuser.Identifier+'/'+orgUnitId+'/Grades/Details', '_blank'); 
        });

        $('#dashboard-student-grades .invisible').removeClass('invisible');


        var contotal_stu = 0;
        if(thisuser.Progress !== undefined) {
            contotal_stu = thisuser.Progress.CompletedItems;
        }
        else {
            if(thisuser.TopicsViewed > 0) {
                contotal_stu = thisuser.TopicsViewed;
            }
        }

        $('#dashboard-student-contentviewed').text(contotal_stu);
        $('#dashboard-student-contenttotal').text(thisuser.Progress.RequiredItems);

        var contentpercent = 0;
        if(thisuser.Progress.RequiredItems > 0) {
            contentpercent = (thisuser.Progress.CompletedItems / thisuser.Progress.RequiredItems) * 100;
        }

        $('#dashboard-student-content .progress-bar').attr("style",'width:'+contentpercent.toFixed(2)+'%');
        $('#dashboard-student-content .progress-bar').attr("aria-valuenow",contentpercent.toFixed(2));

        $('#dashboard-student-content .cc-button').prop("onclick", null).off("click");
        $('#dashboard-student-content .cc-button').on('click',function(){
            window.open('/d2l/le/userprogress/'+thisuser.Identifier+'/'+orgUnitId+'/Content/Details', '_blank'); 
        });

        $('#dashboard-student-content .invisible').removeClass('invisible');

        $('#overdue-items-total .overdue-counter').text(thisuser.Overdue.Total);
        $('#overdue-items-assign .overdue-counter').text(thisuser.Overdue.Assignments);

        $('#overdue-items-quiz .overdue-counter').text(thisuser.Overdue.Quizzes);
        $('#overdue-items-other .overdue-counter').text(thisuser.Overdue.Other);

        $('#dashboard-student-overdue .cc-button').prop("onclick", null).off("click");
        $('#dashboard-student-overdue .cc-button').on('click',function(){
            openModal_LateAssess(thisuser.Identifier);
        });
        $('#dashboard-student-overdue .cc-button').removeAttr('disabled');
        
        $('#dashboard-student-overdue .invisible').removeClass('invisible');            
        
    }
    else {
        buildStudentDashboardPreview();
    }
    
    //frameHeight();
    
}


function openModal_LateAssess(uid) {
    var thisuser;
    for(var u=0; u<alldata.Classlist.Objects.length; u++) {
        if(alldata.Classlist.Objects[u].Identifier === uid) {
            thisuser = alldata.Classlist.Objects[u];
            //console.log(thisuser);
            break;
        }
    }
    
    var modalhtml = '';
    modalhtml += '';
    modalhtml += '<div class="table-responsive-sm">';
    modalhtml += '<table class="table table-striped" id="zerogradeuser-'+thisuser.Identifier+'">';
    modalhtml += '<thead>';
    modalhtml += '<tr><th>Evaluation</th><th class="text-center">Weight</th><th class="text-center">Due Date</th><th class="text-center">Recorded Value</th></tr>';
    modalhtml += '</thead>';
    modalhtml += '<tbody>';
    if(thisuser !== undefined) {
        for(var l=0; l<thisuser.LateAssess.length; l++) {
            for(var g=0; g<alldata.GradeItems.Objects.length; g++) {
                if(alldata.GradeItems.Objects[g].Id === thisuser.LateAssess[l]) {
                    var thisgrade = alldata.GradeItems.Objects[g];
                    //console.log(thisgrade);
                    
                    var iszero = false;
                    if(thisgrade.Values.Objects.length > 0) {
                        //console.log(thisgrade);
                        //console.log(thisgrade.Values.Objects[v]);
                        iszero = false;
                        if(thisgrade.Values.Objects[0].PointsNumerator === 0) {
                            iszero = true;
                        }   
                    }
                    
                    modalhtml += '<tr>';
                    modalhtml += '<td>'+thisgrade.Name+'</td>';
                    modalhtml += '<td class="text-center">'+Math.round(thisgrade.WeightCalc * 100) / 100+'%</td>';
                    
                    /*
                    if(thisgrade.WeightDrop) {
                        modalhtml += '<td class="text-center">Yes</td>';
                    }
                    else {
                        modalhtml += '<td class="text-center">No</td>';
                    }
                    */
                    
                    var edate = new Date(thisgrade.EndDate);
                    modalhtml += '<td class="text-center">'+edate.toLocaleDateString()+'</td>';
                    
                    modalhtml += '<td class="text-center" id="zerograde-'+thisgrade.Id+'">';
                    if(iszero) {
                        modalhtml += '0';
                    }
                    else {
                        modalhtml += 'Ungraded';
                    }
                    modalhtml += '</td>';
                    modalhtml += '</tr>';
                    
                }
            }
        }
    }
    modalhtml += '</tbody>';
    modalhtml += '</table>';
    modalhtml += '</div>';
    
    $('#lateAssessModal .modal-title').html('Late Evaluations for ' + thisuser.FirstName + ' ' + thisuser.LastName);
    $('#lateAssessModal .modal-body').html(modalhtml);
    $('#lateAssessModal .latecheckbox').on('change', function() {
        
        var listchecks = [];
        $('#lateAssessModal .latecheckbox').each(function(){    
            if($(this).prop("checked")) {
                listchecks.push({
                    User:$(this).attr("data-user"),
                    Grade:$(this).attr("data-grade")
                })
            }
        });
        
        if(listchecks.length > 0) {
            $('#checksetzero').removeAttr("disabled");
            $('#checksetzero').attr("onClick","setGradeZero()");
        }
        else {
            $('#checksetzero').attr("disabled","disabled");
            $('#checksetzero').removeAttr("onClick");
        }
        
    });
    
    /*
    var pageh = $('body').height();
    //console.log(pageh);

    var modalh = $('#lateAssessModal .modal-content').actual('height') + 5;
    //console.log(modalh);

    var modalt = $('#stu-'+uid).offset().top;
    //console.log(modalt);

    if ((pageh - modalh) < modalt) {
        $('#lateAssessModal .modal-dialog').css({
            'margin-top': (pageh - modalh) + 'px'
        });
    } else {
        $('#lateAssessModal .modal-dialog').css({
            'margin-top': modalt + 'px'
        });
    }     
    
    */
    $('#lateAssessModal').modal('toggle');
    
}


function openStudentSummary() {
    $('#snapshotStudentSummary').modal('toggle');
}


function viewQuizAttemptLogs() {
    $('#modalQuizAttemptLogs').modal('toggle');
}


function updateQuizAttemptLogs() {
    $('#quizattemptlogsbody').html('');
    var thisqid = parseInt($('#quizattemptselector').val());
    //console.log(thisqid);
    
    if(thisqid > -1) {
        for(var q=0; q<alldata.QuizzesAll.Objects.length; q++) {
            var thisq = alldata.QuizzesAll.Objects[q];
            if(thisq.QuizId === thisqid) {
                var attemptlinkshtml = '';
                if(thisq.Attempts.Objects.length > 0) {
                    attemptlinkshtml += '<table class="table table-responsive">';
                    attemptlinkshtml += '<thead>';
                    attemptlinkshtml += '<tr>';
                    attemptlinkshtml += '<th>Student ID</th>';
                    attemptlinkshtml += '<th>Student Name</th>';
                    attemptlinkshtml += '<th>Attempt Log Link</th>';
                    attemptlinkshtml += '</tr>';
                    attemptlinkshtml += '</thead>';
                    attemptlinkshtml += '<tbody>';
                    for(var qa=0; qa<thisq.Attempts.Objects.length; qa++) {
                        var thisqa = thisq.Attempts.Objects[qa];     
                        if(thisqa.StudentAttempt) {
                            attemptlinkshtml += '<tr>';
                            attemptlinkshtml += '<td>'+thisqa.StudentId+'</td>';
                            attemptlinkshtml += '<td>'+thisqa.StudentName+'</td>';
                            attemptlinkshtml += '<td><a href="/d2l/lms/qc/attempt_log/qc_attempt_log.d2l?ou='+alldata.CourseOffering.Identifier+'&ctid=2&ci='+thisq.QuizId+'&ai='+thisqa.AttemptId+'&d2l_body_type=2" target="_blank">Attempt '+thisqa.AttemptNumber+' <span class="sr-only">Opens in a new tab</span></a></td>';    
                            attemptlinkshtml += '</tr>';
                        }
                    }
                    attemptlinkshtml += '</tbody>';
                    attemptlinkshtml += '</table>';
                }
                else {
                    attemptlinkshtml = '<p>There are no Student Attempts for this Quiz yet.</p>';
                }
                
                $('#quizattemptlogsbody').html(attemptlinkshtml);
                break;
            }
        }
    }
}


function sortQuizAttemptsByStudentName( a, b ) {
  if ( a.StudentName < b.StudentName ){
    return -1;
  }
  if ( a.StudentName > b.StudentName ){
    return 1;
  }
  return 0;
}


function sortQuizAttemptsByUserId( a, b ) {
  if ( a.UserId < b.UserId ){
    return -1;
  }
  if ( a.UserId > b.UserId ){
    return 1;
  }
  return 0;
}


function buildQuizAttemptLogs() {
    var qaselecthtml = '';
    qaselecthtml += '<select class="custom-select" id="quizattemptselector">';
    qaselecthtml += '<option value="-1" selected>Select a Quiz</option>';
    for(var q=0; q<alldata.QuizzesAll.Objects.length; q++) {
        var thisq= alldata.QuizzesAll.Objects[q];
        qaselecthtml += '<option value="'+thisq.QuizId+'">'+thisq.Name;
        if(thisq.Attempts.Objects.length === 0) {
            qaselecthtml += ' (No Attempts)';
        }
        else {
            for(var qa=0; qa<thisq.Attempts.Objects.length; qa++) {
                var thisqa = thisq.Attempts.Objects[qa];
                thisqa.StudentAttempt = false;
                thisqa.StudentId = -1;
                thisqa.StudentName = '';
                for(var cl=0; cl<alldata.Classlist.Objects.length; cl++) {
                    var thisuser = alldata.Classlist.Objects[cl];
                    if(parseInt(thisuser.Identifier) === thisqa.UserId) {
                        thisqa.StudentAttempt = true;
                        thisqa.StudentId = thisuser.OrgDefinedId;
                        thisqa.StudentName = thisuser.FirstName + ' ' + thisuser.LastName;
                        break;
                    }
                }
            }
            thisq.Attempts.Objects.sort(sortQuizAttemptsByStudentName);
        }
        qaselecthtml += '</option>';
    }
    qaselecthtml += '</select>';
    $('#quizattemptselect').html(qaselecthtml);
    
    $('#quizattemptselector').on('change',function(){
        updateQuizAttemptLogs();
    });
    
    $('.link-quizattempts .management-button').removeAttr('disabled');
    
}


var atrisk_list;
var assess_list;
function buildProgressSnapshot() {
    
	atrisk_list = {
		"AccessLast":[],
		"ContentViewed":[],
		"GradeValueMax":[],
		"GradeAvgNow":[],
        "LateAssess":[],
        "AllItems": []
	};
    
    assess_list = {
        "AverageMin":[],
        "AverageMax":[],
        "FailRate":[],
        "UngradedNow": [],
        "AllItems": []
    }
    
    checkLastAccessed();
    checkContentViewed();
    checkGradeLevels();
    checkLateAssess();
    
    checkAssessResults();
    
    alldata.Progress = {
        AtRisk: atrisk_list,
        Assess: assess_list
    }
    
    buildQuizAttemptLogs();
    
    initializeProgressDisplay();

    $('#dashboard-link-stusummary').attr('href','javascript:openStudentSummary()');
    
}