function openReport_EnrollChanges() {
    
	var newenrollshtml = '';
    var newenrollfound = 0;
    var withdrawalhtml = '';
	
	if(alldata.Enrollment.Additions.length > 0) {
		for(var a=0; a<alldata.Enrollment.Additions.length; a++) {

			var uindex = -1;
			for(var u=0; u<alldata.Classlist.Objects.length; u++) {
                //console.log(parseInt(alldata.Classlist.Objects[u].Identifier));
                //console.log(alldata.Enrollment.Additions[a].UserId);
				if(parseInt(alldata.Classlist.Objects[u].Identifier) === alldata.Enrollment.Additions[a].UserId) {
					uindex = u;
                    break;
				}
			}

            //console.log(uindex);
			//console.log(alldata.Classlist.Objects[uindex]);
            
            if(uindex > -1) {
                newenrollfound++

                var newenrollstu = '';
                newenrollstu += '<div class="table-responsive-sm">';
                newenrollstu += '<table class="table table-bordered"><tbody><tr class="danger">';
                if(alldata.Classlist.Objects[uindex].Email !== null) {
                    newenrollstu += '<td style="width:32px; text-align:center"><a href="mailto:'+alldata.Classlist.Objects[uindex].Email+'" title="Send Email" target="_blank"><i class="fa fa-envelope" aria-hidden="true"></i></a></td>';
                }
                else {
                    newenrollstu += '<td style="width:32px; text-align:center"><i class="fa fa-envelope" aria-hidden="true"></i></td>';
                }

                newenrollstu += '<td>' + alldata.Classlist.Objects[uindex].FirstName + ' ' + alldata.Classlist.Objects[uindex].LastName + ' (' + alldata.Classlist.Objects[uindex].OrgDefinedId + ') </td>';
                newenrollstu += '</tr>';
                
                newenrollstu += '<tr><td colspan="2"><strong>This student was enrolled on: '+new Date(alldata.Enrollment.Additions[a].LogDate).toLocaleDateString()+'</strong></td></tr>';
                
                newenrollstu += '</tbody></table>';
                newenrollstu += '</div>';
                newenrollshtml += newenrollstu;
            }
		}
        
        if(newenrollfound === 0) {
            newenrollshtml += '<p>There are currently no recent student additions to the classlist.</p>';
        }
	}
	else {
		newenrollshtml += '<p>There are currently no recent student additions to the classlist.</p>';
	}  
    
	if(alldata.Enrollment.Withdrawals.length > 0) {
		for(var w=0; w<alldata.Enrollment.Withdrawals.length; w++) {            

                var withdrawalstu = '';
                withdrawalstu += '<div class="table-responsive-sm">';
                withdrawalstu += '<table class="table table-bordered"><tbody><tr class="danger">';
                withdrawalstu += '<td style="width:32px; text-align:center"> <i class="fa fa-sign-out" aria-hidden="true"></i></td>';


                withdrawalstu += '<td>' + alldata.Enrollment.Withdrawals[w].FirstName + ' ' + alldata.Enrollment.Withdrawals[w].LastName + '</td>';
                withdrawalstu += '</tr>';

                withdrawalstu += '<tr><td colspan="2"><strong>This student was withdrawn on: '+new Date(alldata.Enrollment.Withdrawals[w].LogDate).toLocaleDateString()+'</strong></td></tr>';

                withdrawalstu += '</tbody></table>';
                withdrawalstu += '</div>';
                withdrawalhtml += withdrawalstu;
        }
    }
	else {
		withdrawalhtml += '<p>There are currently no recent student withdrawals from the classlist.</p>';
	}  
    
	$('#snapshotNewEnrolls .modal-body #pills-additions').html(newenrollshtml);  
	$('#snapshotNewEnrolls .modal-body #pills-withdrawals').html(withdrawalhtml);  
	$('#snapshotNewEnrolls').modal('toggle');    
    
}


