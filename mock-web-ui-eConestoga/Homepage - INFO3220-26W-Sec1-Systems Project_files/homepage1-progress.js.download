function buildStudentPreview() {
    
    var allowselect = false;
    if(alldata.CurrentRole === "Instructor") {
        allowselect = true;
    }
    else {
        if(adminroles.indexOf(alldata.CurrentRole) > -1) {
            allowselect = true;
        }
    }
    
    var stuselectall = '';
    stuselectall += '<h2>Instructor Only Information</h2>';
    stuselectall += '<p>Note that the default information displayed below is for an imaginary student, and it is not based on any of the actual content and evaluations in this course.</p>';

    if(allowselect) {
        if(alldata.Classlist.Objects.length > 0) {
            var stuselect = '';
            stuselect += '<div class="input-group mb-3">';
            stuselect += '<div class="input-group-prepend mobile-hide">';
            stuselect += '<label class="input-group-text" for="previewStudentSelect">Select Student</label>';
            stuselect += '</div>';
            stuselect += '<select class="custom-select" id="previewStudentSelect">';
            stuselect += '<option value="-1" selected>Imaginary Student</option>';
            for(var cl=0; cl<alldata.Classlist.Objects.length; cl++) {
                stuselect += '<option value="'+alldata.Classlist.Objects[cl].Identifier+'">'+alldata.Classlist.Objects[cl].FirstName+ ' ' +alldata.Classlist.Objects[cl].LastName+ ' (' + alldata.Classlist.Objects[cl].OrgDefinedId + ')</option>';
            }
            stuselect += '</select>';
            stuselect += '</div>';

            stuselectall += '<p>You can use the dropdown select menu to view real dashboard data for each student in your classlist. <strong>Students are not presented with this option, and will only see their own results.</strong></p>';
            stuselectall += stuselect;            
            
        }
    }
    
    stuselectall += '</div>';
    $('.ipinstructoronly').html(stuselectall);
    $('.ipinstructoronly').removeClass('d-none');
        
    buildStudentDashboardPreview();
    
    //frameHeight();
    
    $("#previewStudentSelect").on('change',function() {
        buildStudentDashboard(this.value);
    });    
}


