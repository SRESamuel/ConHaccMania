            if (tind === -1) {
                datetypes.push({
                    'Name': dateoutside[o].Type,
                    'Count': 1
                })
                tind = datetypes.length - 1;
            } else {
                datetypes[tind].Count++;
            }

            if ((dateoutside[o].Type === "Announcement") || (dateoutside[o].Type === "CalendarEvent")) {
                if (dateoutside[o].IsPast) {
                    if (datetypes[tind].Past === undefined) {
                        datetypes[tind].Past = 1;
                    } else {
                        datetypes[tind].Past++;
                    }
                }
            }
        }

        //console.log(datetypes);
        //console.log(dateoutside);

        var notehtml = '';
