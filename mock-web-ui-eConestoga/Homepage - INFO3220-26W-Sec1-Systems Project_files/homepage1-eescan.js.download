                notehtml += '<div style="margin-bottom:16px"><btn class="btn btn-primary btn-sm mb-0" data-toggle="collapse" href="#collapseDeletePast">Delete Past Items</btn><div class="collapse" id="collapseDeletePast"><div class="card card-body"><div class="form-group">';

                if (pastannounce > 0) {
