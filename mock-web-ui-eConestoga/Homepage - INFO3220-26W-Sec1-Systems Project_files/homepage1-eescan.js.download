                }

                notehtml += '<button type="submit" class="btn btn-primary" onClick="confirmDeletePast()" disabled="disabled">Confirm</button></div>';
                notehtml += '<p class="confirmDeleteMsg" style="display:none">Items deleted successfully.</p>';
                notehtml += '</div></div></div>';

            }
            */
            
            if ((datetypes.indexOfObject("Name", "Assignment") > -1) || (datetypes.indexOfObject("Name", "ContentModule") > -1) || (datetypes.indexOfObject("Name", "ContentTopic") > -1) || (datetypes.indexOfObject("Name", "DiscussionForum") > -1) || (datetypes.indexOfObject("Name", "DiscussionTopic") > -1) || (datetypes.indexOfObject("Name", "Quiz") > -1)) {

