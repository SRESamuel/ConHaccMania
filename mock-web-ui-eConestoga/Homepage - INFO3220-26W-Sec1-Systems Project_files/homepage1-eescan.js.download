var coursescoredone = false;
function evaluateCourse() {
    var thiscourse = alldata;
    if(alldata.EEScanner === null) {
        alldata.EEScanner = JSON.parse(JSON.stringify(EEScanTemplate));
    }
        
    thiscourse.Score.Total = 0;
    //console.log(thiscourse);
    
    for (var a = 0; a < thiscourse.Score.Categories.length; a++) {
        var thiscat = thiscourse.Score.Categories[a];
        thiscat.SubTotal = 0;
        for (var b = 0; b < thiscourse.Score.Categories[a].Items.length; b++) {
            var thisitem = thiscourse.Score.Categories[a].Items[b];
            evaluateItem(a, b);
        }
    }
    
    var updateinfo = {
        "User": {
            "FirstName": alldata.WhoAmI.FirstName,
            "LastName": alldata.WhoAmI.LastName
        },
        "Date": getServerTime(),
        "Score": thiscourse.Score.Total,
        "Total": calcTotalScore(thiscourse)
    }    
    
    if(alldata.EEScanner !== null) {
        alldata.EEScanner.LastUpdated = updateinfo;
    }
    else {
        alldata.EEScanner = {
            LastUpdated: updateinfo
        }
    }

    var newWidgetData = {
        "Data": JSON.stringify(alldata.EEScanner)
    }

    //console.log(newWidgetData);
    coursescoredone = true;
    updateWidgetDataAuto();
    
    /*
    CSVal.put_custom_widget_data(thiscourse.CourseOffering.Identifier, cWidgetId, newWidgetData);   
    */
    
}


function progressCircle(userscore, elementid) {
    
    //console.log(userscore);
    
    var bar = new ProgressBar.Circle("#"+elementid, {
        easing: 'easeInOut',
        fill: 'rgba(255, 255, 255, 0)',
        duration: 1400,
        text: {
            autoStyleContainer: false
        },
        from: {
            color: '#337780 ',
            width: 10
        },
        to: {
            color: '#337780 ',
            width: 10
        },
        color: '#000 ',
        trailColor: '#eee',
        trailWidth: 10,
        svgStyle: null,
        step: function (state, circle) {
            circle.path.setAttribute('stroke', state.color);
            circle.path.setAttribute('stroke-width', state.width);

            var value = Math.round(circle.value() * 100);
            if (value === 0) {
                circle.setText('0%');
            } else {
                circle.setText(value + '%');
            }

        }
    });
    bar.text.style.fontFamily = '"Raleway", Helvetica, sans-serif';
    bar.text.style.fontSize = '0.9rem';
    bar.animate(userscore); // Number from 0.0 to 1.0	
}


function openRefreshEE() {
    
    $('.essential-elements-controls button').attr('disabled','disabled');
    
    checkCourseScores();
}


function openReviewEE() {
    
    alldata.EEScanner.MoreInformation.Views++;
    alldata.EEScanner.MoreInformation.Date = getServerTime();

    var newWidgetData = {
        "Data": JSON.stringify(alldata.EEScanner)
    }

    //console.log(newWidgetData);
    putCustomWidgetData(CustomWidgetEE); 
    
    $('#eeScannerModal .modal-body').html(buildScannerReview());
    $('#eeScannerModal').modal('show');
}


function showItemDesc(aindex, bindex, tasknum) {

    var thistask = alldata.Score.Categories[aindex].Items[bindex];
    var thisdesc = '';
    
    var thisbtn;
    var thisdisplay;

    thisbtn = $('#' + thistask.Code + '_btn');
    thisdisplay = $('#' + thistask.Code + '_desc');

    if(thisbtn.hasClass('detailsdisplayed')) {
        
        thisdisplay.html('');
        thisbtn.removeClass('detailsdisplayed');
        thisbtn.attr('title','Show Task Feedback');
        
    }
    else {
        if (thistask.Done) {
            thisdesc += '<p>Success! The scan has identified that this item is complete.</p>';
        }

        thisdesc += '<p><strong>' + thistask.Desc + '</strong></p>';

        if (thistask.Note !== undefined) {
            thisdesc += thistask.Note;
        }

        thisdisplay.html(thisdesc);
        thisbtn.addClass('detailsdisplayed');
        thisbtn.attr('title','Hide Task Feedback');
        
    }
    
}


function buildScannerReview() {

    var thiscourse = alldata;
    var userHTML = '<h3>Scan Results: ' + thiscourse.Score.Total + ' / ' + calcTotalScore(thiscourse) + '</h3>';

    var taskindex = 0;

    for (var a = 0; a < thiscourse.Score.Categories.length; a++) {
        userHTML += '<div class="row evaltasks evaltasks-' + thiscourse.CourseOffering.Identifier + '">';
        userHTML += '<div class="col-12">';
        userHTML += '<p><strong>' + thiscourse.Score.Categories[a].Name + ': ' + thiscourse.Score.Categories[a].SubTotal + ' / ' + thiscourse.Score.Categories[a].Items.length + '</strong></p>';
        userHTML += '<p>' + thiscourse.Score.Categories[a].Desc + '</p>';
        userHTML += '</div>';
        userHTML += '</div>';
        
        for (var b = 0; b < thiscourse.Score.Categories[a].Items.length; b++) {

            var thisitem = thiscourse.Score.Categories[a].Items[b];

            userHTML += '<div class="row mt-2 mb-2">';
            
            userHTML += '<div class="col-12 col-md-5 mb-2">';
            userHTML += '<table>';
            userHTML += '<tbody>';
            userHTML += '<tr>';
            userHTML += '<td class="evaltasks-icon">';
            if (!thisitem.Done) {
                userHTML += '<div class="cc-checkbox" title="Item Incomplete"><span class="sr-only">Item Incomplete</span></div>';
            } else {
                userHTML += '<div class="cc-checkbox checked" title="Item Complete"><span class="sr-only">Item Complete</span></div>';
            }
            userHTML += '</td>';
            userHTML += '<td class="evaltasks-title"><strong>' + thisitem.Name + '</strong></td>';
            userHTML += '</tr>';
            userHTML += '</tbody>';
            userHTML += '</table>';
            userHTML += '</div>';
            
            userHTML += '<div class="col-12 col-md-7 mb-2">';
            userHTML += '<table>';
            userHTML += '<tbody>';
            userHTML += '<tr>';
            userHTML += '<td class="evaltasks-info">';
            userHTML += '<button id="' + thisitem.Code + '_btn" class="btn btn-secondary evalPopover" onClick="showItemDesc(' + a + ',' + b + ',' + taskindex + ')" title="Show Task Feedback"><i class="fa fa-info-circle" aria-hidden="true"></i></button>';
            userHTML += '</td>';
            userHTML += '<td class="evaltasks-desc" id="' + thisitem.Code + '_desc"></td>';
            userHTML += '</tr>';
            userHTML += '</tbody>';
            userHTML += '</table>';
            userHTML += '</div>';
            
            userHTML += '</div>';

            taskindex++;
        }

        userHTML += '</div>';
    }

    return userHTML;
}


function checkCourseScores() {
    //ModelAttributes needed to determine length for Models.
    // In non-Model courses alldone.ModelAttributes set to true early in code without fetching data.
    
    //console.log("1");
    //console.log(alldone.ModelAttributes);
    //console.log(alldone.ETextMap);
    
    if((alldone.ModelAttributes === true) && (alldone.ETextMap === true)) {
        //console.log("2");
        
        var thiscourse = alldata;
        if (thiscourse.Score === undefined) {
            thiscourse.Score = JSON.parse(JSON.stringify(scoretemplate));

            var addetext = checkAddEtext(thiscourse);          
            if(addetext) {
                if(checkExcelEtext(thiscourse)) {
                    thiscourse.Score.Categories.push(JSON.parse(JSON.stringify(etextitem)));
                }                
            }

            evaluateCourse();
        }

        var userscore = ((thiscourse.Score.Total / calcTotalScore(thiscourse)).toFixed(2));

        $('.radial-progress').html('');
        $('.radial-progress').removeClass('invisible');    
        progressCircle(userscore, "radial-progress-1");
        progressCircle(userscore, "radial-progress-2");


        $('.essential-elements-controls button').removeAttr('disabled');


        $('.btn-eescan-review').on('click', function () {
            openReviewEE();
        });

        $('.btn-eescan-refresh').on('click', function () {
            openRefreshEE();
        });

        $('.btn-eescan-dismiss').on('click', function () {
            openDismissEE();
        });

        alldata.Displayed.EEScanner = true;

        checkAllDisplayed();
    }
}