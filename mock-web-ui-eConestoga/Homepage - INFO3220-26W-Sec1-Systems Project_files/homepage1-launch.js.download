// JavaScript Document


function checkCommonMerge(code) {
    ecplusClient.courseReadiness.isCommonMerge(code).then(function (resp) {
        if (resp.isSuccess) {
            //console.log(resp);
            alldata.MergeCandidate = resp;
            guidedCopyLoad();
        } else {
            alldata.MergeCandidate = null;
            guidedCopyLoad();
        }
    });
}

